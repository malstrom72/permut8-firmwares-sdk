;
;MODi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Modulus two ints
;
; Note: this test assumes truncation towards zero (also for negative numbers) although this is not guaranteed by all
; C/C++ compilers. In case this test fails the C/C++ compiler that built the VM uses an unusual truncation mode and
; that would be a bad thing that would have to be fixed in an upgrade of GAZL.
;
; Modulus by 0 is considered illegal and should generate a run-time error (or compile-time error if 0 is a constant).
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MODi      i0              #123456         #234
 MODi      i1              #-987654321     i0
 MODi      i2              i1              #-29
 MODi      i3              i1              i2
 NEQi      i3              #-7             @fail

