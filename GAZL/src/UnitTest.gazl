;===============================================================================
; GAZL Unit Test
;===============================================================================

;===============================================================================
; Check version
;===============================================================================

            ! IFDF #GAZL_VERSION @gotVersion
            ! FAIL GAZL_VERSION not defined!
gotVersion: ! EQUi #GAZL_VERSION #1 @versionOK
            ! FAIL This code is for version 1 of GAZL only.
versionOK:  !

            ! IFDF #GAZL_WORD_SIZE @gotBits
            ! FAIL GAZL_WORD_SIZE not defined!
gotBits:    ! EQUi #GAZL_WORD_SIZE #32 @bitsOK
            ! FAIL This code is for 32-bits word size only.
bitsOK:     !


;-------------------------------------------------------------------------------
FALSE:                  ! DEFi #0
TRUE:                   ! DEFi #1
;-------------------------------------------------------------------------------


;-------------------------------------------------------------------------------
GOOD:                   ! DEFi #0
BAD:                    ! DEFi #-1
;-------------------------------------------------------------------------------

;-------------------------------------------------------------------------------
CR:                     ! DEFi #13
LF:                     ! DEFi #10
;-------------------------------------------------------------------------------


;-------------------------------------------------------------------------------
consts:                 CNST *15
;-------------------------------------------------------------------------------
    consts.float:       DATf #-5678.9
    consts.int:         DATi #1234
    consts.pointer:     DATp &consts:1
    consts.string:      DATs hello
                        DATi #CR  #LF #0
    consts.done:        DATs done

;-------------------------------------------------------------------------------
consts.mixed:           CNST *3
;-------------------------------------------------------------------------------
                        DATA #1 #2.0 &consts.int

;-------------------------------------------------------------------------------
gArray:                 TEMP *777
;-------------------------------------------------------------------------------
                        DATi #1
                        DATi #2
                        DATi #3

;-------------------------------------------------------------------------------
global.warming:         GLOB *2
;-------------------------------------------------------------------------------
                        DATi #1
    global.pointer:     DATp &NULL

;-------------------------------------------------------------------------------
test:                   FUNC
;-------------------------------------------------------------------------------
    f0:                 LOCf
    f1:                 LOCf
    f2:                 LOCf
    f3:                 LOCf
    i0:                 LOCi
    i1:                 LOCi
    i2:                 LOCi
    i3:                 LOCi
    p0:                 LOCp
    p1:                 LOCp
    p2:                 LOCp
    p3:                 LOCp
    lArray:             LOCA *777
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

;
; Test that global / const data is initialized correctly.
;
 PEEK       f0		       &consts.float
 PEEK       i0              &consts.int
 PEEK       p0              &consts.pointer
 NEQf       f0              #-5678.9        @fail
 NEQi       i0              #1234           @fail
 NEQp       p0              &consts:1       @fail
 ! MOVi     <A>             #'h'
 ! ADDi     <A>             <A>             #'e'
 ! ADDi     <A>             <A>             #'l'
 ! ADDi     <A>             <A>             #'l'
 ! ADDi     <A>             <A>             #'o'
 ! ADDi     <A>             <A>             #CR
 ! ADDi     <A>             <A>             #LF
 ! ADDi     <A>             <A>             #0
 ! ADDi     <A>             <A>             #'d'
 ! ADDi     <A>             <A>             #'o'
 ! ADDi     <A>             <A>             #'n'
 ! ADDi     <A>             <A>             #'e'
 MOVi       i0              #0
 MOVp       p0              &consts.string
checksumLoop: NOOP
 PEEK       i1              p0
 ADDi       i0              i0              i1
 FORp       p0              &consts.done:4  @checksumLoop
 NEQi       i0              #<A>            @fail
 PEEK       i0              &consts.mixed:0
 PEEK       f0              &consts.mixed:1
 PEEK       p0              &consts.mixed:2
 NEQi       i0              #1              @fail
 NEQf       f0              #2.0            @fail
 NEQp       p0              &consts.int     @fail
 ADRL       p0              lArray          *3
 COPY       p0              &gArray         *3
 NEQi       lArray:0        #1              @fail
 NEQi       lArray:1        #2              @fail
 NEQi       lArray:2        #3              @fail
 MOVp       p0              &gArray:3
checkZeroLoop: NOOP
 PEEK       i0              p0
 NEQi       i0              #0              @fail
 FORp       p0              &gArray:777     @checkZeroLoop

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
; (d)        destination operand
; %temp      local "transient" variable   (e.g. %0, %1)
; int        local int variable           (e.g. myInt, localArray:3, %0)
; float      local float variable         (e.g. myFloat, localArray:3, %0)
; ptr        local pointer variable       (e.g. myPointer, localArray:3, %0)
; var        local variable (any type)    (e.g. myVar, localArray:3, %0)
; #int       constant int                 (e.g. #0, #1, #DEFINED_INT, <A>, <B>)
; #float     constant float               (e.g. #0.0, #1.0, #DEFINED_FLOAT, <A>, <B>)
; &address   constant pointer             (e.g. &global, &globalArray:3, &myFunction, <A>, <B>)
; #const     any constant (incl address)  (e.g. #-1, #3.3, #DEFINED_INT, &global, &globalArray:3, &myFunction, <A>, <B>)
; &function  GAZL function address        (e.g. &myFunction)
; ^native    native function              (e.g. ^print)
; @label     branch label                 (e.g. @jumphere, @choice.1)
; *size      constant integer size        (e.g. *1, *<A>)
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ABSf      float(d)        #float
;          float(d)        float
;
; Absolute of float
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ABSf      f0              #-123.4
 ABSf      f1              f0
 NEQf      f1              #123.4          @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ABSi      int(d)          #int
;          int(d)          int
;
; Absolute of int
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ABSi      i0              #-123
 ABSi      i1              i0
 NEQi      i1              #123            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ADDf      float(d)        #float          #float
;          float(d)        #float          float
;          float(d)        float           #float
;          float(d)        float           float
;
; Add floats
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ADDf      f0              #123.4          #234.5
 ADDf      f1              #-345.6         f0
 ADDf      f2              f1              #456.7
 ADDf      f3              f2              f1
 NEQf      f3              #481.3          @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ADDi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Add ints
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ADDi      i0              #123            #234
 ADDi      i1              #-345           i0
 ADDi      i2              i1              #456
 ADDi      i3              i2              i1
 NEQi      i3              #480            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ADDp      ptr(d)          &address        #int
;          ptr(d)          &address        int
;          ptr(d)          ptr             #int
;          ptr(d)          ptr             int
;
; Add to pointer
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ADDp      p0              &consts:5       #5
 ADDp      p1              &consts         i3
 ADDp      p2              p0              #-10
 ADDp      p3              p2              i3
 NEQp      p3              p1              @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ADRL      ptr(d)          var             *size
;
; Load effective address of local `var` into `ptr(d)`
;
; `*size` should hint how many words is expected to be accessed from `ptr(d)`, i.e. typically one for a single variable
; or the array size for arrays. It may be used to optimize stack frame sizes, for bounds checking etc. It is always
; legal to specify a size of zero if you do not know.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ADRL      p0              lArray          *100
 ADRL      p1              lArray:33       *0
 ADDp      p0              p0              #33
 NEQp      p0              p1              @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;ANDi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Bitwise AND ints
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ANDi      i0              #0xABCD1234     #0xBCDE2345
 ANDi      i1              #0x89ABCDEF     i0
 ANDi      i2              i0              #0xFEDCBA98
 ANDi      i3              i1              i2
 NEQi      i3              #0x88880000     @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;CALL      &function
;          &function       %temp           *size
;          ^native
;          ^native         %temp           *size
;          ptr
;          ptr             %temp           *size
;
; Function call.
;
; %temp should specify the "transient" variable for the first parameter (e.g. %0, %1, %2 etc).
; *size is the number of parameters (counting both input and output parameters).
;
; In GAZL 1.0 there is no compile-time check on the types and number of parameters passed to a function. The size
; operand is merely a hint that might be used to optimize stack frame sizes or for bounds checking etc.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVp      p0              &StopCar
 MOVp      p1              &EarthCheck

 CALL      &StartCar
 CALL      &EarthCheck     %0              *1
 NEQi      %0              #BAD            @fail

 MOVf      %11             #-139413.6582
 MOVf      %12             #38423.4e+3
 CALL      ^testMul        %10             *3

 SUBf      %10             %10             #-5.3567467544819e+12
 ABSf      %10             %10
 GRTf      %10             #1.0e6          @fail

 CALL      ^testCallback

 CALL      p0
 CALL      p1              %0              *1
 NEQi      %0              #GOOD           @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;CNST      *size
;
; Declare a constant data section / array
;
; `*size` defines the size of the section (in number of words). Define the data with DAT directives. You may not define
; more data items than `*size`, but you may define fewer (remaining items will be zeroed). Data in a constant section is
; placed in a write-protected segment of the run-time memory. See consts declarations in top of this file for examples.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;DATf      #float
;DATi      #int
;DATp      &address
;DATA      #const #const #const #const ...
;DATs      any string here
;
; DAT instructions are used to initialize globals and constant arrays. See consts declarations in top of this file for
; examples. Tests on global / const initializers can be found first in the unit-test function.
;
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;COPY      &address(w)     &address(r)     *size
;          &address(w)     ptr             *size
;          ptr             &address(r)     *size
;          ptr             ptr             *size
;
; Copies memory. Behaviour is undefined if target and source overlaps. This instruction can be used to accelerate
; memory access since global and constant data must otherwise be accessed with individual PEEK and POKE instructions.
; With COPY you can copy a range of global / constant data to a local array which can then be used directly with
; arbitrary instructions. (Just remember that you need to use ADRL to obtain the address to the local array.)
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 POKE      &gArray:25      #1234
 POKE      &gArray:26      #5678
 POKE      &gArray:27      #9012
 POKE      &gArray:28      #3456
 POKE      &gArray:29      #987654321
 COPY      &gArray:21      &gArray:25      *4
 PEEK      %0              &gArray:21
 PEEK      %1              &gArray:22
 PEEK      %2              &gArray:23
 PEEK      %3              &gArray:24
 NEQi      %0              #1234           @fail
 NEQi      %1              #5678           @fail
 NEQi      %2              #9012           @fail
 NEQi      %3              #3456           @fail
 PEEK      %0              &gArray:25
 NEQi      %0              #1234           @fail
 MOVi      lArray:4        #1234
 MOVi      lArray:5        #5678
 MOVi      lArray:6        #9012
 MOVi      lArray:7        #3456
 POKE      &gArray:27      #987654321
 ADRL      %0              lArray:4        *4
 COPY      &gArray:23      %0              *4
 PEEK      %0              &gArray:23
 PEEK      %1              &gArray:24
 PEEK      %2              &gArray:25
 PEEK      %3              &gArray:26
 NEQi      %0              #1234           @fail
 NEQi      %1              #5678           @fail
 NEQi      %2              #9012           @fail
 NEQi      %3              #3456           @fail
 PEEK      %0              &gArray:27
 NEQi      %0              #987654321      @fail
 ADRL      %0              lArray:1        *4
 COPY      %0              &gArray:23      *4
 NEQi      lArray:1        #1234           @fail
 NEQi      lArray:2        #5678           @fail
 NEQi      lArray:3        #9012           @fail
 NEQi      lArray:4        #3456           @fail
 NEQi      lArray:5        #5678           @fail
 MOVi      lArray:19       #191919
 ADRL      %0              lArray:15       *4
 ADRL      %1              lArray:1        *4
 COPY      %0              %1              *4
 NEQi      lArray:15       #1234           @fail
 NEQi      lArray:16       #5678           @fail
 NEQi      lArray:17       #9012           @fail
 NEQi      lArray:18       #3456           @fail
 NEQi      lArray:19       #191919         @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;DIFp      int(d)          &address        &address
;          int(d)          &address        ptr
;          int(d)          ptr             &address
;          int(d)          ptr             ptr
;
; Difference of two pointers
;
; You cannot use SUBp to subtract a pointer from another. SUBp is only used for negatively offsetting a pointer.
;
; Notice that for the first variant with two constant addresses, both addresses need to be declared before the
; instruction. (The other variants accepts forward declarations.)
;
; The motivation behind this exception is that the difference of two constant addresses becomes another constant,
; and this may be utilized for local optimizations etc.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVp      p0              &consts:1
 DIFp      i0              &consts:10      &consts:5
 DIFp      i1              &consts:8       p0
 DIFp      i2              p0              &consts:2
 ADRL      p1              lArray:10       *0
 ADRL      p2              lArray:33       *1
 DIFp      i3              p2              p1
 NEQi      i0              #5              @fail
 NEQi      i1              #7              @fail
 NEQi      i2              #-1             @fail
 NEQi      i3              #23             @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;DIVf      float(d)        #float          #float
;          float(d)        #float          float
;          float(d)        float           #float
;          float(d)        float           float
;
; Divide floats
;
; Division by 0 is considered illegal and should generate a run-time error (or compile-time error if 0 is a constant).
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 DIVf      f0              #123.4          #234.5
 DIVf      f1              #-345.6         f0
 DIVf      f2              f1              #456.7
 DIVf      f3              f1              f2
 SUBf      f3              f3              #456.7
 ABSf      f3              f3
 GRTf      f3              #1.0e-6         @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;DIVi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Divide ints
;
; Note: this test assumes truncation towards zero (also for negative numbers) although this is not guaranteed by all
; C/C++ compilers. In case this test fails (for example `i3` turns out #760) the C/C++ compiler that built the VM uses
; an unusual truncation mode and that would be a bad thing that would have to be fixed in an upgrade of GAZL.
;
; Division by 0 is considered illegal and should generate a run-time error (or compile-time error if 0 is a constant).
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 DIVi      i0              #123456         #234
 DIVi      i1              #-987654321     i0
 DIVi      i2              i1              #761
 DIVi      i3              i1              i2
 NEQi      i3              #761            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;EQUf      #float          #float          @label
;          #float          float           @label
;          float           #float          @label
;          float           float           @label
;
; Branch on equal floats
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVf      f0              #-456.7
 SUBf      f1              #0.0            f0
 MOVf      f2              f0
 EQUf      #120.3          #120.4          @fail
 EQUf      #120.3          #120.3          @okEQUf1
 GOTO      @fail
okEQUf1: NOOP
 EQUf      #456.7          f0              @fail
 EQUf      #-456.7         f0              @okEQUf2
 GOTO      @fail
okEQUf2: NOOP
 EQUf      f0              #456.7          @fail
 EQUf      f0              #-456.7         @okEQUf3
 GOTO      @fail
okEQUf3: NOOP
 EQUf      f0              f1              @fail
 EQUf      f0              f2              @okEQUf4
 GOTO      @fail
okEQUf4: NOOP

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;EQUi      #int            #int            @label
;          #int            int             @label
;          int             #int            @label
;          int             int             @label
;
; Branch on equal ints
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVi      i0              #-456
 SUBi      i1              #0              i0
 MOVi      i2              i0
 EQUi      #120            #-120           @fail
 EQUi      #120            #120            @okEQUi5
 GOTO      @fail
okEQUi5: NOOP
 EQUi      #456            i0              @fail
 EQUi      #-456           i0              @okEQUi6
 GOTO      @fail
okEQUi6: NOOP
 EQUi      i0              #456            @fail
 EQUi      i0              #-456           @okEQUi7
 GOTO      @fail
okEQUi7: NOOP
 EQUi      i0              i1              @fail
 EQUi      i0              i2              @okEQUi8
 GOTO      @fail
okEQUi8: NOOP

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;EQUp      &address        &address        @label
;          &address        ptr             @label
;          ptr             &address        @label
;          ptr             ptr             @label
;
; Branch on equal pointers
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 ADRL      p0              lArray:33       *1
 MOVp      p1              &consts
 EQUp      &consts         &consts.int     @fail
 EQUp      &consts         &consts         @okEQUp9
 GOTO      @fail
okEQUp9: NOOP
 EQUp      &consts         p0              @fail
 EQUp      &consts         p1              @okEQUp10
 GOTO      @fail
okEQUp10: NOOP
 EQUp      p0              &consts         @fail
 EQUp      p1              &consts         @okEQUp11
 GOTO      @fail
okEQUp11: NOOP
 EQUp      p0              p1              @fail
 EQUp      p1              p1              @okEQUp12
 GOTO      @fail
okEQUp12: NOOP

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;FLOf      float(d)        #float
;          float(d)        float
;
; Floor of float. Notice that there is no ceil instruction, but ceil is equivalent to -floor(-x).
;
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVf      f1              #12.3
 FLOf      f0              #-123.4
 FLOf      f2              f1
 NEQf      f0              #-124.0         @fail
 NEQf      f2              #12.0           @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;FORi      int(d)          #int            @label
;          int(d)          int             @label
;
; Increment `int(d)` and branch to `@label` if it is less than `#int` / `int`
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVi      i0              #0
 MOVi      i1              #1234
looptest1: NOOP
 ADDi      i1              i1              #2345
 FORi      i0              #777            @looptest1
 NEQi      i0              #777            @fail
 NEQi      i1              #1823299        @fail
 MOVi      i2              #333
looptest2: NOOP
 ADDi      i1              i1              #2345
 FORi      i2              i0              @looptest2
 NEQi      i2              i0              @fail
 NEQi      i1              #2864479        @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;FORp      ptr(d)          &address        @label
;          ptr(d)          ptr             @label
;
; Increment `ptr(d)` and branch to `@label` if it is less than `&address` / `ptr`
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVp      p0              &gArray
 MOVi      i1              #1234
looptest3: NOOP
 ADDi      i1              i1              #2345
 FORp      p0              &gArray:777     @looptest3
 NEQp      p0              &gArray:777     @fail
 NEQi      i1              #1823299        @fail
 ADRL      p1              lArray:333      *444
 ADRL      p2              lArray:777      *0
looptest4: NOOP
 ADDi      i1              i1              #2345
 FORp      p1              p2              @looptest4
 NEQp      p1              p2              @fail
 NEQi      i1              #2864479        @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;FUNC
;
; Declares the beginning of a new function. Any previous function must have ended with either RETU or GOTO.
;
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;GEQf      #float          #float          @label
;          #float          float           @label
;          float           #float          @label
;          float           float           @label
;
; Branch on greater or equal float
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVf      f0              #-456.7
 SUBf      f1              #0.0            f0
 MOVf      f2              f0
 GEQf      #120.3          #120.4          @fail
 GEQf      #120.4          #120.3          @okGEQf13
 GOTO      @fail
okGEQf13: NOOP
 GEQf      #120.3          #120.3          @okGEQf14
 GOTO      @fail
okGEQf14: NOOP
 GEQf      #456.7          f0              @okGEQf15
 GOTO      @fail
okGEQf15: NOOP
 GEQf      #-456.7         f0              @okGEQf16
 GOTO      @fail
okGEQf16: NOOP
 GEQf      #-457.0         f0              @fail
 GEQf      f0              #456.7          @fail
 GEQf      f0              #-456.7         @okGEQf17
 GOTO      @fail
okGEQf17: NOOP
 GEQf      f0              #-457.0         @okGEQf18
 GOTO      @fail
okGEQf18: NOOP
 GEQf      f0              f1              @fail
 GEQf      f0              f2              @okGEQf19
 GOTO      @fail
okGEQf19: NOOP
 GEQf      f1              f0              @okGEQf20
 GOTO      @fail
okGEQf20: NOOP

