;OUTp
;
; Declare a local output parameter (float, int or pointer). OUT declarations must appear after a FUNC declaration but
; before any real instruction.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;PARA      *size
;
; Declare a local parameter section / array (any type, input or output)
;
; `*size` defines the size of the section (in number of words). PARA declarations must appear after a FUNC declaration
; but before any real instruction. You would also normally place PARA before LOC declarations.

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;PEEK      var(d)          &address(r)
;          var(d)          &address(r)     int
;          var(d)          ptr
;          var(d)          ptr             #int
;          var(d)          ptr             int
;
;  Read a value from random access memory with an optional integer offset.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 PEEK      i0              &consts.mixed
 NEQi      i0              #1              @fail
 PEEK      f0              &consts.mixed:1
 NEQf      f0              #2.0            @fail
 MOVi      i1              #2
 PEEK      p0              &consts.mixed   i1
 NEQp      p0              &consts.int     @fail
 MOVp      p1              &consts.mixed
 PEEK      i0              p1
 NEQi      i0              #1              @fail
 PEEK      f0              p1              #1
 NEQf      f0              #2.0            @fail
 PEEK      p0              p1              i1
 NEQp      p0              &consts.int     @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;POKE      &address(w)     #const
;          &address(w)     var
;          &address(w)     int             #const
;          &address(w)     int             var
;          ptr             #const
;          ptr             #int            #const
;          ptr             #int            var
;          ptr             var
;          ptr             int             #const
;          ptr             int             var
;
; Write a value to random access memory with an optional integer offset.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 POKE      &gArray:111     #111
 MOVi      i0              #112
 POKE      &gArray:112     i0
 MOVi      i1              #1
 POKE      &gArray:112     i1              #113
 ADDi      i0              i0              #2
 POKE      &gArray:113     i1              i0
 MOVp      p0              &gArray:115
 POKE      p0              #115
 POKE      p0              #1              #116
 ADDi      i0              i0              #3
 POKE      p0              #2              i0
 ADDp      p0              p0              #3
 ADDi      i0              i0              #1
 POKE      p0              i0
 POKE      p0              i1              #119
 ADDi      i0              i0              #2
 ADDp      p0              p0              #1
 POKE      p0              i1              i0
 MOVi      i1              #111
 MOVp      p0              &gArray:111
pokeloop: NOOP
 PEEK      i0              p0
 NEQi      i0              i1              @fail
 ADDi      i1              i1              #1
 FORp      p0              &gArray:121     @pokeloop

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;RETU
;
; Returns from function call.
;
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SETL      var(d)          int             #const
;          var(d)          int             var
;
; Set local variable `var` (any type) with offset `int`
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVi      i1              #230
 SETL      lArray:4        i1              #3939
 NEQi      lArray:234      #3939           @fail
 SETL      lArray:4        i1              i1
 NEQi      lArray:234      #230            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SHLi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Shift bits left
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 SHLi      i0              #0x55           #3
 SHLi      i0              i0              #1
 SHLi      i1              #1              #2
 SHLi      i0              i0              i1
 NEQi      i0              #0x5500         @fail
 SHLi      i0              #11             i1
 NEQi      i0              #176            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SHRi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int;
;
; Shift bits right (arithmetic, i.e. replicate most significant bit and keep sign)
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 SHRi      i0              #-0x5500        #3
 SHRi      i0              i0              #1
 SHRi      i1              #0x10           #2
 SHRi      i0              i0              i1
 NEQi      i0              #-0x55          @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SHRu      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Shift bits right (logical, i.e. shift in zeroes and lose sign)
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 SHRu      i0              #0xFFFF55FF     #3
 SHRu      i0              i0              #1
 SHRu      i1              #0x10           #2
 SHRu      i0              i0              i1
 NEQi      i0              #0x00FFFF55    @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SUBf      float(d)        #float          #float
;          float(d)        #float          float
;          float(d)        float           #float
;          float(d)        float           float
;
; Subtract floats
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 SUBf      f0              #123.4          #234.5
 SUBf      f1              #-345.6         f0
 SUBf      f2              f1              #456.7
 SUBf      f3              f2              f1
 NEQf      f3              #-456.7         @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SUBi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Subtract ints
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 SUBi      i0              #123            #234
 SUBi      i1              #-345           i0
 SUBi      i2              i1              #456
 SUBi      i3              i2              i1
 NEQi      i3              #-456           @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SUBp      ptr(d)          &address        #int
;          ptr(d)          &address        int
;          ptr(d)          ptr             #int
;          ptr(d)          ptr             int
;
; Subtract from pointer
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 SUBp      p0              &consts:15      #5
 SUBp      p1              &consts         i3
 SUBp      p2              p0              #10
 SUBp      p3              p2              i3
 NEQp      p3              p1              @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;SWCH      int             *size           @label
;
; Switch (multi-way branch)
;
; The switch instruction creates an internal switch table of a chosen size (`*size`) for quick multi-way branching on
; `int`.
;
; Case labels can be defined for integer values between 0 and `*size` - 1. Case labels should be formed by appending
; integer constants to `@label` with either a period `.` or `#` in between. Use `#` to allow any constant literal or
; compile-time variable. E.g. `@myLabel#'B'` and `@myLabel#<A>` are valid case labels.
;
; If `int` is out of range (< 0 or >= `*size`) or a case label is not defined, the default case label (`@label`) is
; used. This label is the only one that must be declared.
;
; The greater the `*size` the more memory will be required for the jump table, so avoid huge switch ranges.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 MOVi      i1              #'A'
 MOVi      i2              #0

 MOVi      i0              #-1
 SWCH      i0              *1              @swchA
 GOTO      @fail
swchA.0:   GOTO @fail
swchA:     NOOP
 MOVi      i0              #1
 SWCH      i0              *1              @swchB
 GOTO      @fail
swchB.0:   GOTO @fail
 ! MOVi    <X>             #1
swchB#<X>: GOTO @doSwchC
swchB:     NOOP
 MOVi      i1              #'B'
 SWCH      i0              *2              @swchB

doSwchC:   NOOP
 SWCH      i1              *256            @swchC
swchC#'C': MULi i2 i2 #3
           GOTO @swchCNext
swchC#'Y': MULi i2 i2 #10
swchC#'X': NOOP
swchC:     ADDi i2 i2 #1
swchCNext: NOOP
 FORi      i1              #'Z'            @doSwchC
 NEQi      i2              #241            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;TEMP      *size
;
; Like `GLOB` but hints that this section contains temporary data that can be ignored in case the GAZL host supports
; memory serialization.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;XORi      int(d)          #int            #int
;          int(d)          #int            int
;          int(d)          int             #int
;          int(d)          int             int
;
; Bitwise XOR ints
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 XORi      i0              #0x5432EDCB     #0x4321DCBA
 XORi      i1              #0x76543210     i0
 XORi      i2              i0              #0x01234567
 XORi      i3              i1              i2
 NEQi      i3              #0x77777777     @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;fTOi      int(d)          #float          #float
;          int(d)          float           #float
;
; Convert float to int
;
; The float is first scaled with the third operand before it is converted to int.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 fTOi      i0              #1.235          #1000.0
 NEQi      i0              #1235           @fail
 MOVf      f0              #100.0
 fTOi      i0              f0              #1.0
 NEQi      i0              #100            @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
;iTOf      float(d)        #int            #float
;          float(d)        int             #float
;
; Convert int to float
;
; The float is scaled with the third operand after it has been converted from int.
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

 iTOf      f0              #1234            #0.001
 LSSf      f0              #1.233999        @fail
 GRTf      f0              #1.240001        @fail
 MOVi      i0              #100
 iTOf      f0              i0               #1.0
 NEQf      f0              #100.0           @fail

;///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
;
; Compile-time instructions.
;
; ! ABSf    <?>             #float
; ! ABSi    <?>             #int
; ! ADDf    <?>             #float          #float
; ! ADDi    <?>             #int            #int
; ! ADDp    <?>             &address        #int
; ! DEFf    #float
; ! DEFi    #int
; ! DEFp    &address
; ! DIFp    <?>             &address        &address
; ! DIVf    <?>             #float          #float
; ! DIVi    <?>             #int            #int
; ! EQUi    #int            #int            @label
; ! EQUp    &address        &address        @label
; ! GEQi    #int            #int            @label
; ! GEQp    &address        &address        @label
; ! GOTO    @label
; ! GRTi    #int            #int            @label
; ! GRTp    &address        &address        @label
; ! IFDF    &address        @label
;           #const          @label
;           ^native         @label
; ! IFND    &address        @label
;           #const          @label
;           ^native         @label
; ! IORi    <?>             #int            #int
; ! LEQi    #int            #int            @label
; ! LEQp    &address        &address        @label
; ! LSSi    #int            #int            @label
; ! LSSp    &address        &address        @label
; ! MODi    <?>             #int            #int
; ! MOVf    <?>             #float
; ! MOVi    <?>             #int
; ! MULf    <?>             #float          #float
; ! MULi    <?>             #int            #int
; ! NEQi    #int            #int            @label
; ! NEQp    &address        &address        @label
; ! SHLi    <?>             #int            #int
; ! SHRi    <?>             #int            #int
; ! SHRu    <?>             #int            #int
; ! SUBf    <?>             #float          #float
; ! SUBi    <?>             #int            #int
; ! SUBp    <?>             &address        #int
; ! XORi    <?>             #int            #int
; ! fTOi    <?>             #float          #float
; ! iTOf    <?>             #int            #float
;
;\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

DEFINED_INT: ! DEFi        #-12345
 ! MOVi    <Z>             #246810
 ! ABSi    <A>             #DEFINED_INT
 ! ADDi    <A>             #54321           #<A>
 ! SUBi    <A>             #<A>             #<Z>
 ! fTOi    <B>             #50.0            #2.0
 ! MULi    <A>             #<A>             #<B>
 ! DIVi    <A>             #<A>             #10
 ! MODi    <A>             #<A>             #1000000
 NEQi      #<A>            #-801440         @fail
 ! XORi    <A>             #<A>             #0x191919
 ! ANDi    <A>             #<A>             #0x0F0F0FAA
 ! IORi    <A>             #<A>             #0x55010100
 NEQi      #<A>            #0x5f0b0d28      @fail
 ! MOVi    <C>             #3
 ! SHLi    <A>             #<A>             #<C>
 ! SHRi    <A>             #<A>             #8
 ! SHRu    <A>             #<A>             #4
 NEQi      #<A>            #0xfff8586       @fail
 ! NEQi    #<A>            #0xfff8586       @compileTimeFail
 ! EQUi    #<A>            #0xfff8585       @compileTimeFail
 ! EQUi    #<A>            #0xfff8585       @compileTimeFail
 ! LSSi    #<A>            #0xfff8586       @compileTimeFail
 ! GRTi    #<A>            #0xfff8586       @compileTimeFail
 ! LSSi    #<A>            #0xfff8585       @compileTimeFail
 ! GRTi    #<A>            #0xfff8587       @compileTimeFail
 ! LEQi    #<A>            #0xfff8585       @compileTimeFail
 ! GEQi    #<A>            #0xfff8587       @compileTimeFail
 ! EQUi    #<A>            #0xfff8586       @ctOK1
 ! GOTO    @compileTimeFail
ctOK1: !
 ! NEQi    #<A>            #0xfff8585       @ctOK2
 ! GOTO    @compileTimeFail
ctOK2: !
 ! NEQi    #<A>            #0xfff8587       @ctOK3
 ! GOTO    @compileTimeFail
ctOK3: !
 ! LSSi    #<A>            #0xfff8587       @ctOK4
 ! GOTO    @compileTimeFail
ctOK4: !
 ! GRTi    #<A>            #0xfff8585       @ctOK5
 ! GOTO    @compileTimeFail
ctOK5: !
 ! LEQi    #<A>            #0xfff8586       @ctOK6
 ! GOTO    @compileTimeFail
ctOK6: !
 ! LEQi    #<A>            #0xfff8587       @ctOK7
 ! GOTO    @compileTimeFail
ctOK7: !
 ! GEQi    #<A>            #0xfff8586       @ctOK8
 ! GOTO    @compileTimeFail
ctOK8: !
 ! GEQi    #<A>            #0xfff8585       @ctOK9
 ! GOTO    @compileTimeFail
ctOK9: !
 ! GOTO    @ctOK10
 ! GOTO    @compileTimeFail
ctOK10: !

DEFINED_FLOAT: ! DEFf      #-1.2345
 ! MOVf    <Z>             #2.0
 ! ABSf    <A>             #DEFINED_FLOAT
 ! ADDf    <A>             #1.0             #<A>
 ! SUBf    <A>             #<A>             #<Z>
 ! iTOf    <B>             #50              #2.0
 ! MULf    <A>             #<A>             #<B>
 ! DIVf    <A>             #<A>             #10.0
 LSSf      #<A>            #2.344999        @fail
 GRTf      #<A>            #2.345001        @fail

 ! DIFp    <D>             &consts:5        &consts:2
 ! NEQi    #<D>            #3               @compileTimeFail

 ! IFDF    &consts.mixed   @ctOK11
 ! GOTO    @compileTimeFail
ctOK11: !
 ! IFDF    #DEFINED_FLOAT  @ctOK12
 ! GOTO    @compileTimeFail
ctOK12: !
 ! IFDF    ^assertFail     @ctOK13
 ! GOTO    @compileTimeFail
ctOK13: !
 ! IFND    &consts.mixed   @compileTimeFail
 ! IFND    #DEFINED_FLOAT  @compileTimeFail
 ! IFND    ^assertFail     @compileTimeFail

 ! IFDF    &shouldnotexist @compileTimeFail
 ! IFDF    #shouldnotexist @compileTimeFail
 ! IFDF    ^shouldnotexist @compileTimeFail
 ! IFND    &shouldnotexist @ctOK14
 ! GOTO    @compileTimeFail
ctOK14: !
 ! IFND    #shouldnotexist @ctOK15
 ! GOTO    @compileTimeFail
ctOK15: !
 ! IFND    ^shouldnotexist @ctOK16
 ! GOTO    @compileTimeFail
ctOK16: !

DEFINED_POINTER: ! DEFp    &gArray:3
 ! MOVi    <Z>             #105
 ! ADDp    <P>             &DEFINED_POINTER	#113
 ! SUBp    <P>             <P>              #<Z>
 ! DIFp    <A>             <P>              &gArray:3
 ! NEQi    #<A>            #8               @compileTimeFail
;
; FIX DROP:
;
; NEQp      #<P>            &gArray:11       @fail
; ! NEQp    #<P>            &gArray:11       @compileTimeFail
; ! EQUp    #<P>            &gArray:10       @compileTimeFail
; ! EQUp    #<P>            &gArray:12       @compileTimeFail
; ! LSSp    #<P>            &gArray:11       @compileTimeFail
; ! GRTp    #<P>            &gArray:11       @compileTimeFail
; ! LSSp    #<P>            &gArray:10       @compileTimeFail
; ! GRTp    #<P>            &gArray:12       @compileTimeFail
; ! LEQp    #<P>            &gArray:10       @compileTimeFail
; ! GEQp    #<P>            &gArray:12       @compileTimeFail
; ! EQUp    #<P>            &gArray:11       @ctOK17
; ! GOTO    @compileTimeFail
;ctOK17: !
; ! NEQp    #<P>            &gArray:10       @ctOK18
; ! GOTO    @compileTimeFail
;ctOK18: !
; ! NEQp    #<P>            &gArray:12       @ctOK19
; ! GOTO    @compileTimeFail
;ctOK19: !
; ! LSSp    #<P>            &gArray:12       @ctOK20
; ! GOTO    @compileTimeFail
;ctOK20: !
; ! GRTp    #<P>            &gArray:10       @ctOK21
; ! GOTO    @compileTimeFail
;ctOK21: !
; ! LEQp    #<P>            &gArray:11       @ctOK22
; ! GOTO    @compileTimeFail
;ctOK22: !
; ! LEQp    #<P>            &gArray:12       @ctOK23
; ! GOTO    @compileTimeFail
;ctOK23: !
; ! GEQp    #<P>            &gArray:11       @ctOK24
; ! GOTO    @compileTimeFail
;ctOK24: !
; ! GEQp    #<P>            &gArray:10       @ctOK25
; ! GOTO    @compileTimeFail
;ctOK25: !
;

    done:               POKE &global.pointer &consts.done
                        RETU
    fail:               CALL ^assertFail
                        RETU

                        ! GOTO @skipCompileTimeFail
compileTimeFail:        ! FAIL Compile-time check failed
skipCompileTimeFail:    !

;-------------------------------------------------------------------------------
StopCar:                FUNC
;
; Function with no input and output.
;-------------------------------------------------------------------------------
                        MOVp %0 &global.warming
                        MOVi %1 #FALSE
                        CALL &WriteGlobal %0 *2
                        RETU

;-------------------------------------------------------------------------------
StartCar:               FUNC
;
; Another function with no input and output.
;-------------------------------------------------------------------------------
                        MOVp %0 &global.warming
                        MOVi %1 #TRUE
                        CALL &WriteGlobal %0 *2
                        RETU

;-------------------------------------------------------------------------------
EarthCheck:             FUNC
    howAreWe:           OUTi
;
; This one has an output integer and a local.
;-------------------------------------------------------------------------------
    areWeWarm:          LOCi
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
                        PEEK areWeWarm &global.warming
                        EQUi areWeWarm #TRUE @yesWarm
    noCold:             MOVi howAreWe #GOOD
                        RETU
    yesWarm:            MOVi howAreWe #BAD
                        RETU

;-------------------------------------------------------------------------------
WriteGlobal:            FUNC
    where:              INPp
    toWhat:             PARA *1
;
; A terribly uninteresting function. The only interesting thing about it is that
; it takes a generic value of any type ("toWhat") defined with PARA.
;-------------------------------------------------------------------------------
                        POKE where toWhat
                        RETU

;-------------------------------------------------------------------------------
ReadGlobal:             FUNC
    isWhat:             PARA *1
    where:              INPp
;
; Another terribly uninteresting function, except perhaps that it uses the PARA
; for output.
;-------------------------------------------------------------------------------
                        PEEK isWhat where
                        RETU

;-------------------------------------------------------------------------------
CallBack:               FUNC
    expect:             INPp
    changeTo:           INPp
;
; We expect this one to get called from the host when we call its 'testCallback'
;
;-------------------------------------------------------------------------------
    pointerContents:    LOCp
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
                        PEEK pointerContents &global.pointer
                        NEQp expect pointerContents @fail
                        POKE &global.pointer changeTo
                        RETU
    fail:               CALL ^assertFail
                        RETU
