		PEEK %1 $b 
		NEQi %0 %1 @.e2
		ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		GOTO @.l0  	; }
	.e2:	PEEK %0 $a 	; d = (int)*a - (int)*b
		PEEK %1 $b 
		SUBi $d %0 %1
		RETU   	; }


