	.l3:	GEQf $m #0.5 @.e4	; while (m < 0.5) 
		MULf $m $m #2.0	; m = m * 2.0
		SUBf $b $b #LOG2	; b = b - LOG2
		GOTO @.l3  	; }
	.e4:	NOOP
	.l5:	LEQf $m #1.5 @.e6	; while (m > 1.5) 
		MULf $m $m #0.5	; m = m * 0.5
		ADDf $b $b #LOG2	; b = b + LOG2
		GOTO @.l5  	; }
	.e6:	SUBf $m #1.0 $m	; m = 1.0 - m
		MOVf $a #-1.0 	; a = -1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #0.0 	; y = 0.0
	.l7:	MOVf $t $y 	; t = y
		MULf $a $a $m	; a = a * m
		DIVf %0 $a $n	; y = y + a / n
		ADDf $y $y %0
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l7	; } while (y != t)
		ADDf $y $y $b	; y = y + b
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
pow:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
	$a:	LOCf
;-----------------------------------------------------------------------------
		MOVf $z #0.0 	; z = 0.0
		MOVf $a $x 	; a = x
		GEQf $a #0.0 @.f1	; if (a < 0.0 && y == floor(y)) a = -a
		FLOf %0 $y 
		NEQf $y %0 @.f1
		SUBf $a #0.0 $a	; a = -a
	.f1:	LEQf $a #0.0 @.f2	; if (a > 0.0) z = (float) exp((float) log(a) * y)
		MOVf %2 $a 	; z = (float) exp((float) log(a) * y)
		CALL &log %1 *2
		MULf %1 %1 $y
		CALL &exp %0 *2
		MOVf $z %0 
		GOTO @.e3  
	.f2:	LSSf $a #0.0 @.t4	; if (a < 0.0 || y <= 0.0) error("Domain error")
		GRTf $y #0.0 @.f5
	.t4:	MOVp %1 &.s_Domain4d7 	; error("Domain error")
		CALL &error %0 *2
	.f5:	NOOP
	.e3:	EQUf $a $x @.f7	; if (a != x && (y * 0.5) != floor(y * 0.5)) z = -z
		MULf %0 $y #0.5
		MULf %1 $y #0.5
		FLOf %0 %0 
		EQUf %1 %0 @.f7
		SUBf $z #0.0 $z	; z = -z
	.f7:	RETU   	; }


;-----------------------------------------------------------------------------
logScale:	FUNC
	$y:	OUTf
	$x:	INPf
	$outFrom:	INPf
	$outTo:	INPf
;-----------------------------------------------------------------------------
		DIVf %1 $outTo $outFrom	; y = outFrom * (float) pow(outTo / outFrom, x)
		MOVf %2 $x 
		CALL &pow %0 *3
		MULf $y $outFrom %0
		RETU   	; }


;-----------------------------------------------------------------------------
decayConstant:	FUNC
	$factor:	OUTf
	$time:	INPf
	$reach:	INPf
;-----------------------------------------------------------------------------
		DIVf %2 #1.0 $reach	; factor = (float) exp(-1.0 / time * (float) log(1.0 / reach))
		CALL &log %1 *2
		DIVf %2 #-1.0 $time
		MULf %1 %2 %1
		CALL &exp %0 *2
		MOVf $factor %0 
		RETU   	; }

HP_EPSILON:	! DEFf #1.0e-011
HP_K:	! DEFf #0.0056828256022101
	GLOB *1
wantsReset:	DATi #FALSE
	GLOB *1
breakLoop:	DATi #FALSE
readRates:	GLOB *256
blockLens:	GLOB *256
minCycles:	GLOB *256
thresDKs:	GLOB *256

;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
	$i:	LOCi
	$x:	LOCf
	$minCycle:	LOCi
;-----------------------------------------------------------------------------
		POKE &wantsReset #TRUE 	; global wantsReset = TRUE
		POKE &breakLoop #TRUE 	; global breakLoop = TRUE
		MOVi $i #0 	; for (i = 0 to 256) 
		GEQi #0 #256 @.e0
	.l1:	NOOP
		! DIVf <A> #1.0 #256.0	; x = itof(i) * (1.0 / 256.0)
		iTOf $x $i <A>
		MOVf %1 $x 	; global readRates[i] = ftoi((float) logScale(x, 32768.0, 131072.0) + 0.5)
		MOVf %2 #32768.0 
		MOVf %3 #131072.0 
		CALL &logScale %0 *4
		ADDf %0 %0 #0.5
		fTOi %0 %0 #1.0
		POKE &readRates $i %0
		MOVf %1 $x 	; global blockLens[i] = ftoi((float) logScale(x, 128.0, 32768.0) + 0.5)
		MOVf %2 #128.0 
		MOVf %3 #32768.0 
		CALL &logScale %0 *4
		ADDf %0 %0 #0.5
		fTOi %0 %0 #1.0
		POKE &blockLens $i %0
		MOVf %1 $x 	; minCycle = ftoi((float) logScale(x, 10.0, 2000.0) + 0.5)
		MOVf %2 #10.0 
		MOVf %3 #2000.0 
		CALL &logScale %0 *4
		ADDf %0 %0 #0.5
		fTOi $minCycle %0 #1.0
		POKE &minCycles $i $minCycle	; global minCycles[i] = minCycle
		iTOf %1 $minCycle #1.0	; global thresDKs[i] = (float) decayConstant(itof(minCycle), 0.6666666)
		MOVf %2 #0.6666666 
		CALL &decayConstant %0 *3
		POKE &thresDKs $i %0
		FORi $i #256 @.l1	; }
	.e0:	POKE &blockLens:0 #0 	; global blockLens[0] = 0
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		POKE &breakLoop #TRUE 	; global breakLoop = TRUE
		RETU   	; }


