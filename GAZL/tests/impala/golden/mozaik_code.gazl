	$clock:	LOCi
	$wcLenL:	LOCi
	$wcLenR:	LOCi
	$blockCounter:	LOCi
	$newRCL:	LOCi
	$newRCR:	LOCi
	$hdL:	LOCf
	$hdR:	LOCf
	$lastYL:	LOCf
	$lastYR:	LOCf
	$cycleParam:	LOCi
	$minCycle:	LOCi
	$maxCycle:	LOCi
	$blockLen:	LOCi
	$readRate:	LOCi
	$rateCrushMask:	LOCi
	$bitCrushMask:	LOCi
	$wcStartL:	LOCi
	$ccStartL:	LOCi
	$ccLenL:	LOCi
	$rcStartL:	LOCi
	$rcLenL:	LOCi
	$playPosL:	LOCi
	$wcStartR:	LOCi
	$ccStartR:	LOCi
	$ccLenR:	LOCi
	$rcStartR:	LOCi
	$rcLenR:	LOCi
	$playPosR:	LOCi
	$thresPosL:	LOCf
	$thresNegL:	LOCf
	$thresPosR:	LOCf
	$thresNegR:	LOCf
	$thresDK:	LOCf
	$stageL:	LOCi
	$stageR:	LOCi
	$writeProtect:	LOCi
	$sync:	LOCi
	$reverseMask:	LOCi
;-----------------------------------------------------------------------------
	.l0:	PEEK %0 &wantsReset 	; if ((int)global wantsReset != FALSE) 
		EQUi %0 #FALSE @.f1
		MOVi $playPosL #0 	; wcStartL = ccStartL = ccLenL = rcStartL = rcLenL = playPosL = 0
		MOVi $rcLenL #0 
		MOVi $rcStartL #0 
		MOVi $ccLenL #0 
		MOVi $ccStartL #0 
		MOVi $wcStartL #0 
		MOVi $playPosR #0 	; wcStartR = ccStartR = ccLenR = rcStartR = rcLenR = playPosR = 0
		MOVi $rcLenR #0 
		MOVi $rcStartR #0 
		MOVi $ccLenR #0 
		MOVi $ccStartR #0 
		MOVi $wcStartR #0 
		MOVf $lastYR #0.0 	; thresPosL = thresNegL = thresPosR = thresNegR = lastYL = lastYR = 0.0
		MOVf $lastYL #0.0 
		MOVf $thresNegR #0.0 
		MOVf $thresPosR #0.0 
		MOVf $thresNegL #0.0 
		MOVf $thresPosL #0.0 
		MOVi $stageR #0 	; stageL = stageR = 0
		MOVi $stageL #0 
		MOVi $blockCounter #0 	; blockCounter = 0
		MOVi $newRCR #FALSE 	; newRCL = newRCR = FALSE
		MOVi $newRCL #FALSE 
		POKE &wantsReset #FALSE 	; global wantsReset = FALSE
	.f1:	PEEK $cycleParam &params:OPERAND_2_HIGH_PARAM_INDEX 	; cycleParam = (int) global params[OPERAND_2_HIGH_PARAM_INDEX]
		PEEK $minCycle &minCycles $cycleParam	; minCycle = (int) global minCycles[cycleParam]
		MULi $maxCycle $minCycle #4	; maxCycle = minCycle * 4
		PEEK $thresDK &thresDKs $cycleParam	; thresDK = (float) global thresDKs[cycleParam]
		PEEK %0 &params:OPERAND_1_HIGH_PARAM_INDEX 	; blockLen = (int) global blockLens[(int) global params[OPERAND_1_HIGH_PARAM_INDEX]]
		PEEK $blockLen &blockLens %0
		PEEK %0 &params:OPERAND_2_LOW_PARAM_INDEX 	; readRate = (int) global readRates[(int) global params[OPERAND_2_LOW_PARAM_INDEX]]
		PEEK $readRate &readRates %0
		PEEK %0 &params:OPERAND_1_LOW_PARAM_INDEX 	; rateCrushMask = ~((int) global params[OPERAND_1_LOW_PARAM_INDEX] & 0xF)
		ANDi %0 %0 #0xF
		XORi $rateCrushMask %0 #-1
		PEEK %0 &params:OPERAND_1_LOW_PARAM_INDEX 	; bitCrushMask = ~((int) global params[OPERAND_1_LOW_PARAM_INDEX] & 0xF0)
		ANDi %0 %0 #0xF0
		XORi $bitCrushMask %0 #-1
		PEEK %0 &params:SWITCHES_PARAM_INDEX 	; writeProtect = ((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_WRITE_PROTECT_MASK)
		ANDi $writeProtect %0 #SWITCHES_WRITE_PROTECT_MASK
		MOVi $reverseMask #0 	; reverseMask = 0
		PEEK %0 &params:SWITCHES_PARAM_INDEX 	; if (((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_REVERSE_MASK) != 0) reverseMask = 0xFFFF
		ANDi %0 %0 #SWITCHES_REVERSE_MASK
		EQUi %0 #0 @.f2
		MOVi $reverseMask #0xFFFF 	; reverseMask = 0xFFFF
	.f2:	PEEK %0 &params:SWITCHES_PARAM_INDEX 	; sync = ((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_SYNC_MASK)
		ANDi $sync %0 #SWITCHES_SYNC_MASK
		POKE &breakLoop #FALSE 	; global breakLoop = FALSE
	.l3:	PEEK %0 &breakLoop 	; while ((int)global breakLoop == FALSE) 
		NEQi %0 #FALSE @.l0
		PEEK %0 &clock 	; clock = global clock ^ reverseMask
		XORi $clock %0 $reverseMask
		NEQi $clock #0 @.f6	; if (clock == 0 && sync != FALSE) blockCounter = 0
		EQUi $sync #FALSE @.f6
		MOVi $blockCounter #0 	; blockCounter = 0
	.f6:	PEEK %0 &signal:0 	; inL = itof((int) global signal[0]) * (1.0 / 2048.0)
		! DIVf <A> #1.0 #2048.0
		iTOf $inL %0 <A>
		SUBf %0 $inL $hdL	; if (abs(inL - hdL) < HP_EPSILON) hdL = inL
		ABSf %0 %0 
		GEQf %0 #HP_EPSILON @.f7
		MOVf $hdL $inL 	; hdL = inL
		GOTO @.e8  
	.f7:	SUBf %0 $inL $hdL	; hdL = hdL + (inL - hdL) * HP_K
		MULf %0 %0 #HP_K
		ADDf $hdL $hdL %0
	.e8:	SUBf $yL $inL $hdL	; yL = inL - hdL
		PEEK %0 &signal:1 	; inR = itof((int) global signal[1]) * (1.0 / 2048.0)
		! DIVf <A> #1.0 #2048.0
		iTOf $inR %0 <A>
		SUBf %0 $inR $hdR	; if (abs(inR - hdR) < HP_EPSILON) hdR = inR
		ABSf %0 %0 
		GEQf %0 #HP_EPSILON @.f9
		MOVf $hdR $inR 	; hdR = inR
		GOTO @.e10  
	.f9:	SUBf %0 $inR $hdR	; hdR = hdR + (inR - hdR) * HP_K
		MULf %0 %0 #HP_K
		ADDf $hdR $hdR %0
	.e10:	SUBf $yR $inR $hdR	; yR = inR - hdR
		fTOi $y2:0 $yL #2048.0	; y2[0] = ftoi(yL * 2048.0)
		fTOi $y2:1 $yR #2048.0	; y2[1] = ftoi(yR * 2048.0)
		MOVi %1 $clock 	; write(clock, 1, y2)
		MOVi %2 #1 
		ADRL %3 $y2 *0
		CALL ^write %0 *4
		MULf $thresPosL $thresPosL $thresDK	; thresPosL = thresPosL * thresDK
		MULf $thresNegL $thresNegL $thresDK	; thresNegL = thresNegL * thresDK
		MULf $thresPosR $thresPosR $thresDK	; thresPosR = thresPosR * thresDK
		MULf $thresNegR $thresNegR $thresDK	; thresNegR = thresNegR * thresDK
		LSSf $yL $thresPosL @.f11	; if (yL >= thresPosL) 
		MOVf $thresPosL $yL 	; thresPosL = yL
		NEQi $stageL #0 @.f11	; if (stageL == 0) stageL = 1
		MOVi $stageL #1 	; stageL = 1
	.f11:	GRTf $yL $thresNegL @.f13	; if (yL <= thresNegL) 
		MOVf $thresNegL $yL 	; thresNegL = yL
		NEQi $stageL #1 @.f13	; if (stageL == 1) stageL = 2
		MOVi $stageL #2 	; stageL = 2
	.f13:	SUBi %0 $clock $wcStartL	; wcLenL = (clock - wcStartL) & 0xFFFF
		ANDi $wcLenL %0 #0xFFFF
		LSSi $wcLenL $maxCycle @.f15	; if (wcLenL >= maxCycle) stageL = 2
		MOVi $stageL #2 	; stageL = 2
	.f15:	GRTf $lastYL #0.0 @.f17	; if (lastYL <= 0.0 && yL >= 0.0 && stageL == 2 && wcLenL >= minCycle) 
		LSSf $yL #0.0 @.f17
		NEQi $stageL #2 @.f17
		LSSi $wcLenL $minCycle @.f17
		MOVi $stageL #0 	; stageL = 0
		MOVi $ccStartL $wcStartL 	; ccStartL = wcStartL
		MOVi $ccLenL $wcLenL 	; ccLenL = wcLenL
		MOVi $wcStartL $clock 	; wcStartL = clock
	.f17:	LSSf $yR $thresPosR @.f18	; if (yR >= thresPosR) 
		MOVf $thresPosR $yR 	; thresPosR = yR
		NEQi $stageR #0 @.f18	; if (stageR == 0) stageR = 1
		MOVi $stageR #1 	; stageR = 1
	.f18:	GRTf $yR $thresNegR @.f20	; if (yR <= thresNegR) 
		MOVf $thresNegR $yR 	; thresNegR = yR
		NEQi $stageR #1 @.f20	; if (stageR == 1) stageR = 2
		MOVi $stageR #2 	; stageR = 2
	.f20:	SUBi %0 $clock $wcStartR	; wcLenR = (clock - wcStartR) & 0xFFFF
		ANDi $wcLenR %0 #0xFFFF
		LSSi $wcLenR $maxCycle @.f22	; if (wcLenR >= maxCycle) stageR = 2
		MOVi $stageR #2 	; stageR = 2
	.f22:	GRTf $lastYR #0.0 @.f24	; if (lastYR <= 0.0 && yR >= 0.0 && stageR == 2 && wcLenR >= minCycle) 
		LSSf $yR #0.0 @.f24
		NEQi $stageR #2 @.f24
		LSSi $wcLenR $minCycle @.f24
		MOVi $stageR #0 	; stageR = 0
		MOVi $ccStartR $wcStartR 	; ccStartR = wcStartR
		MOVi $ccLenR $wcLenR 	; ccLenR = wcLenR
		MOVi $wcStartR $clock 	; wcStartR = clock
	.f24:	MOVf $lastYL $yL 	; lastYL = yL
		MOVf $lastYR $yR 	; lastYR = yR
		GRTi $blockCounter #0 @.f25	; if (blockCounter <= 0) 
		MOVi $blockCounter $blockLen 	; blockCounter = blockLen
		MOVi $newRCL #TRUE 	; newRCL = TRUE
		MOVi $newRCR #TRUE 	; newRCR = TRUE
	.f25:	SUBi $blockCounter $blockCounter #1	; blockCounter = blockCounter - 1
		SHRi %1 $playPosL #16	; read(rcStartL + ((playPosL >> 16) & rateCrushMask ^ reverseMask), 1, y2)
		ANDi %1 %1 $rateCrushMask
		XORi %1 %1 $reverseMask
		ADDi %1 $rcStartL %1
		MOVi %2 #1 
		ADRL %3 $y2 *0
		CALL ^read %0 *4
		ANDi %0 $y2:0 $bitCrushMask	; global signal[0] = (int) y2[0] & bitCrushMask
		POKE &signal:0 %0 
		SHRi %1 $playPosR #16	; read(rcStartR + ((playPosR >> 16) & rateCrushMask ^ reverseMask), 1, y2)
		ANDi %1 %1 $rateCrushMask
		XORi %1 %1 $reverseMask
		ADDi %1 $rcStartR %1
		MOVi %2 #1 
		ADRL %3 $y2 *0
		CALL ^read %0 *4
		ANDi %0 $y2:1 $bitCrushMask	; global signal[1] = (int) y2[1] & bitCrushMask
		POKE &signal:1 %0 
		ADDi $playPosL $playPosL $readRate	; playPosL = playPosL + readRate
		LSSi $playPosL $rcLenL @.f26	; if (playPosL >= rcLenL) 
		EQUi $newRCL #FALSE @.f28	; if (newRCL != FALSE && writeProtect == 0) 
		NEQi $writeProtect #0 @.f28
		ANDi %0 $rcLenL $reverseMask	; rcStartL = ccStartL + (rcLenL & reverseMask)
		ADDi $rcStartL $ccStartL %0
		SHLi $rcLenL $ccLenL #16	; rcLenL = ccLenL << 16
		MOVi $newRCL #FALSE 	; newRCL = FALSE
	.f28:	MOVi $playPosL #0 	; playPosL = 0
	.f26:	ADDi $playPosR $playPosR $readRate	; playPosR = playPosR + readRate
		LSSi $playPosR $rcLenR @.f29	; if (playPosR >= rcLenR) 
		EQUi $newRCR #FALSE @.f31	; if (newRCR != FALSE && writeProtect == 0) 
		NEQi $writeProtect #0 @.f31
		ANDi %0 $rcLenR $reverseMask	; rcStartR = ccStartR + (rcLenR & reverseMask)
		ADDi $rcStartR $ccStartR %0
		SHLi $rcLenR $ccLenR #16	; rcLenR = ccLenR << 16
		MOVi $newRCR #FALSE 	; newRCR = FALSE
	.f31:	MOVi $playPosR #0 	; playPosR = 0
	.f29:	CALL ^yield %0 *1	; yield()
		GOTO @.l3  	; }
		GOTO @.l0  	; }
		RETU   	; }

.s_4d2:	CNST *2
	DATi #32 #0
.s_CRUSH4d3:	CNST *54
