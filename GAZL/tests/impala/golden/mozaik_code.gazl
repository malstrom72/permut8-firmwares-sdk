;-----------------------------------------------------------------------------
error:	FUNC
		PARA *1
	$s:	INPp
;-----------------------------------------------------------------------------
		MOVp %1 $s 	; trace(s)
		CALL ^trace %0 *2
		CALL ^abort %0 *1	; abort()
		RETU   	; }


;-----------------------------------------------------------------------------
exp:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		ABSf $m $x 	; m = abs(x)
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $a $m	; a = a * m / n
		DIVf $a %0 $n
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l0	; } while (y != t)
		GEQf $x #0.0 @.f1	; if (x < 0.0) y = 1.0 / y
		DIVf $y #1.0 $y	; y = 1.0 / y
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
log:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$b:	LOCf
	$m:	LOCf
	$n:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		LEQf $x #0.0 @.t0	; if (x <= 0.0 || x >= 1.0e38) error("Domain error")
