; Compiled with Impala version 1.0


;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
	$buffer:	LOCA *1024
;-----------------------------------------------------------------------------
		MOVp %1 &.s_HEJ4d2 	; print("HEJ")
		CALL ^print %0 *2
		CALL ^printLF %0 *1	; printLF()
		MOVi %2 #10 	; printInt((int) input(10, buffer))
		ADRL %3 $buffer *0
		CALL ^input %1 *3
		CALL ^printInt %0 *2
		CALL ^printLF %0 *1	; printLF()
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		CALL ^printLF %0 *1	; printLF()
		RETU   	; }

.s_HEJ4d2:	CNST *4
	DATs HEJ
	DATi #0