;-----------------------------------------------------------------------------
nextRandom:	FUNC
	$y:	OUTi
	$x:	LOCi
	$t:	LOCi
;-----------------------------------------------------------------------------
		PEEK $x &randPX 	; x = global randPX
		PEEK $y &randPY 	; y = global randPY
		SHLi %0 $x #10	; t = x ^ (x << 10)
		XORi $t $x %0
		MOVi $x $y 	; x = y
		SHRu %0 $y #13	; y = y ^ (y >>> 13) ^ t ^ (t >>> 10)
		XORi %0 $y %0
		XORi %0 %0 $t
		SHRu %1 $t #10
		XORi $y %0 %1
		POKE &randPX $x 	; global randPX = x
		POKE &randPY $y 	; global randPY = y
		RETU   	; }


;-----------------------------------------------------------------------------
initGlobals:	FUNC
		PARA *1
	$i:	LOCi
;-----------------------------------------------------------------------------
		MOVi $i #0 	; for (i = 0 to 64 * BOARD_SIZE) 
		! MULi <B> #64 #BOARD_SIZE
		GEQi #0 <B> @.e0
	.l1:	CALL &nextRandom %0 *1	; global pieceKeys[i] = nextRandom()
		POKE &pieceKeys $i %0
		FORi $i <B> @.l1	; }
	.e0:	MOVi $i #0 	; for (i = 0 to 256) 
		GEQi #0 #256 @.e2
	.l3:	CALL &nextRandom %0 *1	; global xCaptureKeys[i] = nextRandom()
		POKE &xCaptureKeys $i %0
		FORi $i #256 @.l3	; }
	.e2:	CALL &nextRandom %0 *1	; global colorKeys[WHITE] = nextRandom()
		POKE &colorKeys:WHITE %0 
		CALL &nextRandom %0 *1	; global colorKeys[BLACK] = nextRandom()
		POKE &colorKeys:BLACK %0 
		RETU   	; }


;-----------------------------------------------------------------------------
isOnBoard:	FUNC
	$b:	OUTi
	$square:	INPi
;-----------------------------------------------------------------------------
		MOVi $b #FALSE 	; b = FALSE
		LSSi $square #0 @.f1	; if (square >= 0 && square < BOARD_SIZE && (int) global INIT_BOARD[square] != OFFBOARD) 
		GEQi $square #BOARD_SIZE @.f1
		PEEK %0 &INIT_BOARD $square
		EQUi %0 #OFFBOARD @.f1
		MOVi $b #TRUE 	; b = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
isValidColor:	FUNC
	$b:	OUTi
	$color:	INPi
;-----------------------------------------------------------------------------
		MOVi $b #FALSE 	; b = FALSE
		EQUi $color #WHITE @.t0	; if (color == WHITE || color == BLACK) 
		NEQi $color #BLACK @.f1
	.t0:	MOVi $b #TRUE 	; b = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
isValidMove:	FUNC
	$b:	OUTi
	$move:	INPi
;-----------------------------------------------------------------------------
		MOVi $b #FALSE 	; b = FALSE
		ANDi %0 $move #MOVE_MASK	; if ((move & MOVE_MASK) == move && (int) isOnBoard(move & FROM_MASK) != FALSE && (int) isOnBoard((move & TO_MASK) >> TO_SHIFT) != FALSE) 
		NEQi %0 $move @.f1
		ANDi %1 $move #FROM_MASK
		CALL &isOnBoard %0 *2
		EQUi %0 #FALSE @.f1
		ANDi %1 $move #TO_MASK
		SHRi %1 %1 #TO_SHIFT
		CALL &isOnBoard %0 *2
		EQUi %0 #FALSE @.f1
		MOVi $b #TRUE 	; b = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
isValidPiece:	FUNC
	$b:	OUTi
	$piece:	INPi
;-----------------------------------------------------------------------------
		MOVi $b #FALSE 	; b = FALSE
		GRTi #1 $piece @.f1	; if (1 <= piece && piece < 64 && (piece & PIECE_MASK) >= 1 && (piece & PIECE_MASK) <= 6
		GEQi $piece #64 @.f1
		ANDi %0 $piece #PIECE_MASK
		LSSi %0 #1 @.f1
		ANDi %0 $piece #PIECE_MASK
		GRTi %0 #6 @.f1
		ANDi %1 $piece #COLOR_MASK
		CALL &isValidColor %0 *2
		EQUi %0 #FALSE @.f1
		MOVi $b #TRUE 	; b = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
moveFrom:	FUNC
	$f:	OUTi
	$move:	INPi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isValidMove(move) != FALSE)
		MOVi %1 $move 
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisV4d2 
		CALL ^assertFail %0 *1
	.a0:	ANDi $f $move #FROM_MASK	; f = (move & FROM_MASK)
		RETU   	; }


;-----------------------------------------------------------------------------
moveTo:	FUNC
	$t:	OUTi
	$move:	INPi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isValidMove(move) != FALSE)
		MOVi %1 $move 
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisV4d2 
		CALL ^assertFail %0 *1
	.a0:	SHRi $t $move #TO_SHIFT	; t = (move >> TO_SHIFT)
		RETU   	; }


;-----------------------------------------------------------------------------
makeMove:	FUNC
	$m:	OUTi
	$fromCol:	INPi
	$fromRow:	INPi
	$toCol:	INPi
	$toRow:	INPi
;-----------------------------------------------------------------------------
		ADDi %0 $fromRow #2	; m = ((fromRow + 2) * STRIDE + fromCol + 1) | (((toRow + 2) * STRIDE + toCol + 1) << TO_SHIFT)
		MULi %0 %0 #STRIDE
		ADDi %0 %0 $fromCol
		ADDi %1 $toRow #2
		MULi %1 %1 #STRIDE
		ADDi %1 %1 $toCol
		ADDi %1 %1 #1
		ADDi %0 %0 #1
		SHLi %1 %1 #TO_SHIFT
		IORi $m %0 %1
		RETU   	; }


;-----------------------------------------------------------------------------
switchColor:	FUNC
	$c:	OUTi
	$color:	INPi
;-----------------------------------------------------------------------------
		XORi $c $color #COLOR_SWITCH_XOR	; c = (color ^ COLOR_SWITCH_XOR)
		RETU   	; }


