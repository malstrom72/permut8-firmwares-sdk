	.e4:	NOOP
	returnNow:	RETU   	; }


;-----------------------------------------------------------------------------
search:	FUNC
	$result:	OUTi
	$alpha:	INPi
	$beta:	INPi
	$depth:	INPi
	$score:	INPi
	$capturesOnly:	INPi
	$h:	LOCi
	$hashIndex:	LOCi
	$entry:	LOCi
	$firstMove:	LOCi
	$best:	LOCi
	$bestMove:	LOCi
	$s:	LOCi
	$myBeta:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(0 <= depth)
		LEQi #0 $depth @.a0
		MOVp %1 &.a_0depth4f2 
		CALL ^assertFail %0 *1
	.a0:	NOOP
		! EQUi #DEBUG #0 @.a1	; assert((int) checkInvariant() != FALSE)
		CALL &checkInvariant %0 *1
		NEQi %0 #FALSE @.a1
		MOVp %1 &.a_intche4eb 
		CALL ^assertFail %0 *1
	.a1:	MOVi $myBeta $beta 	; myBeta = beta
		ADDi %0 #CAPTURE_KING_MIN_SCORE $depth	; if (myBeta > CAPTURE_KING_MIN_SCORE + depth) 
		LEQi $myBeta %0 @.f2
		ADDi $myBeta #CAPTURE_KING_MIN_SCORE $depth	; myBeta = CAPTURE_KING_MIN_SCORE + depth
	.f2:	PEEK %0 &xCapture 	; h = (global boardHash + (int) global xCaptureKeys[global xCapture] + (int) global colorKeys[global turnColor]) & HASH_MASK
		PEEK %1 &boardHash 
		PEEK %0 &xCaptureKeys %0
		PEEK %2 &turnColor 
		ADDi %1 %1 %0
		PEEK %2 &colorKeys %2
		ADDi %1 %1 %2
		ANDi $h %1 #HASH_MASK
		! SUBi <B> #HASH_TABLE_SIZE #1	; hashIndex = (h & (HASH_TABLE_SIZE - 1))
		ANDi $hashIndex $h <B>
		! XORi <B> #MOVE_MASK #-1	; h = (h & ~MOVE_MASK)
		ANDi $h $h <B>
		PEEK $entry &hashTable $hashIndex	; entry = (int) global hashTable[hashIndex]
		MOVi $firstMove #0 	; firstMove = 0
		! XORi <B> #MOVE_MASK #-1	; if ((entry & ~MOVE_MASK) == h) 
		ANDi %1 $entry <B>
		NEQi %1 $h @.f3
		ANDi $firstMove $entry #MOVE_MASK	; firstMove = entry & MOVE_MASK
	.f3:	EQUi $capturesOnly #FALSE @.f4	; if (capturesOnly != FALSE) 
		MOVi %1 $alpha 	; best = (int) searchCaptures(alpha, myBeta, depth, score, firstMove)
		MOVi %2 $myBeta 
		MOVi %3 $depth 
		MOVi %4 $score 
		MOVi %5 $firstMove 
		CALL &searchCaptures %0 *6
		MOVi $best %0 
		MOVi $result $best 	; result = best
		GOTO @.e5  	; } else 
	.f4:	MOVi %1 $alpha 	; best = (int) searchAll(alpha, myBeta, depth, score, firstMove)
		MOVi %2 $myBeta 
		MOVi %3 $depth 
		MOVi %4 $score 
		MOVi %5 $firstMove 
		CALL &searchAll %0 *6
		MOVi $best %0 
		MOVi $result $best 	; result = best
		SHRi $s $result #SCORE_SHIFT	; s = result >> SCORE_SHIFT
		ADDi %0 #CAPTURE_KING_MIN_SCORE $depth	; if (s == CAPTURE_KING_MIN_SCORE + depth) 
		NEQi $s %0 @.f6
		ANDi %0 $result #SCORE_MASK	; result = (result & SCORE_MASK) | IN_CHECK
		IORi $result %0 #IN_CHECK
		GOTO @.e7  	; } else if (s == -(CAPTURE_KING_MIN_SCORE + depth - 1)) 
	.f6:	ADDi %0 #CAPTURE_KING_MIN_SCORE $depth	; if (s == -(CAPTURE_KING_MIN_SCORE + depth - 1)) 
		SUBi %0 %0 #1
		SUBi %0 #0 %0
		NEQi $s %0 @.f8
		PEEK %2 &turnColor 	; if ((int) canCaptureKing((int) switchColor(global turnColor)) != FALSE) 
		CALL &switchColor %1 *2
		CALL &canCaptureKing %0 *2
		EQUi %0 #FALSE @.f9
		ANDi %0 $result #SCORE_MASK	; result = (result & SCORE_MASK) | CHECKMATE
		IORi $result %0 #CHECKMATE
		GOTO @.e10  	; } else 
	.f9:	SHLi %0 $score #SCORE_SHIFT	; result = (score << SCORE_SHIFT) | STALEMATE
		IORi $result %0 #STALEMATE
	.e10:	NOOP
	.f8:	NOOP
	.e7:	NOOP
	.e5:	ANDi $bestMove $best #MOVE_MASK	; bestMove = (best & MOVE_MASK)
		EQUi $bestMove #0 @.f11	; if (bestMove != 0) 
		! EQUi #DEBUG #0 @.a12	; assert((int) isValidMove(bestMove) != FALSE)
		MOVi %1 $bestMove 
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a12
		MOVp %1 &.a_intisV4f6 
		CALL ^assertFail %0 *1
	.a12:	IORi %0 $h $bestMove	; global hashTable[hashIndex] = h | bestMove
		POKE &hashTable $hashIndex %0
	.f11:	PEEK %0 &evalCounter 	; global evalCounter = global evalCounter + 1
		ADDi %0 %0 #1
		POKE &evalCounter %0 
		PEEK %0 &evalCounter 	; if (global evalCounter < 0) 
		GEQi %0 #0 @.f13
		PEEK %0 &evalCounter 	; global evalCounter = global evalCounter - 1
		SUBi %0 %0 #1
		POKE &evalCounter %0 
	.f13:	RETU   	; }


;-----------------------------------------------------------------------------
executeMove:	FUNC
	$status:	OUTi
	$move:	INPi
	$tos:	LOCA *MAX_TARGET_SQUARES
	$frm:	LOCi
	$t:	LOCi
	$oldPiece:	LOCi
	$captured:	LOCi
	$oldXCapture:	LOCi
	$toCount:	LOCi
	$i:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isValidMove(move) != FALSE)
		MOVi %1 $move 
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisV4d2 
		CALL ^assertFail %0 *1
	.a0:	PEEK %0 &turnColor 	; frm = (int) global nextPiece[global turnColor]
		PEEK $frm &nextPiece %0
	.l1:	PEEK %0 &turnColor 	; while (frm != global turnColor) 
		EQUi $frm %0 @.e2
		! EQUi #DEBUG #0 @.a3	; assert((int) global board[frm] > EMPTY && ((int) global board[frm] & COLOR_MASK) == global turnColor)
		PEEK %0 &board $frm
		LEQi %0 #EMPTY @.f4
		PEEK %0 &board $frm
		ANDi %0 %0 #COLOR_MASK
		PEEK %1 &turnColor 
		EQUi %0 %1 @.a3
	.f4:	MOVp %1 &.a_intglo4f7 
		CALL ^assertFail %0 *1
	.a3:	PEEK %1 &turnColor 	; toCount = (int) listMoves(global turnColor, frm, tos)
		MOVi %2 $frm 
		ADRL %3 $tos *0
		CALL &listMoves %0 *4
		MOVi $toCount %0 
		! EQUi #DEBUG #0 @.a5	; assert(toCount <= MAX_TARGET_SQUARES)
		LEQi $toCount #MAX_TARGET_SQUARES @.a5
		MOVp %1 &.a_toCoun4f0 
		CALL ^assertFail %0 *1
	.a5:	MOVi $i #0 	; for (i = 0 to toCount) 
		GEQi #0 $toCount @.e6
	.l7:	GETL $t $tos $i	; t = (int) tos[i]
		SHLi %0 $t #TO_SHIFT	; if (move == (frm | (t << TO_SHIFT))) 
		IORi %0 $frm %0
		NEQi $move %0 @.f8
		PEEK $oldPiece &board $frm	; oldPiece = (int) global board[frm]
		PEEK $captured &board $t	; captured = (int) global board[t]
		PEEK $oldXCapture &xCapture 	; oldXCapture = global xCapture
		MOVi %1 $frm 	; doMove(frm, t, oldPiece, captured, oldXCapture)
		MOVi %2 $t 
		MOVi %3 $oldPiece 
		MOVi %4 $captured 
		MOVi %5 $oldXCapture 
		CALL &doMove %0 *6
		MOVi %1 #MIN_SCORE 	; switch (((int) search(MIN_SCORE, MAX_SCORE, 1, 0, FALSE) & MOVE_MASK) == IN_CHECK to (CHECKMATE + 1)) 
		MOVi %2 #MAX_SCORE 
		MOVi %3 #1 
		MOVi %4 #0 
		MOVi %5 #FALSE 
		CALL &search %0 *6
		! ADDi <B> #CHECKMATE #1
		! SUBi <B> <B> #IN_CHECK
		ANDi %0 %0 #MOVE_MASK
		SUBi %0 %0 #IN_CHECK
		SWCH %0 *<B> @.s9
	.s9:	MOVi $status #VALID_MOVE 	; status = VALID_MOVE
		GOTO @returnNow  	; goto returnNow
		GOTO @.e10  	; }
		! SUBi <B> #CHECKMATE #IN_CHECK	; case CHECKMATE
	.s9#<B>:	MOVi $status #CHECKMATE 	; status = CHECKMATE
		GOTO @returnNow  	; goto returnNow
		GOTO @.e10  	; }
		! SUBi <B> #STALEMATE #IN_CHECK	; case STALEMATE
	.s9#<B>:	MOVi $status #STALEMATE 	; status = STALEMATE
		GOTO @returnNow  	; goto returnNow
		GOTO @.e10  	; }
		! SUBi <B> #IN_CHECK #IN_CHECK	; case IN_CHECK
	.s9#<B>:	MOVi %1 $frm 	; undoMove(frm, t, oldPiece, captured, oldXCapture)
		MOVi %2 $t 
		MOVi %3 $oldPiece 
		MOVi %4 $captured 
		MOVi %5 $oldXCapture 
		CALL &undoMove %0 *6
		MOVi $status #IN_CHECK 	; status = IN_CHECK
		GOTO @returnNow  	; goto returnNow
	.e10:	NOOP
	.f8:	FORi $i $toCount @.l7	; }
	.e6:	PEEK $frm &nextPiece $frm	; frm = (int) global nextPiece[frm]
		GOTO @.l1  	; }
	.e2:	MOVi $status #INVALID_MOVE 	; status = INVALID_MOVE
	returnNow:	RETU   	; }


;-----------------------------------------------------------------------------
getComputerMove:	FUNC
	$move:	OUTi
	$d:	LOCi
	$m:	LOCi
	$printedThinking:	LOCi
;-----------------------------------------------------------------------------
		MOVi $printedThinking #FALSE 	; printedThinking = FALSE
		MOVi $m #0 	; m = 0
		POKE &evalCounter #0 	; global evalCounter = 0
		MOVi $d #MIN_DEPTH 	; d = MIN_DEPTH
	.l0:	GRTi $d #MAX_DEPTH @.e2	; while (d <= MAX_DEPTH && global evalCounter < global minEvals) 
		PEEK %0 &evalCounter 
		PEEK %1 &minEvals 
		GEQi %0 %1 @.e2
		PEEK %0 &evalCounter 	; if (global evalCounter > 1000000) 
		LEQi %0 #1000000 @.f3
		NEQi $printedThinking #FALSE @.f4	; if (printedThinking == FALSE) 
		MOVp %1 &.s_Thinki4d8 	; print("Thinking...")
		CALL ^print %0 *2
		MOVi $printedThinking #TRUE 	; printedThinking = TRUE
	.f4:	MOVp %1 &.s_Thinki4d8:10 	; print(".")
		CALL ^print %0 *2
	.f3:	MOVi %1 #MIN_SCORE 	; m = (int) search(MIN_SCORE, MAX_SCORE, d, 0, FALSE)
		MOVi %2 #MAX_SCORE 
		MOVi %3 $d 
		MOVi %4 #0 
		MOVi %5 #FALSE 
		CALL &search %0 *6
		MOVi $m %0 
		ADDi $d $d #1	; d = d + 1
		GOTO @.l0  	; }
	.e2:	EQUi $printedThinking #FALSE @.f5	; if (printedThinking != FALSE) 
		CALL ^printLF %0 *1	; printLF()
	.f5:	NOOP
		! EQUi #DEBUG #0 @.a6	; assert((m & MOVE_MASK) == CHECKMATE || (m & MOVE_MASK) == STALEMATE || (int) isValidMove(m & MOVE_MASK) != FALSE)
		ANDi %0 $m #MOVE_MASK
		EQUi %0 #CHECKMATE @.a6
		ANDi %0 $m #MOVE_MASK
		EQUi %0 #STALEMATE @.a6
		ANDi %1 $m #MOVE_MASK
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a6
		MOVp %1 &.a_mMOVEM4f8 
		CALL ^assertFail %0 *1
	.a6:	ANDi $move $m #MOVE_MASK	; move = (m & MOVE_MASK)
		RETU   	; }

LET_COMPUTER_PLAY:	! DEFi #-1
TAKE_BACK:	! DEFi #-2
NEW_GAME:	! DEFi #-3
QUIT:	! DEFi #-4
SYNTAX_ERROR:	! DEFi #-5
MATE:	! DEFi #-6
SET_MAXIMUM_LEVEL:	! DEFi #-93
SET_MINIMUM_LEVEL:	! DEFi #-101

;-----------------------------------------------------------------------------
strcmp:	FUNC
	$d:	OUTi
	$s0:	INPp
	$s1:	INPp
	$a:	LOCp
	$b:	LOCp
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVp $a $s0 	; a = s0
		MOVp $b $s1 	; b = s1
	.l0:	PEEK $c $a 	; while ((d = (c = (int)*a) - (int)*b) == 0 && c != 0) 
		PEEK %0 $b 
		SUBi $d $c %0
		NEQi $d #0 @.e2
		EQUi $c #0 @.e2
		ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		GOTO @.l0  	; }
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
strncmp:	FUNC
	$d:	OUTi
	$s0:	INPp
	$s1:	INPp
	$n:	INPi
	$a:	LOCp
	$b:	LOCp
	$i:	LOCi
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVi $d #0 	; d = 0
		LEQi $n #0 @.f0	; if (n > 0) 
		MOVp $a $s0 	; a = s0
		MOVp $b $s1 	; b = s1
		MOVi $i #1 	; for (i = 1 to n) 
		GEQi #1 $n @.f0
	.l2:	PEEK $c $a 	; if ((d = (c = (int)*a) - (int)*b) != 0 || c == 0) goto done
		PEEK %0 $b 
		SUBi $d $c %0
		NEQi $d #0 @done
		NEQi $c #0 @.f4
		GOTO @done  	; goto done
	.f4:	ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		FORi $i $n @.l2	; }
	done:	NOOP
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
toupper:	FUNC
	$u:	OUTi
	$c:	INPi
;-----------------------------------------------------------------------------
		MOVi $u $c 	; u = c
		LSSi $u #'a' @.f1	; if (u >= 'a' && u <= 'z') 
		GRTi $u #'z' @.f1
		! SUBi <B> #'a' #'A'	; u = u - ('a' - 'A')
		SUBi $u $u <B>
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
getUserMove:	FUNC
	$result:	OUTi
	$level:	LOCi
	$s:	LOCA *256
	$l:	LOCi
	$fromCol:	LOCi
	$fromRow:	LOCi
	$i:	LOCi
	$toCol:	LOCi
	$toRow:	LOCi
;-----------------------------------------------------------------------------
	.l0:	MOVi $result #SYNTAX_ERROR 	; result = SYNTAX_ERROR
		MOVp %1 &.s_4d9 	; print(">")
		CALL ^print %0 *2
		MOVi %1 #1023 	; l = (int) input(1023, s)
		ADRL %2 $s *0
		CALL ^input %0 *3
		MOVi $l %0 
		LEQi $l #0 @.f2	; if (l > 0 && (int) s[l - 1] == '\n') 
		SUBi %0 $l #1
		GETL %0 $s %0
		NEQi %0 #'\n' @.f2
		SUBi %0 $l #1	; s[l - 1] = 0
		SETL $s %0 #0
	.f2:	ADRL %1 $s *0	; if ((int) strcmp(s, "go") == 0) 
		MOVp %2 &.s_go4da 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f3
		MOVi $result #LET_COMPUTER_PLAY 	; result = LET_COMPUTER_PLAY
		GOTO @.e4  	; } else if ((int) strcmp(s, "back") == 0) 
	.f3:	ADRL %1 $s *0	; if ((int) strcmp(s, "back") == 0) 
		MOVp %2 &.s_back4db 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f5
		MOVi $result #TAKE_BACK 	; result = TAKE_BACK
		GOTO @.e6  	; } else if ((int) strcmp(s, "new") == 0) 
	.f5:	ADRL %1 $s *0	; if ((int) strcmp(s, "new") == 0) 
		MOVp %2 &.s_new4dc 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f7
		MOVi $result #NEW_GAME 	; result = NEW_GAME
		GOTO @.e8  	; } else if ((int) strncmp(s, "level ", 6) == 0 && l == 7 && (level = (int) s[6] - '0') >= 1 && level <= 9) 
	.f7:	ADRL %1 $s *0	; if ((int) strncmp(s, "level ", 6) == 0 && l == 7 && (level = (int) s[6] - '0') >= 1 && level <= 9) 
		MOVp %2 &.s_level4dd 
		MOVi %3 #6 
		CALL &strncmp %0 *4
		NEQi %0 #0 @.f10
		NEQi $l #7 @.f10
		SUBi $level $s:6 #'0'
		LSSi $level #1 @.f10
		GRTi $level #9 @.f10
		ADDi %0 #SET_MINIMUM_LEVEL $level	; result = SET_MINIMUM_LEVEL + level - 1
		SUBi $result %0 #1
		GOTO @.e11  	; } else if ((int) strcmp(s, "quit") == 0) 
	.f10:	ADRL %1 $s *0	; if ((int) strcmp(s, "quit") == 0) 
		MOVp %2 &.s_quit4de 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f12
		MOVi $result #QUIT 	; result = QUIT
		GOTO @.e13  	; } else 
	.f12:	MOVE %1 $s:0 	; fromCol = ((int) toupper(s[0]) - 'A')
		CALL &toupper %0 *2
		SUBi $fromCol %0 #'A'
		SUBi $fromRow $s:1 #'1'	; fromRow = ((int) s[1] - '1')
		MOVi $i #2 	; i = 2
		NEQi $s:2 #'-' @.f14	; if ((int) s[2] == '-') i = 3
		MOVi $i #3 	; i = 3
	.f14:	GETL %1 $s $i	; toCol = ((int) toupper(s[i]) - 'A')
		CALL &toupper %0 *2
		SUBi $toCol %0 #'A'
		ADDi %0 $i #1	; toRow = ((int) s[i + 1] - '1')
		GETL %0 $s %0
		SUBi $toRow %0 #'1'
		LSSi $fromCol #0 @.f16	; if (fromCol >= 0 && fromCol < 8 && fromRow >= 0 && fromRow < 8
		GEQi $fromCol #8 @.f16
		LSSi $fromRow #0 @.f16
		GEQi $fromRow #8 @.f16
		LSSi $toCol #0 @.f16
		GEQi $toCol #8 @.f16
		LSSi $toRow #0 @.f16
		GEQi $toRow #8 @.f16
		MOVi %1 $fromCol 	; result = (int) makeMove(fromCol, fromRow, toCol, toRow)
		MOVi %2 $fromRow 
		MOVi %3 $toCol 
		MOVi %4 $toRow 
		CALL &makeMove %0 *5
		MOVi $result %0 
		GOTO @.e17  	; } else 
	.f16:	MOVp %1 &.s_Enterm4df 	; print("Enter moves like 'd2d4' or:\n'level 1-9' to set computer level (default is 3).\n'go' to switch color and let the computer play.\n'back' to take back a step.\n'new' to start a new game.\n'quit' to exit.\n")
		CALL ^print %0 *2
	.e17:	NOOP
	.e13:	NOOP
	.e11:	NOOP
	.e8:	NOOP
	.e6:	NOOP
	.e4:	EQUi $result #SYNTAX_ERROR @.l0	; } while (result == SYNTAX_ERROR)
		RETU   	; }


;-----------------------------------------------------------------------------
printBoard:	FUNC
		PARA *1
	$frm:	INPi
	$t:	INPi
	$y:	LOCi
	$lastI:	LOCi
	$buffer:	LOCA *2
	$i:	LOCi
	$c:	LOCi
	$x:	LOCi
;-----------------------------------------------------------------------------
		MOVi $buffer:1 #0 	; buffer[1] = 0
		MOVi $lastI #-1 	; lastI = -1
		MOVp %1 &.s_ABCDEF4e0 	; print("    A B C D E F G H\n")
		CALL ^print %0 *2
		MOVp %1 &.s_4e1 	; print("  +-----------------+\n")
		CALL ^print %0 *2
		MOVi $y #0 	; for (y = 0 to 8) 
		GEQi #0 #8 @.e0
	.l1:	SUBi $buffer:0 #'8' $y	; buffer[0] = '8' - y
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		MOVp %1 &.s_4e2 	; print(" |")
		CALL ^print %0 *2
		MOVi $x #0 	; for (x = 0 to 8) 
		GEQi #0 #8 @.e2
	.l3:	SUBi %0 #9 $y	; i = (9 - y) * STRIDE + (x + 1)
		MULi %0 %0 #STRIDE
		ADDi %1 $x #1
		ADDi $i %0 %1
		MOVi $c #' ' 	; c = ' '
		EQUi $i $frm @.t4	; if (i == frm || i == t) c = '('
		NEQi $i $t @.f5
	.t4:	MOVi $c #'(' 	; c = '('
	.f5:	EQUi $lastI $frm @.t6	; if (lastI == frm || lastI == t) 
		NEQi $lastI $t @.f7
	.t6:	NEQi $c #'(' @.f8	; if (c == '(') c = ' '
		MOVi $c #' ' 	; c = ' '
		GOTO @.e9  
	.f8:	MOVi $c #')' 	; c = ')'
	.e9:	NOOP
	.f7:	MOVi $buffer:0 $c 	; buffer[0] = c
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		PEEK %0 &board $i	; c = (int) global PIECE_CHARS[(int) global board[i] & (PIECE_MASK | BLACK)]
		! IORi <B> #PIECE_MASK #BLACK
		ANDi %0 %0 <B>
		PEEK $c #PIECE_CHARS %0
		NEQi $c #' ' @.f11	; if (c == ' ' && ((x ^ y) & 1) == 1) c = '.'
		XORi %0 $x $y
		ANDi %0 %0 #1
		NEQi %0 #1 @.f11
		MOVi $c #'.' 	; c = '.'
	.f11:	MOVi $buffer:0 $c 	; buffer[0] = c
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		MOVi $lastI $i 	; lastI = i
		FORi $x #8 @.l3	; }
	.e2:	MOVi $c #' ' 	; c = ' '
		EQUi $lastI $frm @.t12	; if (lastI == frm || lastI == t) c = ')'
		NEQi $lastI $t @.f13
	.t12:	MOVi $c #')' 	; c = ')'
	.f13:	MOVi $buffer:0 $c 	; buffer[0] = c
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		MOVp %1 &.s_4e3 	; print("| ")
		CALL ^print %0 *2
		SUBi $buffer:0 #'8' $y	; buffer[0] = '8' - y
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		CALL ^printLF %0 *1	; printLF()
		MOVi $lastI #-1 	; lastI = -1
		FORi $y #8 @.l1	; }
	.e0:	MOVp %1 &.s_4e1 	; print("  +-----------------+\n")
		CALL ^print %0 *2
		MOVp %1 &.s_ABCDEF4e4 	; print("    A B C D E F G H\n\n")
		CALL ^print %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
registerMove:	FUNC
		PARA *1
	$move:	INPi
	$piece:	INPi
	$captured:	INPi
	$xCapture:	INPi
	$i:	LOCi
	$j:	LOCi
;-----------------------------------------------------------------------------
		PEEK %0 &historyCount 	; if (global historyCount >= HISTORY_SIZE) 
		LSSi %0 #HISTORY_SIZE @.f0
		PEEK %0 &historyCount 	; global historyCount = global historyCount - 1
		SUBi %0 %0 #1
		POKE &historyCount %0 
		MOVi $j #0 	; for (j = 0 to global historyCount * 4) 
		PEEK %0 &historyCount 
		MULi %0 %0 #4
		GEQi #0 %0 @.f0
	.l2:	ADDi %1 $j #4	; global history[j] = global history[j + 4]
		PEEK %1 &history %1
		POKE &history $j %1
		FORi $j %0 @.l2	; }
	.f0:	PEEK %0 &historyCount 	; i = global historyCount * 4
		MULi $i %0 #4
		ADDi %0 $i #0	; global history[i + 0] = move
		POKE &history %0 $move
		ADDi %0 $i #1	; global history[i + 1] = piece
		POKE &history %0 $piece
		ADDi %0 $i #2	; global history[i + 2] = captured
		POKE &history %0 $captured
		ADDi %0 $i #3	; global history[i + 3] = xCapture
		POKE &history %0 $xCapture
		PEEK %0 &historyCount 	; global historyCount = global historyCount + 1
		ADDi %0 %0 #1
		POKE &historyCount %0 
		RETU   	; }


;-----------------------------------------------------------------------------
takeBackMove:	FUNC
	$move:	OUTi
	$i:	LOCi
	$frm:	LOCi
	$t:	LOCi
;-----------------------------------------------------------------------------
		PEEK %0 &historyCount 	; if (global historyCount > 0) 
		LEQi %0 #0 @.f0
		PEEK %0 &historyCount 	; global historyCount = global historyCount - 1
		SUBi %0 %0 #1
		POKE &historyCount %0 
		PEEK %0 &historyCount 	; i = global historyCount * 4
		MULi $i %0 #4
		ADDi %0 $i #0	; move = (int) global history[i + 0]
		PEEK $move &history %0
		MOVi %1 $move 	; frm = (int) moveFrom(move)
		CALL &moveFrom %0 *2
		MOVi $frm %0 
		MOVi %1 $move 	; t = (int) moveTo(move)
		CALL &moveTo %0 *2
		MOVi $t %0 
		MOVi %1 $frm 	; undoMove(frm, t, (int) global history[i + 1], (int) global history[i + 2], (int) global history[i + 3])
		MOVi %2 $t 
		ADDi %3 $i #1
		PEEK %3 &history %3
		ADDi %4 $i #2
		PEEK %4 &history %4
		ADDi %5 $i #3
		PEEK %5 &history %5
		CALL &undoMove %0 *6
		GOTO @.e1  	; } else 
	.f0:	MOVi $move #0 	; move = 0
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
setLevel:	FUNC
		PARA *1
	$level:	INPi
	$i:	LOCi
;-----------------------------------------------------------------------------
		POKE &minEvals #100 	; global minEvals = 100
		MOVi $i #0 	; for (i = 0 to level) global minEvals = global minEvals * 5
		GEQi #0 $level @.e0
	.l1:	PEEK %0 &minEvals 	; global minEvals = global minEvals * 5
		MULi %0 %0 #5
		POKE &minEvals %0 
		FORi $i $level @.l1
	.e0:	RETU   	; }


;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
	$lastFrom:	LOCi
	$lastTo:	LOCi
	$lastPiece:	LOCi
	$isComputersTurn:	LOCi
	$lastMove:	LOCi
	$moveResult:	LOCi
	$action:	LOCp
	$buffer:	LOCA *256
	$lastCaptured:	LOCi
	$lastXCapture:	LOCi
	$p:	LOCp
	$level:	LOCi
;-----------------------------------------------------------------------------
		CALL &initGlobals %0 *1	; initGlobals()
		CALL &restart %0 *1	; restart()
		MOVi %1 #2 	; setLevel(2)
		CALL &setLevel %0 *2
		MOVi %1 #0 	; printBoard(0, 0)
		MOVi %2 #0 
		CALL &printBoard %0 *3
		MOVi $isComputersTurn #FALSE 	; isComputersTurn = FALSE
		MOVi $lastMove #0 	; lastMove = 0
		MOVi $moveResult #0 	; moveResult = 0
	.l0:	LSSi $lastMove #0 @.f1	; if (lastMove >= 0) 
		MOVp $p &.s_Blacks4e5 	; p = "Black's turn.\n"
		PEEK %0 &turnColor 	; if (global turnColor == WHITE) p = "White's turn.\n"
		NEQi %0 #WHITE @.f2
		MOVp $p &.s_Whites4e6 	; p = "White's turn.\n"
	.f2:	MOVp %1 $p 	; print(p)
		CALL ^print %0 *2
	.f1:	MOVp $action &.s_Lastmo4e7 	; action = "Last move:"
		NEQi $isComputersTurn #FALSE @.f3	; if (isComputersTurn == FALSE) 
		CALL &getUserMove %0 *1	; lastMove = (int) getUserMove()
		MOVi $lastMove %0 
		! ADDi <B> #LET_COMPUTER_PLAY #1	; switch (lastMove == NEW_GAME to LET_COMPUTER_PLAY + 1) 
		! SUBi <B> <B> #NEW_GAME
		SUBi %0 $lastMove #NEW_GAME
		SWCH %0 *<B> @.s4
		! SUBi <B> #LET_COMPUTER_PLAY #NEW_GAME	; case LET_COMPUTER_PLAY
	.s4#<B>:	MOVi $isComputersTurn #TRUE 	; isComputersTurn = TRUE
		GOTO @.e5  	; }
		! SUBi <B> #TAKE_BACK #NEW_GAME	; case TAKE_BACK
	.s4#<B>:	CALL &takeBackMove %0 *1	; lastMove = (int) takeBackMove()
		MOVi $lastMove %0 
		LEQi $lastMove #0 @.f6	; if (lastMove > 0) 
		MOVi %1 $lastMove 	; lastFrom = (int) moveFrom(lastMove)
		CALL &moveFrom %0 *2
		MOVi $lastFrom %0 
		MOVi %1 $lastMove 	; lastTo = (int) moveTo(lastMove)
		CALL &moveTo %0 *2
		MOVi $lastTo %0 
		MOVi $lastMove #0 	; lastMove = 0
		MOVp $action &.s_Tookba4e8 	; action = "Took back move:"
		GOTO @.e5  	; } else 
	.f6:	MOVp %1 &.s_Nomove4e9 	; print("No move to take back.\n")
		CALL ^print %0 *2
		MOVi $lastMove #-1 	; lastMove = -1
	.e7:	GOTO @.e5  	; }
		! SUBi <B> #NEW_GAME #NEW_GAME	; case NEW_GAME
	.s4#<B>:	CALL &restart %0 *1	; restart()
		MOVi $lastMove #0 	; lastMove = 0
		MOVi $lastFrom #0 	; lastFrom = 0
		MOVi $lastTo #0 	; lastTo = 0
		GOTO @.e5  	; }
	.s4:	LSSi $lastMove #SET_MINIMUM_LEVEL @.f3	; if (lastMove >= SET_MINIMUM_LEVEL && lastMove <= SET_MAXIMUM_LEVEL) 
		GRTi $lastMove #SET_MAXIMUM_LEVEL @.f3
		SUBi $level $lastMove #SET_MINIMUM_LEVEL	; level = lastMove - SET_MINIMUM_LEVEL
		MOVi %1 $level 	; setLevel(level)
		CALL &setLevel %0 *2
		MOVp %1 &.s_Setcom4ea 	; print("Set computer level to ")
		CALL ^print %0 *2
		ADDi %1 $level #1	; printInt(level + 1)
		CALL ^printInt %0 *2
		MOVp %1 &.s_Nomove4e9:20 	; print(".\n")
		CALL ^print %0 *2
		MOVi $lastMove #-1 	; lastMove = -1
	.e5:	NOOP
	.f3:	EQUi $isComputersTurn #FALSE @.f10	; if (isComputersTurn != FALSE) 
		CALL &getComputerMove %0 *1	; lastMove = (int) getComputerMove()
		MOVi $lastMove %0 
	.f10:	MOVi $moveResult #0 	; moveResult = 0
		EQUi $lastMove #CHECKMATE @.t11	; if (lastMove == CHECKMATE || lastMove == STALEMATE) 
		NEQi $lastMove #STALEMATE @.f12
	.t11:	MOVi $moveResult $lastMove 	; moveResult = lastMove
		MOVi $isComputersTurn #FALSE 	; isComputersTurn = FALSE
		MOVi $lastMove #-1 	; lastMove = -1
	.f12:	LEQi $lastMove #0 @.f13	; if (lastMove > 0) 
		MOVi %1 $lastMove 	; lastFrom = (int) moveFrom(lastMove)
		CALL &moveFrom %0 *2
		MOVi $lastFrom %0 
		MOVi %1 $lastMove 	; lastTo = (int) moveTo(lastMove)
		CALL &moveTo %0 *2
		MOVi $lastTo %0 
		PEEK $lastPiece &board $lastFrom	; lastPiece = (int) global board[lastFrom]
		PEEK $lastCaptured &board $lastTo	; lastCaptured = (int) global board[lastTo]
		PEEK $lastXCapture &xCapture 	; lastXCapture = global xCapture
		MOVi %1 $lastMove 	; moveResult = (int) executeMove(lastMove)
		CALL &executeMove %0 *2
		MOVi $moveResult %0 
		! ADDi <B> #CHECKMATE #1	; switch (moveResult == VALID_MOVE to CHECKMATE + 1) 
		! SUBi <B> <B> #VALID_MOVE
		SUBi %0 $moveResult #VALID_MOVE
		SWCH %0 *<B> @.s14
		! SUBi <B> #VALID_MOVE #VALID_MOVE	; case VALID_MOVE, CHECKMATE, STALEMATE
	.s14#<B>:	NOOP
		! SUBi <B> #CHECKMATE #VALID_MOVE
	.s14#<B>:	NOOP
		! SUBi <B> #STALEMATE #VALID_MOVE
	.s14#<B>:	MOVi %1 $lastMove 	; registerMove(lastMove, lastPiece, lastCaptured, lastXCapture)
		MOVi %2 $lastPiece 
		MOVi %3 $lastCaptured 
		MOVi %4 $lastXCapture 
		CALL &registerMove %0 *5
		NEQi $moveResult #VALID_MOVE @.f16	; if (moveResult == VALID_MOVE) 
		SUBi $isComputersTurn #TRUE $isComputersTurn	; isComputersTurn = TRUE - isComputersTurn
		GOTO @.e15  	; } else 
	.f16:	MOVi $isComputersTurn #FALSE 	; isComputersTurn = FALSE
	.e17:	GOTO @.e15  	; }
		! SUBi <B> #IN_CHECK #VALID_MOVE	; case IN_CHECK
	.s14#<B>:	MOVp %1 &.s_Kingin4eb 	; print("King in check.\n")
		CALL ^print %0 *2
		MOVi $lastMove #-1 	; lastMove = -1
		GOTO @.e15  	; }
	.s14:	NEQi $moveResult #INVALID_MOVE @.f13	; if (moveResult == INVALID_MOVE) 
		MOVp %1 &.s_Invali4ec 	; print("Invalid move.\n")
		CALL ^print %0 *2
		MOVi $lastMove #-1 	; lastMove = -1
	.e15:	NOOP
	.f13:	LSSi $lastMove #0 @.f19	; if (lastMove >= 0) 
		CALL ^printLF %0 *1	; printLF()
		MOVi %1 $lastFrom 	; printBoard(lastFrom, lastTo)
		MOVi %2 $lastTo 
		CALL &printBoard %0 *3
		EQUi $lastFrom #0 @.f19	; if (lastFrom != 0 && lastTo != 0) 
		EQUi $lastTo #0 @.f19
		MOVp %1 $action 	; print(action)
		CALL ^print %0 *2
		MOVp %1 &.s_Setcom4ea:21 	; print(" ")
		CALL ^print %0 *2
		ANDi %1 $lastPiece #PIECE_MASK	; print(global PIECE_NAMES[lastPiece & PIECE_MASK])
		PEEK %1 &PIECE_NAMES %1
		CALL ^print %0 *2
		MOVp %1 &.s_Setcom4ea:21 	; print(" ")
		CALL ^print %0 *2
		MODi %0 $lastFrom #STRIDE	; buffer[0] = ('A' + (lastFrom % STRIDE - 1))
		SUBi %0 %0 #1
		ADDi $buffer:0 #'A' %0
		DIVi %0 $lastFrom #STRIDE	; buffer[1] = ('1' + (lastFrom / STRIDE - 2))
		SUBi %0 %0 #2
		ADDi $buffer:1 #'1' %0
		MOVi $buffer:2 #0 	; buffer[2] = 0
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		MOVp %1 &.s_Setcom4ea:18 	; print(" to ")
		CALL ^print %0 *2
		MODi %0 $lastTo #STRIDE	; buffer[0] = ('A' + (lastTo % STRIDE - 1))
		SUBi %0 %0 #1
		ADDi $buffer:0 #'A' %0
		DIVi %0 $lastTo #STRIDE	; buffer[1] = ('1' + (lastTo / STRIDE - 2))
		SUBi %0 %0 #2
		ADDi $buffer:1 #'1' %0
		ADRL %1 $buffer *0	; print(buffer)
		CALL ^print %0 *2
		MOVp %1 &.s_4ed 	; print(".\n\n")
		CALL ^print %0 *2
	.f19:	NEQi $moveResult #CHECKMATE @.f22	; if (moveResult == CHECKMATE) 
		MOVp $p &.s_Checkm4ee 	; p = "Checkmate! White wins.\n"
		PEEK %0 &turnColor 	; if (global turnColor == WHITE) p = "Checkmate! Black wins.\n"
		NEQi %0 #WHITE @.f23
		MOVp $p &.s_Checkm4ef 	; p = "Checkmate! Black wins.\n"
	.f23:	MOVp %1 $p 	; print(p)
		CALL ^print %0 *2
		MOVi $lastMove #MATE 	; lastMove = MATE
		GOTO @.e24  	; } else if (moveResult == STALEMATE) 
	.f22:	NEQi $moveResult #STALEMATE @.f25	; if (moveResult == STALEMATE) 
		MOVp %1 &.s_Stalem4f0 	; print("Stalemate!\n")
		CALL ^print %0 *2
		MOVi $lastMove #MATE 	; lastMove = MATE
	.f25:	NOOP
	.e24:	NEQi $lastMove #QUIT @.l0	; } while (lastMove != QUIT)
		RETU   	; }

