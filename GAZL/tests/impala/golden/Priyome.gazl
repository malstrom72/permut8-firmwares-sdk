	.s7#<B>:	GEQi $t #RANK_6 @.f24	; if (t < RANK_6) 
		ADDi %0 $t #STRIDE	; global xCapture = t + STRIDE
		POKE &xCapture %0 
		ADDi $score $score #PAWN_ADVANCE_SCORE	; score = score + PAWN_ADVANCE_SCORE
	.f24:	ADDi $score $score #PAWN_ADVANCE_SCORE	; score = score + PAWN_ADVANCE_SCORE
		GOTO @.e8  	; }
	.s7:	DIVi %0 $t #STRIDE	; score = score + (int) global RANK_VALUES[t / STRIDE] - (int) global RANK_VALUES[frm / STRIDE]
		PEEK %0 &RANK_VALUES %0
		DIVi %1 $frm #STRIDE
		ADDi %0 $score %0
		PEEK %1 &RANK_VALUES %1
		SUBi $score %0 %1
	.e8:	LEQi $captured #EMPTY @.f25	; if (captured > EMPTY) 
		MOVi %1 $t 	; liftPiece(t)
		CALL &liftPiece %0 *2
	.f25:	MOVi %1 $frm 	; movePiece(frm, t, newPiece | MOVED_MASK)
		MOVi %2 $t 
		IORi %3 $newPiece #MOVED_MASK
		CALL &movePiece %0 *4
		! IORi <B> #PIECE_MASK #COLOR_MASK	; switch ((captured & (PIECE_MASK | COLOR_MASK)) == 0 to MAX_PIECE_AND_MOVED_VALUE) 
		ANDi %0 $captured <B>
		SWCH %0 *MAX_PIECE_AND_MOVED_VALUE @.s26
	.s26#EMPTY:	GOTO @.e27  	; 
		! IORi <B> #PAWN #WHITE	; case PAWN | WHITE
	.s26#<B>:	DIVi %0 $t #STRIDE	; score = score + PAWN_VALUE + (t / STRIDE - 3) * PAWN_ADVANCE_SCORE
		SUBi %0 %0 #3
		ADDi %1 $score #PAWN_VALUE
		MULi %0 %0 #PAWN_ADVANCE_SCORE
		ADDi $score %1 %0
		GOTO @.e27  	; }
		! IORi <B> #PAWN #BLACK	; case PAWN | BLACK
	.s26#<B>:	DIVi %1 $t #STRIDE	; score = score + PAWN_VALUE + (8 - t / STRIDE) * PAWN_ADVANCE_SCORE
		SUBi %1 #8 %1
		ADDi %0 $score #PAWN_VALUE
		MULi %1 %1 #PAWN_ADVANCE_SCORE
		ADDi $score %0 %1
		GOTO @.e27  	; }
	.s26:	ANDi %0 $captured #PIECE_MASK	; score = score + (int) global PIECE_VALUES[captured & PIECE_MASK] + (int) global RANK_VALUES[t / STRIDE]
		PEEK %0 &PIECE_VALUES %0
		DIVi %1 $t #STRIDE
		ADDi %0 $score %0
		PEEK %1 &RANK_VALUES %1
		ADDi $score %0 %1
	.e27:	PEEK %1 &turnColor 	; global turnColor = (int) switchColor(global turnColor)
		CALL &switchColor %0 *2
		POKE &turnColor %0 
		! EQUi #DEBUG #0 @.a28	; assert((int) checkInvariant() != FALSE)
		CALL &checkInvariant %0 *1
		NEQi %0 #FALSE @.a28
		MOVp %1 &.a_intche4eb 
		CALL ^assertFail %0 *1
	.a28:	RETU   	; }


;-----------------------------------------------------------------------------
undoMove:	FUNC
		PARA *1
	$frm:	INPi
	$t:	INPi
	$oldPiece:	INPi
	$captured:	INPi
	$oldXCapture:	INPi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isOnBoard(frm) != FALSE)
		MOVi %1 $frm 
		CALL &isOnBoard %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisO4e5 
		CALL ^assertFail %0 *1
	.a0:	NOOP
		! EQUi #DEBUG #0 @.a1	; assert((int) isOnBoard(t) != FALSE)
		MOVi %1 $t 
		CALL &isOnBoard %0 *2
		NEQi %0 #FALSE @.a1
		MOVp %1 &.a_intisO4e6 
		CALL ^assertFail %0 *1
	.a1:	NOOP
		! EQUi #DEBUG #0 @.a2	; assert((int) isValidPiece(oldPiece) != FALSE)
		MOVi %1 $oldPiece 
		CALL &isValidPiece %0 *2
		NEQi %0 #FALSE @.a2
		MOVp %1 &.a_intisV4ea 
		CALL ^assertFail %0 *1
	.a2:	NOOP
		! EQUi #DEBUG #0 @.a3	; assert(captured == EMPTY || (int) isValidPiece(captured) != FALSE)
		EQUi $captured #EMPTY @.a3
		MOVi %1 $captured 
		CALL &isValidPiece %0 *2
		NEQi %0 #FALSE @.a3
		MOVp %1 &.a_captur4ec 
		CALL ^assertFail %0 *1
	.a3:	NOOP
		! EQUi #DEBUG #0 @.a5	; assert(frm != t)
		NEQi $frm $t @.a5
		MOVp %1 &.a_frmt4e8 
		CALL ^assertFail %0 *1
	.a5:	NOOP
		! EQUi #DEBUG #0 @.a6	; assert((int) checkInvariant() != FALSE)
		CALL &checkInvariant %0 *1
		NEQi %0 #FALSE @.a6
		MOVp %1 &.a_intche4eb 
		CALL ^assertFail %0 *1
	.a6:	POKE &xCapture $oldXCapture 	; global xCapture = oldXCapture
		MOVi %1 $frm 	; putPiece(frm, oldPiece)
		MOVi %2 $oldPiece 
		CALL &putPiece %0 *3
		MOVi %1 $t 	; liftPiece(t)
		CALL &liftPiece %0 *2
		LEQi $captured #EMPTY @.f7	; if (captured > EMPTY) 
		MOVi %1 $t 	; putPiece(t, captured)
		MOVi %2 $captured 
		CALL &putPiece %0 *3
	.f7:	SWCH $oldPiece *MAX_PIECE_AND_MOVED_VALUE @.s8	; switch (oldPiece == 0 to MAX_PIECE_AND_MOVED_VALUE) 
		! IORi <B> #KING #WHITE	; case KING | WHITE
	.s8#<B>:	NOOP
		! ADDi <B> #RANK_1 #7	; switch (t == RANK_1 + 3 to RANK_1 + 7 + 1) 
		! ADDi <A> #RANK_1 #3
		! ADDi <B> <B> #1
		! SUBi <B> <B> <A>
		SUBi %0 $t <A>
		SWCH %0 *<B> @.s10
		! ADDi <B> #RANK_1 #3	; case RANK_1 + 3
		! SUBi <B> <B> <A>
	.s10#<B>:	ADDi %1 #RANK_1 #4	; movePiece(RANK_1 + 4, RANK_1 + 1, ROOK | WHITE)
		ADDi %2 #RANK_1 #1
		IORi %3 #ROOK #WHITE
		CALL &movePiece %0 *4
		GOTO @.e9  	; }
		! ADDi <B> #RANK_1 #7	; case RANK_1 + 7
		! SUBi <B> <B> <A>
	.s10#<B>:	ADDi %1 #RANK_1 #6	; movePiece(RANK_1 + 6, RANK_1 + 8, ROOK | WHITE)
		ADDi %2 #RANK_1 #8
		IORi %3 #ROOK #WHITE
		CALL &movePiece %0 *4
	.s10:	NOOP
	.e11:	GOTO @.e9  	; }
		! IORi <A> #KING #BLACK	; case KING | BLACK
	.s8#<A>:	NOOP
		! ADDi <A> #RANK_8 #7	; switch (t == RANK_8 + 3 to RANK_8 + 7 + 1) 
		! ADDi <B> #RANK_8 #3
		! ADDi <A> <A> #1
		! SUBi <A> <A> <B>
		SUBi %0 $t <B>
		SWCH %0 *<A> @.s12
		! ADDi <A> #RANK_8 #3	; case RANK_8 + 3
		! SUBi <A> <A> <B>
	.s12#<A>:	ADDi %1 #RANK_8 #4	; movePiece(RANK_8 + 4, RANK_8 + 1, ROOK | BLACK)
		ADDi %2 #RANK_8 #1
		IORi %3 #ROOK #BLACK
		CALL &movePiece %0 *4
		GOTO @.e9  	; }
		! ADDi <A> #RANK_8 #7	; case RANK_8 + 7
		! SUBi <A> <A> <B>
	.s12#<A>:	ADDi %1 #RANK_8 #6	; movePiece(RANK_8 + 6, RANK_8 + 8, ROOK | BLACK)
		ADDi %2 #RANK_8 #8
		IORi %3 #ROOK #BLACK
		CALL &movePiece %0 *4
	.s12:	NOOP
	.e13:	GOTO @.e9  	; }
		! IORi <B> #PAWN #WHITE	; case PAWN | WHITE | MOVED_MASK
		! IORi <B> <B> #MOVED_MASK
	.s8#<B>:	NEQi $t $oldXCapture @.e9	; if (t == oldXCapture) 
		SUBi %1 $t #STRIDE	; putPiece(t - STRIDE, PAWN | BLACK | MOVED_MASK)
		! IORi <B> #PAWN #BLACK
		IORi %2 <B> #MOVED_MASK
		CALL &putPiece %0 *3
		GOTO @.e9  	; }
		! IORi <B> #PAWN #BLACK	; case PAWN | BLACK | MOVED_MASK
		! IORi <B> <B> #MOVED_MASK
	.s8#<B>:	NEQi $t $oldXCapture @.f15	; if (t == oldXCapture) 
		ADDi %1 $t #STRIDE	; putPiece(t + STRIDE, PAWN | WHITE | MOVED_MASK)
		! IORi <B> #PAWN #WHITE
		IORi %2 <B> #MOVED_MASK
		CALL &putPiece %0 *3
	.f15:	NOOP
	.s8:	NOOP
	.e9:	PEEK %1 &turnColor 	; global turnColor = (int) switchColor(global turnColor)
		CALL &switchColor %0 *2
		POKE &turnColor %0 
		! EQUi #DEBUG #0 @.a16	; assert((int) checkInvariant() != FALSE)
		CALL &checkInvariant %0 *1
		NEQi %0 #FALSE @.a16
		MOVp %1 &.a_intche4eb 
		CALL ^assertFail %0 *1
	.a16:	RETU   	; }


;-----------------------------------------------------------------------------
traceRBQ:	FUNC
	$newToCount:	OUTi
	$color:	INPi
	$frm:	INPi
	$toCount:	INPi
	$tos:	INPp
	$start:	INPi
	$step:	INPi
	$cx:	LOCi
	$d:	LOCi
	$toInc:	LOCi
	$t:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isOnBoard(frm) != FALSE)
		MOVi %1 $frm 
		CALL &isOnBoard %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisO4e5 
		CALL ^assertFail %0 *1
	.a0:	MOVi $newToCount $toCount 	; newToCount = toCount
		MOVi %1 $color 	; cx = (int) switchColor(color)
		CALL &switchColor %0 *2
		MOVi $cx %0 
		MOVi $d $start 	; d = start
	.l1:	GEQi $d #8 @.e2	; while (d < 8) 
		PEEK $toInc &DIRS $d	; toInc = (int) global DIRS[d]
		ADDi $t $frm $toInc	; t = frm + toInc
	.l3:	PEEK %0 &board $t	; while ((int) global board[t] == EMPTY) 
		NEQi %0 #EMPTY @.e4
		POKE $tos $newToCount $t	; tos[newToCount] = t
		ADDi $newToCount $newToCount #1	; newToCount = newToCount + 1
		ADDi $t $t $toInc	; t = t + toInc
		GOTO @.l3  	; }
	.e4:	PEEK %0 &board $t	; if (((int) global board[t] & COLOR_MASK) == cx) 
		ANDi %0 %0 #COLOR_MASK
		NEQi %0 $cx @.f5
		POKE $tos $newToCount $t	; tos[newToCount] = t
		ADDi $newToCount $newToCount #1	; newToCount = newToCount + 1
	.f5:	ADDi $d $d $step	; d = d + step
		GOTO @.l1  	; }
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
listMoves:	FUNC
	$toCount:	OUTi
	$color:	INPi
	$frm:	INPi
	$tos:	INPp
	$t:	LOCi
	$piece:	LOCi
	$cx:	LOCi
	$s:	LOCi
	$d:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isOnBoard(frm) != FALSE)
		MOVi %1 $frm 
		CALL &isOnBoard %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisO4e5 
		CALL ^assertFail %0 *1
	.a0:	MOVi $toCount #0 	; toCount = 0
		PEEK $piece &board $frm	; piece = (int) global board[frm]
		ANDi %0 $piece #PIECE_MASK	; switch ((piece & PIECE_MASK) == 0 to MAX_PIECE_AND_MOVED_VALUE) 
		SWCH %0 *MAX_PIECE_AND_MOVED_VALUE @.s1
	.s1#PAWN:	MOVi $s #STRIDE 	; s = STRIDE
		NEQi $color #BLACK @.f3	; if (color == BLACK) s = -STRIDE
		! SUBi <B> #0 #STRIDE	; s = -STRIDE
		MOVi $s <B> 
	.f3:	ADDi $t $frm $s	; t = frm + s
		PEEK %0 &board $t	; if ((int) global board[t] == EMPTY) 
		NEQi %0 #EMPTY @.f4
		POKE $tos $toCount $t	; tos[toCount] = t
		ADDi $toCount $toCount #1	; toCount = toCount + 1
		ANDi %0 $piece #MOVED_MASK	; if ((piece & MOVED_MASK) == 0 && (int) global board[t + s] == EMPTY) 
		NEQi %0 #0 @.f4
		ADDi %0 $t $s
		PEEK %0 &board %0
		NEQi %0 #EMPTY @.f4
		ADDi %0 $t $s	; tos[toCount] = t + s
		POKE $tos $toCount %0
		ADDi $toCount $toCount #1	; toCount = toCount + 1
	.f4:	MOVi %1 $color 	; cx = (int) switchColor(color)
		CALL &switchColor %0 *2
		MOVi $cx %0 
		SUBi $t $t #1	; t = t - 1
		PEEK %0 &board $t	; if (((int) global board[t] & COLOR_MASK) == cx || global xCapture == t || (int) squareCapturesCastlingKing(t) != FALSE) 
		ANDi %0 %0 #COLOR_MASK
		EQUi %0 $cx @.t7
		PEEK %0 &xCapture 
		EQUi %0 $t @.t7
		MOVi %1 $t 
		CALL &squareCapturesCastlingKing %0 *2
		EQUi %0 #FALSE @.f8
	.t7:	POKE $tos $toCount $t	; tos[toCount] = t
		ADDi $toCount $toCount #1	; toCount = toCount + 1
	.f8:	ADDi $t $t #2	; t = t + 2
		PEEK %0 &board $t	; if (((int) global board[t] & COLOR_MASK) == cx || global xCapture == t || (int) squareCapturesCastlingKing(t) != FALSE) 
		ANDi %0 %0 #COLOR_MASK
		EQUi %0 $cx @.t9
		PEEK %0 &xCapture 
		EQUi %0 $t @.t9
		MOVi %1 $t 
		CALL &squareCapturesCastlingKing %0 *2
		EQUi %0 #FALSE @.e2
	.t9:	POKE $tos $toCount $t	; tos[toCount] = t
		ADDi $toCount $toCount #1	; toCount = toCount + 1
		GOTO @.e2  	; }
	.s1#ROOK:	MOVi %1 $color 	; toCount = (int) traceRBQ(color, frm, toCount, tos, 0, 2)
		MOVi %2 $frm 
		MOVi %3 $toCount 
		MOVp %4 $tos 
		MOVi %5 #0 
		MOVi %6 #2 
		CALL &traceRBQ %0 *7
		MOVi $toCount %0 
		GOTO @.e2  
	.s1#BISHOP:	MOVi %1 $color 	; toCount = (int) traceRBQ(color, frm, toCount, tos, 1, 2)
		MOVi %2 $frm 
		MOVi %3 $toCount 
		MOVp %4 $tos 
		MOVi %5 #1 
		MOVi %6 #2 
		CALL &traceRBQ %0 *7
		MOVi $toCount %0 
		GOTO @.e2  
	.s1#QUEEN:	MOVi %1 $color 	; toCount = (int) traceRBQ(color, frm, toCount, tos, 0, 1)
		MOVi %2 $frm 
		MOVi %3 $toCount 
		MOVp %4 $tos 
		MOVi %5 #0 
		MOVi %6 #1 
		CALL &traceRBQ %0 *7
		MOVi $toCount %0 
		GOTO @.e2  
	.s1#KING:	MOVi $d #0 	; for (d = 0 to 8) 
		GEQi #0 #8 @.e11
	.l12:	PEEK %0 &DIRS $d	; t = frm + (int) global DIRS[d]
		ADDi $t $frm %0
		PEEK %0 &board $t	; if (((int) global board[t] & color) == 0) 
		ANDi %0 %0 $color
		NEQi %0 #0 @.f13
		POKE $tos $toCount $t	; tos[toCount] = t
		ADDi $toCount $toCount #1	; toCount = toCount + 1
	.f13:	FORi $d #8 @.l12	; }
	.e11:	ANDi %0 $piece #MOVED_MASK	; if ((piece & MOVED_MASK) == 0) 
		NEQi %0 #0 @.e2
		MOVi $t #RANK_1 	; t = RANK_1
		NEQi $color #BLACK @.f15	; if (color == BLACK) t = RANK_8
		MOVi $t #RANK_8 	; t = RANK_8
	.f15:	ADDi %0 $t #2	; if (((int) global board[t + 2] | (int) global board[t + 3] | (int) global board[t + 4]) == EMPTY
		ADDi %1 $t #3
		PEEK %0 &board %0
		PEEK %1 &board %1
		ADDi %2 $t #4
		IORi %0 %0 %1
		PEEK %2 &board %2
		IORi %0 %0 %2
		NEQi %0 #EMPTY @.f17
		ADDi %0 $t #1
		PEEK %0 &board %0
		ANDi %0 %0 #PIECE_AND_MOVED_MASK
		NEQi %0 #ROOK @.f17
		ADDi %0 $t #3	; tos[toCount] = t + 3
		POKE $tos $toCount %0
		ADDi $toCount $toCount #1	; toCount = toCount + 1
	.f17:	ADDi %0 $t #7	; if (((int) global board[t + 7] | (int) global board[t + 6]) == EMPTY
		ADDi %2 $t #6
		PEEK %0 &board %0
		PEEK %2 &board %2
		IORi %0 %0 %2
		NEQi %0 #EMPTY @.e2
		ADDi %0 $t #8
		PEEK %0 &board %0
		ANDi %0 %0 #PIECE_AND_MOVED_MASK
		NEQi %0 #ROOK @.e2
		ADDi %0 $t #7	; tos[toCount] = t + 7
		POKE $tos $toCount %0
		ADDi $toCount $toCount #1	; toCount = toCount + 1
		GOTO @.e2  	; }
	.s1#KNIGHT:	MOVi $d #0 	; for (d = 0 to 8) 
		GEQi #0 #8 @.e2
	.l21:	PEEK %0 &KNIGHT_MOVES $d	; t = frm + (int) global KNIGHT_MOVES[d]
		ADDi $t $frm %0
		PEEK %0 &board $t	; if (((int) global board[t] & color) == 0) 
		ANDi %0 %0 $color
		NEQi %0 #0 @.f22
		POKE $tos $toCount $t	; tos[toCount] = t
		ADDi $toCount $toCount #1	; toCount = toCount + 1
	.f22:	FORi $d #8 @.l21	; }
		GOTO @.e2  	; }
	.s1:	NOOP
		! EQUi #DEBUG #0 @.a23	; assert(0 != 0)
		NEQi #0 #0 @.a23
		MOVp %1 &.a_004ef 
		CALL ^assertFail %0 *1
	.a23:	NOOP
	.e2:	NOOP
		! EQUi #DEBUG #0 @.a24	; assert(toCount <= MAX_TARGET_SQUARES)
		LEQi $toCount #MAX_TARGET_SQUARES @.a24
		MOVp %1 &.a_toCoun4f0 
		CALL ^assertFail %0 *1
	.a24:	RETU   	; }


;-----------------------------------------------------------------------------
canCaptureKing:	FUNC
	$b:	OUTi
	$color:	INPi
	$tos:	LOCA *MAX_TARGET_SQUARES
	$frm:	LOCi
	$toCount:	LOCi
	$i:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert((int) isValidColor(color) != FALSE)
		MOVi %1 $color 
		CALL &isValidColor %0 *2
		NEQi %0 #FALSE @.a0
		MOVp %1 &.a_intisV4f1 
		CALL ^assertFail %0 *1
	.a0:	MOVi $b #FALSE 	; b = FALSE
		PEEK $frm &nextPiece $color	; frm = (int) global nextPiece[color]
	.l1:	EQUi $frm $color @.e2	; while (frm != color) 
		MOVi %1 $color 	; toCount = (int) listMoves(color, frm, tos)
		MOVi %2 $frm 
		ADRL %3 $tos *0
		CALL &listMoves %0 *4
		MOVi $toCount %0 
		MOVi $i #0 	; for (i = 0 to toCount) 
		GEQi #0 $toCount @.e3
	.l4:	GETL %1 $tos $i	; if ((int) squareCapturesKing(tos[i]) != FALSE) 
		CALL &squareCapturesKing %0 *2
		EQUi %0 #FALSE @.f5
		MOVi $b #TRUE 	; b = TRUE
		GOTO @returnNow  	; goto returnNow
	.f5:	FORi $i $toCount @.l4	; }
	.e3:	PEEK $frm &nextPiece $frm	; frm = (int) global nextPiece[frm]
		GOTO @.l1  	; }
	.e2:	NOOP
	returnNow:	RETU   	; }


;-----------------------------------------------------------------------------
findBestMove:	FUNC
	$bestMove:	OUTi
	$lowestScore:	INPi
	$alpha:	INPi
	$beta:	INPi
	$depth:	INPi
	$score:	INPi
	$movesCount:	INPi
	$moves:	INPp
	$bestScore:	LOCi
	$move:	LOCi
	$frm:	LOCi
	$t:	LOCi
	$oldPiece:	LOCi
	$captured:	LOCi
	$oldXCapture:	LOCi
	$moveScore:	LOCi
	$s:	LOCi
	$i:	LOCi
	$capturesOnly:	LOCi
	$myAlpha:	LOCi
;-----------------------------------------------------------------------------
		MOVi $myAlpha $alpha 	; myAlpha = alpha
		MOVi $bestScore $lowestScore 	; bestScore = lowestScore
		MOVi $bestMove #0 	; bestMove = 0
		MOVi $i #0 	; i = 0
	.l0:	GEQi $i $movesCount @.e2	; while (i < movesCount && myAlpha < beta) 
		GEQi $myAlpha $beta @.e2
		PEEK $move $moves $i	; move = (int) moves[i]
		MOVi %1 $move 	; frm = (int) moveFrom(move)
		CALL &moveFrom %0 *2
		MOVi $frm %0 
		MOVi %1 $move 	; t = (int) moveTo(move)
		CALL &moveTo %0 *2
		MOVi $t %0 
		PEEK $oldPiece &board $frm	; oldPiece = (int) global board[frm]
		PEEK $captured &board $t	; captured = (int) global board[t]
		PEEK $oldXCapture &xCapture 	; oldXCapture = global xCapture
		MOVi %1 $frm 	; moveScore = (int) doMove(frm, t, oldPiece, captured, oldXCapture)
		MOVi %2 $t 
		MOVi %3 $oldPiece 
		MOVi %4 $captured 
		MOVi %5 $oldXCapture 
		CALL &doMove %0 *6
		MOVi $moveScore %0 
		ADDi $s $score $moveScore	; s = score + moveScore
		LEQi $depth #0 @.f3	; if (depth > 0) 
		MOVi $capturesOnly #FALSE 	; capturesOnly = FALSE
		GEQi $depth #QUIESCENCE_DEPTH @.f4	; if (depth < QUIESCENCE_DEPTH) 
		MOVi $capturesOnly #TRUE 	; capturesOnly = TRUE
	.f4:	SUBi %1 #0 $beta	; s = -((int) search(-beta, -myAlpha, depth - 1, -s, capturesOnly) >> SCORE_SHIFT)
		SUBi %2 #0 $myAlpha
		SUBi %3 $depth #1
		SUBi %4 #0 $s
		MOVi %5 $capturesOnly 
		CALL &search %0 *6
		SHRi %0 %0 #SCORE_SHIFT
		SUBi $s #0 %0
	.f3:	GEQi $bestScore $s @.f5	; if (bestScore < s) 
		MOVi $bestScore $s 	; bestScore = s
		MOVi $bestMove $move 	; bestMove = move
		GEQi $myAlpha $bestScore @.f5	; if (myAlpha < bestScore) 
		MOVi $myAlpha $bestScore 	; myAlpha = bestScore
	.f5:	MOVi %1 $frm 	; undoMove(frm, t, oldPiece, captured, oldXCapture)
		MOVi %2 $t 
		MOVi %3 $oldPiece 
		MOVi %4 $captured 
		MOVi %5 $oldXCapture 
		CALL &undoMove %0 *6
		ADDi $i $i #1	; i = i + 1
		GOTO @.l0  	; }
	.e2:	SHLi %0 $bestScore #SCORE_SHIFT	; bestMove = bestMove | (bestScore << SCORE_SHIFT)
		IORi $bestMove $bestMove %0
		RETU   	; }


;-----------------------------------------------------------------------------
searchCaptures:	FUNC
	$bestMove:	OUTi
	$alpha:	INPi
	$beta:	INPi
	$depth:	INPi
	$score:	INPi
	$firstMove:	INPi
	$capturesCount:	LOCi
	$frm:	LOCi
	$moves:	LOCA *MAX_MOVES
	$tos:	LOCA *MAX_TARGET_SQUARES
	$myAlpha:	LOCi
	$toCount:	LOCi
	$i:	LOCi
	$t:	LOCi
	$move:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(0 <= depth)
		LEQi #0 $depth @.a0
		MOVp %1 &.a_0depth4f2 
		CALL ^assertFail %0 *1
	.a0:	NOOP
		! EQUi #DEBUG #0 @.a1	; assert(firstMove == 0 || (int) isValidMove(firstMove) != FALSE)
		EQUi $firstMove #0 @.a1
		MOVi %1 $firstMove 
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a1
		MOVp %1 &.a_firstM4f3 
		CALL ^assertFail %0 *1
	.a1:	MOVi $myAlpha $alpha 	; myAlpha = alpha
		GEQi $myAlpha $score @.f3	; if (myAlpha < score) 
		MOVi $myAlpha $score 	; myAlpha = score
	.f3:	LSSi $myAlpha $beta @.f4	; if (myAlpha >= beta) 
		SHLi $bestMove $score #SCORE_SHIFT	; bestMove = (score << SCORE_SHIFT)
		GOTO @.e5  	; } else 
	.f4:	MOVi $capturesCount #0 	; capturesCount = 0
		PEEK %0 &turnColor 	; frm = (int) global nextPiece[global turnColor]
		PEEK $frm &nextPiece %0
	.l6:	PEEK %0 &turnColor 	; while (frm != global turnColor) 
		EQUi $frm %0 @.e7
		PEEK %1 &turnColor 	; toCount = (int) listMoves(global turnColor, frm, tos)
		MOVi %2 $frm 
		ADRL %3 $tos *0
		CALL &listMoves %0 *4
		MOVi $toCount %0 
		MOVi $i #0 	; for (i = 0 to toCount) 
		GEQi #0 $toCount @.e8
	.l9:	GETL $t $tos $i	; t = (int) tos[i]
		SHLi %0 $t #TO_SHIFT	; move = frm | (t << TO_SHIFT)
		IORi $move $frm %0
		MOVi %1 $t 	; if ((int) squareCapturesKing(t) != FALSE) 
		CALL &squareCapturesKing %0 *2
		EQUi %0 #FALSE @.f10
		ADDi %0 #CAPTURE_KING_MIN_SCORE $depth	; bestMove = ((CAPTURE_KING_MIN_SCORE + depth) << SCORE_SHIFT) | move
		SHLi %0 %0 #SCORE_SHIFT
		IORi $bestMove %0 $move
		GOTO @returnNow  	; goto returnNow
	.f10:	PEEK %0 &board $t	; if ((int) global board[t] > EMPTY || global xCapture == t) 
		GRTi %0 #EMPTY @.t11
		PEEK %0 &xCapture 
		NEQi %0 $t @.f12
	.t11:	NOOP
		! EQUi #DEBUG #0 @.a13	; assert(capturesCount < MAX_MOVES)
		LSSi $capturesCount #MAX_MOVES @.a13
		MOVp %1 &.a_captur4f4 
		CALL ^assertFail %0 *1
	.a13:	NEQi $move $firstMove @.f14	; if (move == firstMove) 
		SETL $moves $capturesCount $moves:0	; moves[capturesCount] = moves[0]
		ADDi $capturesCount $capturesCount #1	; capturesCount = capturesCount + 1
		MOVi $moves:0 $move 	; moves[0] = move
		GOTO @.e15  	; } else 
	.f14:	SETL $moves $capturesCount $move	; moves[capturesCount] = move
		ADDi $capturesCount $capturesCount #1	; capturesCount = capturesCount + 1
	.e15:	NOOP
	.f12:	FORi $i $toCount @.l9	; }
	.e8:	PEEK $frm &nextPiece $frm	; frm = (int) global nextPiece[frm]
		GOTO @.l6  	; }
	.e7:	MOVi %1 $score 	; bestMove = (int) findBestMove(score, myAlpha, beta, depth, score, capturesCount, moves)
		MOVi %2 $myAlpha 
		MOVi %3 $beta 
		MOVi %4 $depth 
		MOVi %5 $score 
		MOVi %6 $capturesCount 
		ADRL %7 $moves *0
		CALL &findBestMove %0 *8
		MOVi $bestMove %0 
	.e5:	NOOP
	returnNow:	RETU   	; }


;-----------------------------------------------------------------------------
searchAll:	FUNC
	$bestMove:	OUTi
	$alpha:	INPi
	$beta:	INPi
	$depth:	INPi
	$score:	INPi
	$firstMove:	INPi
	$moves:	LOCA *MAX_MOVES
	$tos:	LOCA *MAX_TARGET_SQUARES
	$movesCount:	LOCi
	$capturesCount:	LOCi
	$frm:	LOCi
	$toCount:	LOCi
	$i:	LOCi
	$t:	LOCi
	$move:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(0 <= depth)
		LEQi #0 $depth @.a0
		MOVp %1 &.a_0depth4f2 
		CALL ^assertFail %0 *1
	.a0:	NOOP
		! EQUi #DEBUG #0 @.a1	; assert(firstMove == 0 || (int) isValidMove(firstMove) != FALSE)
		EQUi $firstMove #0 @.a1
		MOVi %1 $firstMove 
		CALL &isValidMove %0 *2
		NEQi %0 #FALSE @.a1
		MOVp %1 &.a_firstM4f3 
		CALL ^assertFail %0 *1
	.a1:	LSSi $alpha $beta @.f3	; if (alpha >= beta) 
		! SUBi <B> #MIN_SCORE #1	; bestMove = (MIN_SCORE - 1) << SCORE_SHIFT
		! SHLi <B> <B> #SCORE_SHIFT
		MOVi $bestMove <B> 
		GOTO @.e4  	; } else 
	.f3:	MOVi $movesCount #0 	; movesCount = 0
		MOVi $capturesCount #0 	; capturesCount = 0
		PEEK %0 &turnColor 	; frm = (int) global nextPiece[global turnColor]
		PEEK $frm &nextPiece %0
	.l5:	PEEK %0 &turnColor 	; while (frm != global turnColor) 
		EQUi $frm %0 @.e6
		PEEK %1 &turnColor 	; toCount = (int) listMoves(global turnColor, frm, tos)
		MOVi %2 $frm 
		ADRL %3 $tos *0
		CALL &listMoves %0 *4
		MOVi $toCount %0 
		MOVi $i #0 	; for (i = 0 to toCount) 
		GEQi #0 $toCount @.e7
	.l8:	GETL $t $tos $i	; t = (int) tos[i]
		SHLi %0 $t #TO_SHIFT	; move = frm | (t << TO_SHIFT)
		IORi $move $frm %0
		MOVi %1 $t 	; if ((int) squareCapturesKing(t) != FALSE) 
		CALL &squareCapturesKing %0 *2
		EQUi %0 #FALSE @.f9
		ADDi %0 #CAPTURE_KING_MIN_SCORE $depth	; bestMove = ((CAPTURE_KING_MIN_SCORE + depth) << SCORE_SHIFT) | move
		SHLi %0 %0 #SCORE_SHIFT
		IORi $bestMove %0 $move
		GOTO @returnNow  	; goto returnNow
	.f9:	NOOP
		! EQUi #DEBUG #0 @.a10	; assert(movesCount < MAX_MOVES)
		LSSi $movesCount #MAX_MOVES @.a10
		MOVp %1 &.a_movesC4f5 
		CALL ^assertFail %0 *1
	.a10:	NEQi $move $firstMove @.f11	; if (move == firstMove) 
		GETL %0 $moves $capturesCount	; moves[movesCount] = moves[capturesCount]
		SETL $moves $movesCount %0
		ADDi $movesCount $movesCount #1	; movesCount = movesCount + 1
		! EQUi #DEBUG #0 @.a12	; assert(capturesCount < MAX_MOVES)
		LSSi $capturesCount #MAX_MOVES @.a12
		MOVp %1 &.a_captur4f4 
		CALL ^assertFail %0 *1
	.a12:	SETL $moves $capturesCount $moves:0	; moves[capturesCount] = moves[0]
		ADDi $capturesCount $capturesCount #1	; capturesCount = capturesCount + 1
		MOVi $moves:0 $move 	; moves[0] = move
		GOTO @.e13  	; } else if ((int) global board[t] > EMPTY || global xCapture == t) 
	.f11:	PEEK %0 &board $t	; if ((int) global board[t] > EMPTY || global xCapture == t) 
		GRTi %0 #EMPTY @.t14
		PEEK %0 &xCapture 
		NEQi %0 $t @.f15
	.t14:	GETL %0 $moves $capturesCount	; moves[movesCount] = moves[capturesCount]
		SETL $moves $movesCount %0
		ADDi $movesCount $movesCount #1	; movesCount = movesCount + 1
		! EQUi #DEBUG #0 @.a16	; assert(capturesCount < MAX_MOVES)
		LSSi $capturesCount #MAX_MOVES @.a16
		MOVp %1 &.a_captur4f4 
		CALL ^assertFail %0 *1
	.a16:	SETL $moves $capturesCount $move	; moves[capturesCount] = move
		ADDi $capturesCount $capturesCount #1	; capturesCount = capturesCount + 1
		GOTO @.e17  	; } else 
	.f15:	SETL $moves $movesCount $move	; moves[movesCount] = move
		ADDi $movesCount $movesCount #1	; movesCount = movesCount + 1
	.e17:	NOOP
	.e13:	FORi $i $toCount @.l8	; }
	.e7:	PEEK $frm &nextPiece $frm	; frm = (int) global nextPiece[frm]
		GOTO @.l5  	; }
	.e6:	SUBi %1 #MIN_SCORE #1	; bestMove = (int) findBestMove((MIN_SCORE - 1), alpha, beta, depth, score, movesCount, moves)
		MOVi %2 $alpha 
		MOVi %3 $beta 
		MOVi %4 $depth 
		MOVi %5 $score 
		MOVi %6 $movesCount 
