process:	FUNC
		PARA *1
	$nx:	LOCf
	$lpx:	LOCf
	$lpy:	LOCf
	$rpx:	LOCf
	$rpy:	LOCf
	$lrx:	LOCf
	$lry:	LOCf
	$rrx:	LOCf
	$rry:	LOCf
	$i:	LOCi
	$idx:	LOCi
;-----------------------------------------------------------------------------
		ADRL %0 $lpx *0	; copy (8 from &global lpx to &lpx)
		COPY %0 &lpx *8
		MULf %0 $lpx $lrx	; nx = lpx - lpx * lrx - lpy * lry
		SUBf %0 $lpx %0
		MULf %1 $lpy $lry
		SUBf $nx %0 %1
		MULf %0 $lpx $lry	; lpy = lpx * lry + lpy - lpy * lrx
		ADDf %0 %0 $lpy
		MULf %1 $lpy $lrx
		SUBf $lpy %0 %1
		MOVf $lpx $nx 	; lpx = nx
		MULf %0 $rpx $rrx	; nx = rpx - rpx * rrx - rpy * rry
		SUBf %0 $rpx %0
		MULf %1 $rpy $rry
		SUBf $nx %0 %1
		MULf %0 $rpx $rry	; rpy = rpx * rry + rpy - rpy * rrx
		ADDf %0 %0 $rpy
		MULf %1 $rpy $rrx
		SUBf $rpy %0 %1
		MOVf $rpx $nx 	; rpx = nx
		fTOi %0 $lpx #1.0	; global left = ftoi(lpx)
		POKE &left %0 
		fTOi %0 $rpx #1.0	; global right = ftoi(rpx)
		POKE &right %0 
		ADRL %0 $lpx *0	; copy (4 from &lpx to &global lpx)
		COPY &lpx %0 *4
		RETU   	; }

