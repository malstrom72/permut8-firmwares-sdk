PRAWN_FIRMWARE_PATCH_FORMAT:	! DEFi #1
FALSE:	! DEFi #0
TRUE:	! DEFi #1
panelTextRows:	CNST *8
	DATA &.s_Sillyr4d2 &.s_4d3 &.s_4d3 &.s_LEFTDE4d4 &.s_4d3
	DATA &.s_4d3 &.s_4d3 &.s_RINGMO4d5
	GLOB *1
clock:	DATi #0
params:	GLOB *PARAM_COUNT
displayLEDs:	GLOB *4
	GLOB *1
instance:	DATi #0
	CNST *1
clockFreqLimit:	DATi #132300
signal:	GLOB *2

;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
	$i:	LOCi
	$buf:	LOCA *256
;-----------------------------------------------------------------------------
		RETU   	; }


;-----------------------------------------------------------------------------
reset:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$buf:	LOCA *256
	$params:	LOCA *PARAM_COUNT
;-----------------------------------------------------------------------------
		RETU   	; }

f:	! DEFi #0x309977

;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	$t:	LOCi
	$u:	LOCi
	$v:	LOCi
	$b:	LOCi
	$y:	LOCi
	$z:	LOCi
;-----------------------------------------------------------------------------
		MOVi $t #0 	; t = 0
	.l0:	MOVi $z #0 	; for (z = 0 to 16) 
		GEQi #0 #16 @.e1
	.l2:	NOOP
		! SHRi <A> #f #8	; u = ((t * (f >> 8)) >> 12 >> 2)
		MULi %0 $t <A>
		SHRi %0 %0 #12
		SHRi $u %0 #2
		SHRi %0 $t #2	; v = (t >> 2) + (1 << 11)
		! SHLi <A> #1 #11
		ADDi $v %0 <A>
		SHRi %0 $v #11	; b = ((u * (v >> 11)) * 7771777)
		MULi %0 $u %0
		MULi $b %0 #7771777
		ANDi %0 $b #3	; y = (((b << (b & 3)) & (1 << 31)) >> 11) * (~v & (1 << 11) - 1)
		SHLi %0 $b %0
		! SHLi <A> #1 #31
		ANDi %0 %0 <A>
		! SHLi <A> #1 #11
		XORi %1 $v #-1
		! SUBi <A> <A> #1
		SHRi %0 %0 #11
		ANDi %1 %1 <A>
		MULi $y %0 %1
		FORi $z #16 @.l2	; }
	.e1:	SHRi $y $y #20	; global signal[0] = (y = y >> 20)
		POKE &signal:0 $y 
		POKE &signal:1 $y 	; global signal[1] = y
		CALL ^yield %0 *1	; yield()
		ADDi $t $t #1	; t = t + 1
		GOTO @.l0  	; }
		RETU   	; }

.s_Sillyr4d2:	CNST *52
	DATi #32 #32 #32
	DATs Silly ring-modulator firmware demo by M Lidstrom
	DATi #0
.s_4d3:	CNST *2
	DATi #32 #0
.s_LEFTDE4d4:	CNST *54
	DATi #32 #32 #32 #32
	DATs |----- LEFT DELAY -----| |----- RIGHT DELAY ----|
	DATi #0
.s_RINGMO4d5:	CNST *54
	DATi #32 #32 #32 #32
	DATs |--- RING MOD RATE ----| |---- STEREO PHASE ----|
	DATi #0