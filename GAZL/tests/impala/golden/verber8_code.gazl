; Compiled with Impala version 1.0

PRAWN_FIRMWARE_PATCH_FORMAT:	! DEFi #2
FALSE:	! DEFi #0
TRUE:	! DEFi #1
panelTextRows:	CNST *8
	DATA &.s_4d2 &.s_4d2 &.s_4d2 &.s_ROOMSI4d3 &.s_4d2 &.s_4d2
	DATA &.s_4d2 &.s_FEEDBA4d4
	GLOB *1
clock:	DATi #0
signal:	GLOB *2
params:	GLOB *PARAM_COUNT
displayLEDs:	GLOB *4
	GLOB *1
instance:	DATi #0
	CNST *1
clockFreqLimit:	DATi #88200
	CNST *1
	! SHLi <A> #1 #OPERAND_1_HIGH_PARAM_INDEX
	! SHLi <B> #1 #OPERAND_1_LOW_PARAM_INDEX
	! IORi <A> <A> <B>
	! SHLi <B> #1 #OPERAND_2_HIGH_PARAM_INDEX
	! IORi <A> <A> <B>
	! SHLi <B> #1 #OPERAND_2_LOW_PARAM_INDEX
	! IORi <A> <A> <B>
updateMask:	DATi <A>
TAPS_COUNT:	! DEFi #10
BATCH_SIZE:	! DEFi #32
	! MULi <A> #BATCH_SIZE #2
BATCH_SIZE_2:	! DEFi <A>
T0:	! DEFi #0
T3:	! DEFi #1
T5:	! DEFi #2
T7:	! DEFi #3
T11:	! DEFi #4
T13:	! DEFi #5
TFB:	! DEFi #6
TL1:	! DEFi #7
TL2:	! DEFi #8
TR:	! DEFi #9
	GLOB *1
feedback:	DATi #0
	GLOB *1
damping:	DATi #0
taps:	GLOB *TAPS_COUNT

;-----------------------------------------------------------------------------
displayBarValue:	FUNC
	$y:	OUTi
	$x:	LOCi
;-----------------------------------------------------------------------------
		! SUBi <A> #8 #3	; y = ~(0x7F >> (x >> (8 - 3)))
		SHRi %0 $x <A>
		SHRi %0 #0x7F %0
		XORi $y %0 #-1
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$params:	LOCA *PARAM_COUNT
	$taps:	LOCA *TAPS_COUNT
	$size:	LOCi
	$predelay:	LOCi
	$damping:	LOCi
;-----------------------------------------------------------------------------
		ADRL %0 $params *0	; copy (PARAM_COUNT from global params to params)
		COPY %0 &params *PARAM_COUNT
		MOVi $size $params:OPERAND_1_HIGH_PARAM_INDEX 	; size = (int) params[OPERAND_1_HIGH_PARAM_INDEX]
		MULi %0 $size $size	; size = size * size + BATCH_SIZE * 13
		! MULi <A> #BATCH_SIZE #13
		ADDi $size %0 <A>
		SHLi $predelay $params:OPERAND_1_LOW_PARAM_INDEX #7	; predelay = (int) params[OPERAND_1_LOW_PARAM_INDEX] << 7
		POKE &feedback $params:OPERAND_2_HIGH_PARAM_INDEX 	; global feedback = (int) params[OPERAND_2_HIGH_PARAM_INDEX]
		SUBi $damping #256 $params:OPERAND_2_LOW_PARAM_INDEX	; damping = 256 - (int) params[OPERAND_2_LOW_PARAM_INDEX]
		MULi %0 $damping $damping	; global damping = (damping * damping + 255) >> 8
		ADDi %0 %0 #255
		SHRi %0 %0 #8
		POKE &damping %0 
		MOVi %1 $params:OPERAND_1_HIGH_PARAM_INDEX 	; global displayLEDs[0] = (int) displayBarValue((int) params[OPERAND_1_HIGH_PARAM_INDEX])
		CALL &displayBarValue %0 *2
		POKE &displayLEDs:0 %0 
		MOVi %1 $params:OPERAND_1_LOW_PARAM_INDEX 	; global displayLEDs[1] = (int) displayBarValue((int) params[OPERAND_1_LOW_PARAM_INDEX])
		CALL &displayBarValue %0 *2
		POKE &displayLEDs:1 %0 
		MOVi %1 $params:OPERAND_2_HIGH_PARAM_INDEX 	; global displayLEDs[2] = (int) displayBarValue((int) params[OPERAND_2_HIGH_PARAM_INDEX])
		CALL &displayBarValue %0 *2
		POKE &displayLEDs:2 %0 
		MOVi %1 $params:OPERAND_2_LOW_PARAM_INDEX 	; global displayLEDs[3] = (int) displayBarValue((int) params[OPERAND_2_LOW_PARAM_INDEX])
		CALL &displayBarValue %0 *2
		POKE &displayLEDs:3 %0 
		MOVi $taps:T0 #0 	; taps[T0] = 0
		ADDi %0 $size #1	; taps[T3] = (size + 1) / 3
		DIVi $taps:T3 %0 #3
		ADDi %0 $size #2	; taps[T5] = (int) taps[T3] + (size + 2) / 5
		DIVi %0 %0 #5
		ADDi $taps:T5 $taps:T3 %0
		ADDi %0 $size #3	; taps[T7] = (int) taps[T5] + (size + 3) / 7
		DIVi %0 %0 #7
		ADDi $taps:T7 $taps:T5 %0
		ADDi %0 $size #5	; taps[T11] = (int) taps[T3] + (size + 5) / 11
		DIVi %0 %0 #11
		ADDi $taps:T11 $taps:T3 %0
		ADDi %0 $size #6	; taps[T13] = (size + 6) / 13
		DIVi $taps:T13 %0 #13
		MOVi $taps:TFB $size 	; taps[TFB] = size
		ADDi $taps:TL1 $taps:T7 $predelay	; taps[TL1] = (int) taps[T7] + predelay
		ADDi $taps:TL2 $taps:TL1 #2311	; taps[TL2] = (int) taps[TL1] + 2311
		ADDi $taps:TR $taps:TL1 #1057	; taps[TR] = (int) taps[TL1] + 1057
		ADRL %0 $taps *0	; copy (TAPS_COUNT from taps to global taps)
		COPY &taps %0 *TAPS_COUNT
		RETU   	; }


;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	! MULi <A> #BATCH_SIZE_2 #TAPS_COUNT
	$offset:	LOCi
	$i:	LOCi
	$in:	LOCi
	$fb:	LOCi
	$lp:	LOCi
	$dI:	LOCi
	$l:	LOCi
	$bi:	LOCi
	$bd:	LOCi
	$t0:	LOCi
	$t3:	LOCi
	$t5:	LOCi
	$t7:	LOCi
	$t11:	LOCi
	$t13:	LOCi
	$tfb:	LOCi
	$tl1:	LOCi
	$tl2:	LOCi
	$tr:	LOCi
	$p:	LOCp
	$b:	LOCp
	$taps:	LOCA *TAPS_COUNT
	$buffers:	LOCA *<A>
;-----------------------------------------------------------------------------
	.l0:	ADRL %0 $taps *0	; copy (TAPS_COUNT from global taps to taps)
		COPY %0 &taps *TAPS_COUNT
		PEEK $lp &damping 	; lp = global damping
		PEEK $fb &feedback 	; fb = global feedback
		PEEK %0 &params:SWITCHES_PARAM_INDEX 	; if (((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_REVERSE_MASK) == 0) 
		ANDi %0 %0 #SWITCHES_REVERSE_MASK
		NEQi %0 #0 @.f1
		PEEK $offset &clock 	; offset = global clock
		ADRL $b $buffers *0	; b = buffers
		MOVi $bd #2 	; bd = 2
		GOTO @.e2  	; } else 
	.f1:	PEEK %0 &clock 	; offset = global clock - BATCH_SIZE
		SUBi $offset %0 #BATCH_SIZE
		! SUBi <A> #BATCH_SIZE_2 #2	; b = &buffers[BATCH_SIZE_2 - 2]
		ADRL $b $buffers:<A> *0
		MOVi $bd #-2 	; bd = -2
	.e2:	NOOP
		! MULi <A> #T3 #BATCH_SIZE_2	; p = &buffers[T3 * BATCH_SIZE_2]
		ADRL $p $buffers:<A> *0
		MOVi $i #T3 	; for (i = T3 to TR + 1) 
		! ADDi <A> #TR #1
		GEQi #T3 <A> @.e3
	.l4:	GETL %1 $taps $i	; read(offset - (int) taps[i], BATCH_SIZE, p)
		SUBi %1 $offset %1
		MOVi %2 #BATCH_SIZE 
		MOVp %3 $p 
		CALL ^read %0 *4
		ADDp $p $p #BATCH_SIZE_2	; p = p + BATCH_SIZE_2
		FORi $i <A> @.l4	; }
	.e3:	MOVi $bi #0 	; for (bi = 0 to BATCH_SIZE) 
		GEQi #0 #BATCH_SIZE @.e5
	.l6:	NOOP
		! MULi <A> #T3 #BATCH_SIZE_2	; t3 = (int) b[T3 * BATCH_SIZE_2]
		PEEK $t3 $b <A>
		! MULi <A> #T5 #BATCH_SIZE_2	; t5 = (int) b[T5 * BATCH_SIZE_2]
		PEEK $t5 $b <A>
		! MULi <A> #T7 #BATCH_SIZE_2	; t7 = (int) b[T7 * BATCH_SIZE_2]
		PEEK $t7 $b <A>
		! MULi <A> #T11 #BATCH_SIZE_2	; t11 = (int) b[T11 * BATCH_SIZE_2]
		PEEK $t11 $b <A>
		! MULi <A> #T13 #BATCH_SIZE_2	; t13 = (int) b[T13 * BATCH_SIZE_2]
		PEEK $t13 $b <A>
		! MULi <A> #TFB #BATCH_SIZE_2	; tfb = (int) b[TFB * BATCH_SIZE_2]
		PEEK $tfb $b <A>
		! MULi <A> #TL1 #BATCH_SIZE_2	; tl1 = (int) b[TL1 * BATCH_SIZE_2]
		PEEK $tl1 $b <A>
		! MULi <A> #TL2 #BATCH_SIZE_2	; tl2 = (int) b[TL2 * BATCH_SIZE_2]
		PEEK $tl2 $b <A>
		! MULi <A> #TR #BATCH_SIZE_2	; tr = (int) b[TR * BATCH_SIZE_2]
		PEEK $tr $b <A>
		PEEK %0 &signal:0 	; in = ((int) global signal[0] + (int) global signal[1]) >> 1
		PEEK %1 &signal:1 
		ADDi %0 %0 %1
		SHRi $in %0 #1
		MULi %0 $tfb $fb	; dI = dI + ((in + (tfb * fb >> 8) - dI) * lp >> 8)
		SHRi %0 %0 #8
		ADDi %0 $in %0
		SUBi %0 %0 $dI
		MULi %0 %0 $lp
		SHRi %0 %0 #8
		ADDi $dI $dI %0
		MOVi $t0 $dI 	; t0 = dI
		SHRi %0 $t3 #1	; t0  = t0  + (t3  >> 1)
		ADDi $t0 $t0 %0
		SHRi %0 $t0 #1	; t3  = t3  - (t0  >> 1)
		SUBi $t3 $t3 %0
		SHRi %0 $t13 #1	; t0  = t0  + (t13 >> 1)
		ADDi $t0 $t0 %0
		SHRi %0 $t0 #1	; t13 = t13 - (t0  >> 1)
		SUBi $t13 $t13 %0
		SHRi %0 $t5 #1	; t3  = t3  + (t5  >> 1)
		ADDi $t3 $t3 %0
		SHRi %0 $t3 #1	; t5  = t5  - (t3  >> 1)
		SUBi $t5 $t5 %0
		SHRi %0 $t11 #1	; t3  = t3  + (t11 >> 1)
		ADDi $t3 $t3 %0
		SHRi %0 $t3 #1	; t11 = t11 - (t3  >> 1)
		SUBi $t11 $t11 %0
		SHRi %0 $t7 #1	; t5  = t5  + (t7  >> 1)
		ADDi $t5 $t5 %0
		SHRi %0 $t5 #1	; t7  = t7  - (t5  >> 1)
		SUBi $t7 $t7 %0
		SUBi $l $tl1 $tl2	; l = tl1 - tl2
		SHRi %0 $l #2	; global signal[0] = l - (l >> 2) - (l >> 4)
		SUBi %0 $l %0
		SHRi %1 $l #4
		SUBi %0 %0 %1
		POKE &signal:0 %0 
		POKE &signal:1 $tr 	; global signal[1] = (int) tr
		CALL ^yield %0 *1	; yield()
		! MULi <A> #T0 #BATCH_SIZE_2	; b[T0 * BATCH_SIZE_2] = t0
		POKE $b <A> $t0
		! MULi <A> #T3 #BATCH_SIZE_2	; b[T3 * BATCH_SIZE_2] = t3
		POKE $b <A> $t3
		! MULi <A> #T5 #BATCH_SIZE_2	; b[T5 * BATCH_SIZE_2] = t5
		POKE $b <A> $t5
		! MULi <A> #T7 #BATCH_SIZE_2	; b[T7 * BATCH_SIZE_2] = t7
		POKE $b <A> $t7
		! MULi <A> #T11 #BATCH_SIZE_2	; b[T11 * BATCH_SIZE_2] = t11
		POKE $b <A> $t11
		! MULi <A> #T13 #BATCH_SIZE_2	; b[T13 * BATCH_SIZE_2] = t13
		POKE $b <A> $t13
		ADDp $b $b $bd	; b = b + bd
		FORi $bi #BATCH_SIZE @.l6	; }
	.e5:	NOOP
		! MULi <A> #T0 #BATCH_SIZE_2	; p = &buffers[T0 * BATCH_SIZE_2]
		ADRL $p $buffers:<A> *0
		MOVi $i #T0 	; for (i = T0 to T13 + 1) 
		! ADDi <A> #T13 #1
		GEQi #T0 <A> @.l0
	.l8:	GETL %1 $taps $i	; write(offset - (int) taps[i], BATCH_SIZE, p)
		SUBi %1 $offset %1
		MOVi %2 #BATCH_SIZE 
		MOVp %3 $p 
		CALL ^write %0 *4
		ADDp $p $p #BATCH_SIZE_2	; p = p + BATCH_SIZE_2
		FORi $i <A> @.l8	; }
		GOTO @.l0  	; }
		RETU   	; }

.s_4d2:	CNST *2
	DATi #32 #0
.s_ROOMSI4d3:	CNST *54
	DATi #32 #32 #32 #32
	DATs |----- ROOM SIZE ------| |----- PRE-DELAY ------|
	DATi #0
.s_FEEDBA4d4:	CNST *54
	DATi #32 #32 #32 #32
	DATs |------ FEEDBACK ------| |------ DAMPING -------|
	DATi #0