; Compiled with Impala version 1.0

ga:	GLOB *100

;-----------------------------------------------------------------------------
test:	FUNC
		PARA *1
	$i:	LOCi
	$f:	LOCf
	$p:	LOCp
	$a:	LOCA *100
	$fp:	LOCp
;-----------------------------------------------------------------------------
		ADRL $p $i *0	; p = &i
		ADRL $p $f *0	; p = &f
		MOVi $i #23 	; i = 23
		ADRL %0 $a *0	; p = a + i
		ADDp $p %0 $i
		ADDp $p &ga $i	; p = &global ga[i]
		MULi %0 $i #23	; p = &a[i * 23 + 1] + i * 55 + 432
		ADDi %0 %0 #1
		ADRL %1 $a *0
		ADDp %1 %1 %0
		MULi %0 $i #55
		ADDp %1 %1 %0
		ADDp $p %1 #432
		GETL $i $a $i	; i = (int) a[i]
		MOVi $i $i 	; i = (int) i
		GETL $f $a $i	; f = (float) a[i]
		MOVf $f $f 	; f = (float) f
		GETL $fp $a $i	; fp = (funcptr) a[i]
		MOVp $fp $fp 	; fp = (funcptr) fp
		GETL $p $a $i	; p = (pointer) a[i]
		MOVp $p $p 	; p = (pointer) p
		SUBi $i #0 $i	; i = -i
		SUBf $f #0.0 $f	; f = -f
		XORi $i $i #-1	; i = ~i
		ADRL $p $p *0	; p = &p
		ADDp %1 &ga #11	; p = global ga + 11 + SOME_CONST
		ADDp $p %1 #SOME_CONST
		PEEK $a:0 $p 	; a[0] = *p
		PEEK $p $p #23	; p = (pointer) *(p + 23)
		PEEK $p $p #-23	; p = (pointer) *(p - 23)
		MULi %1 $i #123	; p = (pointer) *(p + i * 123 + i)
		ADDp %1 $p %1
		PEEK $p %1 $i
		MULi %1 $i #123	; p = (pointer) *(p - i * 123 - i)
		SUBp %1 $p %1
		SUBp %1 %1 $i
		PEEK $p %1 
		MOVp $fp &test 	; fp = test
		iTOf $f $i #1.0	; f = itof(i)
		fTOi $i $f #1.0	; i = ftoi(f)
		! SUBi <A> #23 #12	; i = abs(i * (23 - 12))
		MULi %1 $i <A>
		ABSi $i %1 
		! SUBi <A> #23 #12	; i = 57 * abs((23 - 12))
		! ABSi <A> <A> 
		! MULi <A> #57 <A>
		MOVi $i <A> 
		ABSf $f $f 	; f = abs(f)
		! MULf <A> #55.5 #1234.5	; f = itof(ftoi(abs(55.5 * 1234.5 + 2345.5)))
		! ADDf <A> <A> #2345.5
		! ABSf <A> <A> 
		! fTOi <A> <A> #1.0
		! iTOf <A> <A> #1.0
		MOVf $f <A> 
		CALL $fp %0 *1	; fp()
		RETU   	; }