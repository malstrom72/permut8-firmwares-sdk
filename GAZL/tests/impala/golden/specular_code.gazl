;-----------------------------------------------------------------------------
trunc:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		GEQf $x #0.0 @.f0	; if (x < 0.0) y = -floor(-x)
		SUBf %0 #0.0 $x	; y = -floor(-x)
		FLOf %0 %0 
		SUBf $y #0.0 %0
		GOTO @.e1  
	.f0:	FLOf $y $x 	; y = floor(x)
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
fmod:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
;-----------------------------------------------------------------------------
		NEQf $y #0.0 @.f0	; if (y == 0.0) error("Division by zero")
		MOVp %1 &.s_Divisi4d7 	; error("Division by zero")
		CALL &error %0 *2
		GOTO @.e1  
	.f0:	DIVf %1 $x $y	; z = x - (float) trunc(x / y) * y
		CALL &trunc %0 *2
		MULf %0 %0 $y
		SUBf $z $x %0
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
cos:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; m = (float) fmod(x, TWICE_PI)
		MOVf %2 #TWICE_PI 
		CALL &fmod %0 *3
		MOVf $m %0 
		SUBf %0 #0.0 $m	; m = -m * m
		MULf $m %0 $m
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $n $n	; a = a * m / (n * n + n)
		MULf %1 $a $m
		ADDf %0 %0 $n
		DIVf $a %1 %0
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #2.0	; n = n + 2.0
		NEQf $y $t @.l0	; } while (y != t)
		ABSf %1 $y 	; if (abs(y) < COS_EPSILON) y = 0.0
		GEQf %1 #COS_EPSILON @.f1
		MOVf $y #0.0 	; y = 0.0
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
sin:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		SUBf %1 $x #HALF_PI	; y = (float) cos(x - HALF_PI)
		CALL &cos %0 *2
		MOVf $y %0 
		RETU   	; }


;-----------------------------------------------------------------------------
sqrt:	FUNC
	$y:	OUTf
	$x:	INPf
	$t:	LOCf
;-----------------------------------------------------------------------------
		GEQf $x #0.0 @.f0	; if (x < 0.0) error("Domain error")
		MOVp %1 &.s_Domain4d8 	; error("Domain error")
		CALL &error %0 *2
	.f0:	MOVf $y $x 	; y = x
		MOVf $t #0.0 	; t = 0.0
	.l1:	EQUf $y $t @.e2	; while (y != t) 
		MOVf $t $y 	; t = y
		DIVf %0 $x $y	; y = 0.5 * (y + x / y)
		ADDf %0 $y %0
		MULf $y #0.5 %0
		GOTO @.l1  	; }
	.e2:	RETU   	; }

