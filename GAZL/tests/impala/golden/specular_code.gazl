;-----------------------------------------------------------------------------
fftReIndex:	FUNC
		PARA *1
	$n:	INPi
	$data:	INPp
	$nn:	LOCi
	$j:	LOCi
	$i:	LOCi
	$m:	LOCi
	$t:	LOCf
;-----------------------------------------------------------------------------
		SHRi $nn $n #1	; nn = n >> 1
		MOVi $j #0 	; j = 0
		MOVi $i #0 	; i = 0
	.l0:	GEQi $i $n @.e1	; while (i < n) 
		LEQi $j $i @.f2	; if (j > i) 
		PEEK $t $data $j	; t = (float) data[j]
		PEEK %0 $data $i	; (float) data[j] = (float) data[i]
		POKE $data $j %0
		POKE $data $i $t	; (float) data[i] = t
		ADDi %0 $j #1	; t = (float) data[j + 1]
		PEEK $t $data %0
		ADDi %0 $j #1	; (float) data[j + 1] = (float) data[i + 1]
		ADDi %1 $i #1
		PEEK %1 $data %1
		POKE $data %0 %1
		ADDi %1 $i #1	; (float) data[i + 1] = t
		POKE $data %1 $t
	.f2:	MOVi $m $nn 	; m = nn
	.l3:	LSSi $m #2 @.e5	; while (m >= 2 && j >= m) 
		LSSi $j $m @.e5
		SUBi $j $j $m	; j = j - m
		SHRi $m $m #1	; m = m >> 1
		GOTO @.l3  	; }
	.e5:	ADDi $j $j $m	; j = j + m
		ADDi $i $i #2	; i = i + 2
		GOTO @.l0  	; }
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
fftPass4:	FUNC
		PARA *1
	$n:	INPi
	$data:	INPp
	$fftStep:	INPi
	$mmax:	LOCi
	$m:	LOCi
	$i:	LOCi
	$i1:	LOCi
	$i2:	LOCi
	$i3:	LOCi
	$j:	LOCi
	$j1:	LOCi
	$j2:	LOCi
	$j3:	LOCi
	$wTemp:	LOCf
	$wpRe:	LOCf
	$wpIm:	LOCf
	$wRe:	LOCf
	$wIm:	LOCf
	$w2Re:	LOCf
	$w2Im:	LOCf
	$w3Re:	LOCf
	$w3Im:	LOCf
	$d0Re:	LOCf
	$d0Im:	LOCf
	$d1Re:	LOCf
	$d1Im:	LOCf
	$d2Re:	LOCf
	$d2Im:	LOCf
	$d3Re:	LOCf
	$d3Im:	LOCf
;-----------------------------------------------------------------------------
		SHLi $mmax #2 $fftStep	; mmax = 2 << fftStep
		PEEK $wpRe &fftWPRe $fftStep	; wpRe = (float) global fftWPRe[fftStep]
		PEEK $wpIm &fftWPIm $fftStep	; wpIm = (float) global fftWPIm[fftStep]
		MOVf $wRe #1.0 	; wRe = 1.0
		MOVf $wIm #0.0 	; wIm = 0.0
		MOVi $m #0 	; m = 0
	.l0:	GEQi $m $mmax @.e1	; while (m < mmax) 
		MOVi $i $m 	; i = m
	.l2:	GEQi $i $n @.e3	; while (i < n) 
		ADDi $i1 $i $mmax	; i1 = i + mmax
		ADDi $j1 $i1 #1	; j1 = i1 + 1
		PEEK %1 $data $i1	; d1Re = ((float) data[i1] * w2Re - (float) data[j1] * w2Im)
		PEEK %0 $data $j1
		MULf %1 %1 $w2Re
		MULf %0 %0 $w2Im
		SUBf $d1Re %1 %0
		PEEK %1 $data $j1	; d1Im = ((float) data[j1] * w2Re + (float) data[i1] * w2Im)
		PEEK %0 $data $i1
		MULf %1 %1 $w2Re
		MULf %0 %0 $w2Im
		ADDf $d1Im %1 %0
		ADDi $i2 $i1 $mmax	; i2 = i1 + mmax
		ADDi $j2 $i2 #1	; j2 = i2 + 1
		PEEK %1 $data $i2	; d2Re = ((float) data[i2] * wRe - (float) data[j2] * wIm)
		PEEK %0 $data $j2
		MULf %1 %1 $wRe
		MULf %0 %0 $wIm
		SUBf $d2Re %1 %0
		PEEK %1 $data $j2	; d2Im = ((float) data[j2] * wRe + (float) data[i2] * wIm)
		PEEK %0 $data $i2
		MULf %1 %1 $wRe
		MULf %0 %0 $wIm
		ADDf $d2Im %1 %0
		ADDi $i3 $i2 $mmax	; i3 = i2 + mmax
		ADDi $j3 $i3 #1	; j3 = i3 + 1
		PEEK %1 $data $i3	; d3Re = ((float) data[i3] * w3Re - (float) data[j3] * w3Im)
		PEEK %0 $data $j3
		MULf %1 %1 $w3Re
		MULf %0 %0 $w3Im
		SUBf $d3Re %1 %0
		PEEK %1 $data $j3	; d3Im = ((float) data[j3] * w3Re + (float) data[i3] * w3Im)
		PEEK %0 $data $i3
		MULf %1 %1 $w3Re
		MULf %0 %0 $w3Im
		ADDf $d3Im %1 %0
		PEEK $d0Re $data $i	; d0Re = (float) data[i]
		ADDi %1 $i #1	; d0Im = (float) data[i + 1]
		PEEK $d0Im $data %1
		SUBf %1 $d0Re $d2Im	; data[i3] = (d0Re - d2Im) - (d1Re - d3Im)
		SUBf %0 $d1Re $d3Im
		SUBf %1 %1 %0
		POKE $data $i3 %1
		ADDf %1 $d0Im $d2Re	; data[j3] = (d0Im + d2Re) - (d1Im + d3Re)
		ADDf %0 $d1Im $d3Re
		SUBf %1 %1 %0
		POKE $data $j3 %1
		SUBf %1 $d0Re $d2Re	; data[i2] = (d0Re - d2Re) + (d1Re - d3Re)
		SUBf %0 $d1Re $d3Re
		ADDf %1 %1 %0
		POKE $data $i2 %1
		SUBf %1 $d0Im $d2Im	; data[j2] = (d0Im - d2Im) + (d1Im - d3Im)
		SUBf %0 $d1Im $d3Im
		ADDf %1 %1 %0
		POKE $data $j2 %1
		ADDf %1 $d0Re $d2Im	; data[i1] = (d0Re + d2Im) - (d1Re + d3Im)
		ADDf %0 $d1Re $d3Im
		SUBf %1 %1 %0
		POKE $data $i1 %1
		SUBf %1 $d0Im $d2Re	; data[j1] = (d0Im - d2Re) - (d1Im - d3Re)
		SUBf %0 $d1Im $d3Re
		SUBf %1 %1 %0
		POKE $data $j1 %1
		ADDf %1 $d0Re $d2Re	; data[i] = (d0Re + d2Re) + (d1Re + d3Re)
		ADDf %0 $d1Re $d3Re
		ADDf %1 %1 %0
		POKE $data $i %1
		ADDi %1 $i #1	; data[i + 1] = (d0Im + d2Im) + (d1Im + d3Im)
		ADDf %0 $d0Im $d2Im
		ADDf %2 $d1Im $d3Im
		ADDf %0 %0 %2
		POKE $data %1 %0
		MULi %0 $mmax #4	; i = i + mmax * 4
		ADDi $i $i %0
		GOTO @.l2  	; }
	.e3:	MOVf $wTemp $wRe 	; wTemp = wRe
		MULf %0 $wRe $wpRe	; wRe = wRe + wRe * wpRe - wIm * wpIm
		ADDf %0 $wRe %0
		MULf %1 $wIm $wpIm
		SUBf $wRe %0 %1
		MULf %0 $wIm $wpRe	; wIm = wIm + wIm * wpRe + wTemp * wpIm
		ADDf %0 $wIm %0
		MULf %1 $wTemp $wpIm
		ADDf $wIm %0 %1
		MULf %0 $wRe $wRe	; w2Re = (wRe * wRe - wIm * wIm)
		MULf %1 $wIm $wIm
		SUBf $w2Re %0 %1
		MULf %0 $wIm $wRe	; w2Im = (wIm * wRe + wRe * wIm)
		MULf %1 $wRe $wIm
		ADDf $w2Im %0 %1
		MULf %0 $w2Re $wRe	; w3Re = (w2Re * wRe - w2Im * wIm)
		MULf %1 $w2Im $wIm
		SUBf $w3Re %0 %1
		MULf %0 $w2Im $wRe	; w3Im = (w2Im * wRe + w2Re * wIm)
		MULf %1 $w2Re $wIm
		ADDf $w3Im %0 %1
		ADDi $m $m #2	; m = m + 2
		GOTO @.l0  	; }
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
fftPass0:	FUNC
		PARA *1
	$n:	INPi
	$data:	INPp
	$i:	LOCi
	$i1:	LOCi
	$j:	LOCi
	$j1:	LOCi
	$m:	LOCi
	$dj0:	LOCf
	$dj1:	LOCf
	$di0:	LOCf
	$di1:	LOCf
;-----------------------------------------------------------------------------
		MOVi $m #0 	; m = 0
		MOVi $i $m 	; i = m
	.l0:	GEQi $i $n @.e1	; while (i < n) 
		ADDi $j $i #2	; j = i + 2
		ADDi $i1 $i #1	; i1 = i + 1
		ADDi $j1 $j #1	; j1 = j + 1
		PEEK $dj0 $data $j	; dj0 = (float) data[j]
		PEEK $dj1 $data $j1	; dj1 = (float) data[j1]
		PEEK $di0 $data $i	; di0 = (float) data[i]
		PEEK $di1 $data $i1	; di1 = (float) data[i1]
		SUBf %0 $di0 $dj0	; data[j] = (float) di0 - dj0
		POKE $data $j %0
		SUBf %0 $di1 $dj1	; data[j1] = (float) di1 - dj1
		POKE $data $j1 %0
		ADDf %0 $di0 $dj0	; data[i] = (float) di0 + dj0
		POKE $data $i %0
		ADDf %0 $di1 $dj1	; data[i1] = (float) di1 + dj1
		POKE $data $i1 %0
		ADDi $i $j #2	; i = j + 2
		GOTO @.l0  	; }
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
fftPass:	FUNC
		PARA *1
	$n:	INPi
	$data:	INPp
	$fftStep:	INPi
	$mmax:	LOCi
	$i:	LOCi
	$i1:	LOCi
	$j:	LOCi
	$j1:	LOCi
	$m:	LOCi
	$wTemp:	LOCf
	$wpRe:	LOCf
	$wpIm:	LOCf
	$wRe:	LOCf
	$wIm:	LOCf
	$tempRe:	LOCf
	$tempIm:	LOCf
	$dj0:	LOCf
	$dj1:	LOCf
	$di0:	LOCf
	$di1:	LOCf
;-----------------------------------------------------------------------------
		SHLi $mmax #2 $fftStep	; mmax = 2 << fftStep
		PEEK $wpRe &fftWPRe $fftStep	; wpRe = (float) global fftWPRe[fftStep]
		PEEK $wpIm &fftWPIm $fftStep	; wpIm = (float) global fftWPIm[fftStep]
		MOVf $wRe #1.0 	; wRe = 1.0
		MOVf $wIm #0.0 	; wIm = 0.0
		MOVi $m #0 	; m = 0
	.l0:	MOVi $i $m 	; i = m
	.l1:	GEQi $i $n @.e2	; while (i < n) 
		ADDi $j $i $mmax	; j = i + mmax
		ADDi $i1 $i #1	; i1 = i + 1
		ADDi $j1 $j #1	; j1 = j + 1
		PEEK $dj0 $data $j	; dj0 = (float) data[j]
		PEEK $dj1 $data $j1	; dj1 = (float) data[j1]
		PEEK $di0 $data $i	; di0 = (float) data[i]
		PEEK $di1 $data $i1	; di1 = (float) data[i1]
		MULf %0 $wRe $dj0	; tempRe = wRe * (float) dj0 - wIm * (float) dj1
		MULf %1 $wIm $dj1
		SUBf $tempRe %0 %1
		MULf %0 $wRe $dj1	; tempIm = wRe * (float) dj1 + wIm * (float) dj0
		MULf %1 $wIm $dj0
		ADDf $tempIm %0 %1
		SUBf %0 $di0 $tempRe	; data[j] = (float) di0 - tempRe
		POKE $data $j %0
		SUBf %0 $di1 $tempIm	; data[j1] = (float) di1 - tempIm
		POKE $data $j1 %0
		ADDf %0 $di0 $tempRe	; data[i] = (float) di0 + tempRe
		POKE $data $i %0
		ADDf %0 $di1 $tempIm	; data[i1] = (float) di1 + tempIm
		POKE $data $i1 %0
		ADDi $i $j $mmax	; i = j + mmax
		GOTO @.l1  	; }
	.e2:	MOVf $wTemp $wRe 	; wTemp = wRe
		MULf %0 $wRe $wpRe	; wRe = wRe + (wRe * wpRe - wIm * wpIm)
		MULf %1 $wIm $wpIm
		SUBf %0 %0 %1
		ADDf $wRe $wRe %0
		MULf %0 $wIm $wpRe	; wIm = wIm + (wIm * wpRe + wTemp * wpIm)
		MULf %1 $wTemp $wpIm
		ADDf %0 %0 %1
		ADDf $wIm $wIm %0
		ADDi $m $m #2	; m = m + 2
		LSSi $m $mmax @.l0	; } while (m < mmax)
		RETU   	; }


;-----------------------------------------------------------------------------
fftUntangleParams:	FUNC
		PARA *1
	$n:	INPi
	$params:	INPp
	$wpRe:	LOCf
	$wpIm:	LOCf
;-----------------------------------------------------------------------------
		MOVf %1 #2.0 	; wpRe = (float) sqrt(2.0) * (float) sin(2.0 * PI * 0.5 / itof(n))
		CALL &sqrt %0 *2
		! MULf <A> #2.0 #PI
		! MULf <A> <A> #0.5
		iTOf %2 $n #1.0
		DIVf %2 <A> %2
		CALL &sin %1 *2
		MULf $wpRe %0 %1
		MULf $wpRe $wpRe $wpRe	; wpRe = wpRe * wpRe
		! MULf <A> #2.0 #PI	; wpIm = (float) sin(2.0 * PI / itof(n))
		iTOf %1 $n #1.0
		DIVf %1 <A> %1
		CALL &sin %0 *2
		MOVf $wpIm %0 
		POKE $params #0 $wpRe	; params[0] = wpRe
		POKE $params #1 $wpIm	; params[1] = wpIm
		RETU   	; }


;-----------------------------------------------------------------------------
fftUntangle:	FUNC
		PARA *1
	$n:	INPi
	$data:	INPp
	$params:	INPp
	$indexA:	LOCi
	$indexB:	LOCi
	$i:	LOCi
	$r0:	LOCf
	$i0:	LOCf
	$wRe:	LOCf
	$wIm:	LOCf
	$wpRe:	LOCf
	$wpIm:	LOCf
	$nwr:	LOCf
	$nwy:	LOCf
	$r1:	LOCf
	$i1:	LOCf
	$r0r1:	LOCf
	$i0i1:	LOCf
	$i0i1wr:	LOCf
	$i0i1wi:	LOCf
	$r1r0wr:	LOCf
	$r0r1wi:	LOCf
	$re0:	LOCf
	$im0:	LOCf
	$re1:	LOCf
	$im1:	LOCf
;-----------------------------------------------------------------------------
		PEEK $r0 $data #0	; r0 = (float) data[0]
		PEEK $i0 $data #1	; i0 = (float) data[1]
		ADDf %0 $r0 $i0	; data[0] = (r0 + i0)
		POKE $data #0 %0
		SUBf %0 $r0 $i0	; data[1] = (r0 - i0)
		POKE $data #1 %0
		MOVf $wRe #1.0 	; wRe = 1.0
		MOVf $wIm #0.0 	; wIm = 0.0
		PEEK $wpRe $params #0	; wpRe = (float) params[0]
		PEEK $wpIm $params #1	; wpIm = (float) params[1]
		MOVi $indexA #2 	; indexA = 2
		SUBi $indexB $n #2	; indexB = n - 2
		MOVi $i #1 	; for (i = 1 to n / 4) 
		DIVi %0 $n #4
		GEQi #1 %0 @.e0
	.l1:	MULf %1 $wRe $wpRe	; nwr = wRe - wRe * wpRe - wIm * wpIm
		SUBf %1 $wRe %1
		MULf %2 $wIm $wpIm
		SUBf $nwr %1 %2
		MULf %1 $wRe $wpIm	; nwy = wRe * wpIm + wIm - wIm * wpRe
		ADDf %1 %1 $wIm
		MULf %2 $wIm $wpRe
		SUBf $nwy %1 %2
		MOVf $wRe $nwr 	; wRe = nwr
		MOVf $wIm $nwy 	; wIm = nwy
		PEEK $r0 $data $indexA	; r0 = (float) data[indexA]
		ADDi %1 $indexA #1	; i0 = (float) data[indexA + 1]
		PEEK $i0 $data %1
		PEEK $r1 $data $indexB	; r1 = (float) data[indexB]
		ADDi %1 $indexB #1	; i1 = (float) data[indexB + 1]
		PEEK $i1 $data %1
		ADDf $r0r1 $r0 $r1	; r0r1 = r0 + r1
		SUBf $i0i1 $i0 $i1	; i0i1 = i0 - i1
		ADDf %1 $i0 $i1	; i0i1wr = (i0 + i1) * wRe
		MULf $i0i1wr %1 $wRe
		ADDf %1 $i0 $i1	; i0i1wi = (i0 + i1) * wIm
		MULf $i0i1wi %1 $wIm
		SUBf %1 $r1 $r0	; r1r0wr = (r1 - r0) * wRe
		MULf $r1r0wr %1 $wRe
		SUBf %1 $r0 $r1	; r0r1wi = (r0 - r1) * wIm
		MULf $r0r1wi %1 $wIm
		SUBf %1 $i0i1wr $r0r1wi	; re0 = 0.5 * (i0i1wr - r0r1wi + r0r1)
		ADDf %1 %1 $r0r1
		MULf $re0 #0.5 %1
		SUBf %1 $r1r0wr $i0i1wi	; im0 = 0.5 * (r1r0wr - i0i1wi + i0i1)
		ADDf %1 %1 $i0i1
		MULf $im0 #0.5 %1
		SUBf %1 $r0r1wi $i0i1wr	; re1 = 0.5 * (r0r1wi - i0i1wr + r0r1)
		ADDf %1 %1 $r0r1
		MULf $re1 #0.5 %1
		SUBf %1 $r1r0wr $i0i1wi	; im1 = 0.5 * (r1r0wr - i0i1wi - i0i1)
		SUBf %1 %1 $i0i1
		MULf $im1 #0.5 %1
		POKE $data $indexA $re0	; data[indexA] = re0
		ADDi %1 $indexA #1	; data[indexA + 1] = im0
		POKE $data %1 $im0
		POKE $data $indexB $re1	; data[indexB] = re1
		ADDi %1 $indexB #1	; data[indexB + 1] = im1
		POKE $data %1 $im1
		ADDi $indexA $indexA #2	; indexA = indexA + 2
		SUBi $indexB $indexB #2	; indexB = indexB - 2
		FORi $i %0 @.l1	; }
	.e0:	RETU   	; }


;-----------------------------------------------------------------------------
mixOutput:	FUNC
		PARA *1
	$fftBuffer:	INPp
	$mixBuffer:	INPp
	$mixBufferOffset:	INPi
	$channel:	INPi
	$i:	LOCi
	$i2:	LOCi
;-----------------------------------------------------------------------------
		ADDi $i2 $mixBufferOffset $channel	; i2 = mixBufferOffset + channel
		MOVi $i #0 	; for (i = 0 to FFT_SIZE_2) 
		GEQi #0 #FFT_SIZE_2 @.e0
	.l1:	PEEK %0 $fftBuffer $i	; mixBuffer[i2] = (int) mixBuffer[i2] + ftoi((float) fftBuffer[i] * (float) global window[i] * 2048.0)
		PEEK %1 &window $i
		MULf %0 %0 %1
		PEEK %1 $mixBuffer $i2
		fTOi %0 %0 #2048.0
		ADDi %1 %1 %0
		POKE $mixBuffer $i2 %1
		ADDi $i2 $i2 #2	; i2 = i2 + 2
		FORi $i #FFT_SIZE_2 @.l1	; }
	.e0:	SUBi %1 #FFT_SIZE $mixBufferOffset	; i2 = FFT_SIZE - mixBufferOffset + channel
		ADDi $i2 %1 $channel
		MOVi $i #FFT_SIZE_2 	; for (i = FFT_SIZE_2 to FFT_SIZE) 
		GEQi #FFT_SIZE_2 #FFT_SIZE @.e2
	.l3:	NOOP
		! SUBi <A> #FFT_SIZE #1	; mixBuffer[i2] = ftoi((float) fftBuffer[i] * (float) global window[FFT_SIZE - 1 - i] * 2048.0)
		SUBi %1 <A> $i
		PEEK %0 $fftBuffer $i
		PEEK %1 &window %1
		MULf %0 %0 %1
		fTOi %0 %0 #2048.0
		POKE $mixBuffer $i2 %0
		ADDi $i2 $i2 #2	; i2 = i2 + 2
		FORi $i #FFT_SIZE @.l3	; }
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
	$i:	LOCi
	$theta:	LOCf
	$wTemp:	LOCf
	$prng:	LOCi
;-----------------------------------------------------------------------------
		MOVp %1 &.s_init4d9 	; trace("init")
		CALL ^trace %0 *2
		MOVi $i #0 	; for (i = 0 to FFT_SIZE_2) 
		GEQi #0 #FFT_SIZE_2 @.e0
	.l1:	NOOP
		! iTOf <A> #FFT_SIZE #1.0	; global window[i] = (float) sin(PI / itof(FFT_SIZE) * itof(i))
		! DIVf <A> #PI <A>
		iTOf %1 $i <A>
		CALL &sin %0 *2
		POKE &window $i %0
		FORi $i #FFT_SIZE_2 @.l1	; }
	.e0:	MOVi $i #0 	; for (i = 0 to 256) 
		GEQi #0 #256 @.e2
	.l3:	NOOP
		! MULf <A> #2.0 #PI	; theta = 2.0 * PI / 256.0 * itof(i)
		! DIVf <A> <A> #256.0
		iTOf $theta $i <A>
		MOVf %1 $theta 	; global cRotateRe[i] = (float) cos(theta)
		CALL &cos %0 *2
		POKE &cRotateRe $i %0
		MOVf %1 $theta 	; global cRotateIm[i] = (float) sin(theta)
		CALL &sin %0 *2
		POKE &cRotateIm $i %0
		FORi $i #256 @.l3	; }
	.e2:	MOVi $i #0 	; for (i = 0 to 8) 
		GEQi #0 #8 @.e4
	.l5:	ADDi %1 $i #1	; global partialGains[i] = IFFT_SCALE / (float) sqrt(itof(i + 1))
		iTOf %1 %1 #1.0
		CALL &sqrt %0 *2
		DIVf %0 #IFFT_SCALE %0
		POKE &partialGains $i %0
		FORi $i #8 @.l5	; }
	.e4:	MOVi $i #0 	; for (i = 0 to FFT_POWER - 1) 
		! SUBi <A> #FFT_POWER #1
		GEQi #0 <A> @.e6
	.l7:	SHLi %0 #2 $i	; theta = -(2.0 * PI / itof(2 << i))
		! MULf <B> #2.0 #PI
		iTOf %0 %0 #1.0
		DIVf %0 <B> %0
		SUBf $theta #0.0 %0
		MULf %1 #0.5 $theta	; wTemp = (float) sin(0.5 * theta)
		CALL &sin %0 *2
		MOVf $wTemp %0 
		MULf %0 #-2.0 $wTemp	; global fftWPRe[i] = -2.0 * wTemp * wTemp
		MULf %0 %0 $wTemp
		POKE &fftWPRe $i %0
		MOVf %1 $theta 	; global fftWPIm[i] = (float) sin(theta)
		CALL &sin %0 *2
		POKE &fftWPIm $i %0
		FORi $i <A> @.l7	; }
	.e6:	PEEK %0 &instance 	; prng = 2463534242 ^ (global instance << 13)
		SHLi %0 %0 #13
		XORi $prng #2463534242 %0
		MOVi $i #1 	; for (i = 1 to FFT_SIZE_2) 
		GEQi #1 #FFT_SIZE_2 @.e8
	.l9:	SHLi %0 $prng #13	; prng = prng ^ (prng << 13)
		XORi $prng $prng %0
		SHRu %0 $prng #17	; prng = prng ^ (prng >>> 17)
		XORi $prng $prng %0
		SHLi %0 $prng #5	; prng = prng ^ (prng << 5)
		XORi $prng $prng %0
		ANDi %0 $prng #255	; global randomArray[i] = prng & 255
		POKE &randomArray $i %0
		FORi $i #FFT_SIZE_2 @.l9	; }
	.e8:	MOVi %1 #FFT_SIZE 	; fftUntangleParams(FFT_SIZE, global untangleParams)
		MOVp %2 &untangleParams 
		CALL &fftUntangleParams %0 *3
		RETU   	; }


;-----------------------------------------------------------------------------
reset:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		MOVp %1 &.s_reset4da 	; trace("reset")
		CALL ^trace %0 *2
		POKE &doReset #TRUE 	; global doReset = TRUE
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$f:	LOCf
;-----------------------------------------------------------------------------
		MOVp %1 &.s_update4db 	; trace("update")
		CALL ^trace %0 *2
		PEEK %0 &params:THRESHOLD_PARAM 	; f = itof((int) global params[THRESHOLD_PARAM]) * (1.0 / 255.0)
		! DIVf <A> #1.0 #255.0
		iTOf $f %0 <A>
		MULf %0 $f $f	; f = f * f * f
		MULf $f %0 $f
		POKE &threshold $f 	; global threshold = f
		PEEK %0 &params:DECAY_PARAM 	; f = 1.0 - itof((int) global params[DECAY_PARAM]) * (1.0 / 255.0)
		! DIVf <A> #1.0 #255.0
		iTOf %0 %0 <A>
		SUBf $f #1.0 %0
		MULf %0 $f $f	; global decayConstant = 1.0 - (f * f * f)
		MULf %0 %0 $f
		SUBf %0 #1.0 %0
		POKE &decayConstant %0 
		PEEK %2 &decayConstant 	; global outputGain = (float) sqrt((float) sqrt(1.0 - global decayConstant))
		SUBf %2 #1.0 %2
		CALL &sqrt %1 *2
		CALL &sqrt %0 *2
		POKE &outputGain %0 
		RETU   	; }


;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	! MULi <A> #FFT_SIZE #2
	$fftBuffer:	LOCA *FFT_SIZE
	$inputBuffer:	LOCA *FFT_SIZE
	$clock:	LOCi
	$i:	LOCi
	$i2:	LOCi
	$processStep:	LOCi
	$useThreshold:	LOCf
	$bandBits:	LOCi
	$nextBandBit:	LOCi
	$re:	LOCf
	$im:	LOCf
	$power:	LOCf
	$feedbackRe:	LOCA *FFT_SIZE_2
	$feedbackIm:	LOCA *FFT_SIZE_2
	$k:	LOCf
	$partial:	LOCi
	$partialBase1:	LOCi
	$partialBase1Div2:	LOCi
	$g:	LOCf
	$cMulARe:	LOCf
	$cMulAIm:	LOCf
	$cMulBRe:	LOCf
	$cMulBIm:	LOCf
	$cMulRe:	LOCf
	$cMulIm:	LOCf
	$rotateIndex:	LOCi
	$x:	LOCi
	$y:	LOCi
	$t:	LOCi
	$prng:	LOCi
	$mixBuffer:	LOCA *<A>
	$mixBufferOffset:	LOCi
	$myInstance:	LOCi
;-----------------------------------------------------------------------------
		POKE &doReset #TRUE 	; global doReset = TRUE
		PEEK $t &instance 	; t = global instance
		MOVi $myInstance #0 	; myInstance = 0
		MOVi $i #0 	; for (i = 0 to PROCESS_SPREAD_FACTOR) 
		GEQi #0 #PROCESS_SPREAD_FACTOR @.e0
	.l1:	SHLi %0 $myInstance #1	; myInstance = (myInstance << 1) | (t & 1)
		ANDi %1 $t #1
		IORi $myInstance %0 %1
		SHRi $t $t #1	; t = t >> 1
		FORi $i #PROCESS_SPREAD_FACTOR @.l1	; }
	.e0:	SHLi %0 $myInstance #13	; prng = 2463534242 ^ (myInstance << 13)
		XORi $prng #2463534242 %0
		MOVi $i #0 	; for (i = 0 to FFT_SIZE) 
		GEQi #0 #FFT_SIZE @.e2
	.l3:	SETL $inputBuffer $i #0.0	; inputBuffer[i] = 0.0
		FORi $i #FFT_SIZE @.l3	; }
	.e2:	MOVi $mixBufferOffset #0 	; mixBufferOffset = 0
		MOVi $processStep #PROCESS_STEPS 	; processStep = PROCESS_STEPS
	.l4:	PEEK $clock &clock 	; clock = global clock
		! SHLi <A> #1 #PROCESS_SPREAD_FACTOR	; if ((clock & ((1 << PROCESS_SPREAD_FACTOR) - 1)) == myInstance) 
		! SUBi <A> <A> #1
		ANDi %0 $clock <A>
		NEQi %0 $myInstance @.f5
		ADDi $processStep $processStep #1	; processStep = processStep + 1
		! SUBi <A> #FFT_SIZE_2 #1	; if ((clock & (FFT_SIZE_2 - 1)) == myInstance) 
		ANDi %0 $clock <A>
		NEQi %0 $myInstance @.f6
		MOVi $processStep #PERFORM_RESET 	; processStep = PERFORM_RESET
	.f6:	SWCH $processStep *PROCESS_STEPS @.s7	; switch (processStep == 0 to PROCESS_STEPS) 
	.s7#PERFORM_RESET:	PEEK %0 &doReset 	; if (global doReset != FALSE) 
		EQUi %0 #FALSE @.e8
		POKE &doReset #FALSE 	; global doReset = FALSE
		MOVi $i #0 	; for (i = 0 to FFT_SIZE_2) 
		GEQi #0 #FFT_SIZE_2 @.e10
	.l11:	SETL $feedbackIm $i #0.0	; feedbackIm[i] = 0.0
		SETL $feedbackRe $i #0.0	; feedbackRe[i] = 0.0
		FORi $i #FFT_SIZE_2 @.l11	; }
	.e10:	MOVi $i #0 	; for (i = 0 to FFT_SIZE) 
		GEQi #0 #FFT_SIZE @.e12
	.l13:	SETL $mixBuffer $i #0	; mixBuffer[i] = 0
		FORi $i #FFT_SIZE @.l13	; }
	.e12:	MOVi $mixBufferOffset #0 	; mixBufferOffset = 0
		GOTO @.e8  	; }
	.s7#ANALYSIS_WINDOW:	MOVi $i #0 	; for (i = 0 to FFT_SIZE_2) 
		GEQi #0 #FFT_SIZE_2 @.e14
	.l15:	SUBi %0 $clock #FFT_SIZE	; fftBuffer[i] = (float) inputBuffer[(clock - FFT_SIZE + i) & (FFT_SIZE - 1)] * (float) global window[i]
		ADDi %0 %0 $i
		! SUBi <A> #FFT_SIZE #1
		ANDi %0 %0 <A>
		GETL %0 $inputBuffer %0
		PEEK %1 &window $i
		MULf %0 %0 %1
		SETL $fftBuffer $i %0
		FORi $i #FFT_SIZE_2 @.l15	; }
	.e14:	MOVi $i #FFT_SIZE_2 	; for (i = FFT_SIZE_2 to FFT_SIZE) 
		GEQi #FFT_SIZE_2 #FFT_SIZE @.e8
	.l17:	SUBi %0 $clock #FFT_SIZE	; fftBuffer[i] = (float) inputBuffer[(clock - FFT_SIZE + i) & (FFT_SIZE - 1)] * (float) global window[FFT_SIZE - 1 - i]
		ADDi %0 %0 $i
		! SUBi <A> #FFT_SIZE #1
		ANDi %0 %0 <A>
		! SUBi <A> #FFT_SIZE #1
		SUBi %1 <A> $i
		GETL %0 $inputBuffer %0
		PEEK %1 &window %1
		MULf %0 %0 %1
		SETL $fftBuffer $i %0
		FORi $i #FFT_SIZE @.l17	; }
		GOTO @.e8  	; }
	.s7#ANALYSIS_REINDEX:	NOOP
	.s7#SYNTHESIS_REINDEX_LEFT:	NOOP
	.s7#SYNTHESIS_REINDEX_RIGHT:	MOVi %1 #FFT_SIZE 	; fftReIndex(FFT_SIZE, fftBuffer)
		ADRL %2 $fftBuffer *0
		CALL &fftReIndex %0 *3
		GOTO @.e8  	; }
	.s7#ANALYSIS_FFT_2:	MOVi %1 #FFT_SIZE 	; fftPass0(FFT_SIZE, fftBuffer)
		ADRL %2 $fftBuffer *0
		CALL &fftPass0 %0 *3
		GOTO @.e8  	; }
		! ADDi <A> #ANALYSIS_FFT_2 #1	; case ANALYSIS_FFT_2 + 1, ANALYSIS_FFT_2 + 2, ANALYSIS_FFT_2 + 3
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #2
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #3
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #4
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #5
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #6
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #7
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #8
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #9
	.s7#<A>:	NOOP
		! ADDi <A> #ANALYSIS_FFT_2 #10
	.s7#<A>:	MOVi %1 #FFT_SIZE 	; fftPass(FFT_SIZE, fftBuffer, processStep - ANALYSIS_FFT_2)
		ADRL %2 $fftBuffer *0
		SUBi %3 $processStep #ANALYSIS_FFT_2
		CALL &fftPass %0 *4
		GOTO @.e8  	; }
	.s7#ANALYSIS_UNTANGLE:	NOOP
	.s7#SYNTHESIS_UNTANGLE_LEFT:	NOOP
	.s7#SYNTHESIS_UNTANGLE_RIGHT:	MOVi %1 #FFT_SIZE 	; fftUntangle(FFT_SIZE, fftBuffer, global untangleParams)
		ADRL %2 $fftBuffer *0
		MOVp %3 &untangleParams 
		CALL &fftUntangle %0 *4
		GOTO @.e8  	; }
	.s7#PROCESS_FIND_MAX:	MOVf $useThreshold #0.0 	; useThreshold = 0.0
		PEEK $bandBits &params:BAND_PARAM 	; bandBits = (int) global params[BAND_PARAM]
		! SUBi <A> #FFT_POWER #8	; nextBandBit = 1 << (FFT_POWER - 8)
		! SHLi <A> #1 <A>
		MOVi $nextBandBit <A> 
		MOVi $i #1 	; for (i = 1 to FFT_SIZE_2) 
		GEQi #1 #FFT_SIZE_2 @.e18
	.l19:	NEQi $i $nextBandBit @.f20	; if (i == nextBandBit) 
		SHLi $nextBandBit $nextBandBit #1	; nextBandBit = nextBandBit << 1
		SHLi $bandBits $bandBits #1	; bandBits = bandBits << 1
	.f20:	MULi $i2 $i #2	; i2 = i * 2
		! SHLi <A> #1 #7	; if ((bandBits & (1 << 7)) == 0) 
		ANDi %0 $bandBits <A>
		NEQi %0 #0 @.f21
		SETL $fftBuffer $i2 #0.0	; fftBuffer[i2] = 0.0
		ADDi %0 $i2 #1	; fftBuffer[i2 + 1] = 0.0
		SETL $fftBuffer %0 #0.0
		GOTO @.e22  	; } else 
	.f21:	GETL $re $fftBuffer $i2	; re = (float) fftBuffer[i2]
		ADDi %0 $i2 #1	; im = (float) fftBuffer[i2 + 1]
		GETL $im $fftBuffer %0
		MULf %0 $re $re	; power = re * re + im * im
		MULf %1 $im $im
		ADDf $power %0 %1
		LEQf $power $useThreshold @.f23	; if (power > useThreshold) 
		MOVf $useThreshold $power 	; useThreshold = power
	.f23:	NOOP
	.e22:	FORi $i #FFT_SIZE_2 @.l19	; }
	.e18:	PEEK %0 &threshold 	; useThreshold = useThreshold * global threshold
		MULf $useThreshold $useThreshold %0
		GOTO @.e8  	; }
	.s7#PROCESS_FEEDBACK:	PEEK $k &decayConstant 	; k = global decayConstant
		MOVi $i #1 	; for (i = 1 to FFT_SIZE_2) 
		GEQi #1 #FFT_SIZE_2 @.e8
	.l25:	GETL %0 $feedbackRe $i	; feedbackRe[i] = (float) feedbackRe[i] * k + ANTI_DENORMAL_CONSTANT
		MULf %0 %0 $k
		ADDf %0 %0 #ANTI_DENORMAL_CONSTANT
		SETL $feedbackRe $i %0
		GETL %0 $feedbackIm $i	; feedbackIm[i] = (float) feedbackIm[i] * k + ANTI_DENORMAL_CONSTANT
		MULf %0 %0 $k
		ADDf %0 %0 #ANTI_DENORMAL_CONSTANT
		SETL $feedbackIm $i %0
		LEQi $i #256 @.f27	; if (i > 256 && (i & 15) == 0) 
		ANDi %0 $i #15
		NEQi %0 #0 @.f27
		! DIVf <A> #1.0 #256.0	; k = k * (1.0 - 1.0 / 256.0)
		! SUBf <A> #1.0 <A>
		MULf $k $k <A>
	.f27:	MULi $i2 $i #2	; i2 = i * 2
		GETL $re $fftBuffer $i2	; re = (float) fftBuffer[i2]
		ADDi %0 $i2 #1	; im = (float) fftBuffer[i2 + 1]
		GETL $im $fftBuffer %0
		MULf %0 $re $re	; if (re * re + im * im < useThreshold) 
		MULf %1 $im $im
		ADDf %0 %0 %1
		GEQf %0 $useThreshold @.f28
		SETL $fftBuffer $i2 #0.0	; fftBuffer[i2] = 0.0
		ADDi %0 $i2 #1	; fftBuffer[i2 + 1] = 0.0
		SETL $fftBuffer %0 #0.0
	.f28:	FORi $i #FFT_SIZE_2 @.l25	; }
		GOTO @.e8  	; }
	.s7#PROCESS_PARTIAL_1:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #1	; case PROCESS_PARTIAL_1, PROCESS_PARTIAL_1 + 1, PROCESS_PARTIAL_1 + 2, PROCESS_PARTIAL_1 + 3
	.s7#<A>:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #2
	.s7#<A>:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #3
	.s7#<A>:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #4
	.s7#<A>:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #5
	.s7#<A>:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #6
	.s7#<A>:	NOOP
		! ADDi <A> #PROCESS_PARTIAL_1 #7
	.s7#<A>:	SUBi $partial $processStep #PROCESS_PARTIAL_1	; partial = processStep - PROCESS_PARTIAL_1
		PEEK %0 &params:PARTIALS_PARAM 	; if (((int) global params[PARTIALS_PARAM] & (128 >>> partial)) != 0) 
		SHRu %1 #128 $partial
		ANDi %0 %0 %1
		EQUi %0 #0 @.e8
		PEEK %0 &outputGain 	; g = global outputGain * (float) global partialGains[partial]
		PEEK %1 &partialGains $partial
		MULf $g %0 %1
		ADDi $partialBase1 $partial #1	; partialBase1 = (partial + 1)
		DIVi $partialBase1Div2 $partialBase1 #2	; partialBase1Div2 = (partialBase1 / 2)
		MOVi $i #1 	; for (i = 1 to FFT_SIZE_2) 
		GEQi #1 #FFT_SIZE_2 @.e8
	.l31:	ADDi %0 $i $partialBase1Div2	; i2 = (i + partialBase1Div2) / partialBase1 * 2
		DIVi %0 %0 $partialBase1
		MULi $i2 %0 #2
		GETL %0 $fftBuffer $i2	; feedbackRe[i] = (float) feedbackRe[i] + (float) fftBuffer[i2] * g
		GETL %1 $feedbackRe $i
		MULf %0 %0 $g
		ADDf %1 %1 %0
		SETL $feedbackRe $i %1
		ADDi %1 $i2 #1	; feedbackIm[i] = (float) feedbackIm[i] + (float) fftBuffer[i2 + 1] * g
		GETL %1 $fftBuffer %1
		GETL %0 $feedbackIm $i
		MULf %1 %1 $g
		ADDf %0 %0 %1
		SETL $feedbackIm $i %0
		FORi $i #FFT_SIZE_2 @.l31	; }
		GOTO @.e8  	; }
	.s7#SYNTHESIS_SMEAR_LEFT:	NOOP
	.s7#SYNTHESIS_SMEAR_RIGHT:	MOVi $i #1 	; for (i = 1 to FFT_SIZE_2) 
		GEQi #1 #FFT_SIZE_2 @.e32
	.l33:	ADDi %0 $prng $i	; rotateIndex = (int) global randomArray[(prng + i) & (FFT_SIZE_2 - 1)]
		! SUBi <A> #FFT_SIZE_2 #1
		ANDi %0 %0 <A>
		PEEK $rotateIndex &randomArray %0
		PEEK $cMulARe &cRotateRe $rotateIndex	; cMulARe = (float) global cRotateRe[rotateIndex]
		PEEK $cMulAIm &cRotateIm $rotateIndex	; cMulAIm = (float) global cRotateIm[rotateIndex]
		GETL $cMulBRe $feedbackRe $i	; cMulBRe = (float) feedbackRe[i]
		GETL $cMulBIm $feedbackIm $i	; cMulBIm = (float) feedbackIm[i]
		MULf %0 $cMulARe $cMulBRe	; cMulRe = (cMulARe * cMulBRe - cMulAIm * cMulBIm)
		MULf %1 $cMulAIm $cMulBIm
		SUBf $cMulRe %0 %1
		MULf %0 $cMulAIm $cMulBRe	; cMulIm = (cMulAIm * cMulBRe + cMulARe * cMulBIm)
		MULf %1 $cMulARe $cMulBIm
		ADDf $cMulIm %0 %1
		SETL $feedbackRe $i $cMulRe	; feedbackRe[i] = cMulRe
		SETL $feedbackIm $i $cMulIm	; feedbackIm[i] = cMulIm
		SUBi %0 #FFT_SIZE_2 $i	; i2 = (FFT_SIZE_2 - i) * 2
		MULi $i2 %0 #2
		SETL $fftBuffer $i2 $cMulRe	; fftBuffer[i2] = cMulRe
		ADDi %0 $i2 #1	; fftBuffer[i2 + 1] = cMulIm
		SETL $fftBuffer %0 $cMulIm
		FORi $i #FFT_SIZE_2 @.l33	; }
	.e32:	MOVf $fftBuffer:0 #0.0 	; fftBuffer[0] = 0.0
		MOVf $fftBuffer:1 #0.0 	; fftBuffer[1] = 0.0
		SHLi %0 $prng #13	; prng = prng ^ (prng << 13)
		XORi $prng $prng %0
		SHRu %0 $prng #17	; prng = prng ^ (prng >>> 17)
		XORi $prng $prng %0
		SHLi %0 $prng #5	; prng = prng ^ (prng << 5)
		XORi $prng $prng %0
		GOTO @.e8  	; }
	.s7#SYNTHESIS_FFT_LEFT_2:	MOVi %1 #FFT_SIZE 	; fftPass0(FFT_SIZE, fftBuffer)
		ADRL %2 $fftBuffer *0
		CALL &fftPass0 %0 *3
		GOTO @.e8  	; }
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #1	; case SYNTHESIS_FFT_LEFT_2 + 1, SYNTHESIS_FFT_LEFT_2 + 2, SYNTHESIS_FFT_LEFT_2 + 3
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #2
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #3
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #4
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #5
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #6
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #7
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #8
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #9
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_LEFT_2 #10
	.s7#<A>:	MOVi %1 #FFT_SIZE 	; fftPass(FFT_SIZE, fftBuffer, processStep - SYNTHESIS_FFT_LEFT_2)
		ADRL %2 $fftBuffer *0
		SUBi %3 $processStep #SYNTHESIS_FFT_LEFT_2
		CALL &fftPass %0 *4
		GOTO @.e8  	; }
	.s7#SYNTHESIS_FFT_RIGHT_2:	MOVi %1 #FFT_SIZE 	; fftPass0(FFT_SIZE, fftBuffer)
		ADRL %2 $fftBuffer *0
		CALL &fftPass0 %0 *3
		GOTO @.e8  	; }
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #1	; case SYNTHESIS_FFT_RIGHT_2 + 1, SYNTHESIS_FFT_RIGHT_2 + 2, SYNTHESIS_FFT_RIGHT_2 + 3
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #2
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #3
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #4
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #5
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #6
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #7
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #8
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #9
	.s7#<A>:	NOOP
		! ADDi <A> #SYNTHESIS_FFT_RIGHT_2 #10
	.s7#<A>:	MOVi %1 #FFT_SIZE 	; fftPass(FFT_SIZE, fftBuffer, processStep - SYNTHESIS_FFT_RIGHT_2)
		ADRL %2 $fftBuffer *0
		SUBi %3 $processStep #SYNTHESIS_FFT_RIGHT_2
		CALL &fftPass %0 *4
		GOTO @.e8  	; }
	.s7#SYNTHESIS_MIX_LEFT:	ADRL %1 $fftBuffer *0	; mixOutput(fftBuffer, mixBuffer, mixBufferOffset, 0)
		ADRL %2 $mixBuffer *0
		MOVi %3 $mixBufferOffset 
		MOVi %4 #0 
		CALL &mixOutput %0 *5
		GOTO @.e8  	; }
	.s7#SYNTHESIS_MIX_RIGHT:	ADRL %1 $fftBuffer *0	; mixOutput(fftBuffer, mixBuffer, mixBufferOffset, 1)
		ADRL %2 $mixBuffer *0
		MOVi %3 $mixBufferOffset 
		MOVi %4 #1 
		CALL &mixOutput %0 *5
		! SUBi <A> #FFT_SIZE_2 #1	; write((clock & ~(FFT_SIZE_2 - 1)) + (PROCESS_STEPS << PROCESS_SPREAD_FACTOR), FFT_SIZE_2, mixBuffer + mixBufferOffset)
		! XORi <A> <A> #-1
		ANDi %1 $clock <A>
		! SHLi <A> #PROCESS_STEPS #PROCESS_SPREAD_FACTOR
		ADDi %1 %1 <A>
		MOVi %2 #FFT_SIZE_2 
		ADRL %3 $mixBuffer *0
		ADDp %3 %3 $mixBufferOffset
		CALL ^write %0 *4
		SUBi $mixBufferOffset #FFT_SIZE $mixBufferOffset	; mixBufferOffset = FFT_SIZE - mixBufferOffset
	.s7:	NOOP
	.e8:	NOOP
	.f5:	NOOP
		! SUBi <A> #FFT_SIZE #1	; inputBuffer[clock & (FFT_SIZE - 1)] = itof((int) global signal[0] + (int) global signal[1]) * (1.0 / (2048.0 * 2.0))
		ANDi %0 $clock <A>
		PEEK %1 &signal:0 
		PEEK %2 &signal:1 
		ADDi %1 %1 %2
		! MULf <A> #2048.0 #2.0
		! DIVf <A> #1.0 <A>
		iTOf %1 %1 <A>
		SETL $inputBuffer %0 %1
		MOVi %1 $clock 	; read(clock, 1, global signal)
		MOVi %2 #1 
		MOVp %3 &signal 
		CALL ^read %0 *4
		CALL ^yield %0 *1	; yield()
		GOTO @.l4  	; }
		RETU   	; }

.s_4d2:	CNST *2
	DATi #32 #0
.s_THRESH4d3:	CNST *53
	DATi #32 #32 #32 #32 #32
	DATs _____ THRESHOLD ______   _______ BANDS ________
	DATi #0
.s_00FFlo4d4:	CNST *53
	DATi #32 #32 #32 #32 #32 #32 #32 #32 #32 #32 #32
	DATs 00 -> FF           low      mid      high
	DATi #0
.s_DECAYP4d5:	CNST *53
	DATi #32 #32 #32 #32 #32
	DATs ________ DECAY _______   ______ PARTIALS ______
	DATi #0
.s_00FFx14d6:	CNST *53
	DATi #32 #32 #32 #32 #32 #32 #32 #32 #32 #32 #32 #32
	DATs 00 -> FF         x1 x2 x3 x4 x5 x6 x7 x8
	DATi #0
.s_Divisi4d7:	CNST *17
	DATs Division by zero
	DATi #0
.s_Domain4d8:	CNST *13
	DATs Domain error
	DATi #0
.s_init4d9:	CNST *5
	DATs init
	DATi #0
.s_reset4da:	CNST *6
	DATs reset
	DATi #0
.s_update4db:	CNST *7
	DATs update
	DATi #0