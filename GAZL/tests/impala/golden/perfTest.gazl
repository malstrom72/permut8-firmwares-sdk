PRAWN_FIRMWARE_PATCH_FORMAT:	! DEFi #1
LOG2:	! DEFf #0.69314718055994530942
LOG2R:	! DEFf #1.44269504088896340736
LOG10R:	! DEFf #0.43429448190325182765
E:	! DEFf #2.71828182845904523536
HALF_PI:	! DEFf #1.57079632679489661923
PI:	! DEFf #3.14159265358979323846
	! MULf <A> #PI #2.0
TWICE_PI:	! DEFf <A>
COS_EPSILON:	! DEFf #1.0e-6
FALSE:	! DEFi #0
TRUE:	! DEFi #1

;-----------------------------------------------------------------------------
error:	FUNC
		PARA *1
	$s:	INPp
;-----------------------------------------------------------------------------
		EQUp $s &NULL @.f0	; if (s != null) 
		MOVp %1 &.s_Error4d2 	; print("Error: ")
		CALL ^print %0 *2
		MOVp %1 $s 	; print(s)
		CALL ^print %0 *2
		CALL ^abort %0 *1	; abort()
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
exp:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		ABSf $m $x 	; m = abs(x)
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $a $m	; a = a * m / n
		DIVf $a %0 $n
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l0	; } while (y != t)
		GEQf $x #0.0 @.f1	; if (x < 0.0) y = 1.0 / y
		DIVf $y #1.0 $y	; y = 1.0 / y
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
log:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$b:	LOCf
	$m:	LOCf
	$n:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		LEQf $x #0.0 @.t0	; if (x <= 0.0 || x >= 1.0e38) error("Domain error")
		LSSf $x #1.0e38 @.f1
	.t0:	MOVp %1 &.s_Domain4d3 	; error("Domain error")
		CALL &error %0 *2
		GOTO @.e2  
	.f1:	MOVf $b #0.0 	; b = 0.0
		MOVf $m $x 	; m = x
	.l3:	GEQf $m #0.5 @.e4	; while (m < 0.5) 
		MULf $m $m #2.0	; m = m * 2.0
		SUBf $b $b #LOG2	; b = b - LOG2
		GOTO @.l3  	; }
	.e4:	NOOP
	.l5:	LEQf $m #1.5 @.e6	; while (m > 1.5) 
		MULf $m $m #0.5	; m = m * 0.5
		ADDf $b $b #LOG2	; b = b + LOG2
		GOTO @.l5  	; }
	.e6:	SUBf $m #1.0 $m	; m = 1.0 - m
		MOVf $a #-1.0 	; a = -1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #0.0 	; y = 0.0
	.l7:	MOVf $t $y 	; t = y
		MULf $a $a $m	; a = a * m
		DIVf %0 $a $n	; y = y + a / n
		ADDf $y $y %0
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l7	; } while (y != t)
		ADDf $y $y $b	; y = y + b
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
log2:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float)log(x) * LOG2R
		CALL &log %0 *2
		MULf $y %0 #LOG2R
		RETU   	; }


;-----------------------------------------------------------------------------
log10:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float)log(x) * LOG10R
		CALL &log %0 *2
		MULf $y %0 #LOG10R
		RETU   	; }


;-----------------------------------------------------------------------------
trunc:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		GEQf $x #0.0 @.f0	; if (x < 0.0) y = -floor(-x)
		SUBf %0 #0.0 $x	; y = -floor(-x)
		FLOf %0 %0 
		SUBf $y #0.0 %0
		GOTO @.e1  
	.f0:	FLOf $y $x 	; y = floor(x)
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
fmod:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
;-----------------------------------------------------------------------------
		NEQf $y #0.0 @.f0	; if (y == 0.0) error("Division by zero")
		MOVp %1 &.s_Divisi4d4 	; error("Division by zero")
		CALL &error %0 *2
		GOTO @.e1  
	.f0:	DIVf %1 $x $y	; z = x - (float)trunc(x / y) * y
		CALL &trunc %0 *2
		MULf %0 %0 $y
		SUBf $z $x %0
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
cos:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; m = (float)fmod(x, TWICE_PI)
		MOVf %2 #TWICE_PI 
		CALL &fmod %0 *3
		MOVf $m %0 
		SUBf %0 #0.0 $m	; m = -m * m
		MULf $m %0 $m
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $n $n	; a = a * m / (n * n + n)
		MULf %1 $a $m
		ADDf %0 %0 $n
		DIVf $a %1 %0
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #2.0	; n = n + 2.0
		NEQf $y $t @.l0	; } while (y != t)
		ABSf %1 $y 	; if (abs(y) < COS_EPSILON) y = 0.0
		GEQf %1 #COS_EPSILON @.f1
		MOVf $y #0.0 	; y = 0.0
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
sin:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		SUBf %1 $x #HALF_PI	; y = (float)cos(x - HALF_PI)
		CALL &cos %0 *2
		MOVf $y %0 
		RETU   	; }


;-----------------------------------------------------------------------------
tan:	FUNC
	$y:	OUTf
	$x:	INPf
	$c:	LOCf
;-----------------------------------------------------------------------------
		MOVf $y #0.0 	; y = 0.0
		MOVf %1 $x 	; c = (float)cos(x)
		CALL &cos %0 *2
		MOVf $c %0 
		NEQf $c #0.0 @.f0	; if (c == 0.0) error("Domain error")
		MOVp %1 &.s_Domain4d3 	; error("Domain error")
		CALL &error %0 *2
		GOTO @.e1  
	.f0:	MOVf %1 $x 	; y = (float)sin(x) / c
		CALL &sin %0 *2
		DIVf $y %0 $c
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
pow:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
	$a:	LOCf
;-----------------------------------------------------------------------------
		MOVf $z #0.0 	; z = 0.0
		MOVf $a $x 	; a = x
		GEQf $a #0.0 @.f1	; if (a < 0.0 && y == floor(y)) a = -a
		FLOf %0 $y 
		NEQf $y %0 @.f1
		SUBf $a #0.0 $a	; a = -a
	.f1:	LEQf $a #0.0 @.f2	; if (a > 0.0) z = (float)exp((float)log(a) * y)
		MOVf %2 $a 	; z = (float)exp((float)log(a) * y)
		CALL &log %1 *2
		MULf %1 %1 $y
		CALL &exp %0 *2
		MOVf $z %0 
		GOTO @.e3  
	.f2:	LSSf $a #0.0 @.t4	; if (a < 0.0 || y <= 0.0) error("Domain error")
		GRTf $y #0.0 @.f5
	.t4:	MOVp %1 &.s_Domain4d3 	; error("Domain error")
		CALL &error %0 *2
	.f5:	NOOP
	.e3:	EQUf $a $x @.f7	; if (a != x && (y * 0.5) != floor(y * 0.5)) z = -z
		MULf %0 $y #0.5
		MULf %1 $y #0.5
		FLOf %0 %0 
		EQUf %1 %0 @.f7
		SUBf $z #0.0 $z	; z = -z
	.f7:	RETU   	; }


;-----------------------------------------------------------------------------
ceil:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		SUBf %1 #0.0 $x	; y = -floor(-x)
		FLOf %1 %1 
		SUBf $y #0.0 %1
		RETU   	; }


;-----------------------------------------------------------------------------
sqrt:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float)pow(x, 0.5)
		MOVf %2 #0.5 
		CALL &pow %0 *3
		MOVf $y %0 
		RETU   	; }

gGlobalState:	GLOB *14

;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
	$fpi:	LOCf
	$rq:	LOCf
	$dxL:	LOCf
	$d0L:	LOCf
	$d1L:	LOCf
	$d2L:	LOCf
	$d3L:	LOCf
	$gL:	LOCf
	$dxR:	LOCf
	$d0R:	LOCf
	$d1R:	LOCf
	$d2R:	LOCf
	$d3R:	LOCf
	$gR:	LOCf
	$r:	LOCf
	$k:	LOCf
	$g0:	LOCf
	$dxzL:	LOCf
	$d0zL:	LOCf
	$d1zL:	LOCf
	$d2zL:	LOCf
	$d3zL:	LOCf
	$dxzR:	LOCf
	$d0zR:	LOCf
	$d1zR:	LOCf
	$d2zR:	LOCf
	$d3zR:	LOCf
	$left:	LOCf
	$right:	LOCf
	$i:	LOCi
;-----------------------------------------------------------------------------
		MOVf $d3zL #0.0 	; dxzL = d0zL = d1zL = d2zL = d3zL = 0.0
		MOVf $d2zL #0.0 
		MOVf $d1zL #0.0 
		MOVf $d0zL #0.0 
		MOVf $dxzL #0.0 
		MOVf $d3zR #0.0 	; dxzR = d0zR = d1zR = d2zR = d3zR = 0.0
		MOVf $d2zR #0.0 
		MOVf $d1zR #0.0 
		MOVf $d0zR #0.0 
		MOVf $dxzR #0.0 
		! DIVf <A> #1.0 #255.0	; rq = itof(55) * (1.0 / 255.0 * 2.0)
		! MULf <A> <A> #2.0
		! iTOf <A> #55 <A>
		MOVf $rq <A> 
		! DIVf <A> #1.0 #256.0	; fpi = itof(102) * (1.0 / 256.0 * 0.5 * PI)
		! MULf <A> <A> #0.5
		! MULf <A> <A> #PI
		! iTOf <A> #102 <A>
		MOVf $fpi <A> 
		SUBf %0 #4.0 $rq	; r = (4.0 - rq) / (1.0 + rq)
		ADDf %1 #1.0 $rq
		DIVf $r %0 %1
		MOVf %1 $fpi 	; k = ((float) sin(fpi)) / ((float) cos(fpi) + (float) sin(fpi))
		CALL &sin %0 *2
		MOVf %2 $fpi 
		CALL &cos %1 *2
		MOVf %3 $fpi 
		CALL &sin %2 *2
		ADDf %1 %1 %2
		DIVf $k %0 %1
		MULf %0 $r $k	; g0 = r / (1.0 + r * k * k * k * k)
		MULf %0 %0 $k
		MULf %0 %0 $k
		MULf %0 %0 $k
		ADDf %0 #1.0 %0
		DIVf $g0 $r %0
		ADDf $r #1.0 $r	; r = (1.0 + r)
		MOVi $i #0 	; for (i = 0 to 44100) 
		GEQi #0 #44100 @.e0
	.l1:	ADRL %0 $r *0	; copy (13 from global gGlobalState to &r)
		COPY %0 &gGlobalState *13
		MOVf $left #0.5 	; left = 0.5
		MOVf $right #0.5 	; right = 0.5
		MULf %0 $left $r	; dxL = 0.5 * (dxzL + left * r)
		ADDf %0 $dxzL %0
		MULf $dxL #0.5 %0
		SUBf %0 $dxL $d0zL	; d0L = d0zL + k * (dxL - d0zL)
		MULf %0 $k %0
		ADDf $d0L $d0zL %0
		SUBf %0 $d0L $d1zL	; d1L = d1zL + k * (d0L - d1zL)
		MULf %0 $k %0
		ADDf $d1L $d1zL %0
		SUBf %0 $d1L $d2zL	; d2L = d2zL + k * (d1L - d2zL)
		MULf %0 $k %0
		ADDf $d2L $d2zL %0
		SUBf %0 $d2L $d3zL	; d3L = d3zL + k * (d2L - d3zL)
		MULf %0 $k %0
		ADDf $d3L $d3zL %0
		ADDf %0 $d3L $d3L	; gL = g0 * (d3L + d3L - d3zL)
		SUBf %0 %0 $d3zL
		MULf $gL $g0 %0
		ADDf %0 $dxL $dxL	; dxzL = dxL + dxL - dxzL - gL
		SUBf %0 %0 $dxzL
		SUBf $dxzL %0 $gL
		MULf $gL $gL $k	; gL = gL * k
		ADDf %0 $d0L $d0L	; d0zL = d0L + d0L - d0zL - gL
		SUBf %0 %0 $d0zL
		SUBf $d0zL %0 $gL
		MULf $gL $gL $k	; gL = gL * k
		ADDf %0 $d1L $d1L	; d1zL = d1L + d1L - d1zL - gL
		SUBf %0 %0 $d1zL
		SUBf $d1zL %0 $gL
		MULf $gL $gL $k	; gL = gL * k
		ADDf %0 $d2L $d2L	; d2zL = d2L + d2L - d2zL - gL
		SUBf %0 %0 $d2zL
		SUBf $d2zL %0 $gL
		MULf $gL $gL $k	; gL = gL * k
		ADDf %0 $d3L $d3L	; d3zL = d3L + d3L - d3zL - gL
		SUBf %0 %0 $d3zL
		SUBf $d3zL %0 $gL
		MULf %0 $right $r	; dxR = 0.5 * (dxzR + right * r)
		ADDf %0 $dxzR %0
		MULf $dxR #0.5 %0
		SUBf %0 $dxR $d0zR	; d0R = d0zR + k * (dxR - d0zR)
		MULf %0 $k %0
		ADDf $d0R $d0zR %0
		SUBf %0 $d0R $d1zR	; d1R = d1zR + k * (d0R - d1zR)
		MULf %0 $k %0
		ADDf $d1R $d1zR %0
		SUBf %0 $d1R $d2zR	; d2R = d2zR + k * (d1R - d2zR)
		MULf %0 $k %0
		ADDf $d2R $d2zR %0
		SUBf %0 $d2R $d3zR	; d3R = d3zR + k * (d2R - d3zR)
		MULf %0 $k %0
		ADDf $d3R $d3zR %0
		ADDf %0 $d3R $d3R	; gR = g0 * (d3R + d3R - d3zR)
		SUBf %0 %0 $d3zR
		MULf $gR $g0 %0
		ADDf %0 $dxR $dxR	; dxzR = dxR + dxR - dxzR - gR
		SUBf %0 %0 $dxzR
		SUBf $dxzR %0 $gR
		MULf $gR $gR $k	; gR = gR * k
		ADDf %0 $d0R $d0R	; d0zR = d0R + d0R - d0zR - gR
		SUBf %0 %0 $d0zR
		SUBf $d0zR %0 $gR
		MULf $gR $gR $k	; gR = gR * k
		ADDf %0 $d1R $d1R	; d1zR = d1R + d1R - d1zR - gR
		SUBf %0 %0 $d1zR
		SUBf $d1zR %0 $gR
		MULf $gR $gR $k	; gR = gR * k
		ADDf %0 $d2R $d2R	; d2zR = d2R + d2R - d2zR - gR
		SUBf %0 %0 $d2zR
		SUBf $d2zR %0 $gR
		MULf $gR $gR $k	; gR = gR * k
		ADDf %0 $d3R $d3R	; d3zR = d3R + d3R - d3zR - gR
		SUBf %0 %0 $d3zR
		SUBf $d3zR %0 $gR
		ADRL %0 $dxzL *0	; copy (10 from &dxzL to &global gGlobalState[3])
		COPY &gGlobalState:3 %0 *10
		FORi $i #44100 @.l1	; }
	.e0:	RETU   	; }

.s_Error4d2:	CNST *8
	DATs Error:
	DATi #32 #0
.s_Domain4d3:	CNST *13
	DATs Domain error
	DATi #0
.s_Divisi4d4:	CNST *17
	DATs Division by zero
	DATi #0