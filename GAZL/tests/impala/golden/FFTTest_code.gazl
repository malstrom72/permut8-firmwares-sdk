complexFFT:	FUNC
		PARA *1
	$n:	INPi
	$data:	INPp
	$i:	LOCi
	$j:	LOCi
	$m:	LOCi
	$mmax:	LOCi
	$theta:	LOCf
	$rx:	LOCf
	$ry:	LOCf
	$px:	LOCf
	$py:	LOCf
	$nx:	LOCf
	$ny:	LOCf
	$tr:	LOCf
	$ti:	LOCf
	$tmp:	LOCA *2
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(n >= 2 && (n & (n - 1)) == 0)
		LSSi $n #2 @.f1
		SUBi %0 $n #1
		ANDi %0 $n %0
		EQUi %0 #0 @.a0
	.f1:	MOVp %1 &.a_n2nn104d5 
		CALL ^assertFail %0 *1
	.a0:	MOVi $j #1 	; j = 1
		MOVi $i #1 	; i = 1
	.l2:	GEQi $i $n @.e3	; while (i < n) 
		LEQi $j $i @.f4	; if (j > i) 
		SUBi %0 $j #1	; tmp[0] = data[j - 1]
		PEEK $tmp:0 $data %0
		PEEK $tmp:1 $data $j	; tmp[1] = data[j]
		SUBi %0 $j #1	; data[j - 1] = data[i - 1]
		SUBi %1 $i #1
		PEEK %1 $data %1
		POKE $data %0 %1
		PEEK %1 $data $i	; data[j] = data[i]
		POKE $data $j %1
		SUBi %1 $i #1	; data[i - 1] = tmp[0]
		POKE $data %1 $tmp:0
		POKE $data $i $tmp:1	; data[i] = tmp[1]
	.f4:	SHRi $m $n #1	; m = n >> 1
	.l5:	LSSi $m #2 @.e7	; while (m >= 2 && j > m) 
		LEQi $j $m @.e7
		SUBi $j $j $m	; j = j - m
		SHRi $m $m #1	; m = m >> 1
		GOTO @.l5  	; }
	.e7:	ADDi $j $j $m	; j = j + m
		ADDi $i $i #2	; i = i + 2
		GOTO @.l2  	; }
	.e3:	MOVi $mmax #2 	; mmax = 2
	.l8:	GEQi $mmax $n @.e9	; while (mmax < n) 
		! MULf <A> #-2.0 #PI	; theta = -2.0 * PI / itof(mmax)
		iTOf %1 $mmax #1.0
		DIVf $theta <A> %1
		MULf %2 $theta #0.5	; rx = 2.0 * (float) square((float) sin(theta * 0.5))
		CALL &sin %1 *2
		CALL &square %0 *2
		MULf $rx #2.0 %0
		MOVf %1 $theta 	; ry = (float) sin(theta)
		CALL &sin %0 *2
		MOVf $ry %0 
		MOVf $px #1.0 	; px = 1.0
		MOVf $py #0.0 	; py = 0.0
		MOVi $m #0 	; m = 0
	.l10:	GEQi $m $mmax @.e11	; while (m < mmax) 
		MOVi $i $m 	; i = m
	.l12:	GEQi $i $n @.e13	; while (i < n) 
		ADDi $j $i $mmax	; j = i + mmax
		ADDi %0 $j #0	; tr = px * (float) data[j + 0] - py * (float) data[j + 1]
		PEEK %0 $data %0
		ADDi %1 $j #1
		PEEK %1 $data %1
		MULf %0 $px %0
		MULf %1 $py %1
		SUBf $tr %0 %1
		ADDi %0 $j #1	; ti = px * (float) data[j + 1] + py * (float) data[j + 0]
		PEEK %0 $data %0
		ADDi %1 $j #0
		PEEK %1 $data %1
		MULf %0 $px %0
		MULf %1 $py %1
		ADDf $ti %0 %1
		ADDi %0 $j #0	; data[j + 0] = (float) data[i + 0] - tr
		ADDi %1 $i #0
		PEEK %1 $data %1
		SUBf %1 %1 $tr
		POKE $data %0 %1
		ADDi %1 $j #1	; data[j + 1] = (float) data[i + 1] - ti
		ADDi %0 $i #1
		PEEK %0 $data %0
		SUBf %0 %0 $ti
		POKE $data %1 %0
		ADDi %0 $i #0	; data[i + 0] = (float) data[i + 0] + tr
		ADDi %1 $i #0
		PEEK %1 $data %1
		ADDf %1 %1 $tr
		POKE $data %0 %1
		ADDi %1 $i #1	; data[i + 1] = (float) data[i + 1] + ti
		ADDi %0 $i #1
		PEEK %0 $data %0
		ADDf %0 %0 $ti
		POKE $data %1 %0
		SHLi %0 $mmax #1	; i = i + (mmax << 1)
		ADDi $i $i %0
		GOTO @.l12  	; }
	.e13:	MULf %0 $px $rx	; nx = px - px * rx - py * ry
		SUBf %0 $px %0
		MULf %1 $py $ry
		SUBf $nx %0 %1
		MULf %0 $px $ry	; ny = px * ry + py - py * rx
		ADDf %0 %0 $py
		MULf %1 $py $rx
		SUBf $ny %0 %1
		MOVf $px $nx 	; px = nx
		MOVf $py $ny 	; py = ny
		ADDi $m $m #2	; m = m + 2
		GOTO @.l10  	; }
	.e11:	SHLi $mmax $mmax #1	; mmax = mmax << 1
		GOTO @.l8  	; }
	.e9:	RETU   	; }


;-----------------------------------------------------------------------------
realFFT:	FUNC
		PARA *1
	$n:	INPi
	$input:	INPp
	$output:	INPp
	$i:	LOCi
	$j:	LOCi
	$r0:	LOCf
	$i0:	LOCf
	$r1:	LOCf
	$i1:	LOCf
	$theta:	LOCf
	$rx:	LOCf
	$ry:	LOCf
	$px:	LOCf
	$py:	LOCf
	$nx:	LOCf
	$ny:	LOCf
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(n >= 2 && (n & (n - 1)) == 0)
		LSSi $n #2 @.f1
		SUBi %0 $n #1
		ANDi %0 $n %0
		EQUi %0 #0 @.a0
	.f1:	MOVp %1 &.a_n2nn104d5 
		CALL ^assertFail %0 *1
	.a0:	NOOP
		! EQUi #DEBUG #0 @.a2	; assert(output != input)
		NEQp $output $input @.a2
		MOVp %1 &.a_output4d6 
		CALL ^assertFail %0 *1
	.a2:	MOVi %1 $n 	; complexFFT(n, input)
		MOVp %2 $input 
		CALL &complexFFT %0 *3
		PEEK $r0 $input #0	; r0 = (float) input[0]
		PEEK $i0 $input #1	; i0 = (float) input[1]
		ADDf %0 $r0 $i0	; output[0] = (r0 + i0)
		POKE $output #0 %0
		SUBf %0 $i0 $r0	; output[1] = (i0 - r0)
		POKE $output #1 %0
		! MULf <A> #2.0 #PI	; theta = 2.0 * PI / itof(n)
		iTOf %0 $n #1.0
		DIVf $theta <A> %0
		MULf %2 $theta #0.5	; rx = 2.0 * (float) square((float) sin(theta * 0.5))
		CALL &sin %1 *2
		CALL &square %0 *2
		MULf $rx #2.0 %0
		MOVf %1 $theta 	; ry = (float) sin(theta)
		CALL &sin %0 *2
		MOVf $ry %0 
		MOVf $px #1.0 	; px = 1.0
		MOVf $py #0.0 	; py = 0.0
		SUBi $j $n #2	; j = n - 2
		MOVi $i #2 	; i = 2
	.l3:	GEQi $i $n @.e4	; while (i < n) 
		MULf %0 $px $rx	; nx = px - px * rx - py * ry
		SUBf %0 $px %0
		MULf %1 $py $ry
		SUBf $nx %0 %1
		MULf %0 $px $ry	; ny = px * ry + py - py * rx
		ADDf %0 %0 $py
		MULf %1 $py $rx
		SUBf $ny %0 %1
		MOVf $px $nx 	; px = nx
		MOVf $py $ny 	; py = ny
		ADDi %0 $i #0	; r0 = (float) input[i + 0]
		PEEK $r0 $input %0
		ADDi %0 $i #1	; i0 = (float) input[i + 1]
		PEEK $i0 $input %0
		ADDi %0 $j #0	; r1 = (float) input[j + 0]
		PEEK $r1 $input %0
		ADDi %0 $j #1	; i1 = (float) input[j + 1]
		PEEK $i1 $input %0
		ADDi %0 $i #0	; output[i + 0] = 0.5 * (r0 - r0 * py + i0 * px + r1 + r1 * py + i1 * px)
		MULf %1 $r0 $py
		SUBf %1 $r0 %1
		MULf %2 $i0 $px
		ADDf %1 %1 %2
		ADDf %1 %1 $r1
		MULf %2 $r1 $py
		ADDf %1 %1 %2
		MULf %2 $i1 $px
		ADDf %1 %1 %2
		MULf %1 #0.5 %1
		POKE $output %0 %1
		ADDi %1 $i #1	; output[i + 1] = 0.5 * (i0 - i0 * py - r0 * px + r1 * px - i1 - i1 * py)
		MULf %0 $i0 $py
		SUBf %0 $i0 %0
		MULf %2 $r0 $px
		SUBf %0 %0 %2
		MULf %2 $r1 $px
		ADDf %0 %0 %2
		SUBf %0 %0 $i1
		MULf %2 $i1 $py
		SUBf %0 %0 %2
		MULf %0 #0.5 %0
		POKE $output %1 %0
		SUBi $j $j #2	; j = j - 2
		ADDi $i $i #2	; i = i + 2
		GOTO @.l3  	; }
	.e4:	RETU   	; }


;-----------------------------------------------------------------------------
exp:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		ABSf $m $x 	; m = abs(x)
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $a $m	; a = a * m / n
		DIVf $a %0 $n
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l0	; } while (y != t)
		GEQf $x #0.0 @.f1	; if (x < 0.0) y = 1.0 / y
		DIVf $y #1.0 $y	; y = 1.0 / y
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
log:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$b:	LOCf
	$m:	LOCf
	$n:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		LEQf $x #0.0 @.t0	; if (x <= 0.0 || x >= 1.0e38) error("Domain error")
		LSSf $x #1.0e38 @.f1
	.t0:	MOVp %1 &.s_Domain4d8 	; error("Domain error")
		CALL &error %0 *2
		GOTO @.e2  
	.f1:	MOVf $b #0.0 	; b = 0.0
		MOVf $m $x 	; m = x
	.l3:	GEQf $m #0.5 @.e4	; while (m < 0.5) 
		MULf $m $m #2.0	; m = m * 2.0
		SUBf $b $b #LOG2	; b = b - LOG2
		GOTO @.l3  	; }
	.e4:	NOOP
	.l5:	LEQf $m #1.5 @.e6	; while (m > 1.5) 
		MULf $m $m #0.5	; m = m * 0.5
		ADDf $b $b #LOG2	; b = b + LOG2
		GOTO @.l5  	; }
	.e6:	SUBf $m #1.0 $m	; m = 1.0 - m
		MOVf $a #-1.0 	; a = -1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #0.0 	; y = 0.0
	.l7:	MOVf $t $y 	; t = y
		MULf $a $a $m	; a = a * m
		DIVf %0 $a $n	; y = y + a / n
		ADDf $y $y %0
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l7	; } while (y != t)
		ADDf $y $y $b	; y = y + b
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
pow:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
	$a:	LOCf
;-----------------------------------------------------------------------------
		MOVf $z #0.0 	; z = 0.0
		MOVf $a $x 	; a = x
		GEQf $a #0.0 @.f1	; if (a < 0.0 && y == floor(y)) a = -a
		FLOf %0 $y 
		NEQf $y %0 @.f1
		SUBf $a #0.0 $a	; a = -a
	.f1:	LEQf $a #0.0 @.f2	; if (a > 0.0) z = (float) exp((float) log(a) * y)
		MOVf %2 $a 	; z = (float) exp((float) log(a) * y)
		CALL &log %1 *2
		MULf %1 %1 $y
		CALL &exp %0 *2
		MOVf $z %0 
		GOTO @.e3  
	.f2:	LSSf $a #0.0 @.t4	; if (a < 0.0 || y <= 0.0) error("Domain error")
		GRTf $y #0.0 @.f5
	.t4:	MOVp %1 &.s_Domain4d8 	; error("Domain error")
		CALL &error %0 *2
	.f5:	NOOP
	.e3:	EQUf $a $x @.f7	; if (a != x && (y * 0.5) != floor(y * 0.5)) z = -z
		MULf %0 $y #0.5
		MULf %1 $y #0.5
		FLOf %0 %0 
		EQUf %1 %0 @.f7
		SUBf $z #0.0 $z	; z = -z
	.f7:	RETU   	; }


;-----------------------------------------------------------------------------
sqrt:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float) pow(x, 0.5)
		MOVf %2 #0.5 
		CALL &pow %0 *3
		MOVf $y %0 
		RETU   	; }


;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
	$i:	LOCi
	$buf:	LOCA *256
;-----------------------------------------------------------------------------
		MOVp %1 &.s_init4d9 	; trace("init")
		CALL ^trace %0 *2
		PEEK %2 &instance 	; trace(intToString(global instance, 10, 1, buf))
		MOVi %3 #10 
		MOVi %4 #1 
		ADRL %5 $buf *0
		CALL &intToString %1 *5
		CALL ^trace %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
reset:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		MOVp %1 &.s_reset4da 	; trace("reset")
		CALL ^trace %0 *2
		MOVp %1 &.s_params4db 	; traceInts(" params: ", PARAM_COUNT, global params)
		MOVi %2 #PARAM_COUNT 
		MOVp %3 &params 
		CALL &traceInts %0 *4
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$buf:	LOCA *256
	$params:	LOCA *PARAM_COUNT
;-----------------------------------------------------------------------------
		RETU   	; }


;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	$idx:	LOCi
	$maxI:	LOCi
	$i:	LOCi
	$out:	LOCi
	$fftInput:	LOCA *512
	$fftOutput:	LOCA *512
	$ph:	LOCf
	$rate:	LOCf
	$a:	LOCf
	$x:	LOCf
	$y:	LOCf
	$maxY:	LOCf
	$targetA:	LOCf
;-----------------------------------------------------------------------------
		MOVf $ph #0.0 	; ph = 0.0
		MOVf $rate #0.0 	; rate = 0.0
		MOVf $targetA #0.0 	; targetA = 0.0
	.l0:	MOVi $idx #0 	; for (idx = 0 to 512) 
		GEQi #0 #512 @.e1
	.l2:	PEEK %0 &signal:0 	; fftInput[idx] = itof(((int) global signal[0] + (int) global signal[1])) * (1.0 / 4096.0)
		PEEK %1 &signal:1 
		ADDi %0 %0 %1
		! DIVf <A> #1.0 #4096.0
		iTOf %0 %0 <A>
		SETL $fftInput $idx %0
		ADDf $ph $ph $rate	; ph = ph + rate
	.l3:	NOOP
		! MULf <A> #2.0 #PI	; while (ph >= (2.0 * PI)) 
		LSSf $ph <A> @.e4
		! MULf <A> #2.0 #PI	; ph = ph - (2.0 * PI)
		SUBf $ph $ph <A>
		GOTO @.l3  	; }
	.e4:	SUBf %0 $targetA $a	; a = a + (targetA - a) * rate * 0.1
		MULf %0 %0 $rate
		MULf %0 %0 #0.1
		ADDf $a $a %0
		MOVf %1 $ph 	; out = ftoi((float) sin(ph) * a * 2047.0)
		CALL &sin %0 *2
		MULf %0 %0 $a
		fTOi $out %0 #2047.0
		POKE &signal:0 $out 	; global signal[0] = out
		POKE &signal:1 $out 	; global signal[1] = out
		NEQi $idx #256 @.f5	; if (idx == 256) 
		MOVf $maxY #-1.0 	; maxY = -1.0
		MOVi $maxI #-1 	; maxI = -1
		MOVi $i #1 	; for (i = 1 to 256) 
		GEQi #1 #256 @.e6
	.l7:	MULi %0 $i #2	; x = (float) fftOutput[i * 2 + 0]
		ADDi %0 %0 #0
		GETL $x $fftOutput %0
		MULi %0 $i #2	; y = (float) fftOutput[i * 2 + 1]
		ADDi %0 %0 #1
		GETL $y $fftOutput %0
		MULf %0 $x $x	; y = x * x + y * y
		MULf %1 $y $y
		ADDf $y %0 %1
		LEQf $y $maxY @.f8	; if (y > maxY) 
		MOVf $maxY $y 	; maxY = y
		MOVi $maxI $i 	; maxI = i
	.f8:	FORi $i #256 @.l7	; }
	.e6:	NOOP
		! MULf <A> #2.0 #PI	; rate = itof(maxI) / (512.0 / (2.0 * PI)) * 0.5
		iTOf %0 $maxI #1.0
		! DIVf <A> #512.0 <A>
		DIVf %0 %0 <A>
		MULf $rate %0 #0.5
	.f5:	NEQi $idx #384 @.f9	; if (idx == 384) 
		DIVf %1 $maxY #512.0	; targetA = (float) sqrt(maxY / 512.0)
		CALL &sqrt %0 *2
		MOVf $targetA %0 
	.f9:	CALL ^yield %0 *1	; yield()
		FORi $idx #512 @.l2	; }
	.e1:	MOVi %1 #512 	; realFFT(512, fftInput, fftOutput)
		ADRL %2 $fftInput *0
		ADRL %3 $fftOutput *0
		CALL &realFFT %0 *4
		GOTO @.l0  	; }
		RETU   	; }

.s_Sillyr4d2:	CNST *52
	DATi #32 #32 #32
	DATs Silly ring-modulator firmware demo by M Lidstrom
	DATi #0
.s_4d3:	CNST *2
	DATi #32 #0
.s_LEFTDE4d4:	CNST *54
	DATi #32 #32 #32 #32
	DATs |----- LEFT DELAY -----| |----- RIGHT DELAY ----|
	DATi #0
.s_RINGMO4d5:	CNST *54
	DATi #32 #32 #32 #32
	DATs |--- RING MOD RATE ----| |---- STEREO PHASE ----|
	DATi #0
.s_fedcba4d6:	CNST *32
	DATs fedcba9876543210123456789abcdef
	DATi #0
.s_Divisi4d7:	CNST *17
	DATs Division by zero
	DATi #0
.s_Domain4d8:	CNST *13
	DATs Domain error
	DATi #0
.s_init4d9:	CNST *5
	DATs init
	DATi #0
.s_reset4da:	CNST *6
	DATs reset
	DATi #0
.s_params4db:	CNST *10
	DATi #32
	DATs params:
	DATi #32 #0
	! EQUi #DEBUG #0 @.noAssertStrings
.a_2radix4d2:	CNST *28
	DATs (2 <= radix && radix <= 16)
	DATi #0
.a_0minLe4d3:	CNST *48
	DATs (0 <= minLength && minLength <= GAZL_WORD_SIZE)
	DATi #0
.a_pbuffe4d4:	CNST *18
	DATs (p >= buffer + 2)
	DATi #0
.a_n2nn104d5:	CNST *31
	DATs (n >= 2 && (n & (n - 1)) == 0)
	DATi #0
.a_output4d6:	CNST *18
	DATs (output != input)
	DATi #0
.noAssertStrings:	!