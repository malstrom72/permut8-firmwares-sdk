;-----------------------------------------------------------------------------
cos:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; m = (float) fmod(x, TWICE_PI)
