		MOVf $a #1.0 
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $n $n	; a = a * m / (n * n + n)
		MULf %1 $a $m
		ADDf %0 %0 $n
		DIVf $a %1 %0
