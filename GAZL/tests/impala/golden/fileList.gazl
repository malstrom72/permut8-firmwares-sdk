FILE_TYPE_COUNT:	! DEFi #4
FILE_TYPE_EXE:	! DEFi #0
FILE_TYPE_SYS:	! DEFi #1
FILE_TYPE_TXT:	! DEFi #2
FILE_TYPE_BIN:	! DEFi #3
FILE_TYPE_STRINGS:	CNST *FILE_TYPE_COUNT
	DATA &.s_exe4d2 &.s_sys4d3 &.s_txt4d4 &.s_bin4d5
FILE_FIELD_NAME:	! DEFi #0
FILE_FIELD_TYPE:	! DEFi #1
FILE_FIELD_SIZE:	! DEFi #2
FILE_FIELD_DATE:	! DEFi #3
FILE_FIELD_COUNT:	! DEFi #4
MAX_FILE_COUNT:	! DEFi #100
MAX_FILE_NAME_LENGTH:	! DEFi #31
BUILT_IN_FILE_COUNT:	! DEFi #14
	GLOB *1
fileCount:	DATi #BUILT_IN_FILE_COUNT
	! MULi <A> #MAX_FILE_COUNT #FILE_FIELD_COUNT
FILES:	GLOB *<A>
	DATA &.s_about4d6 #FILE_TYPE_TXT #2 &.s_1113844d7
	DATA &.s_advent4d8 #FILE_TYPE_EXE #91 &.s_221784d9
	DATA &.s_blupri4da #FILE_TYPE_TXT #2 &.s_65794db
	DATA &.s_calc4dc #FILE_TYPE_EXE #7 &.s_1125774dd
	DATA &.s_chess4de #FILE_TYPE_EXE #16 &.s_36844df
	DATA &.s_disasm4e0 #FILE_TYPE_EXE #4 &.s_1125774dd
	DATA &.s_fredri4e1 #FILE_TYPE_TXT #5 &.s_714844e2
	DATA &.s_life4e3 #FILE_TYPE_EXE #5 &.s_312794e4
	DATA &.s_magnus4e5 #FILE_TYPE_TXT #5 &.s_622844e6
	DATA &.s_patch4e7 #FILE_TYPE_EXE #3 &.s_218844e8
	DATA &.s_permut4e9 #FILE_TYPE_SYS #82 &.s_31834ea
	DATA &.s_prawno4eb #FILE_TYPE_SYS #58 &.s_1011844ec
	DATA &.s_readme4ed #FILE_TYPE_TXT #2 &.s_1214794ee
	DATA &.s_versio4ef #FILE_TYPE_TXT #1 &.s_1113844d7
	! ADDi <A> #MAX_FILE_NAME_LENGTH #1
	! MULi <A> #MAX_FILE_COUNT <A>
FILE_NAMES:	GLOB *<A>
	! MULi <A> #MAX_FILE_COUNT #9
FILE_DATES:	GLOB *<A>
	GLOB *1
filesAreInited:	DATi #0

;-----------------------------------------------------------------------------
strcmp:	FUNC
	$d:	OUTi
	$s0:	INPp
	$s1:	INPp
	$a:	LOCp
	$b:	LOCp
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVp $a $s0 	; a = s0
		MOVp $b $s1 	; b = s1
	.l0:	PEEK $c $a 	; while ((d = (c = (int)*a) - (int)*b) == 0 && c != 0) 
		PEEK %0 $b 
		SUBi $d $c %0
		NEQi $d #0 @.e2
		EQUi $c #0 @.e2
		ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		GOTO @.l0  	; }
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
sortFiles:	FUNC
		PARA *1
	$i:	LOCi
	$j:	LOCi
	$minJ:	LOCi
	$minS:	LOCp
	$s:	LOCp
	$temp:	LOCA *FILE_FIELD_COUNT
	$p0:	LOCp
	$p1:	LOCp
;-----------------------------------------------------------------------------
		MOVi $i #0 	; for (i = 0 to global fileCount - 1) 
		PEEK %0 &fileCount 
		SUBi %0 %0 #1
		GEQi #0 %0 @.e0
	.l1:	MOVi $minJ $i 	; minJ = i
		MULi %1 $i #FILE_FIELD_COUNT	; minS = (pointer) global FILES[i * FILE_FIELD_COUNT]
		PEEK $minS &FILES %1
		ADDi $j $i #1	; for (j = i + 1 to global fileCount) 
		PEEK %1 &fileCount 
		GEQi $j %1 @.e2
	.l3:	MULi %3 $j #FILE_FIELD_COUNT	; if ((int) strcmp((s = (pointer) global FILES[j * FILE_FIELD_COUNT + FILE_FIELD_NAME]), minS) < 0) 
		ADDi %3 %3 #FILE_FIELD_NAME
		PEEK $s &FILES %3
		MOVp %3 $s 
		MOVp %4 $minS 
		CALL &strcmp %2 *3
		GEQi %2 #0 @.f4
		MOVi $minJ $j 	; minJ = j
		MOVp $minS $s 	; minS = s
	.f4:	FORi $j %1 @.l3	; }
	.e2:	MULi %1 $minJ #FILE_FIELD_COUNT	; copy (FILE_FIELD_COUNT from (p0 = &global FILES[minJ * FILE_FIELD_COUNT]) to temp)
		ADDp $p0 &FILES %1
		ADRL %1 $temp *0
		COPY %1 $p0 *FILE_FIELD_COUNT
		MULi %1 $i #FILE_FIELD_COUNT	; copy (FILE_FIELD_COUNT from (p1 = &global FILES[i * FILE_FIELD_COUNT]) to p0)
		ADDp $p1 &FILES %1
		COPY $p0 $p1 *FILE_FIELD_COUNT
		ADRL %1 $temp *0	; copy (FILE_FIELD_COUNT from temp to p1)
		COPY $p1 %1 *FILE_FIELD_COUNT
		FORi $i %0 @.l1	; }
	.e0:	RETU   	; }


;-----------------------------------------------------------------------------
initFilesIfNecessary:	FUNC
		PARA *1
	$index:	LOCi
	$size:	LOCi
	$filePointer:	LOCp
	$namePointer:	LOCp
	$datePointer:	LOCp
;-----------------------------------------------------------------------------
		PEEK %0 &filesAreInited 	; if (global filesAreInited == 0) 
		NEQi %0 #0 @.f0
		! EQUi #DEBUG #0 @.a1	; assert(global fileCount == BUILT_IN_FILE_COUNT)
		PEEK %0 &fileCount 
		EQUi %0 #BUILT_IN_FILE_COUNT @.a1
		MOVp %1 &.a_global4d2 
		CALL ^assertFail %0 *1
	.a1:	MOVi $index #0 	; index = 0
		! MULi <A> #BUILT_IN_FILE_COUNT #FILE_FIELD_COUNT	; filePointer = &global FILES[BUILT_IN_FILE_COUNT * FILE_FIELD_COUNT]
		MOVp $filePointer &FILES:<A> 
		MOVp $namePointer &FILE_NAMES 	; namePointer = global FILE_NAMES
		MOVp $datePointer &FILE_DATES 	; datePointer = global FILE_DATES
	.l2:	MOVi %1 $index 	; while ((int) findFirmwarePatch(index, 31, namePointer, &size, datePointer) == 1) 
		MOVi %2 #31 
		MOVp %3 $namePointer 
		ADRL %4 $size *0
		MOVp %5 $datePointer 
		CALL ^findFirmwarePatch %0 *6
		NEQi %0 #1 @.e3
		GEQi $index #MAX_FILE_COUNT @.l2	; if (index < MAX_FILE_COUNT) 
		POKE $filePointer #FILE_FIELD_NAME $namePointer	; filePointer[FILE_FIELD_NAME] = namePointer
		POKE $filePointer #FILE_FIELD_TYPE #FILE_TYPE_BIN	; filePointer[FILE_FIELD_TYPE] = FILE_TYPE_BIN
		ADDi %0 $size #1023	; filePointer[FILE_FIELD_SIZE] = (size + 1023) / 1024
		DIVi %0 %0 #1024
		POKE $filePointer #FILE_FIELD_SIZE %0
		POKE $filePointer #FILE_FIELD_DATE $datePointer	; filePointer[FILE_FIELD_DATE] = datePointer
		ADDi $index $index #1	; index = index + 1
		ADDp $filePointer $filePointer #FILE_FIELD_COUNT	; filePointer = filePointer + FILE_FIELD_COUNT
		! ADDi <A> #MAX_FILE_NAME_LENGTH #1	; namePointer = namePointer + (MAX_FILE_NAME_LENGTH + 1)
		ADDp $namePointer $namePointer <A>
		ADDp $datePointer $datePointer #9	; datePointer = datePointer + 9
		! EQUi #DEBUG #0 @.a5	; assert(filePointer < &global FILES[MAX_FILE_COUNT * FILE_FIELD_COUNT])
		! MULi <A> #MAX_FILE_COUNT #FILE_FIELD_COUNT
		LSSp $filePointer &FILES:<A> @.a5
		MOVp %1 &.a_filePo4d3 
		CALL ^assertFail %0 *1
	.a5:	NOOP
		! EQUi #DEBUG #0 @.a6	; assert(namePointer < &global FILE_NAMES[MAX_FILE_COUNT * (MAX_FILE_NAME_LENGTH + 1)])
		! ADDi <A> #MAX_FILE_NAME_LENGTH #1
		! MULi <A> #MAX_FILE_COUNT <A>
		LSSp $namePointer &FILE_NAMES:<A> @.a6
		MOVp %1 &.a_namePo4d4 
		CALL ^assertFail %0 *1
	.a6:	NOOP
		! EQUi #DEBUG #0 @.a7	; assert(datePointer < &global FILE_DATES[MAX_FILE_COUNT * 9])
		! MULi <A> #MAX_FILE_COUNT #9
		LSSp $datePointer &FILE_DATES:<A> @.l2
		MOVp %1 &.a_datePo4d5 
		CALL ^assertFail %0 *1
	.a7:	GOTO @.l2  	; }
	.e3:	ADDi %0 #BUILT_IN_FILE_COUNT $index	; global fileCount = BUILT_IN_FILE_COUNT + index
		POKE &fileCount %0 
		CALL &sortFiles %0 *1	; sortFiles()
		POKE &filesAreInited #1 	; global filesAreInited = 1
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
findFile:	FUNC
	$file:	OUTi
	$s0:	INPp
;-----------------------------------------------------------------------------
		CALL &initFilesIfNecessary %0 *1	; initFilesIfNecessary()
		MOVi $file #0 	; for (file = 0 to global fileCount)
		PEEK %0 &fileCount 
		GEQi #0 %0 @.e0
	.l1:	MOVp %2 $s0 	; if ((int)strcmp(s0, global FILES[file * FILE_FIELD_COUNT + FILE_FIELD_NAME]) == 0) goto found
		MULi %3 $file #FILE_FIELD_COUNT
		ADDi %3 %3 #FILE_FIELD_NAME
		PEEK %3 &FILES %3
		CALL &strcmp %1 *3
		NEQi %1 #0 @.f2
		GOTO @found  	; goto found
	.f2:	FORi $file %0 @.l1
	.e0:	MOVi $file #-1 	; file = -1
	found:	RETU   	; }


;-----------------------------------------------------------------------------
lower:	FUNC
		PARA *1
	$s:	INPp
	$p:	LOCp
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVp $p $s 	; p = s
	.l0:	PEEK $c $p 	; while ((c = (int)*p) != 0) 
		EQUi $c #0 @.e1
		LSSi $c #'A' @.f3	; if (c >= 'A' && c <= 'Z') *p = c + ('a' - 'A')
		GRTi $c #'Z' @.f3
		! SUBi <A> #'a' #'A'	; *p = c + ('a' - 'A')
		ADDi %0 $c <A>
		POKE $p %0 
	.f3:	ADDp $p $p #1	; p = p + 1
		GOTO @.l0  	; }
	.e1:	RETU   	; }

