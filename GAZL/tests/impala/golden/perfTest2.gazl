; Compiled with Impala version 1.0


;-----------------------------------------------------------------------------
fib:	FUNC
	$x:	OUTi
	$y:	INPi
;-----------------------------------------------------------------------------
		LSSi $y #2 @.f0	; if (y >= 2) 
		SUBi %1 $y #1	; x = (int) fib(y - 1) + (int) fib(y - 2)
		CALL &fib %0 *2
		SUBi %2 $y #2
		CALL &fib %1 *2
		ADDi $x %0 %1
		GOTO @.e1  	; } else 
	.f0:	MOVi $x $y 	; x = y
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		MOVi %2 #35 	; printInt(fib(35))
		CALL &fib %1 *2
		CALL ^printInt %0 *2
		RETU   	; }