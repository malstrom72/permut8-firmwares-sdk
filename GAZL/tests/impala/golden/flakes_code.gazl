;-----------------------------------------------------------------------------
exp:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
