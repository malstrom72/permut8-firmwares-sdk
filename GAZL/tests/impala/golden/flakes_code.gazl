		GETL %0 $octsList $octaveIndex	; stepOcts[i] = octsList[octaveIndex]
		SETL $stepOcts $i %0
		ANDi %0 $i #15	; if ((op1LowBits & (0x80 >> ((i & 15) >> 2))) != 0) 
		SHRi %0 %0 #2
		SHRi %0 #0x80 %0
		ANDi %0 $op1LowBits %0
		EQUi %0 #0 @.f48
		SUBi $noteIndex $noteIndex #1	; noteIndex = noteIndex - 1
		GEQi $noteIndex #0 @.e51	; if (noteIndex < 0) 
		SUBi $noteIndex $semisCount #1	; noteIndex = semisCount - 1
		SUBi $octaveIndex $octaveIndex #1	; octaveIndex = octaveIndex - 1
		GEQi $octaveIndex #0 @.e51	; if (octaveIndex < 0) 
		SUBi $octaveIndex $octsCount #1	; octaveIndex = octsCount - 1
		GOTO @.e51  	; } else 
	.f48:	ADDi $noteIndex $noteIndex #1	; noteIndex = noteIndex + 1
		LSSi $noteIndex $semisCount @.f47	; if (noteIndex >= semisCount) 
		MOVi $noteIndex #0 	; noteIndex = 0
		ADDi $octaveIndex $octaveIndex #1	; octaveIndex = octaveIndex + 1
		LSSi $octaveIndex $octsCount @.f47	; if (octaveIndex >= octsCount) 
		MOVi $octaveIndex #0 	; octaveIndex = 0
	.e51:	NOOP
	.f47:	FORi $i #16 @.l45	; }
	.e44:	MOVi $i #0 	; for (i = 0 to 16) 
		GEQi #0 #16 @.f5
	.l55:	ADDi %0 $i #1	; stepTies[i] = ((int) stepTrigs[(i + 1) & 15] ^ TRUE)
		ANDi %0 %0 #15
		GETL %0 $stepTrigs %0
		XORi %0 %0 #TRUE
		SETL $stepTies $i %0
		FORi $i #16 @.l55	; }
	.e38:	NOOP
	.s8:	NOOP
	.e9:	NOOP
	.f5:	MOVi $trig #FALSE 	; trig = FALSE
		NEQi $midiMode #FALSE @.f56	; if (midiMode == FALSE) 
		NEQi $subStep #0 @.f57	; if (subStep == 0) 
		GETL %0 $stepTrigs $step	; if ((int) stepTrigs[step] != FALSE) 
		EQUi %0 #FALSE @.f58
		GETL %0 $stepOcts $step	; key = xpose + (int) stepOcts[step] * 12 + (int) stepSemis[step]
		MULi %0 %0 #12
		ADDi %0 $xpose %0
		GETL %1 $stepSemis $step
		ADDi $key %0 %1
		GETL %0 $stepSemis $step	; global displayLEDs[0] = 0x80 >> (int) stepSemis[step]
		SHRi %0 #0x80 %0
		POKE &displayLEDs:0 %0 
		GETL %0 $stepSemis $step	; global displayLEDs[1] = (0x8000 >> (int) stepSemis[step]) | (8 >> (int) stepOcts[step])
		GETL %1 $stepOcts $step
		SHRi %0 #0x8000 %0
		SHRi %1 #8 %1
		IORi %0 %0 %1
		POKE &displayLEDs:1 %0 
		MOVi $trig #TRUE 	; trig = TRUE
	.f58:	NEQi $noteModeOp #ARPEG_MODE @.f59	; if (noteModeOp == ARPEG_MODE) 
		ANDi %0 $step #7	; global displayLEDs[2] = 0x80 >> (step & 7)
		SHRi %0 #0x80 %0
		POKE &displayLEDs:2 %0 
		SHRi %0 $step #2	; global displayLEDs[3] = 0x80 >> (step >> 2)
		SHRi %0 #0x80 %0
		POKE &displayLEDs:3 %0 
		GOTO @.e60  	; } else 
	.f59:	SHRi %0 #0x8000 $step	; i = euclideanBits & ~(0x8000 >> step)
		XORi %0 %0 #-1
		ANDi $i $euclideanBits %0
		SHRi %0 $i #8	; global displayLEDs[2] = i >> 8
		POKE &displayLEDs:2 %0 
		ANDi %0 $i #0xFF	; global displayLEDs[3] = i & 0xFF
		POKE &displayLEDs:3 %0 
	.e60:	NOOP
	.f57:	NEQi $subStep #0x200 @.f62	; if (subStep == 0x200 && (int) stepTies[step] == FALSE) 
		GETL %0 $stepTies $step
		NEQi %0 #FALSE @.f62
		MOVi $env #0 	; env = 0
		MOVi $gk #SLOW_RELEASE 	; gk = SLOW_RELEASE
	.f62:	NEQi $subStep #0xE00 @.e65	; if (subStep == 0xE00 && (int) stepTrigs[nextStep] != FALSE) 
		GETL %0 $stepTrigs $nextStep
		EQUi %0 #FALSE @.e65
		MOVi $env #0 	; env = 0
		MOVi $gk #FAST_RELEASE 	; gk = FAST_RELEASE
		GOTO @.e65  	; } else 
	.f56:	EQUi $midiNote $lastMidiNote @.f66	; if (midiNote != lastMidiNote) 
		LSSi $midiNote #0 @.f67	; if (midiNote >= 0) 
		MOVi $key $midiNote 	; key = midiNote
		POKE &displayLEDs:0 #0 	; global displayLEDs[0] = 0
		POKE &displayLEDs:1 #0 	; global displayLEDs[1] = 0
		MOVi $trig #TRUE 	; trig = TRUE
		GOTO @.e68  	; } else 
	.f67:	MOVi $env #0 	; env = 0
		MOVi $gk #SLOW_RELEASE 	; gk = SLOW_RELEASE
	.e68:	NOOP
	.f66:	MOVi $lastMidiNote $midiNote 	; lastMidiNote = midiNote
	.e65:	EQUi $trig #FALSE @.f69	; if (trig != FALSE) 
		PEEK $rate &NOTE_RATES $key	; rate = (float) global NOTE_RATES[key]
		PEEK %0 &params:CLOCK_FREQ_PARAM_INDEX 	; f = 65536.0 * C3_FREQUENCY / itof((int) global params[CLOCK_FREQ_PARAM_INDEX]) * rate
		! MULf <A> #65536.0 #C3_FREQUENCY
		iTOf %0 %0 #1.0
		DIVf %0 <A> %0
		MULf $f %0 $rate
		ADDf %0 $f #0.5	; phaseInc = ftoi(floor(f + 0.5))
		FLOf %0 %0 
		fTOi $phaseInc %0 #1.0
		DIVf %0 #4294967296.0 $f	; period = ftoi(floor(4294967296.0 / f + 0.5))
		ADDf %0 %0 #0.5
		FLOf %0 %0 
		fTOi $period %0 #1.0
		MOVi $pos #0 	; pos = 0
		MOVi $phase #0 	; phase = 0
		SHLi $pos $clock #16	; pos = clock << 16
		MOVi $env #0x1000 	; env = 0x1000
		MOVi $gk #STANDARD_ATTACK 	; gk = STANDARD_ATTACK
		SWCH $oscModeOp *5 @.s70	; switch (oscModeOp == 0 to 5) 
	.s70#GRAIN_MODE:	MOVi $inPos $clock 	; inPos = clock
		MOVi $phase #0x10000 	; phase = 0x10000
		EQUi #GRAIN_DRIFT #FALSE @.e71	; if (GRAIN_DRIFT != FALSE) 
		SHRi %0 $phaseInc #4	; phaseInc = phaseInc - (phaseInc >> 4)
		SUBi $phaseInc $phaseInc %0
		GOTO @.e71  	; }
	.s70#SAMPLE_MODE:	NOOP
		! EQUi #DEBUG #0 @.a73	; assert(0 <= key && key < 64)
		GRTi #0 $key @.f74
		LSSi $key #64 @.a73
	.f74:	MOVp %1 &.a_0keyke4d2 
		CALL ^assertFail %0 *1
	.a73:	fTOi $pitchedRate $rate #131072.0	; pitchedRate = ftoi(131072.0 * rate)
		LEQi $pitchedRate #0x10000 @.e71	; if (pitchedRate > 0x10000) 
		EQUi #PITCHED_REVERSED #FALSE @.f76	; if (PITCHED_REVERSED != FALSE) 
		SUBi $pitchedRate #0 $pitchedRate	; pitchedRate = -pitchedRate
		GOTO @.e71  	; } else 
	.f76:	ADDi $pos $pos #0x10000	; pos = pos + 0x10000
	.e77:	GOTO @.e71  	; }
	.s70#COMB_MODE:	MOVi $gk #COMB_ATTACK 	; gk = COMB_ATTACK
	.s70:	NOOP
	.e71:	NOOP
	.f69:	MOVi %1 $clock 	; write(clock, 1, global signal)
		MOVi %2 #1 
		MOVp %3 &signal 
		CALL ^write %0 *4
		MOVi %1 $clock 	; read(clock, 1, global signal)
		MOVi %2 #1 
		MOVp %3 &signal 
		CALL ^read %0 *4
		PEEK $inL &signal:0 	; inL = (int) global signal[0]
		PEEK $inR &signal:1 	; inR = (int) global signal[1]
		SUBi %0 $env $g0	; g0 = g0 + ((env - g0) * gk >> 16)
		MULi %0 %0 $gk
		SHRi %0 %0 #16
		ADDi $g0 $g0 %0
		SUBi %0 $g0 $g1	; g1 = g1 + ((g0 - g1) * gk >> 16)
		MULi %0 %0 $gk
		SHRi %0 %0 #16
		ADDi $g1 $g1 %0
		SWCH $oscModeOp *5 @.s78	; switch (oscModeOp == 0 to 5) 
	.s78#NOP_MODE:	MOVi $left $inL 	; left = inL
		MOVi $right $inR 	; right = inR
		GOTO @.e79  	; }
	.s78#SQUARE_MODE:	MOVi $left #0x200 	; left = 0x200
		GEQi $phase #0x4000 @.f80	; if (phase < 0x4000) 
		MOVi $left #-0x200 	; left = -0x200
	.f80:	MOVi $right $left 	; right = left
		ADDi %0 $phase $phaseInc	; phase = (phase + phaseInc) & 0xFFFF
		ANDi $phase %0 #0xFFFF
		GOTO @.e79  	; }
	.s78#GRAIN_MODE:	LSSi $phase #0x10000 @.f81	; if (phase >= 0x10000) 
		SUBi $pos $pos $period	; pos = pos - period
		SUBi $phase $phase #0x10000	; phase = phase - 0x10000
		MOVi $outPos $inPos 	; outPos = inPos
		SHRi $inPos $pos #16	; inPos = pos >> 16
	.f81:	MOVi %1 $inPos 	; read(inPos, 1, bSamples)
		MOVi %2 #1 
		ADRL %3 $bSamples *0
		CALL ^read %0 *4
		ADDi $inPos $inPos #1	; inPos = inPos + 1
		MOVi %1 $outPos 	; read(outPos, 1, aSamples)
		MOVi %2 #1 
		ADRL %3 $aSamples *0
		CALL ^read %0 *4
		ADDi $outPos $outPos #1	; outPos = outPos + 1
		SUBi %0 $bSamples:0 $aSamples:0	; left = ((int) aSamples[0] + (((int) bSamples[0] - (int) aSamples[0]) * phase >> 16))
		MULi %0 %0 $phase
		SHRi %0 %0 #16
		ADDi $left $aSamples:0 %0
		SUBi %0 $bSamples:1 $aSamples:1	; right = ((int) aSamples[1] + (((int) bSamples[1] - (int) aSamples[1]) * phase >> 16))
		MULi %0 %0 $phase
		SHRi %0 %0 #16
		ADDi $right $aSamples:1 %0
		ADDi $pos $pos #0x10000	; pos = pos + 0x10000
		ADDi $phase $phase $phaseInc	; phase = phase + phaseInc
		GOTO @.e79  	; }
	.s78#SAMPLE_MODE:	SHRi $i $pos #16	; i = pos >> 16
		MOVi %1 $i 	; read(i, 2, aSamples)
		MOVi %2 #2 
		ADRL %3 $aSamples *0
		CALL ^read %0 *4
		ANDi $x $pos #0xFFFF	; x = pos & 0xFFFF
		ADDi $pos $pos $pitchedRate	; pos = pos + pitchedRate
		SUBi %0 $aSamples:2 $aSamples:0	; left = ((int) aSamples[0] + (((int) aSamples[2] - (int) aSamples[0]) * x >> 16))
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $left $aSamples:0 %0
		SUBi %0 $aSamples:3 $aSamples:1	; right = ((int) aSamples[1] + (((int) aSamples[3] - (int) aSamples[1]) * x >> 16))
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $right $aSamples:1 %0
		EQUi #CROSSFADE_SAMPLES #FALSE @.e79	; if (CROSSFADE_SAMPLES != FALSE) 
		SUBi %1 $i #0x8000	; read(i - 0x8000, 2, bSamples)
		MOVi %2 #2 
		ADRL %3 $bSamples *0
		CALL ^read %0 *4
		SUBi %0 $bSamples:2 $bSamples:0	; bL = ((int) bSamples[0] + (((int) bSamples[2] - (int) bSamples[0]) * x >> 16))
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $bL $bSamples:0 %0
		SUBi %0 $bSamples:3 $bSamples:1	; bR = ((int) bSamples[1] + (((int) bSamples[3] - (int) bSamples[1]) * x >> 16))
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $bR $bSamples:1 %0
		SUBi %0 $clock $i	; x = (clock - i) & 0xFFFF
		ANDi $x %0 #0xFFFF
		LSSi $x #0x8000 @.f83	; if (x >= 0x8000) 
		SUBi $x #0x10000 $x	; x = 0x10000 - x
	.f83:	SHRi $x $x #3	; x = x >> 3
		SUBi %0 #4096 $x	; y = (int) global SQRT_TABLE[4096 - x]
		PEEK $y &SQRT_TABLE %0
		PEEK $x &SQRT_TABLE $x	; x = (int) global SQRT_TABLE[x]
		MULi %0 $bL $y	; left = (bL * y + left * x) >> 16
		MULi %1 $left $x
		ADDi %0 %0 %1
		SHRi $left %0 #16
		MULi %0 $bR $y	; right = (bR * y + right * x) >> 16
		MULi %1 $right $x
		ADDi %0 %0 %1
		SHRi $right %0 #16
		GOTO @.e79  	; }
	.s78#COMB_MODE:	SUBi %1 $clock #1	; read(clock - 1 - (period >> 16), 2, aSamples)
		SHRi %2 $period #16
		SUBi %1 %1 %2
		MOVi %2 #2 
		ADRL %3 $aSamples *0
		CALL ^read %0 *4
		ANDi $x $period #0xFFFF	; x = period & 0xFFFF
		SUBi %0 $aSamples:0 $aSamples:2	; fbL = (int) aSamples[2] + (((int) aSamples[0] - (int) aSamples[2]) * x >> 16)
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $fbL $aSamples:2 %0
		SUBi %0 $aSamples:1 $aSamples:3	; fbR = (int) aSamples[3] + (((int) aSamples[1] - (int) aSamples[3]) * x >> 16)
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $fbR $aSamples:3 %0
		SUBi %0 $fbL $fbDL	; fbDL = fbDL + ((fbL - fbDL) >> 8)
		SHRi %0 %0 #8
		ADDi $fbDL $fbDL %0
		SUBi %0 $fbR $fbDR	; fbDR = fbDR + ((fbR - fbDR) >> 8)
		SHRi %0 %0 #8
		ADDi $fbDR $fbDR %0
		SUBi $fbL $fbL $fbDL	; fbL = fbL - fbDL
		SUBi $fbR $fbR $fbDR	; fbR = fbR - fbDR
		GEQi $phase #0x10000 @.f84	; if (phase < 0x10000) 
		ADDi $fbL $fbL $inL	; fbL = fbL + inL
		ADDi $fbR $fbR $inR	; fbR = fbR + inR
		ADDi $phase $phase $phaseInc	; phase = phase + phaseInc
	.f84:	MOVi $left $fbL 	; left = fbL
		MOVi $right $fbR 	; right = fbR
		MULi %0 $left $g1	; bSamples[0] = left * g1 >> 12
		SHRi $bSamples:0 %0 #12
		MULi %0 $right $g1	; bSamples[1] = right * g1 >> 12
		SHRi $bSamples:1 %0 #12
		MOVi %1 $clock 	; write(clock, 1, bSamples)
		MOVi %2 #1 
		ADRL %3 $bSamples *0
		CALL ^write %0 *4
	.s78:	NOOP
	.e79:	EQUi #CROSSFADE_INPUT #FALSE @.f85	; if (CROSSFADE_INPUT != FALSE) 
		SUBi %0 $left $inL	; left = inL + ((left - inL) * g1 >> 12)
		MULi %0 %0 $g1
		SHRi %0 %0 #12
		ADDi $left $inL %0
		SUBi %0 $right $inR	; right = inR + ((right - inR) * g1 >> 12)
		MULi %0 %0 $g1
		SHRi %0 %0 #12
		ADDi $right $inR %0
		GOTO @.e86  	; } else 
	.f85:	MULi %0 $left $g1	; left = left * g1 >> 12
		SHRi $left %0 #12
		MULi %0 $right $g1	; right = right * g1 >> 12
		SHRi $right %0 #12
	.e86:	POKE &signal:0 $left 	; global signal[0] = left
		POKE &signal:1 $right 	; global signal[1] = right
		CALL ^yield %0 *1	; yield()
		GOTO @.l0  	; }
		RETU   	; }

.s_SAMPLE4d2:	CNST *7
	DATs SAMPLE
	DATi #0
.s_SQUARE4d3:	CNST *51
	DATs SQUARE        Enabled Semitones            Octaves
	DATi #0
.s_GRAIN4d4:	CNST *53
	DATs GRAIN __________________________________  __________
	DATi #0
.s_COMBCC4d5:	CNST *54
	DATs COMB /C C# D  D# E  F  F# G   G# A  A# B\/0  1  2  3\
	DATi #0
.s_MIDIMo4d6:	CNST *54
	DATs MIDI Mode (set MIDI CONTROL switch to BITS)
	DATi #32 #32 #32 #32 #32 #32 #32 #32 #32 #32 #0
.s_Oct24d7:	CNST *54
	DATs Oct+2 _______________________________________________
	DATi #0
.s_ARPTri4d8:	CNST *54
	DATs ARP   Triggers  ____________| Direction | Transpose |
	DATi #0
.s_RNDEuc4d9:	CNST *54
	DATs RND   Euclidean |Shift      | Rnd Order | Transpose |
	DATi #0
.s_Domain4da:	CNST *13
	DATs Domain error
	DATi #0
.s_init4db:	CNST *5
	DATs init
	DATi #0
.s_reset4dc:	CNST *6
	DATs reset
	DATi #0
.s_update4dd:	CNST *7
	DATs update
	DATi #0
.s_bitsup4de:	CNST *12
	DATs bits update
	DATi #0
	! EQUi #DEBUG #0 @.noAssertStrings
.a_0keyke4d2:	CNST *23
	DATs (0 <= key && key < 64)
	DATi #0
.noAssertStrings:	!