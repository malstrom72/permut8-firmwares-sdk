;-----------------------------------------------------------------------------
fMPINIT:	FUNC
		PARA *1
	$FIRST:	LOCi
	$I:	LOCi
	$J:	LOCi
	$LAST:	LOCi
	$VAL:	LOCi
;-----------------------------------------------------------------------------
		MOVi $I #1 	; for (I=1 to 129) 
		GEQi #1 #129 @.e0
	.l1:	POKE &MAP1 $I #-1	; global MAP1[I]= -1
		FORi $I #129 @.l1	; } /* end loop */
	.e0:	MOVi $VAL #0 	; VAL=0
		MOVi $I #0 	; for (I=0 to 7) 
		GEQi #0 #7 @.e2
	.l3:	MULi %0 $I #2	; FIRST=(int)global fMPINIT_RUNS[I * 2 + 0]
		ADDi %0 %0 #0
		PEEK $FIRST &fMPINIT_RUNS %0
		MULi %0 $I #2	; LAST=(int)global fMPINIT_RUNS[I * 2 + 1]
		ADDi %0 %0 #1
		PEEK $LAST &fMPINIT_RUNS %0
		ADDi $J $FIRST #1	; for (J=FIRST+1 to LAST+2) 
		ADDi %0 $LAST #2
		GEQi $J %0 @.e4
	.l5:	PEEK %1 &MAP1 $J	; if(!((int)global MAP1[J] >= 0)) 
		GEQi %1 #0 @.f6
		POKE &MAP1 $J $VAL	; global MAP1[J]=VAL
		ADDi $VAL $VAL #1	; VAL=VAL+1
	.f6:	FORi $J %0 @.l5	; } /* end loop */
	.e4:	FORi $I #7 @.l3	; } /* end loop */
	.e2:	PEEK %0 &MAP1:10 	; global MAP1[128]=global MAP1[10]
		POKE &MAP1:128 %0 
		PEEK %0 &MAP1:33 	; global MAP1[10]=global MAP1[33]
		POKE &MAP1:10 %0 
		PEEK %0 &MAP1:33 	; global MAP1[11]=global MAP1[33]
		POKE &MAP1:11 %0 
		MOVi $I #0 	; for (I=0 to 127) 
		GEQi #0 #127 @.e7
	.l8:	ADDi %0 $I #1	; VAL=(int)global MAP1[I+1]+1
		PEEK %0 &MAP1 %0
		ADDi $VAL %0 #1
		! SUBi <A> #'B' #'A'	; global MAP2[VAL]=I*('B'-'A')
		MULi %0 $I <A>
		POKE &MAP2 $VAL %0
		LSSi $I #64 @.f9	; if(I >= 64)global MAP2[VAL]=(I-64)*('B'-'A')+'@'
		SUBi %0 $I #64	; global MAP2[VAL]=(I-64)*('B'-'A')+'@'
		! SUBi <A> #'B' #'A'
		MULi %0 %0 <A>
		ADDi %0 %0 #'@'
		POKE &MAP2 $VAL %0
	.f9:	FORi $I #127 @.l8	; } /* end loop */
	.e7:	RETU   	; }


;-----------------------------------------------------------------------------
fMAPLIN:	FUNC
		PARA *1
	$FIL:	INPi
	$I:	LOCi
	$VAL:	LOCi
;-----------------------------------------------------------------------------
		PEEK %0 &MAP2:1 	; if((int)global MAP2[1] == 0)fMPINIT()
		NEQi %0 #0 @.l1
		CALL &fMPINIT %0 *1	; fMPINIT()
	.l1:	NEQi $FIL #FALSE @.f2	; if(FIL==FALSE) 
		MOVi %1 #99 	; input(99, global INLINE+1)
		ADDp %2 &INLINE #1
		CALL ^input %0 *3
		CALL ^inputEOF %0 *1	; if ((int)inputEOF() != FALSE) score(1)
		EQUi %0 #FALSE @.e4
		MOVi %1 #1 	; score(1)
		CALL &score %0 *2
		GOTO @.e4  	; } else 
	.f2:	MOVi %1 #-1 	; fBUG(-1)
		CALL &fBUG %0 *2
	.e4:	POKE &LNLENG #0 	; global LNLENG=0
		MOVi $I #1 	; for (I=1 to 100+1) 
		! ADDi <A> #100 #1
		GEQi #1 <A> @.e5
	.l6:	PEEK %0 &INLINE $I	; if ((int)global INLINE[I] == 0) goto break1
		NEQi %0 #0 @.f7
		GOTO @break1  	; goto break1
	.f7:	PEEK %0 &INLINE $I	; VAL=(int)global INLINE[I]+1
		ADDi $VAL %0 #1
		PEEK %0 &MAP1 $VAL	; global INLINE[I]=global MAP1[VAL]
		POKE &INLINE $I %0
		PEEK %0 &INLINE $I	; if((int)global INLINE[I] != 0)global LNLENG=I
		EQUi %0 #0 @.f8
		POKE &LNLENG $I 	; global LNLENG=I
	.f8:	FORi $I <A> @.l6	; } /* end loop */
	.e5:	NOOP
	break1:	POKE &LNPOSN #1 	; break1:
		EQUi $FIL #FALSE @.f9	; } while (FIL != FALSE && global LNLENG == 0)
		PEEK %0 &LNLENG 
		EQUi %0 #0 @.l1
	.f9:	RETU   	; }

