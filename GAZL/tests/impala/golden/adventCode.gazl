fRNDVOC:	FUNC
	$RNDVOC:	OUTi
	$CHAR:	INPi
	$FORCE:	INPi
	$DIV:	LOCi
	$I:	LOCi
	$J:	LOCi
;-----------------------------------------------------------------------------
		MOVi $RNDVOC $FORCE 	; RNDVOC=FORCE
		NEQi $RNDVOC #0 @.f0	; if(RNDVOC == 0) 
		MOVi $I #1 	; for (I=1 to 5+1) 
		! ADDi <A> #5 #1
		GEQi #1 <A> @.f0
	.l2:	MOVi %1 #26 	; J=11+(int)fRAN(26)
		CALL &fRAN %0 *2
		ADDi $J #11 %0
		NEQi $I #2 @.f3	; if(I == 2)J=CHAR
		MOVi $J $CHAR 	; J=CHAR
	.f3:	MULi %0 $RNDVOC #64	; RNDVOC=RNDVOC*64+J
		ADDi $RNDVOC %0 $J
		FORi $I <A> @.l2	; } /* end loop */
	.f0:	MOVi $J #10000 	; J=10000
		! MULi <A> #64 #64	; DIV=64*64*64
		! MULi <A> <A> #64
		MOVi $DIV <A> 
		MOVi $I #1 	; for (I=1 to TABSIZ+1) 
		! ADDi <A> #TABSIZ #1
		GEQi #1 <A> @.e4
	.l5:	ADDi $J $J #7	; J=J+7
		PEEK %0 &ATAB $I	; if(((((int)global ATAB[I]-J*J)/DIV)%64) == CHAR) 
		MULi %1 $J $J
		SUBi %0 %0 %1
		DIVi %0 %0 $DIV
		MODi %0 %0 #64
		NEQi %0 $CHAR @.f6
		MULi %0 $J $J	; (int)global ATAB[I]=RNDVOC+J*J
		ADDi %0 $RNDVOC %0
		POKE &ATAB $I %0
		GOTO @return  	; goto return
	.f6:	FORi $I <A> @.l5	; } /* end loop */
	.e4:	MOVi %1 #5 	; fBUG(5)
		CALL &fBUG %0 *2
	return:	RETU   	; }


;-----------------------------------------------------------------------------
initialise:	FUNC
		PARA *1
	$I:	LOCi
	$K:	LOCi
;-----------------------------------------------------------------------------
		MOVi $I #1 	; for (I=1 to 100+1) 
		! ADDi <A> #100 #1
		GEQi #1 <A> @.e0
	.l1:	POKE &PLACE $I #0	; global PLACE[I]=0
		POKE &PROP $I #0	; global PROP[I]=0
		POKE &LINK $I #0	; global LINK[I]=0
		ADDi %0 $I #100	; global LINK[I + 100]=0
		POKE &LINK %0 #0
		FORi $I <A> @.l1	; } /* end loop */
	.e0:	MOVi $I #1 	; for (I=1 to LOCSIZ+1) 
		! ADDi <A> #LOCSIZ #1
		GEQi #1 <A> @.e2
	.l3:	POKE &ABB $I #0	; global ABB[I]=0
		PEEK %0 &LTEXT $I	; if(!((int)global LTEXT[I] == 0 || (int)global KEY[I] == 0)) 
		EQUi %0 #0 @.f5
		PEEK %0 &KEY $I
		EQUi %0 #0 @.f5
		PEEK $K &KEY $I	; K=(int)global KEY[I]
		PEEK %0 &TRAVEL $K	; if(((abs((int)global TRAVEL[K]))%1000) == 1)global COND[I]=2
		ABSi %0 %0 
		MODi %0 %0 #1000
		NEQi %0 #1 @.f5
		POKE &COND $I #2	; global COND[I]=2
	.f5:	POKE &ATLOC $I #0	; global ATLOC[I]=0
		FORi $I <A> @.l3	; } /* end loop */
	.e2:	MOVi $I #1 	; for (I=1 to 100+1) 
		! ADDi <A> #100 #1
		GEQi #1 <A> @.e7
	.l8:	SUBi $K #101 $I	; K=101-I
		PEEK %0 &FIXD $K	; if(!((int)global FIXD[K] <= 0)) 
		LEQi %0 #0 @.f9
		ADDi %1 $K #100	; fDROP(K+100,global FIXD[K])
		PEEK %2 &FIXD $K
		CALL &fDROP %0 *3
		MOVi %1 $K 	; fDROP(K,global PLAC[K])
		PEEK %2 &PLAC $K
		CALL &fDROP %0 *3
	.f9:	FORi $I <A> @.l8	; } /* end loop */
	.e7:	MOVi $I #1 	; for (I=1 to 100+1) 
		! ADDi <A> #100 #1
		GEQi #1 <A> @.e10
	.l11:	SUBi $K #101 $I	; K=101-I
		PEEK %0 &FIXD $K	; global FIXED[K]=global FIXD[K]
		POKE &FIXED $K %0
		PEEK %0 &PLAC $K	; if((int)global PLAC[K] != 0 && (int)global FIXD[K] <= 0)fDROP(K,global PLAC[K])
		EQUi %0 #0 @.f13
		PEEK %0 &FIXD $K
		GRTi %0 #0 @.f13
		MOVi %1 $K 	; fDROP(K,global PLAC[K])
		PEEK %2 &PLAC $K
		CALL &fDROP %0 *3
	.f13:	FORi $I <A> @.l11	; } /* end loop */
	.e10:	POKE &TALLY #0 	; global TALLY=0
		MOVi $I #50 	; for (I=50 to MAXTRS+1) 
		! ADDi <A> #MAXTRS #1
		GEQi #50 <A> @.e14
	.l15:	PEEK %0 &PTEXT $I	; if((int)global PTEXT[I] != 0)global PROP[I]= -1
		EQUi %0 #0 @.f16
		POKE &PROP $I #-1	; global PROP[I]= -1
	.f16:	PEEK %0 &TALLY 	; global TALLY=global TALLY-(int)global PROP[I]
		PEEK %1 &PROP $I
		SUBi %0 %0 %1
		POKE &TALLY %0 
		FORi $I <A> @.l15	; } /* end loop */
	.e14:	MOVi $I #1 	; for (I=1 to HNTMAX+1) 
		! ADDi <A> #HNTMAX #1
		GEQi #1 <A> @.e17
	.l18:	POKE &HINTED $I #FALSE	; global HINTED[I]=FALSE
		POKE &HINTLC $I #0	; global HINTLC[I]=0
		FORi $I <A> @.l18	; } /* end loop */
	.e17:	MOVi $I #1 	; for (I=1 to 6+1) 
		! ADDi <A> #6 #1
		GEQi #1 <A> @.e19
	.l20:	POKE &DSEEN $I #FALSE	; global DSEEN[I]=FALSE
		FORi $I <A> @.l20	; } /* end loop */
	.e19:	POKE &DFLAG #0 	; global DFLAG=0
		POKE &DLOC:1 #19 	; global DLOC[1]=19
		POKE &DLOC:2 #27 	; global DLOC[2]=27
		POKE &DLOC:3 #33 	; global DLOC[3]=33
		POKE &DLOC:4 #44 	; global DLOC[4]=44
		POKE &DLOC:5 #64 	; global DLOC[5]=64
		POKE &DLOC:6 #CHLOC 	; global DLOC[6]=CHLOC
		POKE &THRESH #-1 	; global THRESH= -1
		LEQi #TRNVLS #0 @.f21	; if(TRNVLS > 0)global THRESH=(((int)global TRNVAL[1])%100000)+1
		PEEK %0 &TRNVAL:1 	; global THRESH=(((int)global TRNVAL[1])%100000)+1
		MODi %0 %0 #100000
		ADDi %0 %0 #1
		POKE &THRESH %0 
	.f21:	MOVi $I #0 	; for (I=0 to 4+1) 
		! ADDi <A> #4 #1
		GEQi #0 <A> @.e22
	.l23:	MULi %0 #2 $I	; if((int)global RTEXT[2*I+81] != 0)global MAXDIE=I+1
		ADDi %0 %0 #81
		PEEK %0 &RTEXT %0
		EQUi %0 #0 @.f24
		ADDi %0 $I #1	; global MAXDIE=I+1
		POKE &MAXDIE %0 
	.f24:	FORi $I <A> @.l23	; } /* end loop */
	.e22:	RETU   	; }


;-----------------------------------------------------------------------------
TOTING:	FUNC
	$r:	OUTi
	$OBJ:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		PEEK %0 &PLACE $OBJ	; if ((int)global PLACE[OBJ] == -1) r = TRUE
		NEQi %0 #-1 @.f0
		MOVi $r #TRUE 	; r = TRUE
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
AT:	FUNC
	$r:	OUTi
	$OBJ:	INPi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		PEEK %0 &PLACE $OBJ	; if ((int)global PLACE[OBJ] == LOC || (int)global FIXED[OBJ] == LOC) r = TRUE
		EQUi %0 $LOC @.t0
		PEEK %0 &FIXED $OBJ
		NEQi %0 $LOC @.f1
	.t0:	MOVi $r #TRUE 	; r = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
HERE:	FUNC
	$r:	OUTi
	$OBJ:	INPi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		MOVi %1 $OBJ 	; if (((int)AT(OBJ, LOC) | (int)TOTING(OBJ)) != FALSE) r = TRUE
		MOVi %2 $LOC 
		CALL &AT %0 *3
		MOVi %2 $OBJ 
		CALL &TOTING %1 *2
		IORi %0 %0 %1
		EQUi %0 #FALSE @.f0
		MOVi $r #TRUE 	; r = TRUE
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
LIQ2:	FUNC
	$r:	OUTi
	$PBOTL:	INPi
;-----------------------------------------------------------------------------
		SUBi %0 #1 $PBOTL	; r = ((1-(PBOTL))*WATER+((PBOTL)/2)*(WATER+OIL))
		DIVi %1 $PBOTL #2
		! ADDi <A> #WATER #OIL
		MULi %0 %0 #WATER
		MULi %1 %1 <A>
		ADDi $r %0 %1
		RETU   	; }


;-----------------------------------------------------------------------------
LIQ:	FUNC
	$r:	OUTi
;-----------------------------------------------------------------------------
		PEEK %0 &PROP:BOTTLE 	; if ((int)global PROP[BOTTLE]<0) r = -1-(int)global PROP[BOTTLE]
		GEQi %0 #0 @.f0
		PEEK %0 &PROP:BOTTLE 	; r = -1-(int)global PROP[BOTTLE]
		SUBi $r #-1 %0
		GOTO @.e1  
	.f0:	PEEK $r &PROP:BOTTLE 	; r = (int)global PROP[BOTTLE]
	.e1:	MOVi %1 $r 	; r = (int)LIQ2(r)
		CALL &LIQ2 %0 *2
		MOVi $r %0 
		RETU   	; }


;-----------------------------------------------------------------------------
LIQLOC:	FUNC
	$r:	OUTi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		PEEK %1 &COND $LOC	; r = (int)LIQ2(((((int)global COND[LOC]/2*2)%8)-5)*(((int)global COND[LOC]/4)%2)+1)
		DIVi %1 %1 #2
		MULi %1 %1 #2
		MODi %1 %1 #8
		PEEK %2 &COND $LOC
		DIVi %2 %2 #4
		SUBi %1 %1 #5
		MODi %2 %2 #2
		MULi %1 %1 %2
		ADDi %1 %1 #1
		CALL &LIQ2 %0 *2
		MOVi $r %0 
		RETU   	; }


;-----------------------------------------------------------------------------
CNDBIT:	FUNC
	$r:	OUTi
	$L:	INPi
	$N:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		PEEK %0 &COND $L	; if (((int)global COND[L] & (1 << N)) != 0) r = TRUE
		SHLi %1 #1 $N
		ANDi %0 %0 %1
		EQUi %0 #0 @.f0
		MOVi $r #TRUE 	; r = TRUE
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
DARK:	FUNC
	$r:	OUTi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		MOVi %1 $LOC 	; if (((int)CNDBIT(LOC,0) == FALSE) && ((int)global PROP[LAMP] == 0 || (int)HERE(LAMP, LOC) == FALSE)) r = TRUE
		MOVi %2 #0 
		CALL &CNDBIT %0 *3
		NEQi %0 #FALSE @.f2
		PEEK %0 &PROP:LAMP 
		EQUi %0 #0 @.t1
		MOVi %1 #LAMP 
		MOVi %2 $LOC 
		CALL &HERE %0 *3
		NEQi %0 #FALSE @.f2
	.t1:	MOVi $r #TRUE 	; r = TRUE
	.f2:	RETU   	; }


;-----------------------------------------------------------------------------
GSTONE:	FUNC
	$r:	OUTi
	$OBJ:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		EQUi $OBJ #EMRALD @.t0	; if ((OBJ) == EMRALD || (OBJ) == RUBY || (OBJ) == AMBER || (OBJ) == SAPPH) r = TRUE
		EQUi $OBJ #RUBY @.t0
		EQUi $OBJ #AMBER @.t0
		NEQi $OBJ #SAPPH @.f1
	.t0:	MOVi $r #TRUE 	; r = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
FOREST:	FUNC
	$r:	OUTi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		LSSi $LOC #145 @.f1	; if ((LOC) >= 145 && (LOC) <= 166) r = TRUE
		GRTi $LOC #166 @.f1
		MOVi $r #TRUE 	; r = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
OUTSID:	FUNC
	$r:	OUTi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		LEQi $LOC #8 @.t0	; if ((LOC) <= 8 || (int)FOREST(LOC) != FALSE || (LOC) == (int)global PLAC[SAPPH] || (LOC) == 180 || (LOC) == 182) r = TRUE
		MOVi %1 $LOC 
		CALL &FOREST %0 *2
		NEQi %0 #FALSE @.t0
		PEEK %0 &PLAC:SAPPH 
		EQUi $LOC %0 @.t0
		EQUi $LOC #180 @.t0
		NEQi $LOC #182 @.f1
	.t0:	MOVi $r #TRUE 	; r = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
INDEEP:	FUNC
	$r:	OUTi
	$LOC:	INPi
;-----------------------------------------------------------------------------
		MOVi $r #FALSE 	; r = FALSE
		LSSi $LOC #15 @.f1	; if ((LOC) >= 15 && (int)OUTSID(LOC) == FALSE && (LOC) != 179) r = TRUE
		MOVi %1 $LOC 
		CALL &OUTSID %0 *2
		NEQi %0 #FALSE @.f1
		EQUi $LOC #179 @.f1
		MOVi $r #TRUE 	; r = TRUE
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
discard:	FUNC
	$goValue:	OUTi
