		GOTO @L10  	; goto L10
	.f3:	MOVi $GETTXT #0 	; GETTXT=0
		MOVi $I #1 	; for (I=1 to 5+1) 
		! ADDi <A> #5 #1
		GEQi #1 <A> @.e4
	.l5:	MULi $GETTXT $GETTXT #64	; GETTXT=GETTXT*64
		PEEK %0 &LNPOSN 	; if(global LNPOSN > global LNLENG || (ONEWRD != FALSE && (int)global INLINE[global LNPOSN] == 0)) goto L15
		PEEK %1 &LNLENG 
		GRTi %0 %1 @L15
		EQUi $ONEWRD #FALSE @.f8
		PEEK %0 &LNPOSN 
		PEEK %0 &INLINE %0
		NEQi %0 #0 @.f8
		GOTO @L15  	; goto L15
	.f8:	PEEK %0 &LNPOSN 	; CHAR=(int)global INLINE[global LNPOSN]
		PEEK $CHAR &INLINE %0
		GEQi $CHAR #63 @.f9	; if(!(CHAR >= 63)) 
		POKE &fGETTXT_SPLITTING #-1 	; global fGETTXT_SPLITTING = -1
		EQUi $UPPER #FALSE @.f11	; if(UPPER != FALSE && CHAR >= 37)CHAR=CHAR-26
		LSSi $CHAR #37 @.f11
		SUBi $CHAR $CHAR #26	; CHAR=CHAR-26
	.f11:	ADDi $GETTXT $GETTXT $CHAR	; GETTXT=GETTXT+CHAR
		GOTO @.e12  	; } else 
	.f9:	PEEK %0 &fGETTXT_SPLITTING 	; if(!(global fGETTXT_SPLITTING == global LNPOSN)) 
		PEEK %1 &LNPOSN 
		EQUi %0 %1 @.f13
		ADDi $GETTXT $GETTXT #63	; GETTXT=GETTXT+63
		PEEK %0 &LNPOSN 	; global fGETTXT_SPLITTING = global LNPOSN
		POKE &fGETTXT_SPLITTING %0 
		GOTO @L15  	; goto L15
	.f13:	ADDi %0 $GETTXT $CHAR	; GETTXT=GETTXT+CHAR-63
		SUBi $GETTXT %0 #63
		POKE &fGETTXT_SPLITTING #-1 	; global fGETTXT_SPLITTING = -1
	.e12:	PEEK %0 &LNPOSN 	; global LNPOSN=global LNPOSN+1
		ADDi %0 %0 #1
		POKE &LNPOSN %0 
	L15:	FORi $I <A> @.l5	; } /* end loop */
	.e4:	EQUi $HASH #FALSE @.f14	; if(HASH != FALSE)GETTXT=GETTXT+((HASH*13579+5432)%97531)*12345+HASH
		MULi %0 $HASH #13579	; GETTXT=GETTXT+((HASH*13579+5432)%97531)*12345+HASH
		ADDi %0 %0 #5432
		MODi %0 %0 #97531
		MULi %0 %0 #12345
		ADDi %0 $GETTXT %0
		ADDi $GETTXT %0 $HASH
	.f14:	NOOP
	return:	RETU   	; }


;-----------------------------------------------------------------------------
fMAKEWD:	FUNC
	$MAKEWD:	OUTi
	$LETTRS:	INPi
	$I:	LOCi
	$L:	LOCi
;-----------------------------------------------------------------------------
		MOVi $MAKEWD #0 	; MAKEWD=0
		MOVi $I #1 	; I=1
		MOVi $L $LETTRS 	; L=LETTRS
	.l0:	MODi %0 $L #50	; MAKEWD=MAKEWD+I*(((L)%50)+10)
		ADDi %0 %0 #10
		MULi %0 $I %0
		ADDi $MAKEWD $MAKEWD %0
		MULi $I $I #64	; I=I*64
		MODi %0 $L #100	; if(((L)%100) > 50)MAKEWD=MAKEWD+I*5
		LEQi %0 #50 @.f1
		MULi %0 $I #5	; MAKEWD=MAKEWD+I*5
		ADDi $MAKEWD $MAKEWD %0
	.f1:	DIVi $L $L #100	; L=L/100
		NEQi $L #0 @.l0	; } while (L != 0)
		! MULi <A> #64 #64	; I=64*64*64*64*64/I
		! MULi <A> <A> #64
		! MULi <A> <A> #64
		! MULi <A> <A> #64
		DIVi $I <A> $I
		MULi $MAKEWD $MAKEWD $I	; MAKEWD=MAKEWD*I
		RETU   	; }


;-----------------------------------------------------------------------------
fSHFTXT:	FUNC
		PARA *1
	$FROM:	INPi
	$DELTA:	INPi
	$I:	LOCi
	$II:	LOCi
	$JJ:	LOCi
;-----------------------------------------------------------------------------
		PEEK %0 &LNLENG 	; if(!(global LNLENG < FROM || DELTA == 0)) 
		LSSi %0 $FROM @.f1
		EQUi $DELTA #0 @.f1
		MOVi $I $FROM 	; for (I=FROM to global LNLENG+1) 
		PEEK %0 &LNLENG 
		ADDi %0 %0 #1
		GEQi $FROM %0 @.f1
	.l3:	MOVi $II $I 	; II=I
		LEQi $DELTA #0 @.f4	; if(DELTA > 0)II=FROM+global LNLENG-I
		PEEK %1 &LNLENG 	; II=FROM+global LNLENG-I
		ADDi %1 $FROM %1
		SUBi $II %1 $I
	.f4:	ADDi $JJ $II $DELTA	; JJ=II+DELTA
		PEEK %1 &INLINE $II	; global INLINE[JJ]=global INLINE[II]
		POKE &INLINE $JJ %1
		FORi $I %0 @.l3	; } /* end loop */
	.f1:	PEEK %0 &LNLENG 	; global LNLENG=global LNLENG+DELTA
		ADDi %0 %0 $DELTA
		POKE &LNLENG %0 
		RETU   	; }


;-----------------------------------------------------------------------------
fPUTTXT:	FUNC
		PARA *1
	$WORD:	INPi
	$sTATE:	INPp
	$CASE:	INPi
	$HASH:	INPi
	$ALPH1:	LOCi
	$ALPH2:	LOCi
	$BYTE:	LOCi
	$DIV:	LOCi
	$I:	LOCi
	$W:	LOCi
;-----------------------------------------------------------------------------
		MULi %0 #13 $CASE	; ALPH1=13*CASE+24
		ADDi $ALPH1 %0 #24
		ABSi %0 $CASE 	; ALPH2=26*abs(CASE)+ALPH1
		MULi %0 #26 %0
		ADDi $ALPH2 %0 $ALPH1
		ABSi %0 $CASE 	; if(abs(CASE) > 1)ALPH1=ALPH2
		LEQi %0 #1 @.f0
		MOVi $ALPH1 $ALPH2 	; ALPH1=ALPH2
	.f0:	NOOP
		! MULi <A> #64 #64	; DIV=64*64*64*64
		! MULi <A> <A> #64
		! MULi <A> <A> #64
		MOVi $DIV <A> 
		MOVi $W $WORD 	; W=WORD
		EQUi $HASH #0 @.f1	; if(HASH!=0)W=W-((HASH*13579+5432)%97531)*12345-HASH
		MULi %0 $HASH #13579	; W=W-((HASH*13579+5432)%97531)*12345-HASH
		ADDi %0 %0 #5432
		MODi %0 %0 #97531
		MULi %0 %0 #12345
		SUBi %0 $W %0
		SUBi $W %0 $HASH
	.f1:	MOVi $I #1 	; for (I=1 to 5+1) 
		! ADDi <A> #5 #1
		GEQi #1 <A> @.e2
	.l3:	GRTi $W #0 @.f5	; if(W <= 0 && (int)(*sTATE) == 0 && abs(CASE) <= 1) goto return
		PEEK %0 $sTATE 
		NEQi %0 #0 @.f5
		ABSi %0 $CASE 
		GRTi %0 #1 @.f5
		GOTO @return  	; goto return
	.f5:	DIVi $BYTE $W $DIV	; BYTE=W/DIV
		PEEK %0 $sTATE 	; if(!((int)(*sTATE) != 0 || BYTE != 63)) 
		NEQi %0 #0 @.f7
		NEQi $BYTE #63 @.f7
		POKE $sTATE #63 	; (int)(*sTATE)=63
		GOTO @.e8  	; } else 
	.f7:	PEEK %1 &LNPOSN 	; fSHFTXT(global LNPOSN,1)
		MOVi %2 #1 
		CALL &fSHFTXT %0 *3
		PEEK %0 $sTATE 	; (*sTATE)=(int)(*sTATE)+BYTE
		ADDi %0 %0 $BYTE
		POKE $sTATE %0 
		PEEK %0 $sTATE 	; if((int)(*sTATE) < ALPH2 && (int)(*sTATE) >= ALPH1)(*sTATE)=(int)(*sTATE)-26*CASE
		GEQi %0 $ALPH2 @.f10
		PEEK %0 $sTATE 
		LSSi %0 $ALPH1 @.f10
		PEEK %0 $sTATE 	; (*sTATE)=(int)(*sTATE)-26*CASE
		MULi %1 #26 $CASE
		SUBi %0 %0 %1
		POKE $sTATE %0 
	.f10:	PEEK %0 &LNPOSN 	; global INLINE[global LNPOSN]=(*sTATE)
		PEEK %1 $sTATE 
		POKE &INLINE %0 %1
		PEEK %1 &LNPOSN 	; global LNPOSN=global LNPOSN+1
		ADDi %1 %1 #1
		POKE &LNPOSN %1 
		POKE $sTATE #0 	; (int)(*sTATE)=0
	.e8:	MULi %1 $BYTE $DIV	; W=(W-BYTE*DIV)*64
		SUBi %1 $W %1
		MULi $W %1 #64
		FORi $I <A> @.l3	; } /* end loop */
	.e2:	NOOP
	return:	RETU   	; }


;-----------------------------------------------------------------------------
fTYPE:	FUNC
		PARA *1
	$I:	LOCi
	$VAL:	LOCi
;-----------------------------------------------------------------------------
		PEEK %1 &LNLENG 	; if(!(global LNLENG != 0)) 
		NEQi %1 #0 @.f0
		MOVp %1 &.s_Seesou4d3:38 	; output("\n")
		CALL ^output %0 *2
		GOTO @return  	; goto return
	.f0:	PEEK %0 &MAP2:1 	; if((int)global MAP2[1] == 0)fMPINIT()
		NEQi %0 #0 @.f1
		CALL &fMPINIT %0 *1	; fMPINIT()
	.f1:	MOVi $I #1 	; for (I=1 to global LNLENG+1) 
		PEEK %0 &LNLENG 
		ADDi %0 %0 #1
		GEQi #1 %0 @.e2
	.l3:	PEEK $VAL &INLINE $I	; VAL=(int)global INLINE[I]
		ADDi %1 $VAL #1	; global INLINE[I]=global MAP2[VAL+1]
		PEEK %1 &MAP2 %1
		POKE &INLINE $I %1
		FORi $I %0 @.l3	; } /* end loop */
	.e2:	PEEK %0 &LNLENG 	; global INLINE[global LNLENG+1]=0
		ADDi %0 %0 #1
		POKE &INLINE %0 #0
		ADDp %1 &INLINE #1	; output(global INLINE+1)
		CALL ^output %0 *2
		MOVp %1 &.s_Seesou4d3:38 	; output("\n")
		CALL ^output %0 *2
	return:	RETU   	; }


;-----------------------------------------------------------------------------
fTYPE0:	FUNC
		PARA *1
	$TEMP:	LOCi
;-----------------------------------------------------------------------------
		PEEK $TEMP &LNLENG 	; TEMP=global LNLENG
		POKE &LNLENG #0 	; global LNLENG=0
		CALL &fTYPE %0 *1	; fTYPE()
		POKE &LNLENG $TEMP 	; global LNLENG=TEMP
		RETU   	; }


;-----------------------------------------------------------------------------
fSPEAK:	FUNC
		PARA *1
	$N:	INPi
	$BLANK:	LOCi
	$CASE:	LOCi
	$I:	LOCi
	$K:	LOCi
	$L:	LOCi
	$NEG:	LOCi
	$NPARMS:	LOCi
	$PARM:	LOCi
	$PRMTYP:	LOCi
	$STATE:	LOCi
;-----------------------------------------------------------------------------
		NEQi $N #0 @.f0	; if(N == 0) goto return
		GOTO @return  	; goto return
	.f0:	PEEK $BLANK &BLKLIN 	; BLANK=global BLKLIN
		MOVi $K $N 	; K=N
		MOVi $NPARMS #1 	; NPARMS=1
	L10:	PEEK %0 &LINES $K	; L10:
		ABSi %0 %0 
		SUBi $L %0 #1
		ADDi $K $K #1	; K=K+1
		POKE &LNLENG #0 	; global LNLENG=0
		POKE &LNPOSN #1 	; global LNPOSN=1
		MOVi $STATE #0 	; STATE=0
		MOVi $I $K 	; for (I=K to L+1) 
		ADDi %0 $L #1
		GEQi $K %0 @.e1
	.l2:	PEEK %2 &LINES $I	; fPUTTXT(global LINES[I],&STATE,2,I)
		ADRL %3 $STATE *0
		MOVi %4 #2 
		MOVi %5 $I 
		CALL &fPUTTXT %1 *5
		FORi $I %0 @.l2	; } /* end loop */
	.e1:	POKE &LNPOSN #0 	; global LNPOSN=0
	L30:	PEEK %0 &LNPOSN 	; L30:
		ADDi %0 %0 #1
		POKE &LNPOSN %0 
	L32:	PEEK %0 &LNPOSN 	; L32:
		PEEK %1 &LNLENG 
		LEQi %0 %1 @.f3
		GOTO @L40  	; goto L40
	.f3:	PEEK %0 &LNPOSN 	; if((int)global INLINE[global LNPOSN] != 63) goto L30
		PEEK %0 &INLINE %0
		EQUi %0 #63 @.f4
		GOTO @L30  	; goto L30
	.f4:	PEEK %0 &LNPOSN 	; PRMTYP=(int)global INLINE[global LNPOSN+1]
		ADDi %0 %0 #1
		PEEK $PRMTYP &INLINE %0
		NEQi $PRMTYP #1 @.f5	; if(PRMTYP == 1) goto return
		GOTO @return  	; goto return
	.f5:	NEQi $PRMTYP #29 @.f6	; if(PRMTYP == 29) goto L320
		GOTO @L320  	; goto L320
	.f6:	NEQi $PRMTYP #30 @.f7	; if(PRMTYP == 30) goto L340
		GOTO @L340  	; goto L340
	.f7:	NEQi $PRMTYP #12 @.f8	; if(PRMTYP == 12) goto L360
		GOTO @L360  	; goto L360
	.f8:	EQUi $PRMTYP #33 @L380	; if(PRMTYP == 33 || PRMTYP == 22 || PRMTYP == 31 || PRMTYP == 13) goto
		EQUi $PRMTYP #22 @L380
		EQUi $PRMTYP #31 @L380
		NEQi $PRMTYP #13 @.f10
		GOTO @L380  	; goto
	.f10:	SUBi $PRMTYP $PRMTYP #64	; PRMTYP=PRMTYP-64
		LSSi $PRMTYP #1 @L30	; if(PRMTYP < 1 || PRMTYP > 9) goto L30
		LEQi $PRMTYP #9 @.f12
		GOTO @L30  	; goto L30
	.f12:	PEEK %1 &LNPOSN 	; fSHFTXT(global LNPOSN+2,PRMTYP-2)
		ADDi %1 %1 #2
		SUBi %2 $PRMTYP #2
		CALL &fSHFTXT %0 *3
		PEEK %0 &LNPOSN 	; global LNPOSN=global LNPOSN+PRMTYP
		ADDi %0 %0 $PRMTYP
		POKE &LNPOSN %0 
		PEEK %0 &PARMS $NPARMS	; PARM=abs((int)global PARMS[NPARMS])
		ABSi $PARM %0 
		MOVi $NEG #0 	; NEG=0
		PEEK %0 &PARMS $NPARMS	; if((int)global PARMS[NPARMS] < 0)NEG=9
		GEQi %0 #0 @.f13
		MOVi $NEG #9 	; NEG=9
	.f13:	MOVi $I #1 	; for (I=1 to PRMTYP+1) 
		ADDi %0 $PRMTYP #1
		GEQi #1 %0 @.e14
	.l15:	PEEK %1 &LNPOSN 	; global LNPOSN=global LNPOSN-1
		SUBi %1 %1 #1
		POKE &LNPOSN %1 
		PEEK %1 &LNPOSN 	; global INLINE[global LNPOSN]=((PARM)%10)+64
		MODi %2 $PARM #10
		ADDi %2 %2 #64
		POKE &INLINE %1 %2
		EQUi $I #1 @L390	; if(I == 1 || PARM != 0) goto L390
		EQUi $PARM #0 @.f17
		GOTO @L390  	; goto L390
	.f17:	PEEK %2 &LNPOSN 	; global INLINE[global LNPOSN]=NEG
		POKE &INLINE %2 $NEG
		MOVi $NEG #0 	; NEG=0
	L390:	DIVi $PARM $PARM #10	; L390:
		FORi $I %0 @.l15	; } /* end loop */
	.e14:	PEEK %0 &LNPOSN 	; global LNPOSN=global LNPOSN+PRMTYP
		ADDi %0 %0 $PRMTYP
		POKE &LNPOSN %0 
	L395:	ADDi $NPARMS $NPARMS #1	; L395:
		GOTO @L32  	; goto L32
	L320:	PEEK %1 &LNPOSN 	; L320:
		ADDi %1 %1 #2
		MOVi %2 #-1 
		CALL &fSHFTXT %0 *3
		PEEK %0 &LNPOSN 	; global INLINE[global LNPOSN]=55
		POKE &INLINE %0 #55
		PEEK %0 &PARMS $NPARMS	; if((int)global PARMS[NPARMS] == 1)fSHFTXT(global LNPOSN+1,-1)
		NEQi %0 #1 @L395
		PEEK %1 &LNPOSN 	; fSHFTXT(global LNPOSN+1,-1)
		ADDi %1 %1 #1
		MOVi %2 #-1 
		CALL &fSHFTXT %0 *3
		GOTO @L395  	; goto L395
	L340:	PEEK %1 &LNPOSN 	; L340:
		ADDi %1 %1 #2
		MOVi %2 #-2 
		CALL &fSHFTXT %0 *3
		MOVi $STATE #0 	; STATE=0
		MOVi $CASE #2 	; CASE=2
	L345:	PEEK %0 &PARMS $NPARMS	; L345:
		GEQi %0 #0 @.f19
		GOTO @L395  	; goto L395
	.f19:	ADDi %0 $NPARMS #1	; if((int)global PARMS[NPARMS+1] < 0)CASE=0
		PEEK %0 &PARMS %0
		GEQi %0 #0 @.f20
		MOVi $CASE #0 	; CASE=0
	.f20:	PEEK %1 &PARMS $NPARMS	; fPUTTXT(global PARMS[NPARMS],&STATE,CASE,0)
		ADRL %2 $STATE *0
		MOVi %3 $CASE 
		MOVi %4 #0 
		CALL &fPUTTXT %0 *5
		ADDi $NPARMS $NPARMS #1	; NPARMS=NPARMS+1
		GOTO @L345  	; goto L345
	L360:	PEEK $PRMTYP &PARMS $NPARMS	; L360:
		PEEK %1 &LNPOSN 	; fSHFTXT(global LNPOSN+2,PRMTYP-2)
		ADDi %1 %1 #2
		SUBi %2 $PRMTYP #2
		CALL &fSHFTXT %0 *3
		NEQi $PRMTYP #0 @.f21	; if(PRMTYP == 0) goto L395
		GOTO @L395  	; goto L395
	.f21:	MOVi $I #1 	; for (I=1 to PRMTYP+1) 
		ADDi %0 $PRMTYP #1
		GEQi #1 %0 @L395
	.l23:	PEEK %1 &LNPOSN 	; global INLINE[global LNPOSN]=0
		POKE &INLINE %1 #0
		PEEK %1 &LNPOSN 	; global LNPOSN=global LNPOSN+1
		ADDi %1 %1 #1
		POKE &LNPOSN %1 
		FORi $I %0 @.l23	; } /* end loop */
		GOTO @L395  	; goto L395
	L380:	PEEK %1 &LNPOSN 	; L380:
		ADDi %1 %1 #2
		MOVi %2 #-2 
		CALL &fSHFTXT %0 *3
		MOVi $STATE #0 	; STATE=0
		MOVi $CASE #-1 	; CASE= -1
		NEQi $PRMTYP #31 @.f24	; if(PRMTYP == 31)CASE=1
		MOVi $CASE #1 	; CASE=1
	.f24:	NEQi $PRMTYP #33 @.f25	; if(PRMTYP == 33)CASE=0
		MOVi $CASE #0 	; CASE=0
	.f25:	PEEK $I &LNPOSN 	; I=global LNPOSN
		PEEK %1 &PARMS $NPARMS	; fPUTTXT(global PARMS[NPARMS],&STATE,CASE,0)
		ADRL %2 $STATE *0
		MOVi %3 $CASE 
		MOVi %4 #0 
		CALL &fPUTTXT %0 *5
		ADDi %1 $NPARMS #1	; fPUTTXT(global PARMS[NPARMS+1],&STATE,CASE,0)
		PEEK %1 &PARMS %1
		ADRL %2 $STATE *0
		MOVi %3 $CASE 
		MOVi %4 #0 
		CALL &fPUTTXT %0 *5
		NEQi $PRMTYP #13 @.f27	; if(PRMTYP == 13 && (int)global INLINE[I] >= 37 && (int)global INLINE[I] <= 62)global INLINE[I]=(int)global INLINE[I]-26
		PEEK %0 &INLINE $I
		LSSi %0 #37 @.f27
		PEEK %0 &INLINE $I
		GRTi %0 #62 @.f27
		PEEK %0 &INLINE $I	; global INLINE[I]=(int)global INLINE[I]-26
		SUBi %0 %0 #26
		POKE &INLINE $I %0
	.f27:	ADDi $NPARMS $NPARMS #2	; NPARMS=NPARMS+2
		GOTO @L32  	; goto L32
	L40:	EQUi $BLANK #FALSE @.f28	; L40:
		CALL &fTYPE0 %0 *1	; fTYPE0()
	.f28:	MOVi $BLANK #FALSE 	; BLANK=FALSE
		CALL &fTYPE %0 *1	; fTYPE()
		ADDi $K $L #1	; K=L+1
		PEEK %0 &LINES $K	; if((int)global LINES[K] >= 0) goto L10
		LSSi %0 #0 @.f29
		GOTO @L10  	; goto L10
	.f29:	NOOP
	return:	RETU   	; }


;-----------------------------------------------------------------------------
fPSPEAK:	FUNC
		PARA *1
	$MSG:	INPi
	$SKIP:	INPi
	$I:	LOCi
	$M:	LOCi
;-----------------------------------------------------------------------------
		PEEK $M &PTEXT $MSG	; M=(int)global PTEXT[MSG]
		LSSi $SKIP #0 @.f0	; if(!(SKIP < 0)) 
		MOVi $I #0 	; for (I=0 to SKIP+1) 
		ADDi %0 $SKIP #1
		GEQi #0 %0 @.f0
	.l2:	NOOP
	.l3:	PEEK %1 &LINES $M	; M=abs((int)global LINES[M])
		ABSi $M %1 
		PEEK %1 &LINES $M	; } while ((int)global LINES[M] >= 0)
		GEQi %1 #0 @.l3
		FORi $I %0 @.l2	; } /* end loop */
	.f0:	MOVi %1 $M 	; fSPEAK(M)
		CALL &fSPEAK %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
fRSPEAK:	FUNC
		PARA *1
	$I:	INPi
