;-----------------------------------------------------------------------------
fVOCAB:	FUNC
	$VOCAB:	OUTi
	$ID:	INPi
	$INIT:	INPi
	$HASH:	LOCi
	$I:	LOCi
;-----------------------------------------------------------------------------
		MOVi $HASH #10000 	; HASH=10000
		MOVi $I #1 	; for (I=1 to TABSIZ+1) 
		! ADDi <A> #TABSIZ #1
		GEQi #1 <A> @.e0
	.l1:	PEEK %0 &KTAB $I	; if((int)global KTAB[I] == -1) 
		NEQi %0 #-1 @.f2
		MOVi $VOCAB #-1 	; VOCAB= -1
		GEQi $INIT #0 @.f3	; if(INIT < 0) goto return
		GOTO @return  	; goto return
	.f3:	MOVi %1 #5 	; fBUG(5)
		CALL &fBUG %0 *2
	.f2:	ADDi $HASH $HASH #7	; HASH=HASH+7
		LSSi $INIT #0 @.f4	; if(!(INIT >= 0 && (int)global KTAB[I]/1000 != INIT)) 
		PEEK %0 &KTAB $I
		DIVi %0 %0 #1000
		NEQi %0 $INIT @.f5
	.f4:	MULi %0 $HASH $HASH	; if((int)global ATAB[I] == ID+HASH*HASH) 
		PEEK %1 &ATAB $I
		ADDi %0 $ID %0
		NEQi %1 %0 @.f5
		PEEK $VOCAB &KTAB $I	; VOCAB=(int)global KTAB[I]
		LSSi $INIT #0 @return	; if(INIT >= 0)VOCAB=((VOCAB)%1000)
		MODi $VOCAB $VOCAB #1000	; VOCAB=((VOCAB)%1000)
		GOTO @return  	; goto return
	.f5:	FORi $I <A> @.l1	; } /* end loop */
	.e0:	MOVi %1 #21 	; fBUG(21)
		CALL &fBUG %0 *2
	return:	RETU   	; }


;-----------------------------------------------------------------------------
fCARRY:	FUNC
		PARA *1
	$OBJECT:	INPi
	$WHERE:	INPi
	$TEMP:	LOCi
;-----------------------------------------------------------------------------
		GRTi $OBJECT #100 @.f0	; if(OBJECT <= 100) 
		PEEK %0 &PLACE $OBJECT	; if((int)global PLACE[OBJECT] == -1) goto return
		NEQi %0 #-1 @.f1
		GOTO @return  	; goto return
	.f1:	POKE &PLACE $OBJECT #-1	; global PLACE[OBJECT]= -1
		PEEK %0 &HOLDNG 	; global HOLDNG=global HOLDNG+1
		ADDi %0 %0 #1
		POKE &HOLDNG %0 
	.f0:	PEEK %0 &ATLOC $WHERE	; if((int)global ATLOC[WHERE] == OBJECT) 
		NEQi %0 $OBJECT @.f2
		PEEK %0 &LINK $OBJECT	; global ATLOC[WHERE]=global LINK[OBJECT]
		POKE &ATLOC $WHERE %0
		GOTO @return  	; goto return
	.f2:	PEEK $TEMP &ATLOC $WHERE	; TEMP=(int)global ATLOC[WHERE]
	.l3:	PEEK %0 &LINK $TEMP	; while ((int)global LINK[TEMP] != OBJECT) 
		EQUi %0 $OBJECT @.e4
		PEEK $TEMP &LINK $TEMP	; TEMP=(int)global LINK[TEMP]
		GOTO @.l3  	; }
	.e4:	PEEK %0 &LINK $OBJECT	; global LINK[TEMP]=global LINK[OBJECT]
		POKE &LINK $TEMP %0
	return:	RETU   	; }


;-----------------------------------------------------------------------------
fDROP:	FUNC
		PARA *1
	$OBJECT:	INPi
	$WHERE:	INPi
;-----------------------------------------------------------------------------
		GRTi $OBJECT #100 @.f0	; if(OBJECT <= 100) 
		PEEK %0 &PLACE $OBJECT	; if((int)global PLACE[OBJECT] == -1)global HOLDNG=global HOLDNG-1
		NEQi %0 #-1 @.f1
		PEEK %0 &HOLDNG 	; global HOLDNG=global HOLDNG-1
		SUBi %0 %0 #1
		POKE &HOLDNG %0 
	.f1:	POKE &PLACE $OBJECT $WHERE	; global PLACE[OBJECT]=WHERE
		GOTO @.e2  	; } else 
	.f0:	SUBi %0 $OBJECT #100	; global FIXED[OBJECT-100]=WHERE
		POKE &FIXED %0 $WHERE
	.e2:	LEQi $WHERE #0 @.f3	; if(WHERE > 0) 
		PEEK %0 &ATLOC $WHERE	; global LINK[OBJECT]=global ATLOC[WHERE]
		POKE &LINK $OBJECT %0
		POKE &ATLOC $WHERE $OBJECT	; global ATLOC[WHERE]=OBJECT
	.f3:	RETU   	; }


;-----------------------------------------------------------------------------
fMOVE:	FUNC
		PARA *1
	$OBJECT:	INPi
	$WHERE:	INPi
	$FROM:	LOCi
;-----------------------------------------------------------------------------
		GRTi $OBJECT #100 @.f0	; if(OBJECT <= 100) 
		PEEK $FROM &PLACE $OBJECT	; FROM=(int)global PLACE[OBJECT]
		GOTO @.e1  	; } else 
	.f0:	SUBi %0 $OBJECT #100	; FROM=(int)global FIXED[OBJECT-100]
		PEEK $FROM &FIXED %0
	.e1:	LEQi $FROM #0 @.f3	; if(FROM > 0 && FROM <= 300)fCARRY(OBJECT,FROM)
		GRTi $FROM #300 @.f3
		MOVi %1 $OBJECT 	; fCARRY(OBJECT,FROM)
		MOVi %2 $FROM 
		CALL &fCARRY %0 *3
	.f3:	MOVi %1 $OBJECT 	; fDROP(OBJECT,WHERE)
		MOVi %2 $WHERE 
		CALL &fDROP %0 *3
		RETU   	; }


;-----------------------------------------------------------------------------
fDSTROY:	FUNC
		PARA *1
	$OBJECT:	INPi
;-----------------------------------------------------------------------------
		MOVi %1 $OBJECT 	; fMOVE(OBJECT,0)
		MOVi %2 #0 
		CALL &fMOVE %0 *3
		RETU   	; }


;-----------------------------------------------------------------------------
fJUGGLE:	FUNC
		PARA *1
	$OBJECT:	INPi
	$I:	LOCi
	$J:	LOCi
;-----------------------------------------------------------------------------
		PEEK $I &PLACE $OBJECT	; I=(int)global PLACE[OBJECT]
		PEEK $J &FIXED $OBJECT	; J=(int)global FIXED[OBJECT]
		MOVi %1 $OBJECT 	; fMOVE(OBJECT,I)
		MOVi %2 $I 
		CALL &fMOVE %0 *3
		ADDi %1 $OBJECT #100	; fMOVE(OBJECT+100,J)
		MOVi %2 $J 
		CALL &fMOVE %0 *3
		RETU   	; }


;-----------------------------------------------------------------------------
fPUT:	FUNC
	$PUT:	OUTi
	$OBJECT:	INPi
	$WHERE:	INPi
	$PVAL:	INPi
;-----------------------------------------------------------------------------
		MOVi %1 $OBJECT 	; fMOVE(OBJECT,WHERE)
		MOVi %2 $WHERE 
		CALL &fMOVE %0 *3
		SUBi $PUT #-1 $PVAL	; PUT=(-1)-PVAL
		RETU   	; }


;-----------------------------------------------------------------------------
fATDWRF:	FUNC
