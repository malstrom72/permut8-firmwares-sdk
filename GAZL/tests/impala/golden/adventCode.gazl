	.l2:	PEEK %0 &DLOC $I	; if((int)global DLOC[I] == WHERE) 
		NEQi %0 $WHERE @.f3
		MOVi $ATDWRF $I 	; ATDWRF=I
		GOTO @return  	; goto return
	.f3:	PEEK %0 &DLOC $I	; if((int)global DLOC[I] != 0)ATDWRF=0
		EQUi %0 #0 @.f4
		MOVi $ATDWRF #0 	; ATDWRF=0
	.f4:	FORi $I <A> @.l2	; } /* end loop */
	.e1:	NOOP
	return:	RETU   	; }


