;-----------------------------------------------------------------------------
fBUG:	FUNC
		PARA *1
	$NUM:	INPi
	$numString:	LOCA *3
;-----------------------------------------------------------------------------
		MOVp %1 &.s_Fatale4d2 	; output("Fatal error ")
		CALL ^output %0 *2
		DIVi %0 $NUM #10	; numString[0] = '0' + NUM / 10
		ADDi $numString:0 #'0' %0
		MODi %0 $NUM #10	; numString[1] = '0' + NUM % 10
		ADDi $numString:1 #'0' %0
		MOVi $numString:2 #0 	; numString[2] = 0
		ADRL %1 $numString *0	; output(numString)
		CALL ^output %0 *2
		MOVp %1 &.s_Seesou4d3 	; output(".  See source code for interpretation.\n")
		CALL ^output %0 *2
		CALL ^abort %0 *1	; abort()
		RETU   	; }

	GLOB *1
fRAN_R:	DATi #0

;-----------------------------------------------------------------------------
fRAN:	FUNC
	$RAN:	OUTi
	$RANGE:	INPi
	$D:	LOCi
	$T:	LOCi
;-----------------------------------------------------------------------------
		MOVi $D #1 	; D=1
		PEEK %0 &fRAN_R 	; if(!(global fRAN_R != 0 && RANGE >= 0)) 
		EQUi %0 #0 @.f0
		GEQi $RANGE #0 @.f1
	.f0:	MOVi $D #1999 	; D=1999
		CALL ^clock %0 *1	; T=(int)clock() & 0x7FFFFFFF
		ANDi $T %0 #0x7FFFFFFF
	.f1:	MOVi $T #1 	; for (T=1 to D+1) global fRAN_R=((global fRAN_R*1093+221587)%1048576)
		ADDi %0 $D #1
		GEQi #1 %0 @.e2
	.l3:	PEEK %1 &fRAN_R 	; global fRAN_R=((global fRAN_R*1093+221587)%1048576)
		MULi %1 %1 #1093
		ADDi %1 %1 #221587
		MODi %1 %1 #1048576
		POKE &fRAN_R %1 
		FORi $T %0 @.l3
	.e2:	PEEK %0 &fRAN_R 	; RAN=(RANGE*global fRAN_R)/1048576
		MULi %0 $RANGE %0
		DIVi $RAN %0 #1048576
		RETU   	; }

