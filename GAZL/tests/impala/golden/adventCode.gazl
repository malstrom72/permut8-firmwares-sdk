		NEQi $just_do_it #FALSE @.f0	; if(just_do_it == FALSE) 
		MOVi %1 #ROD2 	; if((int)TOTING(ROD2) != FALSE && lOBJ == ROD && (int)TOTING(ROD) == FALSE) 
		CALL &TOTING %0 *2
		EQUi %0 #FALSE @.f2
		NEQi $lOBJ #ROD @.f2
		MOVi %1 #ROD 
		CALL &TOTING %0 *2
		NEQi %0 #FALSE @.f2
