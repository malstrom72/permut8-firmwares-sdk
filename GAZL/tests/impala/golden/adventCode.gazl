		NEQi %0 #FALSE @.f3
		MOVi $goValue #GOTO2011 	; goValue = GOTO2011
		GOTO @return  	; goto return
		GOTO @.e4  	; }
	.f3:	NEQi $lOBJ #BIRD @.f6	; if(!(lOBJ != BIRD || (int)HERE(SNAKE, lLOC) == FALSE)) 
		MOVi %1 #SNAKE 
