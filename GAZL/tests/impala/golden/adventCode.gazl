	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
fSETPRM:	FUNC
		PARA *1
	$FIRST:	INPi
	$P1:	INPi
	$P2:	INPi
;-----------------------------------------------------------------------------
		LSSi $FIRST #25 @.f0	; if(FIRST >= 25)fBUG(29)
