;-----------------------------------------------------------------------------
reset:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		MOVp %1 &.s_reset4da 	; trace("reset")
		CALL ^trace %0 *2
		POKE &doReset #TRUE 	; global doReset = TRUE
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$i:	LOCi
	$fx:	LOCi
	$fxRnd:	LOCi
	$fxBits:	LOCi
	$fxCount:	LOCi
	$stepRate:	LOCi
	$fxParams:	LOCi
	$stepBits:	LOCi
	$fxs:	LOCA *8
	$fxCountFloat:	LOCf
;-----------------------------------------------------------------------------
		MOVp %1 &.s_update4db 	; trace("update")
		CALL ^trace %0 *2
		POKE &dirXor #0 	; global dirXor = 0
		PEEK %0 &params:SWITCHES_PARAM_INDEX 	; if (((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_REVERSE_MASK) != 0) 
		ANDi %0 %0 #SWITCHES_REVERSE_MASK
		EQUi %0 #0 @.f0
		POKE &dirXor #0xFFFF 	; global dirXor = 0xFFFF
	.f0:	PEEK $fxBits &params:OPERAND_1_HIGH_PARAM_INDEX 	; fxBits = (int) global params[OPERAND_1_HIGH_PARAM_INDEX]
		MOVi $fxCount #0 	; fxCount = 0
		PEEK $fxParams &params:OPERATOR_1_PARAM_INDEX 	; fxParams = (int) global params[OPERATOR_1_PARAM_INDEX]
		LEQi $fxParams #0 @.f1	; if (fxParams > 0) 
		MOVi $i #0 	; for (i = 0 to 8) 
		GEQi #0 #8 @.f1
	.l3:	SHRi %0 #0x80 $i	; if ((fxBits & (0x80 >> i)) != 0) 
		ANDi %0 $fxBits %0
		EQUi %0 #0 @.f4
		SETL $fxs $fxCount $i	; fxs[fxCount] = i
		ADDi $fxCount $fxCount #1	; fxCount = fxCount + 1
	.f4:	FORi $i #8 @.l3	; }
	.f1:	PEEK %1 &params:OPERAND_1_LOW_PARAM_INDEX 	; seedRandom((int) global params[OPERAND_1_LOW_PARAM_INDEX] + 1)
		ADDi %1 %1 #1
		CALL &seedRandom %0 *2
		PEEK %0 &params:OPERATOR_2_PARAM_INDEX 	; stepRate = (int) global params[OPERATOR_2_PARAM_INDEX] - 1
		SUBi $stepRate %0 #1
		GEQi $stepRate #0 @.f5	; if (stepRate < 0) 
		POKE &clockMask #0x0 	; global clockMask = 0x0
		POKE &clockShift #0 	; global clockShift = 0
		POKE &fxQuantize #0 	; global fxQuantize = 0
		POKE &stepFXs:0 #-1 	; global stepFXs[0] = -1
		LEQi $fxCount #0 @.e7	; if (fxCount > 0) 
		POKE &stepFXs:0 $fxs:0 	; global stepFXs[0] = fxs[0]
		GOTO @.e7  	; } else 
	.f5:	ANDi %0 $stepRate #1	; global clockMask = 0xFFFF | ((stepRate & 1) << 16)
		SHLi %0 %0 #16
		IORi %0 #0xFFFF %0
		POKE &clockMask %0 
		SHRi %0 $stepRate #1	; global clockShift = 12 | (stepRate >> 1)
		IORi %0 #12 %0
		POKE &clockShift %0 
		POKE &fxQuantize #0xFFF 	; global fxQuantize = 0xFFF
		NEQi $fxCount #0 @.f8	; if (fxCount == 0) 
		MOVi $i #0 	; for (i = 0 to STEP_COUNT) 
		GEQi #0 #STEP_COUNT @.e11
	.l10:	POKE &stepFXs $i #-1	; global stepFXs[i] = -1
		FORi $i #STEP_COUNT @.l10	; }
		GOTO @.e11  	; } else 
	.f8:	PEEK %0 &params:OPERAND_2_HIGH_PARAM_INDEX 	; stepBits = ((int) global params[OPERAND_2_HIGH_PARAM_INDEX] << 8) | (int) global params[OPERAND_2_LOW_PARAM_INDEX]
		SHLi %0 %0 #8
		PEEK %1 &params:OPERAND_2_LOW_PARAM_INDEX 
		IORi $stepBits %0 %1
		iTOf $fxCountFloat $fxCount #1.0	; fxCountFloat = itof(fxCount)
		SUBi $fxCount $fxCount #1	; fxCount = fxCount - 1
		MOVi $fx #-1 	; fx = -1
		MOVi $i #0 	; for (i = 0 to STEP_COUNT) 
		GEQi #0 #STEP_COUNT @.e12
	.l13:	CALL &randomFloat %0 *1	; fxRnd = ftoi((float) randomFloat() * fxCountFloat)
		MULf %0 %0 $fxCountFloat
		fTOi $fxRnd %0 #1.0
		LEQi $fxRnd $fxCount @.f14	; if (fxRnd > fxCount) 
		MOVi $fxRnd $fxCount 	; fxRnd = fxCount
	.f14:	ANDi %0 $i #15	; if (((stepBits << (i & 15)) & 0x8000) != 0) 
		SHLi %0 $stepBits %0
		ANDi %0 %0 #0x8000
		EQUi %0 #0 @.f15
		GEQi $fx #0 @.e17	; if (fx < 0) 
		GETL $fx $fxs $fxRnd	; fx = (int) fxs[fxRnd]
		GOTO @.e17  	; } else 
	.f15:	MOVi $fx #-1 	; fx = -1
	.e17:	POKE &stepFXs $i $fx	; global stepFXs[i] = fx
		FORi $i #STEP_COUNT @.l13	; }
	.e12:	NOOP
	.e11:	NOOP
	.e7:	MOVi $i #0 	; for (i = 0 to STEP_COUNT) 
		GEQi #0 #STEP_COUNT @.e18
	.l19:	SWCH $fxParams *5 @.s20	; switch (fxParams == 0 to 5) 
	.s20#0:	MOVi $fx #1 	; fx = 1
		GOTO @.e21  
	.s20#1:	MOVi $fx #1 	; fx = 1
		GOTO @.e21  
	.s20#2:	MOVi $fx #2 	; fx = 2
		GOTO @.e21  
	.s20#3:	MOVi $fx #0 	; fx = 0
		GOTO @.e21  
	.s20#4:	CALL &randomFloat %0 *1	; fx = ftoi((float) randomFloat() * 2.9999)
		fTOi $fx %0 #2.9999
	.s20:	NOOP
	.e21:	POKE &stepFXParams $i $fx	; global stepFXParams[i] = fx
		FORi $i #STEP_COUNT @.l19	; }
	.e18:	RETU   	; }


;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
	$i:	LOCi
	$p:	LOCp
	$fxRate:	LOCi
	$s:	LOCi
	$t:	LOCi
;-----------------------------------------------------------------------------
		MOVp %1 &.s_init4dc 	; trace("init")
		CALL ^trace %0 *2
		CALL &update %0 *1	; update()
		MOVp $p &FX_PARAMS 	; p = global FX_PARAMS
		MOVi $i #0 	; for (i = 0 to 3) 
		GEQi #0 #3 @.e0
	.l1:	SUBi $fxRate $i #1	; fxRate = i - 1
		ADDi %0 #1 $fxRate	; p[FX_PARAM_TAPE_STOP_RATE] = 4 << (1 + fxRate)
		SHLi %0 #4 %0
		POKE $p #FX_PARAM_TAPE_STOP_RATE %0
		SUBi %0 #1 $fxRate	; p[FX_PARAM_TRANCE_GATE_RATE] = 1 - fxRate
		POKE $p #FX_PARAM_TRANCE_GATE_RATE %0
		! XORi <A> #0 #-1	; p[FX_PARAM_BIT_CRUSH_MASK] = ~0 << (2 - fxRate)
		SUBi %0 #2 $fxRate
		SHLi %0 <A> %0
		POKE $p #FX_PARAM_BIT_CRUSH_MASK %0
		SUBi $s #10 $fxRate	; p[FX_PARAM_SHIFT_10] = (s = 10 - fxRate)
		POKE $p #FX_PARAM_SHIFT_10 $s
		SHLi $t #3 $s	; p[FX_PARAM_REPEAT_OFF_3] = (t = 3 << s)
		POKE $p #FX_PARAM_REPEAT_OFF_3 $t
		XORi %0 $t #-1	; p[FX_PARAM_REPEAT_MASK] = ~t
		POKE $p #FX_PARAM_REPEAT_MASK %0
		SHLi $t #1 $s	; p[FX_PARAM_1_LSHIFT_10] = (t = 1 << s)
		POKE $p #FX_PARAM_1_LSHIFT_10 $t
		SUBi %0 $t #1	; p[FX_PARAM_MASK_10] = t - 1
		POKE $p #FX_PARAM_MASK_10 %0
		SUBi $s #9 $fxRate	; p[FX_PARAM_SHIFT_9] = (s = 9 - fxRate)
		POKE $p #FX_PARAM_SHIFT_9 $s
		SHLi %0 #1 $s	; p[FX_PARAM_1_LSHIFT_9] = 1 << s
		POKE $p #FX_PARAM_1_LSHIFT_9 %0
		ADDp $p $p #FX_PARAM_COUNT	; p = p + FX_PARAM_COUNT
		FORi $i #3 @.l1	; }
	.e0:	RETU   	; }


;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	$i:	LOCi
	$x:	LOCi
	$mask:	LOCi
	$stepBits:	LOCi
	$trig:	LOCi
	$step:	LOCi
	$inp:	LOCA *2
	$outp:	LOCA *2
	$samples:	LOCA *4
	$fxParams:	LOCA *FX_PARAM_COUNT
	$clock:	LOCi
	$fx:	LOCi
	$held:	LOCi
	$mix:	LOCi
	$pos:	LOCi
	$posInc:	LOCi
;-----------------------------------------------------------------------------
	.l0:	PEEK %0 &doReset 	; if (global doReset != FALSE) 
		EQUi %0 #FALSE @.f1
		POKE &doReset #FALSE 	; global doReset = FALSE
		MOVi $clock #0 	; clock = 0
		MOVi $fx #-1 	; fx = -1
		MOVi $held #0 	; held = 0
		MOVi $mix #0 	; mix = 0
		MOVi $pos #0 	; pos = 0
		MOVi $posInc #0 	; posInc = 0
		ADRL %0 $fxParams *0	; copy (FX_PARAM_COUNT from global FX_PARAMS to fxParams)
		COPY %0 &FX_PARAMS *FX_PARAM_COUNT
	.f1:	MOVi $trig #FALSE 	; trig = FALSE
		PEEK %0 &clock 	; x = (int) global clock ^ (int) global dirXor
		PEEK %1 &dirXor 
		XORi $x %0 %1
		ANDi %0 $clock #0xFFFF	; if (x != (clock & 0xFFFF)) 
		EQUi $x %0 @.f2
		MOVi $clock $x 	; clock = x
		MOVi $trig #TRUE 	; trig = TRUE
	.f2:	PEEK %0 &fxQuantize 	; if ((clock & global fxQuantize) == 0) 
		ANDi %0 $clock %0
		NEQi %0 #0 @.f3
		PEEK %0 &dirXor 	; step = ((clock ^ (int) global dirXor) & global clockMask) >> global clockShift
		XORi %0 $clock %0
		PEEK %1 &clockMask 
		ANDi %0 %0 %1
		PEEK %1 &clockShift 
		SHRi $step %0 %1
		ANDi %0 $step #15	; global displayLEDs[2] = 0x80 >> (step & 15)
		SHRi %0 #0x80 %0
		POKE &displayLEDs:2 %0 
		ANDi %0 $step #15	; global displayLEDs[3] = 0x8000 >> (step & 15)
		SHRi %0 #0x8000 %0
		POKE &displayLEDs:3 %0 
		PEEK $x &stepFXs $step	; x = (int) global stepFXs[step]
		EQUi $x $fx @.f3	; if (x != fx) 
		MOVi $fx $x 	; fx = x
		LSSi $fx #0 @.f5	; if (fx >= 0) 
		MOVi $trig #TRUE 	; trig = TRUE
		MOVi $held $fx 	; held = fx
		SHRi %0 #0x80 $fx	; global displayLEDs[0] = 0x80 >> fx
		POKE &displayLEDs:0 %0 
		PEEK %0 &stepFXParams $step	; copy (FX_PARAM_COUNT from &global FX_PARAMS[(int) global stepFXParams[step] * FX_PARAM_COUNT] to fxParams)
		MULi %0 %0 #FX_PARAM_COUNT
		ADRL %1 $fxParams *0
		ADDp %0 &FX_PARAMS %0
		COPY %1 %0 *FX_PARAM_COUNT
		GOTO @.e6  	; } else 
	.f5:	POKE &displayLEDs:0 #0 	; global displayLEDs[0] = 0
	.e6:	NOOP
	.f3:	MOVi %1 $clock 	; write(clock, 1, global signal)
		MOVi %2 #1 
		MOVp %3 &signal 
		CALL ^write %0 *4
		MOVi %1 $clock 	; read(clock, 1, inp)
		MOVi %2 #1 
		ADRL %3 $inp *0
		CALL ^read %0 *4
		SWCH $held *8 @.s7	; switch (held == 0 to 8) 
	.s7#REVERSE_FX:	EQUi $trig #FALSE @.f9	; if (trig != FALSE) 
		MOVi $pos $clock 	; pos = clock
	.f9:	SUBi $pos $pos #1	; pos = pos - 1
		MOVi %1 $pos 	; read(pos, 1, outp)
		MOVi %2 #1 
		ADRL %3 $outp *0
		CALL ^read %0 *4
		GOTO @.e8  	; }
	.s7#TAPE_STOP_FX:	EQUi $trig #FALSE @.f10	; if (trig != FALSE) 
		SHLi $pos $clock #16	; pos = clock << 16
		MOVi $posInc #0x10000 	; posInc = 0x10000
	.f10:	ANDi $x $pos #0xFFFF	; x = pos & 0xFFFF
		SHRi %1 $pos #16	; read(pos >> 16, 2, samples)
		MOVi %2 #2 
		ADRL %3 $samples *0
		CALL ^read %0 *4
		SUBi %0 $samples:2 $samples:0	; outp[0] = (int) samples[0] + (((int) samples[2] - (int) samples[0]) * x >> 16)
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $outp:0 $samples:0 %0
		SUBi %0 $samples:3 $samples:1	; outp[1] = (int) samples[1] + (((int) samples[3] - (int) samples[1]) * x >> 16)
		MULi %0 %0 $x
		SHRi %0 %0 #16
		ADDi $outp:1 $samples:1 %0
		ADDi $pos $pos $posInc	; pos = pos + posInc
		SUBi $posInc $posInc $fxParams:FX_PARAM_TAPE_STOP_RATE	; posInc = posInc - (int) fxParams[FX_PARAM_TAPE_STOP_RATE]
		GEQi $posInc #0 @.e8	; if (posInc < 0) 
		MOVi $posInc #0 	; posInc = 0
		GOTO @.e8  	; }
	.s7#HALF_SPEED_EFFECT:	EQUi $trig #FALSE @.f12	; if (trig != FALSE) 
		SHLi $pos $clock #1	; pos = clock << 1
	.f12:	SHRi %1 $pos #1	; read(pos >> 1, 1, outp)
		MOVi %2 #1 
		ADRL %3 $outp *0
		CALL ^read %0 *4
		ADDi $pos $pos #1	; pos = pos + 1
		GOTO @.e8  	; }
	.s7#TRANCE_GATE_EFFECT:	SHRi %0 $clock $fxParams:FX_PARAM_TRANCE_GATE_RATE	; x = (clock >> (int) fxParams[FX_PARAM_TRANCE_GATE_RATE]) & 0x7FF
		ANDi $x %0 #0x7FF
		GEQi $x #0x280 @.f13	; if (x < 0x280) 
		MOVi $x #0x1800 	; x = 0x1800
		GOTO @.e14  	; } else if (x < 0x400) 
	.f13:	GEQi $x #0x400 @.f15	; if (x < 0x400) 
		SUBi %0 $x #0x280	; x = 0x1800 - ((x - 0x280) << 4)
		SHLi %0 %0 #4
		SUBi $x #0x1800 %0
		GOTO @.e16  	; } else if (x < 0x7A0) 
	.f15:	GEQi $x #0x7A0 @.f17	; if (x < 0x7A0) 
		MOVi $x #0x0 	; x = 0x0
		GOTO @.e18  	; } else 
	.f17:	SUBi %0 $x #0x7A0	; x = (x - 0x7A0) << 6
		SHLi $x %0 #6
	.e18:	NOOP
	.e16:	NOOP
	.e14:	MULi %0 $inp:0 $x	; outp[0] = (int) inp[0] * x >> 12
		SHRi $outp:0 %0 #12
		MULi %0 $inp:1 $x	; outp[1] = (int) inp[1] * x >> 12
		SHRi $outp:1 %0 #12
		GOTO @.e8  	; }
	.s7#BIT_CRUSH_EFFECT:	ANDi %1 $clock $fxParams:FX_PARAM_BIT_CRUSH_MASK	; read(clock & (int) fxParams[FX_PARAM_BIT_CRUSH_MASK], 1, outp)
		MOVi %2 #1 
		ADRL %3 $outp *0
		CALL ^read %0 *4
		! XORi <A> #0x7F #-1	; outp[0] = (int) outp[0] & ~0x7F
		ANDi $outp:0 $outp:0 <A>
		! XORi <A> #0x7F #-1	; outp[1] = (int) outp[1] & ~0x7F
		ANDi $outp:1 $outp:1 <A>
		SHRi %0 $outp:0 #1	; outp[0] = (int) outp[0] + ((int) outp[0] >> 1)
		ADDi $outp:0 $outp:0 %0
		SHRi %0 $outp:1 #1	; outp[1] = (int) outp[1] + ((int) outp[1] >> 1)
		ADDi $outp:1 $outp:1 %0
		GOTO @.e8  	; }
	.s7#REPEAT_EFFECT:	ANDi $pos $clock $fxParams:FX_PARAM_REPEAT_MASK	; pos = clock & (int) fxParams[FX_PARAM_REPEAT_MASK]
		MOVi %1 $pos 	; read(pos, 1, samples)
		MOVi %2 #1 
		ADRL %3 $samples *0
		CALL ^read %0 *4
		ANDi %0 $clock $fxParams:FX_PARAM_REPEAT_OFF_3	; if ((clock & (int) fxParams[FX_PARAM_REPEAT_OFF_3]) == (int) fxParams[FX_PARAM_REPEAT_OFF_3]) 
		NEQi %0 $fxParams:FX_PARAM_REPEAT_OFF_3 @.f19
		ADDi $pos $pos $fxParams:FX_PARAM_REPEAT_OFF_3	; pos = pos + (int) fxParams[FX_PARAM_REPEAT_OFF_3]
		GOTO @.e20  	; } else 
	.f19:	SUBi $pos $pos $fxParams:FX_PARAM_1_LSHIFT_10	; pos = pos - (int) fxParams[FX_PARAM_1_LSHIFT_10]
	.e20:	ANDi %0 $clock $fxParams:FX_PARAM_MASK_10	; x = (clock & (int) fxParams[FX_PARAM_MASK_10]) * 2 - (int) fxParams[FX_PARAM_1_LSHIFT_10]
		MULi %0 %0 #2
		SUBi $x %0 $fxParams:FX_PARAM_1_LSHIFT_10
		GEQi $x #0 @.f21	; if (x < 0) 
		MOVi $x #0 	; x = 0
		GOTO @.e22  	; } else if (x > (int) fxParams[FX_PARAM_MASK_10]) 
	.f21:	LEQi $x $fxParams:FX_PARAM_MASK_10 @.f23	; if (x > (int) fxParams[FX_PARAM_MASK_10]) 
		MOVi $x $fxParams:FX_PARAM_MASK_10 	; x = (int) fxParams[FX_PARAM_MASK_10]
	.f23:	NOOP
	.e22:	MOVi %1 $pos 	; read(pos, 1, &samples[2])
		MOVi %2 #1 
		ADRL %3 $samples:2 *0
		CALL ^read %0 *4
		SUBi %0 $samples:2 $samples:0	; outp[0] = (int) samples[0] + (((int) samples[2] - (int) samples[0]) * x >> (int) fxParams[FX_PARAM_SHIFT_10])
		MULi %0 %0 $x
		SHRi %0 %0 $fxParams:FX_PARAM_SHIFT_10
		ADDi $outp:0 $samples:0 %0
		SUBi %0 $samples:3 $samples:1	; outp[1] = (int) samples[1] + (((int) samples[3] - (int) samples[1]) * x >> (int) fxParams[FX_PARAM_SHIFT_10])
		MULi %0 %0 $x
		SHRi %0 %0 $fxParams:FX_PARAM_SHIFT_10
		ADDi $outp:1 $samples:1 %0
		GOTO @.e8  	; }
	.s7#STRETCH_EFFECT:	EQUi $trig #FALSE @.f24	; if (trig != FALSE) 
		MOVi $pos $clock 	; pos = clock
	.f24:	MOVi %1 $pos 	; read(pos, 1, samples)
		MOVi %2 #1 
		ADRL %3 $samples *0
		CALL ^read %0 *4
		SUBi %1 $pos $fxParams:FX_PARAM_1_LSHIFT_9	; read(pos - (int) fxParams[FX_PARAM_1_LSHIFT_9], 1, &samples[2])
		MOVi %2 #1 
		ADRL %3 $samples:2 *0
		CALL ^read %0 *4
		ANDi $x $clock $fxParams:FX_PARAM_MASK_10	; x = clock & (int) fxParams[FX_PARAM_MASK_10]
		SUBi %0 $samples:2 $samples:0	; outp[0] = (int) samples[0] + (((int) samples[2] - (int) samples[0]) * x >> (int) fxParams[FX_PARAM_SHIFT_10])
		MULi %0 %0 $x
		SHRi %0 %0 $fxParams:FX_PARAM_SHIFT_10
		ADDi $outp:0 $samples:0 %0
		SUBi %0 $samples:3 $samples:1	; outp[1] = (int) samples[1] + (((int) samples[3] - (int) samples[1]) * x >> (int) fxParams[FX_PARAM_SHIFT_10])
		MULi %0 %0 $x
		SHRi %0 %0 $fxParams:FX_PARAM_SHIFT_10
		ADDi $outp:1 $samples:1 %0
		ADDi $pos $pos #1	; pos = pos + 1
		NEQi $x $fxParams:FX_PARAM_MASK_10 @.e8	; if (x == (int) fxParams[FX_PARAM_MASK_10]) 
		SUBi $pos $pos $fxParams:FX_PARAM_1_LSHIFT_9	; pos = pos - (int) fxParams[FX_PARAM_1_LSHIFT_9]
		GOTO @.e8  	; }
	.s7#PITCH_SHIFT_EFFECT:	SUBi %0 $fxParams:FX_PARAM_1_LSHIFT_9 #1	; x = clock & ((int) fxParams[FX_PARAM_1_LSHIFT_9] - 1)
		ANDi $x $clock %0
		SUBi %0 $fxParams:FX_PARAM_1_LSHIFT_9 #1	; pos = (clock & ~((int) fxParams[FX_PARAM_1_LSHIFT_9] - 1)) + x * 2
		XORi %0 %0 #-1
		ANDi %0 $clock %0
		MULi %1 $x #2
		ADDi $pos %0 %1
		SUBi %1 $pos $fxParams:FX_PARAM_1_LSHIFT_9	; read(pos - (int) fxParams[FX_PARAM_1_LSHIFT_9], 1, samples)
		MOVi %2 #1 
		ADRL %3 $samples *0
		CALL ^read %0 *4
		SUBi %1 $pos $fxParams:FX_PARAM_1_LSHIFT_10	; read(pos - (int) fxParams[FX_PARAM_1_LSHIFT_10], 1, &samples[2])
		MOVi %2 #1 
		ADRL %3 $samples:2 *0
		CALL ^read %0 *4
		SUBi %0 $samples:2 $samples:0	; outp[0] = (int) samples[0] + (((int) samples[2] - (int) samples[0]) * x >> (int) fxParams[FX_PARAM_SHIFT_9])
		MULi %0 %0 $x
		SHRi %0 %0 $fxParams:FX_PARAM_SHIFT_9
		ADDi $outp:0 $samples:0 %0
		SUBi %0 $samples:3 $samples:1	; outp[1] = (int) samples[1] + (((int) samples[3] - (int) samples[1]) * x >> (int) fxParams[FX_PARAM_SHIFT_9])
		MULi %0 %0 $x
		SHRi %0 %0 $fxParams:FX_PARAM_SHIFT_9
		ADDi $outp:1 $samples:1 %0
	.s7:	NOOP
	.e8:	LSSi $fx #0 @.f26	; if (fx >= 0) 
		ADDi $mix $mix #0x800	; mix = mix + 0x800
		LEQi $mix #0x8000 @.e28	; if (mix > 0x8000) 
		MOVi $mix #0x8000 	; mix = 0x8000
		GOTO @.e28  	; } else 
	.f26:	SUBi $mix $mix #0x100	; mix = mix - 0x100
		GEQi $mix #0 @.f29	; if (mix < 0) 
		MOVi $mix #0 	; mix = 0
	.f29:	NOOP
	.e28:	SUBi %0 $outp:0 $inp:0	; global signal[0] = (int) inp[0] + (((int) outp[0] - (int) inp[0]) * mix >> 15)
		MULi %0 %0 $mix
		SHRi %0 %0 #15
		ADDi %0 $inp:0 %0
		POKE &signal:0 %0 
		SUBi %0 $outp:1 $inp:1	; global signal[1] = (int) inp[1] + (((int) outp[1] - (int) inp[1]) * mix >> 15)
		MULi %0 %0 $mix
		SHRi %0 %0 #15
		ADDi %0 $inp:1 %0
		POKE &signal:1 %0 
		CALL ^yield %0 *1	; yield()
		ADDi $clock $clock #1	; clock = clock + 1
		GOTO @.l0  	; }
		RETU   	; }

.s_stdREV4d2:	CNST *25
	DATs std  REVERSE     STRETCH
	DATi #0
.s_fastCR4d3:	CNST *50
	DATs fast |  CRUSH    |  PITCH    <--- Enabled Effects
	DATi #0
.s_slowCH4d4:	CNST *53
	DATs slow |  |  CHOP  |  |  SLOW    _____________________
	DATi #0
.s_rndAK44d5:	CNST *54
	DATs rnd  |  |  | AK47|  |  | STOP /  Random Order Seed  \
	DATi #0
.s_16164d6:	CNST *6
	DATs 16/16
	DATi #0
.s_32164d7:	CNST *6
	DATs 32/16
	DATi #0
.s_884d8:	CNST *53
	DATs 8/8   ______________________________________________
	DATi #0
.s_168Gat4d9:	CNST *54
	DATs 16/8 /  Gates (prev step off = trigger new effect)  \
	DATi #0
.s_reset4da:	CNST *6
	DATs reset
	DATi #0
.s_update4db:	CNST *7
	DATs update
	DATi #0
.s_init4dc:	CNST *5
	DATs init
	DATi #0