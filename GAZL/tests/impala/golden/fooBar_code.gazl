FALSE:	! DEFi #0
TRUE:	! DEFi #1
panelTextRows:	CNST *8
	DATA &.s_stdREV4d2 &.s_fastCR4d3 &.s_slowCH4d4
	DATA &.s_rndAK44d5 &.s_16164d6 &.s_32164d7 &.s_884d8
	DATA &.s_168Gat4d9
	GLOB *1
clock:	DATi #0
params:	GLOB *PARAM_COUNT
