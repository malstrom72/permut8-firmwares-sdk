		CALL &outputLine %0 *2
		MOVp %1 &.s_randis4d9 	; outputLine("    'rand %' (% is likelihood of setting a cell from 0 to 100 %)")
		CALL &outputLine %0 *2
		MOVp %1 &.s_quit4da 	; outputLine("    'quit'")
		CALL &outputLine %0 *2
		MOVp %1 &.s_quit4da:10 	; outputLine("")
		CALL &outputLine %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
run:	FUNC
		PARA *1
	$dimX:	INPi
	$dimY:	INPi
	$cells:	INPp
	$generations:	INPi
	! MULi <A> #MAX_DIM_X #MAX_DIM_Y
	$genCounter:	LOCi
	$x_1:	LOCi
	$x:	LOCi
	$x1:	LOCi
	$y_1:	LOCi
	$y:	LOCi
	$y1:	LOCi
	$n:	LOCi
	$c:	LOCi
	$i:	LOCi
	$size:	LOCi
	$cells2:	LOCA *<A>
	$p1:	LOCp
	$p2:	LOCp
	$t:	LOCp
;-----------------------------------------------------------------------------
		MOVp $p1 $cells 	; p1 = cells
		ADRL $p2 $cells2 *0	; p2 = cells2
		MULi $size $dimY $dimX	; size = dimY * dimX
		MOVi $genCounter #0 	; for (genCounter = 0 to generations) 
		GEQi #0 $generations @.e0
	.l1:	SUBi $y $size $dimX	; y = size - dimX
	.l2:	LSSi $y #0 @.e3	; while (y >= 0) 
		SUBi %0 $y $dimX	; y_1 = (((y - dimX) + size) % size)
		ADDi %0 %0 $size
		MODi $y_1 %0 $size
		ADDi %0 $y $dimX	; y1 = ((y + dimX) % size)
		MODi $y1 %0 $size
		MOVi $x #0 	; for (x = 0 to dimX) 
		GEQi #0 $dimX @.e4
	.l5:	SUBi %0 $x #1	; x_1 = ((x - 1) + dimX) % dimX
		ADDi %0 %0 $dimX
		MODi $x_1 %0 $dimX
		ADDi %0 $x #1	; x1 = (x + 1) % dimX
		MODi $x1 %0 $dimX
		ADDi %0 $y_1 $x_1	; n = (int)p1[y_1 + x_1]
		PEEK $n $p1 %0
		ADDi %0 $y_1 $x	; n = n + (int)p1[y_1 + x]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		ADDi %0 $y_1 $x1	; n = n + (int)p1[y_1 + x1]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		ADDi %0 $y $x_1	; n = n + (int)p1[y + x_1]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		ADDi %0 $y $x1	; n = n + (int)p1[y + x1]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		ADDi %0 $y1 $x_1	; n = n + (int)p1[y1 + x_1]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		ADDi %0 $y1 $x	; n = n + (int)p1[y1 + x]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		ADDi %0 $y1 $x1	; n = n + (int)p1[y1 + x1]
		PEEK %0 $p1 %0
		ADDi $n $n %0
		MOVi $c #0 	; c = 0
		EQUi $n #3 @.t6	; if (n == 3 || (n == 2 && (int)p1[y + x] == 1)) c = 1
		NEQi $n #2 @.f8
		ADDi %0 $y $x
		PEEK %0 $p1 %0
		NEQi %0 #1 @.f8
	.t6:	MOVi $c #1 	; c = 1
	.f8:	ADDi %0 $y $x	; p2[y + x] = c
		POKE $p2 %0 $c
		FORi $x $dimX @.l5	; }
	.e4:	SUBi $y $y $dimX	; y = y - dimX
		GOTO @.l2  	; }
	.e3:	MOVp $t $p1 	; t = p1
		MOVp $p1 $p2 	; p1 = p2
		MOVp $p2 $t 	; p2 = t
		FORi $genCounter $generations @.l1	; }
	.e0:	EQUp $p1 $cells @.f9	; if (p1 != cells) 
		MOVi $i #0 	; for (i = 0 to size) cells[i] = cells2[i]
		GEQi #0 $size @.f9
	.l11:	GETL %0 $cells2 $i	; cells[i] = cells2[i]
		POKE $cells $i %0
		FORi $i $size @.l11
	.f9:	RETU   	; }


;-----------------------------------------------------------------------------
outputCellsAlive:	FUNC
	$n:	OUTi
	$dimX:	INPi
	$dimY:	INPi
	$cells:	INPp
	$i:	LOCi
;-----------------------------------------------------------------------------
		MOVi $n #0 	; n = 0
		MOVi $i #0 	; for (i = 0 to dimX * dimY) if ((int)cells[i] != 0) n = n + 1
		MULi %0 $dimX $dimY
		GEQi #0 %0 @.e0
	.l1:	PEEK %1 $cells $i	; if ((int)cells[i] != 0) n = n + 1
		EQUi %1 #0 @.f2
		ADDi $n $n #1	; n = n + 1
	.f2:	FORi $i %0 @.l1
	.e0:	MOVp %1 &.s_4db 	; output("(")
		CALL ^output %0 *2
		MOVi %1 $n 	; outputInt(n)
		CALL &outputInt %0 *2
		MOVp %1 &.s_cellsa4dc 	; outputLine(" cells alive)")
		CALL &outputLine %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
randomize:	FUNC
		PARA *1
	$dimX:	INPi
	$dimY:	INPi
	$cells:	INPp
	$percentage:	INPi
	$i:	LOCi
;-----------------------------------------------------------------------------
		MOVi $i #0 	; for (i = 0 to dimX * dimY) 
		MULi %0 $dimX $dimY
		GEQi #0 %0 @.e0
	.l1:	CALL &xorShiftRandom %1 *1	; if (((int)xorShiftRandom() & 0x7FFFFFFF) % 100 <= percentage) cells[i] = 1
		ANDi %1 %1 #0x7FFFFFFF
		MODi %1 %1 #100
		GRTi %1 $percentage @.f2
		POKE $cells $i #1	; cells[i] = 1
	.f2:	FORi $i %0 @.l1	; }
	.e0:	RETU   	; }


;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
	! MULi <A> #MAX_DIM_X #MAX_DIM_Y
	$dimX:	LOCi
	$dimY:	LOCi
	$s:	LOCA *256
	$quit:	LOCi
	$i:	LOCi
	$j:	LOCi
	$x:	LOCi
	$y:	LOCi
	$n:	LOCi
	$cells:	LOCA *<A>
	$c:	LOCi
	$firstTime:	LOCi
	$redraw:	LOCi
;-----------------------------------------------------------------------------
		MOVp %1 &.s_Enterd4dd 	; output("Enter dimensions (X,Y): ")
		CALL ^output %0 *2
		MOVi %1 #255 	; input(255, s)
		ADRL %2 $s *0
		CALL ^input %0 *3
		ADRL %1 $s *0	; parseXY(s, &dimX, &dimY)
		ADRL %2 $dimX *0
		ADRL %3 $dimY *0
		CALL &parseXY %0 *4
		LEQi $dimX #0 @.t0	; if (dimX <= 0 || dimY <= 0) outputLine("Invalid dimensions. Bye!")
		GRTi $dimY #0 @.f1
	.t0:	MOVp %1 &.s_Invali4de 	; outputLine("Invalid dimensions. Bye!")
		CALL &outputLine %0 *2
		GOTO @.e2  
	.f1:	GRTi $dimX #MAX_DIM_X @.t3	; if (dimX > MAX_DIM_X || dimY > MAX_DIM_Y) 
		LEQi $dimY #MAX_DIM_Y @.f4
	.t3:	MOVp %1 &.s_Toolar4df 	; output("Too large. Max dimensions are ")
		CALL ^output %0 *2
		MOVi %1 #MAX_DIM_X 	; outputInt(MAX_DIM_X)
		CALL &outputInt %0 *2
		MOVp %1 &.s_4e0 	; output(",")
		CALL ^output %0 *2
		MOVi %1 #MAX_DIM_Y 	; outputInt(MAX_DIM_Y)
		CALL &outputInt %0 *2
		MOVp %1 &.s_4e1 	; outputLine(".")
		CALL &outputLine %0 *2
		GOTO @.e5  	; } else 
	.f4:	MOVi $i #0 	; for (i = 0 to (dimX * dimY)) cells[i] = 0
		MULi %0 $dimX $dimY
		GEQi #0 %0 @.e6
	.l7:	SETL $cells $i #0	; cells[i] = 0
		FORi $i %0 @.l7
	.e6:	MOVi $firstTime #TRUE 	; firstTime = TRUE
		MOVi $quit #FALSE 	; quit = FALSE
	.l8:	MOVi $s:0 #12 	; s[0] = 12
		MOVi $s:1 #0 	; s[1] = 0
		ADRL %1 $s *0	; output(s)
		CALL ^output %0 *2
		MOVi $i #0 	; for (i = 0 to 3) s[i] = ' '
		GEQi #0 #3 @.e9
	.l10:	SETL $s $i #' '	; s[i] = ' '
		FORi $i #3 @.l10
	.e9:	MOVi $i #0 	; for (i = 0 to dimX) 
		GEQi #0 $dimX @.e11
	.l12:	ADDi %0 $i #3	; s[i + 3] = ' '
		SETL $s %0 #' '
		LSSi $i #10 @.f13	; if (i >= 10) s[i + 3] = '0' + i / 10
		ADDi %0 $i #3	; s[i + 3] = '0' + i / 10
		DIVi %1 $i #10
		ADDi %1 #'0' %1
		SETL $s %0 %1
	.f13:	FORi $i $dimX @.l12	; }
	.e11:	ADDi %1 $dimX #3	; s[dimX + 3] = 0
		SETL $s %1 #0
		ADRL %1 $s *0	; outputLine(s)
		CALL &outputLine %0 *2
		MOVi $i #0 	; for (i = 0 to dimX) s[i + 3] = '0' + i % 10
		GEQi #0 $dimX @.e14
	.l15:	ADDi %0 $i #3	; s[i + 3] = '0' + i % 10
		MODi %1 $i #10
		ADDi %1 #'0' %1
		SETL $s %0 %1
		FORi $i $dimX @.l15
	.e14:	ADRL %1 $s *0	; outputLine(s)
		CALL &outputLine %0 *2
		MOVi $i #0 	; for (i = 0 to dimY) 
		GEQi #0 $dimY @.e16
	.l17:	LSSi $i #10 @.f18	; if (i >= 10) s[0] = '0' + i / 10
		DIVi %0 $i #10	; s[0] = '0' + i / 10
		ADDi $s:0 #'0' %0
	.f18:	MODi %0 $i #10	; s[1] = '0' + i % 10
		ADDi $s:1 #'0' %0
		MOVi $j #0 	; for (j = 0 to dimX) 
		GEQi #0 $dimX @.e19
	.l20:	MOVi $c #'.' 	; c = '.'
		MULi %0 $i $dimX	; if ((int)cells[i * dimX + j] != 0) c = 'X'
		ADDi %0 %0 $j
		GETL %0 $cells %0
		EQUi %0 #0 @.f21
		MOVi $c #'X' 	; c = 'X'
	.f21:	ADDi %0 $j #3	; s[j + 3] = c
		SETL $s %0 $c
		FORi $j $dimX @.l20	; }
	.e19:	ADDi %0 $j #3	; s[j + 3] = 0
		SETL $s %0 #0
		ADRL %1 $s *0	; outputLine(s)
		CALL &outputLine %0 *2
		FORi $i $dimY @.l17	; }
	.e16:	EQUi $firstTime #FALSE @.f22	; if (firstTime != FALSE) 
		CALL &help %0 *1	; help()
		MOVi $firstTime #FALSE 	; firstTime = FALSE
	.f22:	MOVi $redraw #FALSE 	; redraw = FALSE
	.l23:	MOVp %1 &.s_life4e2 	; output("life> ")
		CALL ^output %0 *2
		MOVi %1 #255 	; input(255, s)
		ADRL %2 $s *0
		CALL ^input %0 *3
		ADRL %1 $s *0	; if ((int)strcmp(s, "quit") == 0) 
		MOVp %2 &.s_quit4e3 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f24
		MOVi $quit #TRUE 	; quit = TRUE
		GOTO @.e25  	; } else if ((int)s[0] == 0) 
	.f24:	NEQi $s:0 #0 @.f26	; if ((int)s[0] == 0) 
		MOVi $redraw #TRUE 	; redraw = TRUE
		GOTO @.e27  	; } else if ((int)strcmp(s, "clear") == 0) 
	.f26:	ADRL %1 $s *0	; if ((int)strcmp(s, "clear") == 0) 
		MOVp %2 &.s_clear4e4 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f28
		MOVi $i #0 	; for (i = 0 to dimX * dimY) cells[i] = 0
		MULi %0 $dimX $dimY
		GEQi #0 %0 @.e29
	.l30:	SETL $cells $i #0	; cells[i] = 0
		FORi $i %0 @.l30
	.e29:	MOVp %1 &.s_Cleare4e5 	; outputLine("Cleared all cells.")
		CALL &outputLine %0 *2
		GOTO @.e31  	; } else if ((int)strncmp(s, "rand ", 5) == 0) 
	.f28:	ADRL %1 $s *0	; if ((int)strncmp(s, "rand ", 5) == 0) 
		MOVp %2 &.s_rand4e6 
		MOVi %3 #5 
		CALL &strncmp %0 *4
		NEQi %0 #0 @.f32
		ADRL %1 $s:5 *0	; i = (int)parseInt(&s[5], -10000)
		MOVi %2 #-10000 
		CALL &parseInt %0 *3
		MOVi $i %0 
		LSSi $i #0 @.t33	; if (i < 0 || i > 100) help()
		LEQi $i #100 @.f34
	.t33:	CALL &help %0 *1	; help()
		GOTO @.e36  
	.f34:	MOVi %1 $dimX 	; randomize(dimX, dimY, cells, i)
		MOVi %2 $dimY 
		ADRL %3 $cells *0
		MOVi %4 $i 
		CALL &randomize %0 *5
		MOVp %1 &.s_Random4e7 	; output("Randomized with ")
		CALL ^output %0 *2
		MOVi %1 $i 	; outputInt(i)
		CALL &outputInt %0 *2
		MOVp %1 &.s_4e8 	; output(" %. ")
		CALL ^output %0 *2
		MOVi %1 $dimX 	; outputCellsAlive(dimX, dimY, cells)
		MOVi %2 $dimY 
		ADRL %3 $cells *0
		CALL &outputCellsAlive %0 *4
	.e35:	GOTO @.e36  	; } else 
	.f32:	ADRL %1 $s *0	; i = (int)parseInt(s, -10000)
		MOVi %2 #-10000 
		CALL &parseInt %0 *3
		MOVi $i %0 
		LSSi $i #0 @.f37	; if (i >= 0) 
		GRTi $i #MAX_GENERATIONS @.f38	; if (i <= MAX_GENERATIONS) 
		MOVi %1 $dimX 	; run(dimX, dimY, cells, i)
		MOVi %2 $dimY 
		ADRL %3 $cells *0
		MOVi %4 $i 
		CALL &run %0 *5
		MOVp %1 &.s_Ran4e9 	; output("Ran ")
		CALL ^output %0 *2
		MOVi %1 $i 	; outputInt(i)
		CALL &outputInt %0 *2
		MOVp %1 &.s_genera4ea 	; output(" generations. ")
		CALL ^output %0 *2
		MOVi %1 $dimX 	; outputCellsAlive(dimX, dimY, cells)
		MOVi %2 $dimY 
		ADRL %3 $cells *0
		CALL &outputCellsAlive %0 *4
		GOTO @.e40  	; } else 
	.f38:	MOVp %1 &.s_Maxgen4eb 	; output("Max generations is ")
		CALL ^output %0 *2
		MOVi %1 #MAX_GENERATIONS 	; outputInt(MAX_GENERATIONS)
		CALL &outputInt %0 *2
		MOVp %1 &.s_Cleare4e5:17 	; outputLine(".")
		CALL &outputLine %0 *2
	.e39:	GOTO @.e40  	; } else 
	.f37:	ADRL %1 $s *0	; parseXY(s, &x, &y)
		ADRL %2 $x *0
		ADRL %3 $y *0
		CALL &parseXY %0 *4
		LSSi $x #0 @.f42	; if (x >= 0 && y >= 0) 
		LSSi $y #0 @.f42
		GEQi $x $dimX @.f44	; if (x < dimX && y < dimY) 
		GEQi $y $dimY @.f44
		MULi %0 $y $dimX	; i = y * dimX + x
		ADDi $i %0 $x
		GETL %0 $cells $i	; c = (int)cells[i] ^ 1
		XORi $c %0 #1
		SETL $cells $i $c	; cells[i] = c
		EQUi $c #0 @.f45	; if (c != 0) output("Set ")
		MOVp %1 &.s_Set4ec 	; output("Set ")
		CALL ^output %0 *2
		GOTO @.e46  
	.f45:	MOVp %1 &.s_Reset4ed 	; output("Reset ")
		CALL ^output %0 *2
	.e46:	MOVp %1 &.s_cell4ee 	; output("cell ")
		CALL ^output %0 *2
		MOVi %1 $x 	; outputInt(x)
		CALL &outputInt %0 *2
		MOVp %1 &.s_4e0 	; output(",")
		CALL ^output %0 *2
		MOVi %1 $y 	; outputInt(y)
		CALL &outputInt %0 *2
		MOVp %1 &.s_genera4ea:12 	; output(". ")
		CALL ^output %0 *2
		MOVi %1 $dimX 	; outputCellsAlive(dimX, dimY, cells)
		MOVi %2 $dimY 
		ADRL %3 $cells *0
		CALL &outputCellsAlive %0 *4
		GOTO @.e48  	; } else 
	.f44:	MOVp %1 &.s_Invali4ef 	; outputLine("Invalid coordinates.")
		CALL &outputLine %0 *2
	.e47:	GOTO @.e48  	; } else 
	.f42:	CALL &help %0 *1	; help()
	.e48:	NOOP
	.e40:	NOOP
	.e36:	NOOP
	.e31:	NOOP
	.e27:	NOOP
	.e25:	NEQi $redraw #FALSE @.f49	; } while (redraw == FALSE && quit == FALSE)
		EQUi $quit #FALSE @.l23
	.f49:	EQUi $quit #FALSE @.l8	; } while (quit == FALSE)
		MOVp %1 &.s_Invali4ef:20 	; outputLine("")
		CALL &outputLine %0 *2
