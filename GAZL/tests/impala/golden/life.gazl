FALSE:	! DEFi #0
TRUE:	! DEFi #1
MAX_DIM_X:	! DEFi #76
MAX_DIM_Y:	! DEFi #23
MAX_GENERATIONS:	! DEFi #1000
	GLOB *1
xorShiftRandomSeedX:	DATi #123456789
	GLOB *1
xorShiftRandomSeedY:	DATi #362436069

;-----------------------------------------------------------------------------
xorShiftRandom:	FUNC
	$y:	OUTi
	$x:	LOCi
	$t:	LOCi
;-----------------------------------------------------------------------------
		PEEK $x &xorShiftRandomSeedX 	; x = global xorShiftRandomSeedX
		PEEK $y &xorShiftRandomSeedY 	; y = global xorShiftRandomSeedY
		SHLi %0 $x #10	; t = x ^ (x << 10)
		XORi $t $x %0
		MOVi $x $y 	; x = y
		SHRu %0 $y #13	; y = y ^ (y >>> 13) ^ t ^ (t >>> 10)
		XORi %0 $y %0
		XORi %0 %0 $t
		SHRu %1 $t #10
		XORi $y %0 %1
		POKE &xorShiftRandomSeedX $x 	; global xorShiftRandomSeedX = x
		POKE &xorShiftRandomSeedY $y 	; global xorShiftRandomSeedY = y
		RETU   	; }


;-----------------------------------------------------------------------------
eatWhite:	FUNC
	$q:	OUTp
	$p:	INPp
;-----------------------------------------------------------------------------
		MOVp $q $p 	; q = p
	.l0:	PEEK %0 $q 	; while ((int)*q == ' ') q = q + 1
		NEQi %0 #' ' @.e1
		ADDp $q $q #1	; q = q + 1
		GOTO @.l0  
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
outputLine:	FUNC
		PARA *1
	$s:	INPp
;-----------------------------------------------------------------------------
		MOVp %1 $s 	; output(s)
		CALL ^output %0 *2
		MOVp %1 &.s_4d2 	; output("\n")
		CALL ^output %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
strcmp:	FUNC
	$d:	OUTi
	$s0:	INPp
	$s1:	INPp
	$a:	LOCp
	$b:	LOCp
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVp $a $s0 	; a = s0
		MOVp $b $s1 	; b = s1
	.l0:	PEEK $c $a 	; while ((d = (c = (int)*a) - (int)*b) == 0 && c != 0) 
		PEEK %0 $b 
		SUBi $d $c %0
		NEQi $d #0 @.e2
		EQUi $c #0 @.e2
		ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		GOTO @.l0  	; }
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
strncmp:	FUNC
	$d:	OUTi
	$s0:	INPp
	$s1:	INPp
	$n:	INPi
	$a:	LOCp
	$b:	LOCp
	$i:	LOCi
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVi $d #0 	; d = 0
		LEQi $n #0 @.f0	; if (n > 0) 
		MOVp $a $s0 	; a = s0
		MOVp $b $s1 	; b = s1
		MOVi $i #1 	; for (i = 1 to n) 
		GEQi #1 $n @.f0
	.l2:	PEEK $c $a 	; if ((d = (c = (int)*a) - (int)*b) != 0 || c == 0) goto done
		PEEK %0 $b 
		SUBi $d $c %0
		NEQi $d #0 @done
		NEQi $c #0 @.f4
		GOTO @done  	; goto done
	.f4:	ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		FORi $i $n @.l2	; }
	done:	NOOP
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
intToString:	FUNC
	$p:	OUTp
	$i:	INPi
	$radix:	INPi
	$minLength:	INPi
	$buffer:	INPp
	$e:	LOCp
	$x:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(2 <= radix && radix <= 16)
		GRTi #2 $radix @.f1
		LEQi $radix #16 @.a0
	.f1:	MOVp %1 &.a_2radix4d2 
		CALL ^assertFail %0 *1
	.a0:	NOOP
		! EQUi #DEBUG #0 @.a2	; assert(0 <= minLength && minLength <= GAZL_WORD_SIZE)
		GRTi #0 $minLength @.f3
		LEQi $minLength #GAZL_WORD_SIZE @.a2
	.f3:	MOVp %1 &.a_0minLe4d3 
		CALL ^assertFail %0 *1
	.a2:	ADDp %0 $buffer #GAZL_WORD_SIZE	; *(p = buffer + GAZL_WORD_SIZE + 1) = 0
		ADDp $p %0 #1
		POKE $p #0 
		SUBp $e $p $minLength	; e = p - minLength
		MOVi $x $i 	; x = i
	.l4:	GRTp $p $e @.t5	; while (p > e || x != 0) 
		EQUi $x #0 @.e6
	.t5:	NOOP
		! EQUi #DEBUG #0 @.a7	; assert(p >= buffer + 2)
		ADDp %0 $buffer #2
		GEQp $p %0 @.a7
		MOVp %1 &.a_pbuffe4d4 
		CALL ^assertFail %0 *1
	.a7:	SUBp $p $p #1	; *(p = p - 1) = ("fedcba9876543210123456789abcdef")[15 + x % radix]
		MODi %0 $x $radix
		ADDi %0 #15 %0
		PEEK %0 &.s_fedcba4d3 %0
		POKE $p %0 
		DIVi $x $x $radix	; x = x / radix
		GOTO @.l4  	; }
	.e6:	GEQi $i #0 @.f8	; if (i < 0) *(p = p - 1) = '-'
		SUBp $p $p #1	; *(p = p - 1) = '-'
		POKE $p #'-' 
	.f8:	RETU   	; }


;-----------------------------------------------------------------------------
outputInt:	FUNC
		PARA *1
	$i:	INPi
	! ADDi <A> #GAZL_WORD_SIZE #2
	$buffer:	LOCA *<A>
;-----------------------------------------------------------------------------
		MOVi %2 $i 	; output(intToString(i, 10, 1, buffer))
		MOVi %3 #10 
		MOVi %4 #1 
		ADRL %5 $buffer *0
		CALL &intToString %1 *5
		CALL ^output %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
parseInt:	FUNC
	$i:	OUTi
	$s:	INPp
	$defaultValue:	INPi
	$p:	LOCp
	$sign:	LOCi
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVi $i #0 	; i = 0
		MOVi $sign #1 	; sign = 1
		MOVp %1 $s 	; p = (pointer)eatWhite(s)
		CALL &eatWhite %0 *2
		MOVp $p %0 
		PEEK $c $p 	; if ((c = (int)*p) == '+') p = p + 1
		NEQi $c #'+' @.f0
		ADDp $p $p #1	; p = p + 1
		GOTO @.e1  
	.f0:	NEQi $c #'-' @.f2	; if (c == '-') 
		MOVi $sign #-1 	; sign = -1
		ADDp $p $p #1	; p = p + 1
	.f2:	NOOP
	.e1:	NOOP
	.l3:	PEEK $c $p 	; while ((c = (int)*p) >= '0' && c <= '9') 
		LSSi $c #'0' @.e5
		GRTi $c #'9' @.e5
		MULi %0 $i #10	; i = i * 10 + (c - '0')
		SUBi %1 $c #'0'
		ADDi $i %0 %1
		ADDp $p $p #1	; p = p + 1
		GOTO @.l3  	; }
	.e5:	MOVp %1 $p 	; p = (pointer)eatWhite(p)
		CALL &eatWhite %0 *2
		MOVp $p %0 
		PEEK %0 $p 	; if ((int)*p != 0) i = defaultValue
		EQUi %0 #0 @.f6
		MOVi $i $defaultValue 	; i = defaultValue
		GOTO @.e7  
	.f6:	MULi $i $i $sign	; i = i * sign
	.e7:	RETU   	; }


;-----------------------------------------------------------------------------
parseXY:	FUNC
		PARA *1
	$s:	INPp
	$x:	INPp
	$y:	INPp
	$xp:	LOCp
	$yp:	LOCp
	$c:	LOCi
;-----------------------------------------------------------------------------
		POKE $x #-10000 	; (int)*x = -10000
		POKE $y #-10000 	; (int)*y = -10000
		MOVp $yp $s 	; yp = s
	.l0:	PEEK $c $yp 	; while ((c = (int)*yp) != ' ' && c != ',' && c != 0) yp = yp + 1
		EQUi $c #' ' @.e2
		EQUi $c #',' @.e2
		EQUi $c #0 @.e2
		ADDp $yp $yp #1	; yp = yp + 1
		GOTO @.l0  
	.e2:	EQUi $c #0 @.f3	; if (c != 0) 
		POKE $yp #0 	; *yp = 0
		ADDp $yp $yp #1	; yp = yp + 1
		MOVp %1 $s 	; *x = parseInt(s, -1)
		MOVi %2 #-1 
		CALL &parseInt %0 *3
		POKE $x %0 
		MOVp %1 $yp 	; *y = parseInt(yp, -1)
		MOVi %2 #-1 
		CALL &parseInt %0 *3
		POKE $y %0 
	.f3:	RETU   	; }


;-----------------------------------------------------------------------------
help:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		MOVp %1 &.s_fedcba4d3:31 	; outputLine("")
