; Compiled with Impala version 1.0

PRAWN_FIRMWARE_PATCH_FORMAT:	! DEFi #1
FALSE:	! DEFi #0
TRUE:	! DEFi #1
panelTextRows:	CNST *8
	DATA &.s_sillyr4d2 &.s_sillyr4d2:51 &.s_sillyr4d2:51
	DATA &.s_ROOMSI4d3 &.s_ROOMSI4d3:53 &.s_ROOMSI4d3:53
	DATA &.s_ROOMSI4d3:53 &.s_FEEDBA4d4
	GLOB *1
left:	DATi #0
	GLOB *1
right:	DATi #0
	GLOB *1
clock:	DATi #0
params:	GLOB *PARAM_COUNT
displayLEDs:	GLOB *4
	GLOB *1
instance:	DATi #0
AND:	! DEFi #32767
TAPS_COUNT:	! DEFi #10
ALLPASS_COUNT:	! DEFi #5
T0:	! DEFi #0
T3:	! DEFi #1
T5:	! DEFi #2
T7:	! DEFi #3
T11:	! DEFi #4
T13:	! DEFi #5
TFB:	! DEFi #6
TL1:	! DEFi #7
TL2:	! DEFi #8
TR:	! DEFi #9
ALLPASS_PAIRS_A:	CNST *ALLPASS_COUNT
	DATA #T0 #T0 #T3 #T3 #T5
ALLPASS_PAIRS_B:	CNST *ALLPASS_COUNT
	DATA #T3 #T13 #T5 #T11 #T7
	GLOB *1
roomSize:	DATi #11579
	GLOB *1
preDelay:	DATi #0
	GLOB *1
feedback:	DATf #0.5
	GLOB *1
damping:	DATf #1.0
taps:	GLOB *TAPS_COUNT

;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		RETU   	; }


;-----------------------------------------------------------------------------
reset:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$taps:	LOCA *TAPS_COUNT
	$size:	LOCi
	$predelay:	LOCi
;-----------------------------------------------------------------------------
		PEEK $size &params:OPERAND_1_HIGH_PARAM_INDEX 	; size = (int) global params[OPERAND_1_HIGH_PARAM_INDEX]
		PEEK $predelay &params:OPERAND_1_LOW_PARAM_INDEX 	; predelay = (int) global params[OPERAND_1_LOW_PARAM_INDEX]
		MULi $size $size $size	; size = size * size
		MULi $predelay $predelay $predelay	; predelay = predelay * predelay
		PEEK %0 &params:OPERAND_2_HIGH_PARAM_INDEX 	; global feedback = itof((int) global params[OPERAND_2_HIGH_PARAM_INDEX]) * (1.0 / 255.0)
		! DIVf <A> #1.0 #255.0
		iTOf %0 %0 <A>
		POKE &feedback %0 
		PEEK %0 &params:OPERAND_2_LOW_PARAM_INDEX 	; global damping = 1.0 - itof((int) global params[OPERAND_2_LOW_PARAM_INDEX]) * (1.0 / 256.0)
		! DIVf <A> #1.0 #256.0
		iTOf %0 %0 <A>
		SUBf %0 #1.0 %0
		POKE &damping %0 
		MOVi $taps:T0 #0 	; taps[T0] = 0
		ADDi %0 $size #1	; taps[T3] = (size + 1) / 3
		DIVi $taps:T3 %0 #3
		ADDi %0 $size #2	; taps[T5] = (int) taps[T3] + (size + 2) / 5
		DIVi %0 %0 #5
		ADDi $taps:T5 $taps:T3 %0
		ADDi %0 $size #3	; taps[T7] = (int) taps[T5] + (size + 3) / 7
		DIVi %0 %0 #7
		ADDi $taps:T7 $taps:T5 %0
		ADDi %0 $size #5	; taps[T11] = (int) taps[T3] + (size + 5) / 11
		DIVi %0 %0 #11
		ADDi $taps:T11 $taps:T3 %0
		ADDi %0 $size #6	; taps[T13] = (size + 6) / 13
		DIVi $taps:T13 %0 #13
		MOVi $taps:TFB $size 	; taps[TFB] = size
		ADDi $taps:TL1 $taps:T7 $predelay	; taps[TL1] = (int) taps[T7] + predelay
		ADDi $taps:TL2 $taps:TL1 #2311	; taps[TL2] = (int) taps[TL1] + 2311
		ADDi $taps:TR $taps:TL1 #1057	; taps[TR] = (int) taps[TL1] + 1057
		ADRL %0 $taps *0	; copy (TAPS_COUNT from taps to global taps)
		COPY &taps %0 *TAPS_COUNT
		RETU   	; }


;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	$spinner:	LOCi
	$in:	LOCf
	$dI:	LOCf
	$t:	LOCA *TAPS_COUNT
	$o:	LOCA *TAPS_COUNT
	$taps:	LOCA *TAPS_COUNT
	$index:	LOCi
	$i:	LOCi
	$tA:	LOCi
	$tB:	LOCi
;-----------------------------------------------------------------------------
	.l0:	ADRL %0 $taps *0	; copy (TAPS_COUNT from global taps to taps)
		COPY %0 &taps *TAPS_COUNT
		PEEK %0 &left 	; in = itof(global left + global right) * 0.5
		PEEK %1 &right 
		ADDi %0 %0 %1
		iTOf $in %0 #0.5
		PEEK $spinner &clock 	; spinner = global clock
		MOVi $i #0 	; for (i = 0 to TAPS_COUNT) 
		GEQi #0 #TAPS_COUNT @.e1
	.l2:	GETL %0 $taps $i	; index = spinner - (int) taps[i]
		SUBi $index $spinner %0
		MOVi %1 $index 	; t[i] = itof((int) read(index, 0))
		MOVi %2 #0 
		CALL ^read %0 *3
		iTOf %0 %0 #1.0
		SETL $t $i %0
		SETL $o $i $index	; o[i] = index
		FORi $i #TAPS_COUNT @.l2	; }
	.e1:	PEEK %0 &feedback 	; dI = dI + (in + (float) t[TFB] * global feedback - dI) * global damping
		MULf %0 $t:TFB %0
		ADDf %0 $in %0
		SUBf %0 %0 $dI
		PEEK %1 &damping 
		MULf %0 %0 %1
		ADDf $dI $dI %0
		MOVf $t:T0 $dI 	; (float) t[T0] = dI
		MOVi $i #0 	; for (i = 0 to ALLPASS_COUNT) 
		GEQi #0 #ALLPASS_COUNT @.e3
	.l4:	PEEK $tA &ALLPASS_PAIRS_A $i	; tA = (int) global ALLPASS_PAIRS_A[i]
		PEEK $tB &ALLPASS_PAIRS_B $i	; tB = (int) global ALLPASS_PAIRS_B[i]
		GETL %0 $t $tB	; (float) t[tA]  = (float) t[tA]  + (float) t[tB]  * 0.5
		GETL %1 $t $tA
		MULf %0 %0 #0.5
		ADDf %1 %1 %0
		SETL $t $tA %1
		GETL %1 $t $tA	; (float) t[tB]  = (float) t[tB]  - (float) t[tA]  * 0.5
		GETL %0 $t $tB
		MULf %1 %1 #0.5
		SUBf %0 %0 %1
		SETL $t $tB %0
		FORi $i #ALLPASS_COUNT @.l4	; }
	.e3:	MOVi $i #T0 	; for (i = T0 to T13 + 1) write((int) o[i], 0, ftoi((float) t[i]))
		! ADDi <A> #T13 #1
		GEQi #T0 <A> @.e5
	.l6:	GETL %1 $o $i	; write((int) o[i], 0, ftoi((float) t[i]))
		MOVi %2 #0 
		GETL %3 $t $i
		fTOi %3 %3 #1.0
		CALL ^write %0 *4
		FORi $i <A> @.l6
	.e5:	SUBf %0 $t:TL1 $t:TL2	; global left = ftoi(((float) t[TL1] - (float) t[TL2]) * 0.75)
		fTOi %0 %0 #0.75
		POKE &left %0 
		fTOi %0 $t:TR #1.0	; global right = ftoi((float) t[TR])
		POKE &right %0 
		CALL ^yield %0 *1	; yield()
		GOTO @.l0  	; }
		RETU   	; }

.s_sillyr4d2:	CNST *52
	DATi #32 #32 #32
	DATs silly ring-modulator firmware demo by M Lidstrom
	DATi #0
.s_ROOMSI4d3:	CNST *54
	DATi #32 #32 #32 #32
	DATs ______ ROOM SIZE _______ _______ PRE-DELAY ______
	DATi #0
.s_FEEDBA4d4:	CNST *54
	DATi #32 #32 #32 #32
	DATs _______ FEEDBACK _______ ________ DAMPING _______
	DATi #0