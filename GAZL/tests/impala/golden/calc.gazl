;-----------------------------------------------------------------------------
strcmp:	FUNC
	$d:	OUTi
	$s0:	INPp
	$s1:	INPp
	$a:	LOCp
	$b:	LOCp
	$c:	LOCi
;-----------------------------------------------------------------------------
		MOVp $a $s0 	; a = s0
		MOVp $b $s1 	; b = s1
	.l0:	PEEK $c $a 	; while ((d = (c = (int) *a) - (int) *b) == 0 && c != 0) 
		PEEK %0 $b 
		SUBi $d $c %0
		NEQi $d #0 @.e2
		EQUi $c #0 @.e2
		ADDp $a $a #1	; a = a + 1
		ADDp $b $b #1	; b = b + 1
		GOTO @.l0  	; }
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
error:	FUNC
		PARA *1
	$s:	INPp
;-----------------------------------------------------------------------------
		PEEK %0 &lastError 	; if (global lastError == null) global lastError = s
		NEQp %0 &NULL @.f0
		POKE &lastError $s 	; global lastError = s
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
exp:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		ABSf $m $x 	; m = abs(x)
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $a $m	; a = a * m / n
		DIVf $a %0 $n
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l0	; } while (y != t)
		GEQf $x #0.0 @.f1	; if (x < 0.0) y = 1.0 / y
		DIVf $y #1.0 $y	; y = 1.0 / y
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
log:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$b:	LOCf
	$m:	LOCf
	$n:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		LEQf $x #0.0 @.t0	; if (x <= 0.0 || x >= 1.0e38) error("Domain error")
		LSSf $x #1.0e38 @.f1
	.t0:	MOVp %1 &.s_Domain4d2 	; error("Domain error")
		CALL &error %0 *2
		GOTO @.e2  
	.f1:	MOVf $b #0.0 	; b = 0.0
		MOVf $m $x 	; m = x
	.l3:	GEQf $m #0.5 @.e4	; while (m < 0.5) 
		MULf $m $m #2.0	; m = m * 2.0
		SUBf $b $b #LOG2	; b = b - LOG2
		GOTO @.l3  	; }
	.e4:	NOOP
	.l5:	LEQf $m #1.5 @.e6	; while (m > 1.5) 
		MULf $m $m #0.5	; m = m * 0.5
		ADDf $b $b #LOG2	; b = b + LOG2
		GOTO @.l5  	; }
	.e6:	SUBf $m #1.0 $m	; m = 1.0 - m
		MOVf $a #-1.0 	; a = -1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #0.0 	; y = 0.0
	.l7:	MOVf $t $y 	; t = y
		MULf $a $a $m	; a = a * m
		DIVf %0 $a $n	; y = y + a / n
		ADDf $y $y %0
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l7	; } while (y != t)
		ADDf $y $y $b	; y = y + b
	.e2:	RETU   	; }


;-----------------------------------------------------------------------------
log2:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float) log(x) * LOG2R
		CALL &log %0 *2
		MULf $y %0 #LOG2R
		RETU   	; }


;-----------------------------------------------------------------------------
log10:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float) log(x) * LOG10R
		CALL &log %0 *2
		MULf $y %0 #LOG10R
		RETU   	; }


;-----------------------------------------------------------------------------
trunc:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		GEQf $x #0.0 @.f0	; if (x < 0.0) y = -floor(-x)
		SUBf %0 #0.0 $x	; y = -floor(-x)
		FLOf %0 %0 
		SUBf $y #0.0 %0
		GOTO @.e1  
	.f0:	FLOf $y $x 	; y = floor(x)
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
fmod:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
;-----------------------------------------------------------------------------
		NEQf $y #0.0 @.f0	; if (y == 0.0) error("Division by zero")
		MOVp %1 &.s_Divisi4d3 	; error("Division by zero")
		CALL &error %0 *2
		GOTO @.e1  
	.f0:	DIVf %1 $x $y	; z = x - (float) trunc(x / y) * y
		CALL &trunc %0 *2
		MULf %0 %0 $y
		SUBf $z $x %0
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
cos:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; m = (float) fmod(x, TWICE_PI)
		MOVf %2 #TWICE_PI 
		CALL &fmod %0 *3
		MOVf $m %0 
		SUBf %0 #0.0 $m	; m = -m * m
		MULf $m %0 $m
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $n $n	; a = a * m / (n * n + n)
		MULf %1 $a $m
		ADDf %0 %0 $n
		DIVf $a %1 %0
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #2.0	; n = n + 2.0
		NEQf $y $t @.l0	; } while (y != t)
		ABSf %1 $y 	; if (abs(y) < COS_EPSILON) y = 0.0
		GEQf %1 #COS_EPSILON @.f1
		MOVf $y #0.0 	; y = 0.0
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
sin:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		SUBf %1 $x #HALF_PI	; y = (float) cos(x - HALF_PI)
		CALL &cos %0 *2
		MOVf $y %0 
		RETU   	; }


;-----------------------------------------------------------------------------
tan:	FUNC
	$y:	OUTf
	$x:	INPf
	$c:	LOCf
;-----------------------------------------------------------------------------
		MOVf $y #0.0 	; y = 0.0
		MOVf %1 $x 	; c = (float) cos(x)
		CALL &cos %0 *2
		MOVf $c %0 
		NEQf $c #0.0 @.f0	; if (c == 0.0) error("Domain error")
		MOVp %1 &.s_Domain4d2 	; error("Domain error")
		CALL &error %0 *2
		GOTO @.e1  
	.f0:	MOVf %1 $x 	; y = (float) sin(x) / c
		CALL &sin %0 *2
		DIVf $y %0 $c
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
pow:	FUNC
	$z:	OUTf
	$x:	INPf
	$y:	INPf
	$a:	LOCf
;-----------------------------------------------------------------------------
		MOVf $z #0.0 	; z = 0.0
		MOVf $a $x 	; a = x
		GEQf $a #0.0 @.f1	; if (a < 0.0 && y == floor(y)) a = -a
		FLOf %0 $y 
		NEQf $y %0 @.f1
		SUBf $a #0.0 $a	; a = -a
	.f1:	LEQf $a #0.0 @.f2	; if (a > 0.0) z = (float) exp((float) log(a) * y)
		MOVf %2 $a 	; z = (float) exp((float) log(a) * y)
		CALL &log %1 *2
		MULf %1 %1 $y
		CALL &exp %0 *2
		MOVf $z %0 
		GOTO @.e3  
	.f2:	LSSf $a #0.0 @.t4	; if (a < 0.0 || y <= 0.0) error("Domain error")
		GRTf $y #0.0 @.f5
	.t4:	MOVp %1 &.s_Domain4d2 	; error("Domain error")
		CALL &error %0 *2
	.f5:	NOOP
	.e3:	EQUf $a $x @.f7	; if (a != x && (y * 0.5) != floor(y * 0.5)) z = -z
		MULf %0 $y #0.5
		MULf %1 $y #0.5
		FLOf %0 %0 
		EQUf %1 %0 @.f7
		SUBf $z #0.0 $z	; z = -z
	.f7:	RETU   	; }


;-----------------------------------------------------------------------------
floorFunc:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		FLOf $y $x 	; y = floor(x)
		RETU   	; }


;-----------------------------------------------------------------------------
ceilFunc:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		SUBf %1 #0.0 $x	; y = -floor(-x)
		FLOf %1 %1 
		SUBf $y #0.0 %1
		RETU   	; }


;-----------------------------------------------------------------------------
sqrt:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MOVf %1 $x 	; y = (float) pow(x, 0.5)
		MOVf %2 #0.5 
		CALL &pow %0 *3
		MOVf $y %0 
		RETU   	; }

FUNCTION_COUNT:	! DEFi #10
	! MULi <A> #FUNCTION_COUNT #2
FUNCTIONS:	CNST *<A>
