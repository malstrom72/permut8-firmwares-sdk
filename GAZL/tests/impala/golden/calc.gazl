;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
	$s:	LOCA *256
	$p:	LOCp
	$q:	LOCp
	$f:	LOCf
	$c:	LOCi
	$assignTo:	LOCi
	$buffer:	LOCA *32
	$i:	LOCi
;-----------------------------------------------------------------------------
	.l0:	MOVp %1 &.s_calc4e5 	; output("calc> ")
		CALL ^output %0 *2
		MOVi %1 #255 	; input(255, s)
		ADRL %2 $s *0
		CALL ^input %0 *3
		ADRL %1 $s *0	; p = (pointer) eatWhite(s)
		CALL &eatWhite %0 *2
		MOVp $p %0 
		PEEK %0 $p 	; if ((int) *p == 0 || (int) strcmp(p, "quit") == 0) goto quit
		EQUi %0 #0 @quit
		MOVp %1 $p 
		MOVp %2 &.s_quit4e6 
		CALL &strcmp %0 *3
		NEQi %0 #0 @.f2
		GOTO @quit  	; goto quit
	.f2:	MOVi $assignTo #-1 	; assignTo = -1
		PEEK %1 $p 	; c = (int) lower(*p)
		CALL &lower %0 *2
		MOVi $c %0 
		MOVi %1 $c 	; if ((int) isalpha(c) != FALSE && c != 'e') 
		CALL &isalpha %0 *2
		EQUi %0 #FALSE @.f4
		EQUi $c #'e' @.f4
		ADDp %1 $p #1	; q = (pointer) eatWhite(p + 1)
		CALL &eatWhite %0 *2
		MOVp $q %0 
		PEEK %0 $q 	; if ((int) *q == '=') 
		NEQi %0 #'=' @.f4
		ADDp %1 $q #1	; p = (pointer) eatWhite(q + 1)
		CALL &eatWhite %0 *2
		MOVp $p %0 
		SUBi $assignTo $c #'a'	; assignTo = c - 'a'
	.f4:	POKE &lastError &NULL 	; global lastError = null
		MOVp %1 $p 	; p = (pointer) evaluate(p, &f, 0)
		ADRL %2 $f *0
		MOVi %3 #0 
		CALL &evaluate %0 *4
		MOVp $p %0 
		MOVp %1 $p 	; p = (pointer) eatWhite(p)
		CALL &eatWhite %0 *2
