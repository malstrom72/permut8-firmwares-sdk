	DATA &.s_log104d9 &log10 &.s_sqrt4da &sqrt &.s_cos4db &cos
	DATA &.s_sin4dc &sin &.s_tan4dd &tan

;-----------------------------------------------------------------------------
isalpha:	FUNC
	$b:	OUTi
	$c:	INPi
;-----------------------------------------------------------------------------
		MOVi $b #FALSE 	; b = FALSE
		LSSi $c #'a' @.f0	; if ((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z')) b = TRUE
		LEQi $c #'z' @.t1
	.f0:	LSSi $c #'A' @.f3
		GRTi $c #'Z' @.f3
	.t1:	MOVi $b #TRUE 	; b = TRUE
	.f3:	RETU   	; }


;-----------------------------------------------------------------------------
lower:	FUNC
	$l:	OUTi
	$c:	INPi
;-----------------------------------------------------------------------------
		MOVi $l $c 	; l = c
		LSSi $c #'A' @.f1	; if (c >= 'A' && c <= 'Z') l = l + ('a' - 'A')
		GRTi $c #'Z' @.f1
		! SUBi <A> #'a' #'A'	; l = l + ('a' - 'A')
		ADDi $l $l <A>
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
eatWhite:	FUNC
	$p:	OUTp
	$b:	INPp
;-----------------------------------------------------------------------------
		MOVp $p $b 	; p = b
	.l0:	PEEK %0 $p 	; while ((int) *p == ' ') p = p + 1
		NEQi %0 #' ' @.e1
		ADDp $p $p #1	; p = p + 1
		GOTO @.l0  
	.e1:	RETU   	; }

EPSILON_FLOAT:	! DEFf #1.0e-45
