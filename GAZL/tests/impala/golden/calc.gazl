;-----------------------------------------------------------------------------
hexToFloat:	FUNC
	$p:	OUTp
	$b:	INPp
	$v:	INPp
	$i:	LOCi
	$c:	LOCi
	$d:	LOCi
;-----------------------------------------------------------------------------
		MOVp $p $b 	; p = b
		MOVi $i #0 	; i = 0
	.l0:	PEEK $c $p 	; while (((c = (int) *p) >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) 
		LSSi $c #'0' @.f1
		LEQi $c #'9' @.t2
	.f1:	LSSi $c #'a' @.f3
		LEQi $c #'f' @.t2
	.f3:	LSSi $c #'A' @.e5
		GRTi $c #'F' @.e5
	.t2:	GRTi $c #'9' @.f6	; if (c <= '9') d = (c - '0')
		SUBi $d $c #'0'	; d = (c - '0')
		GOTO @.e7  
	.f6:	NOOP
		! XORi <A> #0x20 #-1	; d = ((c & ~0x20) - ('A' - 10))
		ANDi %0 $c <A>
		! SUBi <A> #'A' #10
		SUBi $d %0 <A>
	.e7:	SHLi %0 $i #4	; i = (i << 4) | d
		IORi $i %0 $d
		ADDp $p $p #1	; p = p + 1
		GOTO @.l0  	; }
	.e5:	iTOf %0 $i #1.0	; *v = itof(i)
		POKE $v %0 
		RETU   	; }


;-----------------------------------------------------------------------------
intToHex:	FUNC
	$p:	OUTp
	$i:	INPi
	$buffer:	INPp
	$x:	LOCi
;-----------------------------------------------------------------------------
		MOVi $x $i 	; x = i
		ADDp $p $buffer #8	; p = buffer + 8
		POKE $p #0 	; *p = 0
	.l0:	SUBp $p $p #1	; *(p = p - 1) = ("FEDCBA9876543210123456789ABCDEF")[15 + (x & 0xF)]
		ANDi %0 $x #0xF
		ADDi %0 #15 %0
		PEEK %0 &.s_FEDCBA4de %0
		POKE $p %0 
		SHRu $x $x #4	; x = x >>> 4
		NEQi $x #0 @.l0	; } while (x != 0)
		RETU   	; }


;-----------------------------------------------------------------------------
stringToFloat:	FUNC
	$p:	OUTp
	$b:	INPp
	$v:	INPp
	$f:	LOCf
	$e:	LOCf
	$n:	LOCi
	$i:	LOCi
	$c:	LOCi
	$q:	LOCp
;-----------------------------------------------------------------------------
		MOVp $p $b 	; p = b
		MOVf $f #0.0 	; f = 0.0
	.l0:	PEEK $c $p 	; while ((c = (int) *p) >= '0' && c <= '9') 
		LSSi $c #'0' @.e2
		GRTi $c #'9' @.e2
		SUBi %0 $c #'0'	; f = f * 10.0 + itof(c - '0')
		MULf %1 $f #10.0
		iTOf %0 %0 #1.0
		ADDf $f %1 %0
		ADDp $p $p #1	; p = p + 1
		GOTO @.l0  	; }
	.e2:	PEEK %1 $p 	; if ((int) *p == '.') 
		NEQi %1 #'.' @.f3
		ADDp $p $p #1	; p = p + 1
		MOVf $e #0.1 	; e = 0.1
	.l4:	PEEK $c $p 	; while ((c = (int) *p) >= '0' && c <= '9') 
		LSSi $c #'0' @.f3
		GRTi $c #'9' @.f3
		SUBi %1 $c #'0'	; f = f + e * itof(c - '0')
		iTOf %1 %1 #1.0
		MULf %1 $e %1
		ADDf $f $f %1
		MULf $e $e #0.1	; e = e * 0.1
		ADDp $p $p #1	; p = p + 1
		GOTO @.l4  	; }
	.f3:	PEEK $c $p 	; if ((c = (int) *p) == 'e' || c == 'E') 
		EQUi $c #'e' @.t7
		NEQi $c #'E' @.f8
	.t7:	ADDp $q $p #1	; q = p + 1
		MOVf $e #10.0 	; e = 10.0
		PEEK $c $q 	; if ((c = (int) *q) == '+') q = q + 1
		NEQi $c #'+' @.f9
		ADDp $q $q #1	; q = q + 1
		GOTO @.e10  
	.f9:	NEQi $c #'-' @.f11	; if (c == '-') 
		MOVf $e #0.1 	; e = 0.1
		ADDp $q $q #1	; q = q + 1
	.f11:	NOOP
	.e10:	MOVi $n #0 	; n = 0
	.l12:	PEEK $c $q 	; while ((c = (int) *q) >= '0' && c <= '9') 
		LSSi $c #'0' @.e14
		GRTi $c #'9' @.e14
		MULi %1 $n #10	; n = n * 10 + (c - '0')
		SUBi %0 $c #'0'
		ADDi $n %1 %0
		ADDp $q $q #1	; q = q + 1
		MOVp $p $q 	; p = q
		GOTO @.l12  	; }
	.e14:	LEQi $n #50 @.f15	; if (n > 50) n = 50
		MOVi $n #50 	; n = 50
	.f15:	MOVi $i #0 	; for (i = 0 to n) f = f * e
		GEQi #0 $n @.f8
	.l17:	MULf $f $f $e	; f = f * e
		FORi $i $n @.l17
	.f8:	POKE $v $f 	; *v = f
		RETU   	; }


;-----------------------------------------------------------------------------
floatToString:	FUNC
	$p:	OUTp
	$f:	INPf
	$precision:	INPi
	$buffer:	INPp
	$x:	LOCf
	$y:	LOCf
	$e:	LOCi
	$g:	LOCf
	$dp:	LOCp
	$pp:	LOCp
	$ep:	LOCp
	$i:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(1 <= precision && precision <= 24)
		GRTi #1 $precision @.f1
		LEQi $precision #24 @.a0
	.f1:	MOVp %1 &.a_1preci4d2 
		CALL ^assertFail %0 *1
	.a0:	ABSf $y $f 	; y = abs(f)
		GRTf $y #EPSILON_FLOAT @.f2	; if (y <= EPSILON_FLOAT) p = "0"
		MOVp $p &.s_log104d9:4 	; p = "0"
		GOTO @.e3  
	.f2:	LSSf $y #HUGE_FLOAT @.f4	; if (y >= HUGE_FLOAT) p = "HUGE"
		MOVp $p &.s_HUGE4df 	; p = "HUGE"
		GOTO @.e5  
	.f4:	MOVi $e #0 	; e = 0
		ADDp %0 $buffer #3	; ep = buffer + 3 + precision
		ADDp $ep %0 $precision
	.l6:	ADDp $pp $buffer #3	; pp = buffer + 3
		MOVf $x $y 	; x = y
	.l7:	LSSf $x #10.0 @.e9	; while (x >= 10.0 && pp < ep) 
		GEQp $pp $ep @.e9
		ADDp $pp $pp #1	; pp = pp + 1
		MULf $x $x #0.1	; x = x * 0.1
		GOTO @.l7  	; }
	.e9:	GEQp $pp $ep @.f11	; if (pp < ep && y > SMALL_FLOAT && y < LARGE_FLOAT) goto break
		LEQf $y #SMALL_FLOAT @.f11
		GEQf $y #LARGE_FLOAT @.f11
		GOTO @break  	; goto break
	.f11:	MOVf $g $y 	; g = y
	.l12:	GEQf $y #1.0 @.e13	; while (y < 1.0) 
		SUBi $e $e #1	; e = e - 1
		MULf $y $y #10.0	; y = y * 10.0
		GOTO @.l12  	; }
	.e13:	NOOP
	.l14:	LSSf $y #10.0 @.l6	; while (y >= 10.0) 
		ADDi $e $e #1	; e = e + 1
		MULf $y $y #0.1	; y = y * 0.1
		GOTO @.l14  	; }
		GOTO @.l6  	; }
	break:	ADDp $dp $buffer #2	; break:
	.l16:	GEQf $x #1.0 @.e18	; while (x < 1.0 && dp < buffer + 32) 
		ADDp %0 $buffer #32
		GEQp $dp %0 @.e18
		POKE $dp #'0' 	; *dp = '0'
		ADDp $dp $dp #1	; dp = dp + 1
		NEQp $dp $pp @.f19	; if (dp == pp) 
		POKE $dp #'9' 	; *dp = '9'
		ADDp $dp $dp #1	; dp = dp + 1
	.f19:	ADDp $ep $ep #1	; ep = ep + 1
		MULf $x $x #10.0	; x = x * 10.0
		GOTO @.l16  	; }
	.e18:	NOOP
	.l20:	GEQp $dp $ep @.e21	; while (dp < ep) 
		fTOi $i $x #1.0	; i = ftoi(x)
		ADDi %0 $i #'0'	; *dp = i + '0'
		POKE $dp %0 
		ADDp $dp $dp #1	; dp = dp + 1
		NEQp $dp $pp @.f22	; if (dp == pp) 
		POKE $dp #'9' 	; *dp = '9'
		ADDp $dp $dp #1	; dp = dp + 1
	.f22:	iTOf %0 $i #1.0	; x = (x - itof(i)) * 10.0
		SUBf %0 $x %0
		MULf $x %0 #10.0
		GOTO @.l20  	; }
