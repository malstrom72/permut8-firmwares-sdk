;-----------------------------------------------------------------------------
maxi:	FUNC
	$y:	OUTi
	$a:	INPi
	$b:	INPi
;-----------------------------------------------------------------------------
		MOVi $y $a 	; y = a
		LEQi $b $y @.f0	; if (b > y) y = b
		MOVi $y $b 	; y = b
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
calcGainsAndDelays:	FUNC
		PARA *1
	$configBits:	INPi
	$stepBits:	INPi
	$initGain:	INPf
	$initDelay:	INPf
	$gains:	INPp
	$delays:	INPp
	$maxGain:	INPp
	$maxDelay:	INPp
	$endGain:	INPp
	$endDelay:	INPp
	$g:	LOCf
	$d:	LOCf
	$i:	LOCi
;-----------------------------------------------------------------------------
		MOVf $g $initGain 	; g = initGain
		MOVf $d $initDelay 	; d = initDelay
		MOVi $i #0 	; for (i = 0 to 8) 
		GEQi #0 #8 @.e0
	.l1:	SHRi %0 #0x80 $i	; if ((stepBits & (0x80 >> i)) != 0) 
		ANDi %0 $stepBits %0
		EQUi %0 #0 @.f2
		! SHLi <A> #1 #VOL_INC_BIT	; if ((configBits & (1 << VOL_INC_BIT)) != 0) g = g * VOL_INC_FACTOR
		ANDi %0 $configBits <A>
		EQUi %0 #0 @.f3
		MULf $g $g #VOL_INC_FACTOR	; g = g * VOL_INC_FACTOR
	.f3:	NOOP
		! SHLi <A> #1 #VOL_DEC_BIT	; if ((configBits & (1 << VOL_DEC_BIT)) != 0) g = g * VOL_DEC_FACTOR
		ANDi %0 $configBits <A>
		EQUi %0 #0 @.f4
		MULf $g $g #VOL_DEC_FACTOR	; g = g * VOL_DEC_FACTOR
	.f4:	NOOP
		! SHLi <A> #1 #ACCELERATE_BIT	; if ((configBits & (1 << ACCELERATE_BIT)) != 0) d = d * TIME_DEC_FACTOR
		ANDi %0 $configBits <A>
		EQUi %0 #0 @.f5
		MULf $d $d #TIME_DEC_FACTOR	; d = d * TIME_DEC_FACTOR
	.f5:	NOOP
		! SHLi <A> #1 #DEACCELERATE_BIT	; if ((configBits & (1 << DEACCELERATE_BIT)) != 0) d = d * TIME_INC_FACTOR
		ANDi %0 $configBits <A>
		EQUi %0 #0 @.f2
		MULf $d $d #TIME_INC_FACTOR	; d = d * TIME_INC_FACTOR
	.f2:	PEEK %0 $maxGain 	; if (g > (float) *maxGain) *maxGain = g
		LEQf $g %0 @.f7
		POKE $maxGain $g 	; *maxGain = g
	.f7:	PEEK %0 $maxDelay 	; if (d > (float) *maxDelay) *maxDelay = d
		LEQf $d %0 @.f8
		POKE $maxDelay $d 	; *maxDelay = d
	.f8:	POKE $gains $i $g	; gains[i] = g
		POKE $delays $i $d	; delays[i] = d
		FORi $i #8 @.l1	; }
	.e0:	POKE $endGain $g 	; *endGain = g
		POKE $endDelay $d 	; *endDelay = d
		RETU   	; }


;-----------------------------------------------------------------------------
addTaps:	FUNC
	$o:	OUTf
	$op:	INPi
	$configBits:	INPi
	$stepBits:	INPi
	$offset:	INPf
	$gains:	INPp
	$delays:	INPp
	$gainScale:	INPf
	$delayScale:	INPf
	$firstStep:	INPi
	$g:	LOCf
	$d:	LOCf
	$i:	LOCi
	$lg:	LOCf
	$rg:	LOCf
	$r:	LOCf
	$p:	LOCp
;-----------------------------------------------------------------------------
		MOVf $o $offset 	; o = offset
		PEEK %0 &tapCount 	; p = global tapData + global tapCount * TAP_STRUCT_SIZE
		MULi %0 %0 #TAP_STRUCT_SIZE
		ADDp $p &tapData %0
		MOVi $i #0 	; for (i = 0 to 8) 
		GEQi #0 #8 @.e0
	.l1:	PEEK %0 $gains $i	; g = (float) gains[i] * gainScale
		MULf $g %0 $gainScale
		PEEK %0 $delays $i	; d = (float) delays[i] * delayScale
		MULf $d %0 $delayScale
		SHRi %0 #0x80 $i	; if ((stepBits & (0x80 >> i)) != 0) 
		ANDi %0 $stepBits %0
		EQUi %0 #0 @.f2
		MOVf $lg $g 	; lg = g
		MOVf $rg $g 	; rg = g
		! SHLi <A> #1 #PAN_LEFT_BIT	; if ((configBits & (1 << PAN_LEFT_BIT)) == 0) lg = lg * PAN_ATTENUATE
		ANDi %0 $configBits <A>
		NEQi %0 #0 @.f3
		MULf $lg $lg #PAN_ATTENUATE	; lg = lg * PAN_ATTENUATE
	.f3:	NOOP
		! SHLi <A> #1 #PAN_RIGHT_BIT	; if ((configBits & (1 << PAN_RIGHT_BIT)) == 0) rg = rg * PAN_ATTENUATE
		ANDi %0 $configBits <A>
		NEQi %0 #0 @.f4
		MULf $rg $rg #PAN_ATTENUATE	; rg = rg * PAN_ATTENUATE
	.f4:	MOVf $r #0.0 	; r = 0.0
		! SHLi <A> #1 #RANDOM_BIT	; if ((configBits & (1 << RANDOM_BIT)) != 0) r = itof((int) xorShiftRandom()) * (XOR_SHIFT_RANDOM_TO_FLOAT_FACTOR * (1.0/12.0)) * d
		ANDi %0 $configBits <A>
		EQUi %0 #0 @.f5
		CALL &xorShiftRandom %0 *1	; r = itof((int) xorShiftRandom()) * (XOR_SHIFT_RANDOM_TO_FLOAT_FACTOR * (1.0/12.0)) * d
		! DIVf <A> #1.0 #12.0
		! MULf <A> #XOR_SHIFT_RANDOM_TO_FLOAT_FACTOR <A>
		iTOf %0 %0 <A>
		MULf $r %0 $d
	.f5:	ADDi %0 $i $firstStep	; p[TAP_BITS] = configBits | (0x80000000 >>> (i + firstStep))
		SHRu %0 #0x80000000 %0
		IORi %0 $configBits %0
		POKE $p #TAP_BITS %0
		ADDf %1 $o $r	; p[TAP_DELAY] = maxi(ftoi(o + r) - BATCH_SIZE, 0)
		fTOi %1 %1 #1.0
		SUBi %1 %1 #BATCH_SIZE
		MOVi %2 #0 
		CALL &maxi %0 *3
		POKE $p #TAP_DELAY %0
		fTOi %0 $lg #1.0	; p[TAP_LEFT_GAIN] = ftoi(lg)
		POKE $p #TAP_LEFT_GAIN %0
		fTOi %0 $rg #1.0	; p[TAP_RIGHT_GAIN] = ftoi(rg)
		POKE $p #TAP_RIGHT_GAIN %0
		ADDp $p $p #TAP_STRUCT_SIZE	; p = p + TAP_STRUCT_SIZE
		PEEK %0 &tapCount 	; global tapCount = global tapCount + 1
		ADDi %0 %0 #1
		POKE &tapCount %0 
	.f2:	ADDf $o $o $d	; o = o + d
		FORi $i #8 @.l1	; }
	.e0:	RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$localParams:	LOCA *PARAM_COUNT
	$i:	LOCi
	$v:	LOCi
	$rebuild:	LOCi
	$stepLength1:	LOCf
	$stepLength2:	LOCf
	$offset:	LOCf
	$gains:	LOCA *16
	$delays:	LOCA *16
	$maxGain1:	LOCf
	$maxDelay1:	LOCf
	$maxGain2:	LOCf
	$maxDelay2:	LOCf
	$endGain:	LOCf
	$endDelay:	LOCf
;-----------------------------------------------------------------------------
		ADRL %0 $localParams *0	; copy (PARAM_COUNT from global params to localParams)
		COPY %0 &params *PARAM_COUNT
		POKE &tapCount #0 	; global tapCount = 0
		POKE &xorShiftRandomSeedX #123456789 	; global xorShiftRandomSeedX = 123456789
		POKE &xorShiftRandomSeedY #362436069 	; global xorShiftRandomSeedY = 362436069
		! DIVf <A> #65536.0 #8.0	; stepLength1 = (65536.0 / 8.0)
		MOVf $stepLength1 <A> 
		MOVf $maxGain1 #0.00001 	; maxGain1 = 0.00001
		MOVf $maxDelay1 #0.00001 	; maxDelay1 = 0.00001
		LEQi $localParams:OPERATOR_1_PARAM_INDEX #0 @.f0	; if ((int) localParams[OPERATOR_1_PARAM_INDEX] > 0) 
		ADDi %0 #2 $localParams:OPERATOR_1_PARAM_INDEX	; stepLength1 = itof(65536 >> (2 + (int) localParams[OPERATOR_1_PARAM_INDEX]))
		SHRi %0 #65536 %0
		iTOf $stepLength1 %0 #1.0
		MOVi %1 $localParams:OPERAND_1_LOW_PARAM_INDEX 	; calcGainsAndDelays((int) localParams[OPERAND_1_LOW_PARAM_INDEX], (int) localParams[OPERAND_1_HIGH_PARAM_INDEX], 1.0, 1.0, gains, delays, &maxGain1, &maxDelay1, &endGain, &endDelay)
		MOVi %2 $localParams:OPERAND_1_HIGH_PARAM_INDEX 
		MOVf %3 #1.0 
		MOVf %4 #1.0 
		ADRL %5 $gains *0
		ADRL %6 $delays *0
		ADRL %7 $maxGain1 *0
		ADRL %8 $maxDelay1 *0
		ADRL %9 $endGain *0
		ADRL %10 $endDelay *0
		CALL &calcGainsAndDelays %0 *11
	.f0:	MOVf $stepLength2 $stepLength1 	; stepLength2 = stepLength1
		MOVf $offset #0.0 	; offset = 0.0
		SWCH $localParams:OPERATOR_2_PARAM_INDEX *5 @.s1	; switch ((int) localParams[OPERATOR_2_PARAM_INDEX] == 0 to 5) 
	.s1#0:	GOTO @noSecond  	; goto noSecond
		GOTO @.e2  
	.s1#1:	GOTO @.e2  	; 
	.s1#2:	MULf $stepLength2 $stepLength2 #0.5	; stepLength2 = stepLength2 * 0.5
		GOTO @.e2  
	.s1#3:	MULf $offset $stepLength2 #0.5	; offset = stepLength2 * 0.5
		GOTO @.e2  
	.s1#4:	MOVi %1 $localParams:OPERAND_2_LOW_PARAM_INDEX 	; calcGainsAndDelays((int) localParams[OPERAND_2_LOW_PARAM_INDEX], (int) localParams[OPERAND_2_HIGH_PARAM_INDEX], endGain, endDelay, &gains[8], &delays[8], &maxGain1, &maxDelay1, &endGain, &endDelay)
		MOVi %2 $localParams:OPERAND_2_HIGH_PARAM_INDEX 
		MOVf %3 $endGain 
		MOVf %4 $endDelay 
		ADRL %5 $gains:8 *0
		ADRL %6 $delays:8 *0
		ADRL %7 $maxGain1 *0
		ADRL %8 $maxDelay1 *0
		ADRL %9 $endGain *0
		ADRL %10 $endDelay *0
		CALL &calcGainsAndDelays %0 *11
		MOVi %1 $localParams:OPERATOR_1_PARAM_INDEX 	; offset = (float) addTaps((int) localParams[OPERATOR_1_PARAM_INDEX], (int) localParams[OPERAND_1_LOW_PARAM_INDEX], (int) localParams[OPERAND_1_HIGH_PARAM_INDEX], 0.0, gains, delays, 256.0 / maxGain1, stepLength1 / maxDelay1, 0)
		MOVi %2 $localParams:OPERAND_1_LOW_PARAM_INDEX 
		MOVi %3 $localParams:OPERAND_1_HIGH_PARAM_INDEX 
		MOVf %4 #0.0 
		ADRL %5 $gains *0
		ADRL %6 $delays *0
		DIVf %7 #256.0 $maxGain1
		DIVf %8 $stepLength1 $maxDelay1
		MOVi %9 #0 
		CALL &addTaps %0 *10
		MOVf $offset %0 
		MOVi %1 $localParams:OPERATOR_2_PARAM_INDEX 	; addTaps((int) localParams[OPERATOR_2_PARAM_INDEX], (int) localParams[OPERAND_2_LOW_PARAM_INDEX], (int) localParams[OPERAND_2_HIGH_PARAM_INDEX], offset, &gains[8], &delays[8], 256.0 / maxGain1, stepLength2 / maxDelay1, 8)
		MOVi %2 $localParams:OPERAND_2_LOW_PARAM_INDEX 
		MOVi %3 $localParams:OPERAND_2_HIGH_PARAM_INDEX 
		MOVf %4 $offset 
		ADRL %5 $gains:8 *0
		ADRL %6 $delays:8 *0
		DIVf %7 #256.0 $maxGain1
		DIVf %8 $stepLength2 $maxDelay1
		MOVi %9 #8 
		CALL &addTaps %0 *10
		GOTO @done  	; goto done
	.s1:	NOOP
	.e2:	MOVf $maxGain2 #0.00001 	; maxGain2 = 0.00001
		MOVf $maxDelay2 #0.00001 	; maxDelay2 = 0.00001
		MOVi %1 $localParams:OPERAND_2_LOW_PARAM_INDEX 	; calcGainsAndDelays((int) localParams[OPERAND_2_LOW_PARAM_INDEX], (int) localParams[OPERAND_2_HIGH_PARAM_INDEX], 1.0, 1.0, &gains[8], &delays[8], &maxGain2, &maxDelay2, &endGain, &endDelay)
		MOVi %2 $localParams:OPERAND_2_HIGH_PARAM_INDEX 
		MOVf %3 #1.0 
		MOVf %4 #1.0 
		ADRL %5 $gains:8 *0
		ADRL %6 $delays:8 *0
		ADRL %7 $maxGain2 *0
		ADRL %8 $maxDelay2 *0
		ADRL %9 $endGain *0
		ADRL %10 $endDelay *0
		CALL &calcGainsAndDelays %0 *11
		MOVi %1 $localParams:OPERATOR_2_PARAM_INDEX 	; addTaps((int) localParams[OPERATOR_2_PARAM_INDEX], (int) localParams[OPERAND_2_LOW_PARAM_INDEX], (int) localParams[OPERAND_2_HIGH_PARAM_INDEX], offset, &gains[8], &delays[8], 256.0 / maxGain2, stepLength2 / maxDelay2, 8)
		MOVi %2 $localParams:OPERAND_2_LOW_PARAM_INDEX 
		MOVi %3 $localParams:OPERAND_2_HIGH_PARAM_INDEX 
		MOVf %4 $offset 
		ADRL %5 $gains:8 *0
		ADRL %6 $delays:8 *0
		DIVf %7 #256.0 $maxGain2
		DIVf %8 $stepLength2 $maxDelay2
		MOVi %9 #8 
		CALL &addTaps %0 *10
	noSecond:	LEQi $localParams:OPERATOR_1_PARAM_INDEX #0 @.f3	; if ((int) localParams[OPERATOR_1_PARAM_INDEX] > 0) 
		MOVi %1 $localParams:OPERATOR_1_PARAM_INDEX 	; addTaps((int) localParams[OPERATOR_1_PARAM_INDEX], (int) localParams[OPERAND_1_LOW_PARAM_INDEX], (int) localParams[OPERAND_1_HIGH_PARAM_INDEX], 0.0, gains, delays, 256.0 / maxGain1, stepLength1 / maxDelay1, 0)
		MOVi %2 $localParams:OPERAND_1_LOW_PARAM_INDEX 
		MOVi %3 $localParams:OPERAND_1_HIGH_PARAM_INDEX 
		MOVf %4 #0.0 
		ADRL %5 $gains *0
		ADRL %6 $delays *0
		DIVf %7 #256.0 $maxGain1
		DIVf %8 $stepLength1 $maxDelay1
		MOVi %9 #0 
		CALL &addTaps %0 *10
	.f3:	NOOP
	done:	RETU   	; }

temp:	GLOB *2
	! MULi <A> #BATCH_SIZE #2
buffer:	GLOB *<A>

;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	! MULi <A> #BATCH_SIZE #2
	$tapData:	LOCA *TAP_STRUCT_SIZE
	$i:	LOCi
	$clock:	LOCi
	$l:	LOCi
	$r:	LOCi
	$p:	LOCp
	$bp:	LOCp
	$bi:	LOCi
	$tapped:	LOCA *<A>
	$tp:	LOCp
	$ledBits:	LOCi
	$dir:	LOCi
;-----------------------------------------------------------------------------
	.l0:	MOVi $ledBits #0 	; ledBits = 0
		MOVp $bp &buffer 	; bp = global buffer
		MOVi $dir #2 	; dir = 2
		PEEK %0 &params:SWITCHES_PARAM_INDEX 	; if (((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_REVERSE_MASK) != 0) 
		ANDi %0 %0 #SWITCHES_REVERSE_MASK
		EQUi %0 #0 @.f1
		! MULi <A> #BATCH_SIZE #2	; bp = bp + (BATCH_SIZE * 2 - 2)
		! SUBi <A> <A> #2
		ADDp $bp $bp <A>
		MOVi $dir #-2 	; dir = -2
	.f1:	MOVi $bi #0 	; for (bi = 0 to BATCH_SIZE) 
		GEQi #0 #BATCH_SIZE @.e2
	.l3:	COPY &temp &signal *2	; copy (2 from global signal to global temp)
		COPY &signal $bp *2	; copy (2 from bp to global signal)
		COPY $bp &temp *2	; copy (2 from global temp to bp)
		ADDp $bp $bp $dir	; bp = bp + dir
		CALL ^yield %0 *1	; yield()
		FORi $bi #BATCH_SIZE @.l3	; }
	.e2:	PEEK %0 &clock 	; clock = global clock - BATCH_SIZE
		SUBi $clock %0 #BATCH_SIZE
		MOVi %1 $clock 	; write(clock, BATCH_SIZE, global buffer)
		MOVi %2 #BATCH_SIZE 
		MOVp %3 &buffer 
		CALL ^write %0 *4
		MOVp $bp &buffer 	; for (bp = global buffer to global buffer + BATCH_SIZE * 2) *bp = 0
		! MULi <A> #BATCH_SIZE #2
		ADDp %0 &buffer <A>
		GEQp &buffer %0 @.e4
	.l5:	POKE $bp #0 	; *bp = 0
		FORp $bp %0 @.l5
	.e4:	MOVp $p &tapData 	; p = global tapData
		MOVi $i #0 	; for (i = 0 to global tapCount) 
		PEEK %0 &tapCount 
		GEQi #0 %0 @.e6
	.l7:	MOVp $bp &buffer 	; bp = global buffer
		ADRL %1 $tapData *0	; copy (TAP_STRUCT_SIZE from p to tapData)
		COPY %1 $p *TAP_STRUCT_SIZE
		SUBi %2 $clock $tapData:TAP_DELAY	; read(clock - (int) tapData[TAP_DELAY], BATCH_SIZE, tapped)
		MOVi %3 #BATCH_SIZE 
		ADRL %4 $tapped *0
		CALL ^read %1 *4
		! SHLi <A> #1 #RECTIFIER_BIT	; if (((int) tapData[TAP_BITS] & (1 << RECTIFIER_BIT)) != 0) 
		ANDi %1 $tapData:TAP_BITS <A>
		EQUi %1 #0 @.f8
		ADRL $tp $tapped *0	; tp = tapped
		MOVi $bi #0 	; for (bi = 0 to BATCH_SIZE / 2) 
		! DIVi <A> #BATCH_SIZE #2
		GEQi #0 <A> @.f8
	.l10:	PEEK %1 $tp 	; l = abs((int) *tp)
		ABSi $l %1 
		SHRi %1 $l #1	; *tp = l + (l >> 1)
		ADDi %1 $l %1
		POKE $tp %1 
		PEEK %1 $tp #1	; r = abs((int) tp[1])
		ABSi $r %1 
		SHRi %1 $r #1	; tp[1] = r + (r >> 1)
		ADDi %1 $r %1
		POKE $tp #1 %1
		PEEK %1 $tp #2	; l = abs((int) tp[2])
		ABSi $l %1 
		SHRi %1 $l #1	; tp[2] = l + (l >> 1)
		ADDi %1 $l %1
		POKE $tp #2 %1
		PEEK %1 $tp #3	; r = abs((int) tp[3])
		ABSi $r %1 
		SHRi %1 $r #1	; tp[3] = r + (r >> 1)
		ADDi %1 $r %1
		POKE $tp #3 %1
		ADDp $tp $tp #4	; tp = tp + 4
		FORi $bi <A> @.l10	; }
	.f8:	MOVi $l $tapData:TAP_LEFT_GAIN 	; l = (int) tapData[TAP_LEFT_GAIN]
		MOVi $r $tapData:TAP_RIGHT_GAIN 	; r = (int) tapData[TAP_RIGHT_GAIN]
		ADRL $tp $tapped *0	; tp = tapped
		PEEK %1 $tp 	; if (abs((int) *tp) > 12) ledBits = ledBits | ((int) tapData[TAP_BITS] >> 16)
		ABSi %1 %1 
		LEQi %1 #12 @.f11
		SHRi %1 $tapData:TAP_BITS #16	; ledBits = ledBits | ((int) tapData[TAP_BITS] >> 16)
		IORi $ledBits $ledBits %1
	.f11:	MOVi $bi #0 	; for (bi = 0 to BATCH_SIZE / 2) 
		! DIVi <A> #BATCH_SIZE #2
		GEQi #0 <A> @.e12
	.l13:	PEEK %1 $tp 	; *bp = (int) *bp + (int) *tp * l
		PEEK %2 $bp 
		MULi %1 %1 $l
		ADDi %2 %2 %1
		POKE $bp %2 
		PEEK %2 $tp #1	; bp[1] = (int) bp[1] + (int) tp[1] * r
		PEEK %1 $bp #1
		MULi %2 %2 $r
		ADDi %1 %1 %2
		POKE $bp #1 %1
		PEEK %1 $tp #2	; bp[2] = (int) bp[2] + (int) tp[2] * l
		PEEK %2 $bp #2
		MULi %1 %1 $l
		ADDi %2 %2 %1
		POKE $bp #2 %2
		PEEK %2 $tp #3	; bp[3] = (int) bp[3] + (int) tp[3] * r
		PEEK %1 $bp #3
		MULi %2 %2 $r
		ADDi %1 %1 %2
		POKE $bp #3 %1
		ADDp $bp $bp #4	; bp = bp + 4
		ADDp $tp $tp #4	; tp = tp + 4
		FORi $bi <A> @.l13	; }
	.e12:	ADDp $p $p #TAP_STRUCT_SIZE	; p = p + TAP_STRUCT_SIZE
		FORi $i %0 @.l7	; }
	.e6:	MOVp $bp &buffer 	; for (bp = global buffer to global buffer + BATCH_SIZE * 2) *bp = (int) *bp >> 8
		! MULi <A> #BATCH_SIZE #2
		ADDp %0 &buffer <A>
		GEQp &buffer %0 @.e14
	.l15:	PEEK %1 $bp 	; *bp = (int) *bp >> 8
		SHRi %1 %1 #8
		POKE $bp %1 
		FORp $bp %0 @.l15
	.e14:	PEEK %0 &params:OPERAND_1_HIGH_PARAM_INDEX 	; global displayLEDs[0] = (int) global params[OPERAND_1_HIGH_PARAM_INDEX] & (ledBits >> 8)
		SHRi %1 $ledBits #8
		ANDi %0 %0 %1
		POKE &displayLEDs:0 %0 
		PEEK %0 &params:OPERAND_2_HIGH_PARAM_INDEX 	; global displayLEDs[2] = (int) global params[OPERAND_2_HIGH_PARAM_INDEX] & ledBits
		ANDi %0 %0 $ledBits
		POKE &displayLEDs:2 %0 
		GOTO @.l0  	; }
		RETU   	; }

