; Compiled with Impala version 1.0

DEBUG:	! DEFi #1
MAX_GRAVITY:	! DEFf #40.0
MIN_SPEED:	! DEFf #0.01
MAX_SPEED:	! DEFf #20.0
GRAVITY_PARAM:	! DEFi #0
BUMPER_FORCE_PARAM:	! DEFi #1
PARAM_COUNT:	! DEFi #2
BALL_COUNT:	! DEFi #3
BALL_ACTIVE_PARAM:	! DEFi #0
BALL_X_PARAM:	! DEFi #1
BALL_Y_PARAM:	! DEFi #2
BALL_DX_PARAM:	! DEFi #3
BALL_DY_PARAM:	! DEFi #4
BALL_PARAMS_COUNT:	! DEFi #5
PI:	! DEFf #3.14159265358979323846

;-----------------------------------------------------------------------------
error:	FUNC
		PARA *1
	$s:	INPp
;-----------------------------------------------------------------------------
		MOVp %1 $s 	; printLF(s)
		CALL ^printLF %0 *2
		CALL ^abort %0 *1	; abort()
		RETU   	; }


;-----------------------------------------------------------------------------
cube:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		MULf %0 $x $x	; y = x * x * x
		MULf $y %0 $x
		RETU   	; }


;-----------------------------------------------------------------------------
clamp:	FUNC
	$y:	OUTf
	$x:	INPf
	$min:	INPf
	$max:	INPf
;-----------------------------------------------------------------------------
		MOVf $y $x 	; y = x
		GEQf $y $min @.f0	; if (y < min) y = min
		MOVf $y $min 	; y = min
		GOTO @.e1  
	.f0:	LEQf $y $max @.f2	; if (y > max) y = max
		MOVf $y $max 	; y = max
	.f2:	NOOP
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
floorMod:	FUNC
	$r:	OUTf
	$a:	INPf
	$n:	INPf
;-----------------------------------------------------------------------------
		DIVf %0 $a $n	; r = a - n * floor(a / n)
		FLOf %0 %0 
		MULf %0 $n %0
		SUBf $r $a %0
		RETU   	; }


;-----------------------------------------------------------------------------
round:	FUNC
	$y:	OUTf
	$x:	INPf
;-----------------------------------------------------------------------------
		ADDf %0 $x #0.5	; y = floor(x + 0.5)
		FLOf $y %0 
		RETU   	; }

params:	GLOB *PARAM_COUNT
	! MULi <A> #BALL_COUNT #BALL_PARAMS_COUNT
balls:	GLOB *<A>

;-----------------------------------------------------------------------------
tick:	FUNC
		PARA *1
	$sampleFrames:	INPi
	$sampleRate:	INPf
	$rsr16:	LOCf
	$gravity:	LOCf
	$bumperForce:	LOCf
	$nx:	LOCf
	$ny:	LOCf
	$d:	LOCf
	$dx:	LOCf
	$dy:	LOCf
	$a:	LOCf
	$v:	LOCf
	$eventCount:	LOCi
	$i:	LOCi
	$offset:	LOCi
	$midiVel:	LOCi
	$octave:	LOCi
	$note:	LOCi
	$ballParams:	LOCA *BALL_PARAMS_COUNT
;-----------------------------------------------------------------------------
		DIVf $rsr16 #16.0 $sampleRate	; rsr16 = 16.0 / sampleRate
		PEEK %1 &params:GRAVITY_PARAM 	; gravity = (float) cube((float) global params[GRAVITY_PARAM]) * MAX_GRAVITY
		CALL &cube %0 *2
		MULf $gravity %0 #MAX_GRAVITY
		PEEK %0 &params:BUMPER_FORCE_PARAM 	; bumperForce = (float) global params[BUMPER_FORCE_PARAM] * 2.0
		MULf $bumperForce %0 #2.0
		MOVi $eventCount #0 	; eventCount = 0
	.l0:	GEQi $offset $sampleFrames @.e1	; while (offset < sampleFrames) 
		MOVi $i #0 	; for (i = 0 to BALL_COUNT) 
		GEQi #0 #BALL_COUNT @.e2
	.l3:	MULi %0 $i #BALL_PARAMS_COUNT	; copy (BALL_PARAMS_COUNT from &global balls[i * BALL_PARAMS_COUNT] to ballParams)
		ADRL %1 $ballParams *0
		ADDp %0 &balls %0
		COPY %1 %0 *BALL_PARAMS_COUNT
		EQUi $ballParams:BALL_ACTIVE_PARAM #0 @.f4	; if ((int) ballParams[BALL_ACTIVE_PARAM] != 0) 
		MULf %1 $ballParams:BALL_DX_PARAM $rsr16	; nx = (float) ballParams[BALL_X_PARAM] + (float) ballParams[BALL_DX_PARAM] * rsr16
		ADDf $nx $ballParams:BALL_X_PARAM %1
		MULf %1 $ballParams:BALL_DY_PARAM $rsr16	; ny = (float) ballParams[BALL_Y_PARAM] + (float) ballParams[BALL_DY_PARAM] * rsr16
		ADDf $ny $ballParams:BALL_Y_PARAM %1
		MULf %1 $nx $nx	; d = nx * nx + ny * ny
		MULf %0 $ny $ny
		ADDf $d %1 %0
		GEQf $d #1.0 @.f5	; if (d < 1.0) 
		MOVf $ballParams:BALL_X_PARAM $nx 	; ballParams[BALL_X_PARAM] = nx
		MOVf $ballParams:BALL_Y_PARAM $ny 	; ballParams[BALL_Y_PARAM] = ny
		MULf %1 $gravity $rsr16	; ballParams[BALL_DY_PARAM] = (float) ballParams[BALL_DY_PARAM] + gravity * rsr16
		ADDf $ballParams:BALL_DY_PARAM $ballParams:BALL_DY_PARAM %1
		GOTO @.e6  	; } else 
	.f5:	MOVf $dx $ballParams:BALL_DX_PARAM 	; dx = (float) ballParams[BALL_DX_PARAM]
		MOVf $dy $ballParams:BALL_DY_PARAM 	; dy = (float) ballParams[BALL_DY_PARAM]
		MULf %1 $dx $ny	; ballParams[BALL_DX_PARAM] = (dx * ny * ny - dx * nx * nx - 2.0 * nx * ny * dy) / d
		MULf %0 $dx $nx
		MULf %1 %1 $ny
		MULf %0 %0 $nx
		MULf %2 #2.0 $nx
		MULf %2 %2 $ny
		SUBf %1 %1 %0
		MULf %2 %2 $dy
		SUBf %1 %1 %2
		DIVf $ballParams:BALL_DX_PARAM %1 $d
		MULf %1 $dy $nx	; ballParams[BALL_DY_PARAM] = (dy * nx * nx - dy * ny * ny - 2.0 * nx * ny * dx) / d
		MULf %2 $dy $ny
		MULf %1 %1 $nx
		MULf %2 %2 $ny
		MULf %0 #2.0 $nx
		MULf %0 %0 $ny
		SUBf %1 %1 %2
		MULf %0 %0 $dx
		SUBf %1 %1 %0
		DIVf $ballParams:BALL_DY_PARAM %1 $d
		MOVf %1 $ballParams:BALL_Y_PARAM 	; a = (float) atan2((float) ballParams[BALL_Y_PARAM], (float) ballParams[BALL_X_PARAM])
		MOVf %2 $ballParams:BALL_X_PARAM 
		CALL ^atan2 %0 *3
		MOVf $a %0 
		MULf %1 $ballParams:BALL_DX_PARAM $ballParams:BALL_DX_PARAM	; v = (float) sqrt((float) ballParams[BALL_DX_PARAM] * (float) ballParams[BALL_DX_PARAM] + (float) ballParams[BALL_DY_PARAM] * (float) ballParams[BALL_DY_PARAM])
		MULf %2 $ballParams:BALL_DY_PARAM $ballParams:BALL_DY_PARAM
		ADDf %1 %1 %2
		CALL ^sqrt %0 *2
		MOVf $v %0 
		MOVi $midiVel #0 	; midiVel = 0
		LEQf $v #0.00001 @.f7	; if (v > 0.00001) midiVel = ftoi((float) clamp((float) round(50.0 * (float) log(v) + 127.0), 0.0, 127.0))
		MOVf %3 $v 	; midiVel = ftoi((float) clamp((float) round(50.0 * (float) log(v) + 127.0), 0.0, 127.0))
		CALL ^log %2 *2
		MULf %2 #50.0 %2
		ADDf %2 %2 #127.0
		CALL &round %1 *2
		MOVf %2 #0.0 
		MOVf %3 #127.0 
		CALL &clamp %0 *4
		fTOi $midiVel %0 #1.0
	.f7:	LEQi $midiVel #0 @.f8	; if (midiVel > 0) 
		ADDi %0 $i #1	; octave = 4 + (i + 1) % 3
		MODi %0 %0 #3
		ADDi $octave #4 %0
		! MULf <A> #2.0 #PI	; note = ftoi((float) floorMod((float) round(a * (12.0 / (2.0 * PI)) + 9.0), 12.0)) + octave * 12
		! DIVf <A> #12.0 <A>
		MULf %2 $a <A>
		ADDf %2 %2 #9.0
		CALL &round %1 *2
		MOVf %2 #12.0 
		CALL &floorMod %0 *3
		fTOi %0 %0 #1.0
		MULi %1 $octave #12
		ADDi $note %0 %1
	.f8:	MULf %0 $v $bumperForce	; if (v * bumperForce < MIN_SPEED) 
		GEQf %0 #MIN_SPEED @.f9
		MOVf $ballParams:BALL_DX_PARAM #0.0 	; ballParams[BALL_DX_PARAM] = 0.0
		MOVf $ballParams:BALL_DY_PARAM #0.0 	; ballParams[BALL_DY_PARAM] = 0.0
		GOTO @.e10  	; } else if (v * bumperForce > MAX_SPEED) 
	.f9:	MULf %0 $v $bumperForce	; if (v * bumperForce > MAX_SPEED) 
		LEQf %0 #MAX_SPEED @.f11
		MULf %0 $ballParams:BALL_DX_PARAM #MAX_SPEED	; ballParams[BALL_DX_PARAM] = (float) ballParams[BALL_DX_PARAM] * MAX_SPEED / v
		DIVf $ballParams:BALL_DX_PARAM %0 $v
		MULf %0 $ballParams:BALL_DY_PARAM #MAX_SPEED	; ballParams[BALL_DY_PARAM] = (float) ballParams[BALL_DY_PARAM] * MAX_SPEED / v
		DIVf $ballParams:BALL_DY_PARAM %0 $v
		GOTO @.e12  	; } else 
	.f11:	MULf $ballParams:BALL_DX_PARAM $ballParams:BALL_DX_PARAM $bumperForce	; ballParams[BALL_DX_PARAM] = (float) ballParams[BALL_DX_PARAM] * bumperForce
		MULf $ballParams:BALL_DY_PARAM $ballParams:BALL_DY_PARAM $bumperForce	; ballParams[BALL_DY_PARAM] = (float) ballParams[BALL_DY_PARAM] * bumperForce
	.e12:	NOOP
	.e10:	NOOP
	.e6:	MULi %0 $i #BALL_PARAMS_COUNT	; copy (BALL_PARAMS_COUNT from ballParams to &global balls[i * BALL_PARAMS_COUNT])
		ADDp %0 &balls %0
		ADRL %1 $ballParams *0
		COPY %0 %1 *BALL_PARAMS_COUNT
	.f4:	FORi $i #BALL_COUNT @.l3	; }
	.e2:	ADDi $offset $offset #16	; offset = offset + 16
		GOTO @.l0  	; }
	.e1:	RETU   	; }


;-----------------------------------------------------------------------------
init:	FUNC
		PARA *1
	$i:	LOCi
	$o:	LOCi
;-----------------------------------------------------------------------------
		MOVi $i #0 	; for (i = 0 to BALL_COUNT) 
		GEQi #0 #BALL_COUNT @.e0
	.l1:	ADDi %0 $o #BALL_ACTIVE_PARAM	; global balls[o + BALL_ACTIVE_PARAM] = 0
		POKE &balls %0 #0
		ADDi %0 $o #BALL_X_PARAM	; global balls[o + BALL_X_PARAM] = 0.0
		POKE &balls %0 #0.0
		ADDi %0 $o #BALL_Y_PARAM	; global balls[o + BALL_Y_PARAM] = 0.0
		POKE &balls %0 #0.0
		ADDi %0 $o #BALL_DX_PARAM	; global balls[o + BALL_DX_PARAM] = 0.0
		POKE &balls %0 #0.0
		ADDi %0 $o #BALL_DY_PARAM	; global balls[o + BALL_DY_PARAM] = 0.0
		POKE &balls %0 #0.0
		ADDi $o $o #BALL_PARAMS_COUNT	; o = o + BALL_PARAMS_COUNT
		FORi $i #BALL_COUNT @.l1	; }
	.e0:	NOOP
		! ADDi <A> #0 #BALL_ACTIVE_PARAM	; global balls[0 + BALL_ACTIVE_PARAM] = 1
		POKE &balls:<A> #1 
		! ADDi <A> #0 #BALL_DY_PARAM	; global balls[0 + BALL_DY_PARAM] = 1.0
		POKE &balls:<A> #1.0 
		RETU   	; }


;-----------------------------------------------------------------------------
main:	FUNC
		PARA *1
	$i:	LOCi
;-----------------------------------------------------------------------------
		CALL &init %0 *1	; init()
		MOVi $i #0 	; for (i = 0 to 100000000) tick(64, 44100.0)
		GEQi #0 #100000000 @.e0
	.l1:	MOVi %1 #64 	; tick(64, 44100.0)
		MOVf %2 #44100.0 
		CALL &tick %0 *3
		FORi $i #100000000 @.l1
	.e0:	RETU   	; }