;-----------------------------------------------------------------------------
stringToFloat:	FUNC
	$p:	OUTp
	$b:	INPp
	$v:	INPp
	$f:	LOCf
	$e:	LOCf
	$n:	LOCi
	$i:	LOCi
	$c:	LOCi
	$q:	LOCp
;-----------------------------------------------------------------------------
		MOVp $p $b 	; p = b
		MOVf $f #0.0 	; f = 0.0
	.l0:	PEEK $c $p 	; while ((c = (int) *p) >= '0' && c <= '9') 
		LSSi $c #'0' @.e2
		GRTi $c #'9' @.e2
		SUBi %0 $c #'0'	; f = f * 10.0 + itof(c - '0')
		MULf %1 $f #10.0
		iTOf %0 %0 #1.0
		ADDf $f %1 %0
		ADDp $p $p #1	; p = p + 1
		GOTO @.l0  	; }
	.e2:	PEEK %1 $p 	; if ((int) *p == '.') 
		NEQi %1 #'.' @.f3
		ADDp $p $p #1	; p = p + 1
		MOVf $e #0.1 	; e = 0.1
	.l4:	PEEK $c $p 	; while ((c = (int) *p) >= '0' && c <= '9') 
		LSSi $c #'0' @.f3
		GRTi $c #'9' @.f3
		SUBi %1 $c #'0'	; f = f + e * itof(c - '0')
		iTOf %1 %1 #1.0
		MULf %1 $e %1
		ADDf $f $f %1
		MULf $e $e #0.1	; e = e * 0.1
		ADDp $p $p #1	; p = p + 1
		GOTO @.l4  	; }
	.f3:	PEEK $c $p 	; if ((c = (int) *p) == 'e' || c == 'E') 
		EQUi $c #'e' @.t7
		NEQi $c #'E' @.f8
	.t7:	ADDp $q $p #1	; q = p + 1
		MOVf $e #10.0 	; e = 10.0
		PEEK $c $q 	; if ((c = (int) *q) == '+') q = q + 1
		NEQi $c #'+' @.f9
		ADDp $q $q #1	; q = q + 1
		GOTO @.e10  
	.f9:	NEQi $c #'-' @.f11	; if (c == '-') 
		MOVf $e #0.1 	; e = 0.1
		ADDp $q $q #1	; q = q + 1
	.f11:	NOOP
	.e10:	MOVi $n #0 	; n = 0
	.l12:	PEEK $c $q 	; while ((c = (int) *q) >= '0' && c <= '9') 
		LSSi $c #'0' @.e14
		GRTi $c #'9' @.e14
		MULi %1 $n #10	; n = n * 10 + (c - '0')
		SUBi %0 $c #'0'
		ADDi $n %1 %0
		ADDp $q $q #1	; q = q + 1
		MOVp $p $q 	; p = q
		GOTO @.l12  	; }
	.e14:	LEQi $n #50 @.f15	; if (n > 50) n = 50
		MOVi $n #50 	; n = 50
	.f15:	MOVi $i #0 	; for (i = 0 to n) f = f * e
		GEQi #0 $n @.f8
	.l17:	MULf $f $f $e	; f = f * e
		FORi $i $n @.l17
	.f8:	POKE $v $f 	; *v = f
		RETU   	; }


;-----------------------------------------------------------------------------
floatToString:	FUNC
	$p:	OUTp
	$f:	INPf
	$precision:	INPi
	$buffer:	INPp
	$x:	LOCf
	$y:	LOCf
	$e:	LOCi
	$g:	LOCf
	$dp:	LOCp
	$pp:	LOCp
	$ep:	LOCp
	$i:	LOCi
;-----------------------------------------------------------------------------
		! EQUi #DEBUG #0 @.a0	; assert(1 <= precision && precision <= 24)
		GRTi #1 $precision @.f1
		LEQi $precision #24 @.a0
	.f1:	MOVp %1 &.a_1preci4d5 
		CALL ^assertFail %0 *1
	.a0:	ABSf $y $f 	; y = abs(f)
		GRTf $y #EPSILON_FLOAT @.f2	; if (y <= EPSILON_FLOAT) p = "0"
		MOVp $p &.s_04db 	; p = "0"
		GOTO @.e3  
	.f2:	LSSf $y #HUGE_FLOAT @.f4	; if (y >= HUGE_FLOAT) p = "HUGE"
		MOVp $p &.s_HUGE4dc 	; p = "HUGE"
		GOTO @.e5  
	.f4:	MOVi $e #0 	; e = 0
		ADDp %0 $buffer #3	; ep = buffer + 3 + precision
		ADDp $ep %0 $precision
	.l6:	ADDp $pp $buffer #3	; pp = buffer + 3
		MOVf $x $y 	; x = y
	.l7:	LSSf $x #10.0 @.e9	; while (x >= 10.0 && pp < ep) 
		GEQp $pp $ep @.e9
		ADDp $pp $pp #1	; pp = pp + 1
		MULf $x $x #0.1	; x = x * 0.1
		GOTO @.l7  	; }
	.e9:	GEQp $pp $ep @.f11	; if (pp < ep && y > SMALL_FLOAT && y < LARGE_FLOAT) goto break
		LEQf $y #SMALL_FLOAT @.f11
		GEQf $y #LARGE_FLOAT @.f11
		GOTO @break  	; goto break
	.f11:	MOVf $g $y 	; g = y
	.l12:	GEQf $y #1.0 @.e13	; while (y < 1.0) 
		SUBi $e $e #1	; e = e - 1
		MULf $y $y #10.0	; y = y * 10.0
		GOTO @.l12  	; }
	.e13:	NOOP
	.l14:	LSSf $y #10.0 @.l6	; while (y >= 10.0) 
		ADDi $e $e #1	; e = e + 1
		MULf $y $y #0.1	; y = y * 0.1
		GOTO @.l14  	; }
		GOTO @.l6  	; }
	break:	ADDp $dp $buffer #2	; break:
	.l16:	GEQf $x #1.0 @.e18	; while (x < 1.0 && dp < buffer + 32) 
		ADDp %0 $buffer #32
		GEQp $dp %0 @.e18
		POKE $dp #'0' 	; *dp = '0'
		ADDp $dp $dp #1	; dp = dp + 1
		NEQp $dp $pp @.f19	; if (dp == pp) 
		POKE $dp #'9' 	; *dp = '9'
		ADDp $dp $dp #1	; dp = dp + 1
	.f19:	ADDp $ep $ep #1	; ep = ep + 1
		MULf $x $x #10.0	; x = x * 10.0
		GOTO @.l16  	; }
	.e18:	NOOP
	.l20:	GEQp $dp $ep @.e21	; while (dp < ep) 
		fTOi $i $x #1.0	; i = ftoi(x)
		ADDi %0 $i #'0'	; *dp = i + '0'
		POKE $dp %0 
		ADDp $dp $dp #1	; dp = dp + 1
		NEQp $dp $pp @.f22	; if (dp == pp) 
		POKE $dp #'9' 	; *dp = '9'
		ADDp $dp $dp #1	; dp = dp + 1
	.f22:	iTOf %0 $i #1.0	; x = (x - itof(i)) * 10.0
		SUBf %0 $x %0
		MULf $x %0 #10.0
		GOTO @.l20  	; }
	.e21:	ADDp $p $buffer #2	; p = buffer + 2
		LSSf $x #5.0 @.f23	; if (x >= 5.0) 
	.l24:	PEEK %0 $dp #-1	; while ((int) dp[-1] == '9') *(dp = dp - 1) = '0'
		NEQi %0 #'9' @.e25
		SUBp $dp $dp #1	; *(dp = dp - 1) = '0'
		POKE $dp #'0' 
		GOTO @.l24  
	.e25:	NEQp $dp $p @.f26	; if (dp == p) *(p = p - 1) = '1'
		SUBp $p $p #1	; *(p = p - 1) = '1'
		POKE $p #'1' 
		GOTO @.e27  
	.f26:	PEEK %0 $dp #-1	; dp[-1] = (int) dp[-1] + 1
		ADDi %0 %0 #1
		POKE $dp #-1 %0
	.e27:	NOOP
	.f23:	POKE $pp #'.' 	; *pp = '.'
		LEQp $ep $pp @.f28	; if (ep > pp) while ((int) ep[-1] == '0') ep = ep - 1
	.l29:	PEEK %0 $ep #-1	; while ((int) ep[-1] == '0') ep = ep - 1
		NEQi %0 #'0' @.f28
		SUBp $ep $ep #1	; ep = ep - 1
		GOTO @.l29  
	.f28:	SUBp %0 $ep #1	; if (ep - 1 == pp) ep = ep - 1
		NEQp %0 $pp @.f31
		SUBp $ep $ep #1	; ep = ep - 1
	.f31:	EQUi $e #0 @.f32	; if (e != 0) 
		POKE $ep #'e' 	; *ep = 'e'
		MOVi $i #'+' 	; i = '+'
		GEQi $e #0 @.f33	; if (e < 0) i = '-'
		MOVi $i #'-' 	; i = '-'
	.f33:	ADDp $ep $ep #1	; *(ep = ep + 1) = i
		POKE $ep $i 
		ABSi $i $e 	; i = abs(e)
		LSSi $i #100 @.f34	; if (i >= 100) *(ep = ep + 1) = '0' + ((i / 100) % 10)
		ADDp $ep $ep #1	; *(ep = ep + 1) = '0' + ((i / 100) % 10)
		DIVi %0 $i #100
		MODi %0 %0 #10
		ADDi %0 #'0' %0
		POKE $ep %0 
	.f34:	LSSi $i #10 @.f35	; if (i >= 10) *(ep = ep + 1) = '0' + ((i / 10) % 10)
		ADDp $ep $ep #1	; *(ep = ep + 1) = '0' + ((i / 10) % 10)
		DIVi %0 $i #10
		MODi %0 %0 #10
		ADDi %0 #'0' %0
		POKE $ep %0 
	.f35:	ADDp $ep $ep #1	; *(ep = ep + 1) = '0' + (i % 10)
		MODi %0 $i #10
		ADDi %0 #'0' %0
		POKE $ep %0 
		ADDp $ep $ep #1	; ep = ep + 1
	.f32:	POKE $ep #0 	; *ep = 0
		GEQf $f #0.0 @.f36	; if (f < 0.0) *(p = p - 1) = '-'
		SUBp $p $p #1	; *(p = p - 1) = '-'
		POKE $p #'-' 
	.f36:	NOOP
	.e5:	NOOP
	.e3:	RETU   	; }


;-----------------------------------------------------------------------------
traceInts:	FUNC
		PARA *1
	$text:	INPp
	$n:	INPi
	$ints:	INPp
	! ADDi <A> #GAZL_WORD_SIZE #2
	$buffer:	LOCA *<A>
	$line:	LOCA *1024
	$i:	LOCi
	$p:	LOCp
;-----------------------------------------------------------------------------
		ADRL $p $line:0 *0	; p = &line[0]
		EQUp $text &NULL @.f0	; if (text != null) p = (pointer) stpcpy(p, text)
		MOVp %1 $p 	; p = (pointer) stpcpy(p, text)
		MOVp %2 $text 
		CALL &stpcpy %0 *3
		MOVp $p %0 
	.f0:	POKE $p #0 	; *p = 0
		MOVi $i #0 	; for (i = 0 to n) 
		GEQi #0 $n @.e1
	.l2:	EQUi $i #0 @.f3	; if (i != 0) 
		POKE $p #',' 	; *p = ','
		ADDp $p $p #1	; p = p + 1
	.f3:	MOVp %1 $p 	; p = (pointer) stpcpy(p, intToString(ints[i], 10, 1, buffer))
		PEEK %3 $ints $i
		MOVi %4 #10 
		MOVi %5 #1 
		ADRL %6 $buffer *0
		CALL &intToString %2 *5
		CALL &stpcpy %0 *3
		MOVp $p %0 
		FORi $i $n @.l2	; }
	.e1:	ADRL %1 $line *0	; trace(line)
		CALL ^trace %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
traceInt:	FUNC
		PARA *1
	$text:	INPp
	$i:	INPi
	$ints:	LOCA *1
;-----------------------------------------------------------------------------
		MOVi $ints:0 $i 	; ints[0] = i
		MOVp %1 $text 	; traceInts(text, 1, ints)
		MOVi %2 #1 
		ADRL %3 $ints *0
		CALL &traceInts %0 *4
		RETU   	; }


;-----------------------------------------------------------------------------
traceFloats:	FUNC
		PARA *1
	$text:	INPp
	$n:	INPi
	$floats:	INPp
	$buffer:	LOCA *33
	$line:	LOCA *1024
	$i:	LOCi
	$p:	LOCp
;-----------------------------------------------------------------------------
		ADRL $p $line:0 *0	; p = &line[0]
		EQUp $text &NULL @.f0	; if (text != null) p = (pointer) stpcpy(p, text)
		MOVp %1 $p 	; p = (pointer) stpcpy(p, text)
		MOVp %2 $text 
		CALL &stpcpy %0 *3
		MOVp $p %0 
	.f0:	POKE $p #0 	; *p = 0
		MOVi $i #0 	; for (i = 0 to n) 
		GEQi #0 $n @.e1
	.l2:	EQUi $i #0 @.f3	; if (i != 0) 
		POKE $p #',' 	; *p = ','
		ADDp $p $p #1	; p = p + 1
	.f3:	MOVp %1 $p 	; p = (pointer) stpcpy(p, floatToString(floats[i], 8, buffer))
		PEEK %3 $floats $i
		MOVi %4 #8 
		ADRL %5 $buffer *0
		CALL &floatToString %2 *4
		CALL &stpcpy %0 *3
		MOVp $p %0 
		FORi $i $n @.l2	; }
	.e1:	ADRL %1 $line *0	; trace(line)
		CALL ^trace %0 *2
		RETU   	; }


;-----------------------------------------------------------------------------
traceFloat:	FUNC
		PARA *1
	$text:	INPp
	$f:	INPf
	$floats:	LOCA *1
;-----------------------------------------------------------------------------
		MOVf $floats:0 $f 	; floats[0] = f
		MOVp %1 $text 	; traceFloats(text, 1, floats)
		MOVi %2 #1 
		ADRL %3 $floats *0
		CALL &traceFloats %0 *4
		RETU   	; }

LOG2:	! DEFf #0.69314718055994530942

;-----------------------------------------------------------------------------
error:	FUNC
		PARA *1
	$s:	INPp
;-----------------------------------------------------------------------------
		MOVp %1 $s 	; trace(s)
		CALL ^trace %0 *2
		CALL ^abort %0 *1	; abort()
		RETU   	; }


;-----------------------------------------------------------------------------
exp:	FUNC
	$y:	OUTf
	$x:	INPf
	$a:	LOCf
	$n:	LOCf
	$m:	LOCf
	$t:	LOCf
;-----------------------------------------------------------------------------
		ABSf $m $x 	; m = abs(x)
		MOVf $a #1.0 	; a = 1.0
		MOVf $n #1.0 	; n = 1.0
		MOVf $y #1.0 	; y = 1.0
	.l0:	MOVf $t $y 	; t = y
		MULf %0 $a $m	; a = a * m / n
		DIVf $a %0 $n
		ADDf $y $y $a	; y = y + a
		ADDf $n $n #1.0	; n = n + 1.0
		NEQf $y $t @.l0	; } while (y != t)
		GEQf $x #0.0 @.f1	; if (x < 0.0) y = 1.0 / y
		DIVf $y #1.0 $y	; y = 1.0 / y
	.f1:	RETU   	; }


;-----------------------------------------------------------------------------
sqrt:	FUNC
	$y:	OUTf
	$x:	INPf
	$t:	LOCf
;-----------------------------------------------------------------------------
		GEQf $x #0.0 @.f0	; if (x < 0.0) error("Domain error")
		MOVp %1 &.s_Domain4dd 	; error("Domain error")
		CALL &error %0 *2
	.f0:	MOVf $y $x 	; y = x
		MOVf $t #0.0 	; t = 0.0
	.l1:	EQUf $y $t @.e2	; while (y != t) 
		MOVf $t $y 	; t = y
		DIVf %0 $x $y	; y = 0.5 * (y + x / y)
		ADDf %0 $y %0
		MULf $y #0.5 %0
		GOTO @.l1  	; }
	.e2:	RETU   	; }

	GLOB *1
rndSeedX:	DATi #123456789
	GLOB *1
rndSeedY:	DATi #362436069

;-----------------------------------------------------------------------------
seedRandom:	FUNC
		PARA *1
	$seed:	INPi
	$x:	LOCi
;-----------------------------------------------------------------------------
		ADDi $x $seed #1	; x = seed + 1
		SHLi %0 $x #11	; x = (x ^ (x << 11))
		XORi $x $x %0
		MULi %0 $x #134775813	; x = x * (x * 134775813 >>> 13)
		SHRu %0 %0 #13
		MULi $x $x %0
		SHRu %0 $x #17	; x = (x ^ (x >>> 17))
		XORi $x $x %0
		POKE &rndSeedX $x 	; global rndSeedX = x
		POKE &rndSeedY #362436069 	; global rndSeedY = 362436069
		RETU   	; }


;-----------------------------------------------------------------------------
randomFloat:	FUNC
	$f:	OUTf
	$x:	LOCi
	$y:	LOCi
	$t:	LOCi
;-----------------------------------------------------------------------------
		PEEK $x &rndSeedX 	; x = global rndSeedX
		PEEK $y &rndSeedY 	; y = global rndSeedY
		SHLi %0 $x #10	; t = x ^ (x << 10)
		XORi $t $x %0
		MOVi $x $y 	; x = y
		SHRu %0 $y #13	; y = y ^ (y >>> 13) ^ t ^ (t >>> 10)
		XORi %0 $y %0
		XORi %0 %0 $t
		SHRu %1 $t #10
		XORi $y %0 %1
		ABSi %0 $y 	; f = itof(abs(y)) * 4.6566128730774e-10
		iTOf $f %0 #4.6566128730774e-10
		POKE &rndSeedX $x 	; global rndSeedX = x
		POKE &rndSeedY $y 	; global rndSeedY = y
		RETU   	; }

