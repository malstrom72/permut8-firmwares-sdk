myrand_seed:	DATi #2463534242

;-----------------------------------------------------------------------------
myrand:	FUNC
	$y:	OUTi
;-----------------------------------------------------------------------------
		PEEK $y &myrand_seed 	; y = global myrand_seed
		SHLi %0 $y #13	; y = y ^ (y << 13)
		XORi $y $y %0
		SHRu %0 $y #17	; y = y ^ (y >>> 17)
		XORi $y $y %0
		SHLi %0 $y #5	; y = y ^ (y << 5)
		XORi $y $y %0
		POKE &myrand_seed $y 	; global myrand_seed = y
		RETU   	; }

