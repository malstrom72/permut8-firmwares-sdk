		CALL ^print %0 *2
		MOVf $myFloat #1000.0 	; myFloat = 1000.0
		! SHLi <B> #1 #anInt	; printInt(ftoi(myFloat * (1.0 / itof(1 << anInt))))
		! iTOf <B> <B> #1.0
		! DIVf <B> #1.0 <B>
		fTOi %1 $myFloat <B>
		CALL ^printInt %0 *2
		CALL ^printLF %0 *1	; printLF()
		CALL &showoff %0 *1	; showoff()
		MOVp %1 &.s_Bye4d4 	; print("Bye!\n")
		CALL ^print %0 *2
		RETU   	; }

