;-----------------------------------------------------------------------------
abortOnZero:	FUNC
		PARA *1
	$v:	INPi
;-----------------------------------------------------------------------------
		NEQi $v #0 @.f0	; if (v == 0) abort()
		CALL ^abort %0 *1	; abort()
	.f0:	RETU   	; }


;-----------------------------------------------------------------------------
fetchSomeConst:	FUNC
	$fetched:	OUTi
	$index:	INPi
;-----------------------------------------------------------------------------
		PEEK $fetched &SOME_CONSTS $index	; fetched = (int) global SOME_CONSTS[index]
		RETU   	; }


;-----------------------------------------------------------------------------
findSmallest:	FUNC
	$j:	OUTi
	$n:	INPi
	$vector:	INPp
	$i:	LOCi
;-----------------------------------------------------------------------------
		MOVi $j #0 	; j = 0
		MOVi $i #1 	; for (i = 1 to n)       // This `for` statement iterates i from 1 up until n (exclusively).
		GEQi #1 $n @.e0
	.l1:	PEEK %0 $vector $i	; if ((int) vector[i] < (int) vector[j])
		PEEK %1 $vector $j
		GEQi %0 %1 @.f2
		MOVi $j $i 	; j = i
	.f2:	FORi $i $n @.l1
	.e0:	RETU   	; }

TEST_SIZE:	! DEFi #50

;-----------------------------------------------------------------------------
test:	FUNC
		PARA *1
	$i:	LOCi
	$mydata:	LOCA *TEST_SIZE
;-----------------------------------------------------------------------------
		MOVi $i #0 	; for (i = 0 to TEST_SIZE)
		GEQi #0 #TEST_SIZE @.e0
	.l1:	CALL &myrand %0 *1	; mydata[i] = myrand()
		SETL $mydata $i %0
		FORi $i #TEST_SIZE @.l1
	.e0:	MOVi $i #0 	; for (i = 0 to TEST_SIZE) 
		GEQi #0 #TEST_SIZE @.e2
	.l3:	GETL %1 $mydata $i	; printInt(mydata[i])
		CALL ^printInt %0 *2
		CALL ^printLF %0 *1	; printLF()
		FORi $i #TEST_SIZE @.l3	; }
	.e2:	MOVi %2 #TEST_SIZE 	; printInt(findSmallest(TEST_SIZE, mydata))
		ADRL %3 $mydata *0
		CALL &findSmallest %1 *3
		CALL ^printInt %0 *2
		RETU   	; }


