		CALL ^printInt %0 *2
		CALL ^printLF %0 *1	; printLF()
		MOVi $b #'xyz' 	; a = b = 'xyz'
		MOVi $a #'xyz' 
		! MULi <A> #345 #123	; a = b = 345 * 123
		MOVi $b <A> 
		MOVi $a <A> 
		ADDi $b $c $d	; a = b = c + d
		MOVi $a $b 
