; Compiled with Impala version 1.0

PRAWN_FIRMWARE_PATCH_FORMAT:	! DEFi #2
FALSE:	! DEFi #0
TRUE:	! DEFi #1
panelTextRows:	CNST *8
	DATA &.s_MUTEst4d2 &.s_REPEAT4d3 &.s_SKIPst4d4
	DATA &.s_HOLDst4d5 &.s_ACCENT4d6 &.s_STUTTE4d7
	DATA &.s_REVERS4d8 &.s_TAPEST4d9
	GLOB *1
clock:	DATi #0
params:	GLOB *PARAM_COUNT
displayLEDs:	GLOB *4
	CNST *1
clockFreqLimit:	DATi #132300
signal:	GLOB *2
	CNST *1
	! SHLi <A> #1 #OPERATOR_1_PARAM_INDEX
	! SHLi <B> #1 #OPERAND_1_HIGH_PARAM_INDEX
	! IORi <A> <A> <B>
	! SHLi <B> #1 #OPERAND_1_LOW_PARAM_INDEX
	! IORi <A> <A> <B>
	! SHLi <B> #1 #OPERATOR_2_PARAM_INDEX
	! IORi <A> <A> <B>
	! SHLi <B> #1 #OPERAND_2_HIGH_PARAM_INDEX
	! IORi <A> <A> <B>
	! SHLi <B> #1 #OPERAND_2_LOW_PARAM_INDEX
	! IORi <A> <A> <B>
updateMask:	DATi <A>
NOP:	! DEFi #0
MUTE:	! DEFi #1
REPEAT:	! DEFi #2
SKIP:	! DEFi #3
HOLD:	! DEFi #4
ACCENT:	! DEFi #1
STUTTER:	! DEFi #2
REVERSE:	! DEFi #3
TAPE_STOP:	! DEFi #4
LOOKAHEAD:	! DEFi #0x80
	GLOB *1
bottomOperator:	DATi #0
steps:	GLOB *16
gains:	GLOB *16
holds:	GLOB *16
sfxs:	GLOB *16
	GLOB *1
lastInStep:	DATi #-1
	GLOB *1
currentOutStep:	DATi #0
	GLOB *1
stopIndex:	DATi #0
	GLOB *1
stopRate:	DATi #0
	GLOB *1
currentGain:	DATi #0

;-----------------------------------------------------------------------------
reset:	FUNC
		PARA *1
;-----------------------------------------------------------------------------
		POKE &lastInStep #-1 	; global lastInStep = -1
		POKE &currentGain #0x10000 	; global currentGain = 0x10000
		RETU   	; }


;-----------------------------------------------------------------------------
update:	FUNC
		PARA *1
	$topOperator:	LOCi
	$bottomOperator:	LOCi
	$topBits:	LOCi
	$bottomBits:	LOCi
	$i:	LOCi
	$j:	LOCi
	$g:	LOCi
;-----------------------------------------------------------------------------
		PEEK $topOperator &params:OPERATOR_1_PARAM_INDEX 	; topOperator = (int) global params[OPERATOR_1_PARAM_INDEX]
		PEEK $bottomOperator &params:OPERATOR_2_PARAM_INDEX 	; bottomOperator = (int) global params[OPERATOR_2_PARAM_INDEX]
		PEEK %0 &params:OPERAND_1_HIGH_PARAM_INDEX 	; topBits = ((int) global params[OPERAND_1_HIGH_PARAM_INDEX] << 8)
		SHLi %0 %0 #8
		PEEK %1 &params:OPERAND_1_LOW_PARAM_INDEX 
		IORi $topBits %0 %1
		PEEK %0 &params:OPERAND_2_HIGH_PARAM_INDEX 	; bottomBits = ((int) global params[OPERAND_2_HIGH_PARAM_INDEX] << 8)
		SHLi %0 %0 #8
		PEEK %1 &params:OPERAND_2_LOW_PARAM_INDEX 
		IORi $bottomBits %0 %1
		POKE &bottomOperator $bottomOperator 	; global bottomOperator = bottomOperator
		MOVi $i #0 	; for (i = 0 to 16) 
		GEQi #0 #16 @.e0
	.l1:	POKE &gains $i #0x10000	; global gains[i] = 0x10000
		POKE &steps $i $i	; global steps[i] = i
		POKE &holds $i #0	; global holds[i] = 0
		POKE &sfxs $i #0	; global sfxs[i] = 0
		FORi $i #16 @.l1	; }
	.e0:	SWCH $topOperator *5 @.s2	; switch (topOperator == 0 to 5) 
	.s2#MUTE:	MOVi $i #0 	; for (i = 0 to 16) 
		GEQi #0 #16 @.e3
	.l5:	POKE &gains $i #0xFFFF	; global gains[i] = 0xFFFF
		SHRi %0 #0x8000 $i	; if ((topBits & (0x8000 >> i)) == 0) global gains[i] = 0
		ANDi %0 $topBits %0
		NEQi %0 #0 @.f6
		POKE &gains $i #0	; global gains[i] = 0
	.f6:	FORi $i #16 @.l5	; }
		GOTO @.e3  	; }
	.s2#REPEAT:	MOVi $j #0 	; j = 0
		MOVi $i #1 	; for (i = 1 to 16) if ((topBits & (0x8000 >> i)) != 0) j = i
		GEQi #1 #16 @.e7
	.l8:	SHRi %0 #0x8000 $i	; if ((topBits & (0x8000 >> i)) != 0) j = i
		ANDi %0 $topBits %0
		EQUi %0 #0 @.f9
		MOVi $j $i 	; j = i
	.f9:	FORi $i #16 @.l8
	.e7:	MOVi $i #0 	; for (i = 0 to 16) 
		GEQi #0 #16 @.e3
	.l11:	SHRi %0 #0x8000 $i	; if ((topBits & (0x8000 >> i)) != 0) j = i
		ANDi %0 $topBits %0
		EQUi %0 #0 @.f12
		MOVi $j $i 	; j = i
	.f12:	POKE &steps $i $j	; global steps[i] = j
		FORi $i #16 @.l11	; }
		GOTO @.e3  	; }
	.s2#SKIP:	EQUi $topBits #0 @.e3	; if (topBits != 0) 
		MOVi $i #0 	; i = 0
		MOVi $j #0 	; j = 0
	.l14:	SHRi %0 #0x8000 $j	; if ((topBits & (0x8000 >> j)) != 0) 
		ANDi %0 $topBits %0
		EQUi %0 #0 @.f15
		POKE &steps $i $j	; global steps[i] = j
		ADDi $i $i #1	; i = i + 1
	.f15:	ADDi %0 $j #1	; j = (j + 1) & 15
		ANDi $j %0 #15
		LSSi $i #16 @.l14	; } while (i < 16)
		GOTO @.e3  	; }
	.s2#HOLD:	MOVi $i #0 	; for (i = 0 to 16) global holds[i] = (topBits & (0x8000 >> i))
		GEQi #0 #16 @.e16
	.l17:	SHRi %0 #0x8000 $i	; global holds[i] = (topBits & (0x8000 >> i))
		ANDi %0 $topBits %0
		POKE &holds $i %0
		FORi $i #16 @.l17
	.e16:	NOOP
	.s2:	NOOP
	.e3:	PEEK %0 &bottomOperator 	; switch (global bottomOperator == 0 to 5) 
		SWCH %0 *5 @.s18
	.s18#ACCENT:	MOVi $i #0 	; for (i = 0 to 16) 
		GEQi #0 #16 @.e19
	.l21:	PEEK $g &gains $i	; g = (int) global gains[i]
		SHRi %0 #0x8000 $i	; if ((bottomBits & (0x8000 >> i)) == 0) g = g >> 1
		ANDi %0 $bottomBits %0
		NEQi %0 #0 @.f22
		SHRi $g $g #1	; g = g >> 1
		GOTO @.e23  
	.f22:	SHLi $g $g #1	; g = g << 1
	.e23:	POKE &gains $i $g	; global gains[i] = g
		FORi $i #16 @.l21	; }
		GOTO @.e19  	; }
	.s18#REVERSE:	NOOP
	.s18#STUTTER:	NOOP
	.s18#TAPE_STOP:	MOVi $i #0 	; for (i = 0 to 16) global sfxs[i] = (bottomBits & (0x8000 >> i))
		GEQi #0 #16 @.e24
	.l25:	SHRi %0 #0x8000 $i	; global sfxs[i] = (bottomBits & (0x8000 >> i))
		ANDi %0 $bottomBits %0
		POKE &sfxs $i %0
		FORi $i #16 @.l25
	.e24:	NOOP
	.s18:	NOOP
	.e19:	RETU   	; }


;-----------------------------------------------------------------------------
process:	FUNC
		PARA *1
	$localClock:	LOCi
	$inStep:	LOCi
	$outStep:	LOCi
	$i:	LOCi
	$gc:	LOCi
	$si:	LOCi
	$sr:	LOCi
	$f:	LOCi
	$gain:	LOCi
	$localSignal:	LOCA *4
;-----------------------------------------------------------------------------
		PEEK $localClock &clock 	; localClock = global clock
		SHRi $inStep $localClock #12	; inStep = localClock >> 12
		SHRi %0 #0x80 $inStep	; global displayLEDs[2] = 0x80 >> inStep
		POKE &displayLEDs:2 %0 
		SHRi %0 #0x8000 $inStep	; global displayLEDs[3] = 0x8000 >> inStep
		POKE &displayLEDs:3 %0 
		PEEK %0 &holds $inStep	; if ((int) global holds[inStep] == 0) 
		NEQi %0 #0 @.f0
		ADRL %0 $localSignal *0	; copy (2 from global signal to localSignal)
		COPY %0 &signal *2
		MOVi %1 $localClock 	; write(localClock, 1, localSignal)
		MOVi %2 #1 
		ADRL %3 $localSignal *0
		CALL ^write %0 *4
	.f0:	PEEK %0 &lastInStep 	; if (global lastInStep != inStep) 
		EQUi %0 $inStep @.f1
		PEEK %0 &steps $inStep	; global currentOutStep = (int) global steps[inStep]
		POKE &currentOutStep %0 
	.f1:	PEEK $outStep &currentOutStep 	; outStep = global currentOutStep
		SHRi %0 #0x80 $outStep	; global displayLEDs[0] = 0x80 >> outStep
		POKE &displayLEDs:0 %0 
		SHRi %0 #0x8000 $outStep	; global displayLEDs[1] = 0x8000 >> outStep
		POKE &displayLEDs:1 %0 
		SHLi $i $outStep #12	; i = outStep << 12
		PEEK %0 &sfxs $inStep	; if ((int) global sfxs[inStep] == 0) 
		NEQi %0 #0 @.f2
		ANDi %1 $localClock #0xFFF	; read(i | (localClock & 0xFFF), 1, localSignal)
		IORi %1 $i %1
		MOVi %2 #1 
		ADRL %3 $localSignal *0
		CALL ^read %0 *4
		GOTO @.e3  	; } else 
	.f2:	PEEK %0 &bottomOperator 	; switch (global bottomOperator == 0 to 5) 
		SWCH %0 *5 @.s4
	.s4#REVERSE:	ANDi %1 $localClock #0xFFF	; read(i + ((localClock & 0xFFF) ^ 0xFFFFFFFFF), 1, localSignal)
		XORi %1 %1 #0xFFFFFFFFF
		ADDi %1 $i %1
		MOVi %2 #1 
		ADRL %3 $localSignal *0
		CALL ^read %0 *4
		GOTO @.e5  
	.s4#STUTTER:	ANDi %1 $localClock #0x3FF	; read(i | (localClock & 0x3FF), 1, localSignal)
		IORi %1 $i %1
		MOVi %2 #1 
		ADRL %3 $localSignal *0
		CALL ^read %0 *4
		GOTO @.e5  
	.s4#TAPE_STOP:	MOVi $si #0x0 	; si = 0x0
		MOVi $sr #0x10000 	; sr = 0x10000
		PEEK %0 &lastInStep 	; if (global lastInStep == inStep) 
		NEQi %0 $inStep @.f6
		PEEK $si &stopIndex 	; si = global stopIndex
		PEEK $sr &stopRate 	; sr = global stopRate
	.f6:	SHRi %1 $si #16	; read(i | (si >> 16), 2, localSignal)
		IORi %1 $i %1
		MOVi %2 #2 
		ADRL %3 $localSignal *0
		CALL ^read %0 *4
		ANDi $f $si #0xFFFF	; f = si & 0xFFFF
		SUBi %0 $localSignal:2 $localSignal:0	; localSignal[0] = (int) localSignal[0] + (((int) localSignal[2] - (int) localSignal[0]) * f >> 16)
		MULi %0 %0 $f
		SHRi %0 %0 #16
		ADDi $localSignal:0 $localSignal:0 %0
		SUBi %0 $localSignal:3 $localSignal:1	; localSignal[1] = (int) localSignal[1] + (((int) localSignal[3] - (int) localSignal[1]) * f >> 16)
		MULi %0 %0 $f
		SHRi %0 %0 #16
		ADDi $localSignal:1 $localSignal:1 %0
		ADDi %0 $si $sr	; global stopIndex = si + sr
		POKE &stopIndex %0 
		SUBi %0 $sr #0x10	; global stopRate = sr - 0x10
		POKE &stopRate %0 
	.s4:	NOOP
	.e5:	NOOP
	.e3:	MOVi $gc #0x10000 	; gc = 0x10000
		ADDi %0 $localClock #LOOKAHEAD	; gain = (int) global gains[(((localClock + LOOKAHEAD) & 0xFFFF) >> 12)]
		ANDi %0 %0 #0xFFFF
		SHRi %0 %0 #12
		PEEK $gain &gains %0
		EQUi $gain #0x10000 @.f7	; if (gain != 0x10000) 
		PEEK $gc &currentGain 	; gc = global currentGain
		MULi %0 $localSignal:0 $gc	; localSignal[0] = ((int) localSignal[0] * gc) >> 16
		SHRi $localSignal:0 %0 #16
		MULi %0 $localSignal:1 $gc	; localSignal[1] = ((int) localSignal[1] * gc) >> 16
		SHRi $localSignal:1 %0 #16
		SUBi %0 $gain $gc	; gc = gc + ((gain - gc) >> 5)
		SHRi %0 %0 #5
		ADDi $gc $gc %0
	.f7:	POKE &lastInStep $inStep 	; global lastInStep = inStep
		POKE &currentGain $gc 	; global currentGain = gc
		ADRL %0 $localSignal *0	; copy (2 from localSignal to global signal)
		COPY &signal %0 *2
		RETU   	; }

.s_MUTEst4d2:	CNST *24
	DATs MUTE steps that are off
	DATi #0
.s_REPEAT4d3:	CNST *36
	DATs REPEAT steps that are on before off
	DATi #0
.s_SKIPst4d4:	CNST *24
	DATs SKIP steps that are off
	DATi #0
.s_HOLDst4d5:	CNST *53
	DATs HOLD steps that are on, turn on WRITE PROT when done
	DATi #0
.s_ACCENT4d6:	CNST *14
	DATs ACCENT effect
	DATi #0
.s_STUTTE4d7:	CNST *15
	DATs STUTTER effect
	DATi #0
.s_REVERS4d8:	CNST *15
	DATs REVERSE effect
	DATi #0
.s_TAPEST4d9:	CNST *17
	DATs TAPE STOP effect
	DATi #0