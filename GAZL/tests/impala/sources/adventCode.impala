					/*  WAVE.  NO EFFECT UNLESS WAVING ROD AT FISSURE OR AT BIRD. */
	
					if(((int)TOTING(lOBJ) == FALSE) && (lOBJ != ROD || (int)TOTING(ROD2) == FALSE))global SPK=29;
					if(lOBJ != ROD || (int)TOTING(lOBJ) == FALSE || ((int)HERE(BIRD, lLOC) == FALSE && (global CLOSNG != FALSE || (int)AT(FISSUR, lLOC) == FALSE))) { goValue = GOTO2011; goto return; }
					if((int)HERE(BIRD, lLOC) != FALSE)global SPK=206+(((int)global PROP[BIRD])%2);
					if(!(global SPK == 206 && lLOC == (int)global PLACE[STEPS] && (int)global PROP[JADE] < 0)) {
						if(global CLOSED != FALSE) { goValue = GOTO18999; goto return; }
						if(global CLOSNG != FALSE || (int)AT(FISSUR, lLOC) == FALSE) { goValue = GOTO2011; goto return; }
						if((int)HERE(BIRD, lLOC) != FALSE)fRSPEAK(global SPK);
						global PROP[FISSUR]=1-(int)global PROP[FISSUR];
						fPSPEAK(FISSUR,2-(int)global PROP[FISSUR]);
						{ goValue = GOTO2012; goto return; }
					}
					
					fDROP(JADE,lLOC);
					global PROP[JADE]=0;
					global TALLY=global TALLY-1;
					global SPK=208;
					{ goValue = GOTO2011; goto return; }	
				}
				
				case 9, 10, 17, 23, 24, 25, 29, 30, 32: { goValue = GOTO2011; goto return; }
				case 11: { goValue = (int)attack(); goto return; }
				case 12: goto L9130;
				case 13: {
					/* EAT TRANSITIVE: FOOD OK, SOME THINGS LOSE APPETITE, REST ARE RIDICULOUS. */
					
					if(lOBJ == FOOD) {
						fDSTROY(FOOD);
						global SPK=72;
						{ goValue = GOTO2011; goto return; }
					}
					if(lOBJ == BIRD || lOBJ == SNAKE || lOBJ == CLAM || lOBJ == OYSTER || lOBJ ==
						DWARF || lOBJ == DRAGON || lOBJ == TROLL || lOBJ == BEAR || lOBJ ==
						OGRE) global SPK=71;
					{ goValue = GOTO2011; goto return; }
				}
				
				case 14: goto L9150;
				case 15: {
					/*  RUB.  YIELDS VARIOUS SNIDE REMARKS EXCEPT FOR LIT URN. */

					if(lOBJ != LAMP)global SPK=76;
					if(lOBJ != URN || (int)global PROP[URN] != 2) { goValue = GOTO2011; goto return; }
					fDSTROY(URN);
					fDROP(AMBER,lLOC);
					global PROP[AMBER]=1;
					global TALLY=global TALLY-1;
					fDROP(CAVITY,lLOC);
					global SPK=216;
					{ goValue = GOTO2011; goto return; }
				}
				
				case 16: { goValue = (int)doThrow(); goto return; }
				case 18, 19: {
					/*  FIND.  MIGHT BE CARRYING IT, OR IT MIGHT BE HERE.  ELSE GIVE CAVEAT. */

					if((int)AT(lOBJ, lLOC) != FALSE || ((int)LIQ() == lOBJ && (int)AT(BOTTLE, lLOC) != FALSE) || lK == (int)LIQLOC(lLOC) || (lOBJ ==
						DWARF && (int)fATDWRF(lLOC) > 0))global SPK=94;
					if(global CLOSED != FALSE)global SPK=138;
					if((int)TOTING(lOBJ) != FALSE)global SPK=24;
					{ goValue = GOTO2011; goto return; }
				}
				case 20: { goValue = (int)feed(lOBJ); goto return; }
				case 21: { goValue = (int)fill(lOBJ); goto return; }
				case 22: goto L9230;
				case 26: goto L9270;
				case 27: {
					/*  BREAK.  ONLY WORKS FOR MIRROR IN REPOSITORY AND, OF COURSE, THE VASE. */

					if(lOBJ == MIRROR)global SPK=148;
					if(!(lOBJ == VASE && (int)global PROP[VASE] == 0)) {
						if(lOBJ != MIRROR || global CLOSED == FALSE) { goValue = GOTO2011; goto return; }
						global SPK=197;
						{ goValue = GOTO18999; goto return; }
					}

					global SPK=198;
					if((int)TOTING(VASE) != FALSE)fDROP(VASE,lLOC);
					global PROP[VASE]=2;
					global FIXED[VASE]= -1;
					{ goValue = GOTO2011; goto return; }
				}
				case 28: {
					/*  WAKE.  ONLY USE IS TO DISTURB THE DWARVES. */

					if(lOBJ != DWARF || global CLOSED == FALSE) { goValue = GOTO2011; goto return; }
					global SPK=199;
					{ goValue = GOTO18999; goto return; }
				}
				case 31: goto L9320;
				case 33: goto L8340;
			}
			fBUG(24);
	   }
	   
	   case 2: {
		/*  ANALYSE AN OBJECT WORD.  SEE IF THE THING IS HERE, WHETHER WE'VE GOT A VERB
		 *  YET, AND SO ON.  OBJECT MUST BE HERE UNLESS VERB IS "FIND" OR "INVENT(ORY)"
		 *  (AND NO NEW VERB YET TO BE ANALYSED).  WATER AND OIL ARE ALSO FUNNY, SINCE
		 *  THEY ARE NEVER ACTUALLY DROPPED AT ANY LOCATION, BUT MIGHT BE HERE INSIDE
		 *  THE BOTTLE OR URN OR AS A FEATURE OF THE LOCATION. */

			lOBJ=lK; global gOBJ = lK;
			if((int)HERE(lK, lLOC) != FALSE) {
			L5010:
				if(global WD2 > 0) { goValue = GOTO2800; goto return; }
				if(global VERB != 0) goto L4090;
				fSETPRM(1,global WD1,global WD1X);
				fRSPEAK(255);
				{ goValue = GOTO2600; goto return; }
			}
			
			if(lK == GRATE) {
				if(lLOC == 1 || lLOC == 4 || lLOC == 7) { lK=DPRSSN; global gK = lK; }
				if(lLOC > 9 && lLOC < 15) { lK=ENTRNC; global gK = lK; }
				if(lK != GRATE) { goValue = GOTO8; goto return; }
			}
			if(lK == DWARF && (int)fATDWRF(lLOC) > 0) goto L5010;
			if(((int)LIQ() == lK && (int)HERE(BOTTLE, lLOC) != FALSE) || lK == (int)LIQLOC(lLOC)) goto L5010;
			if(!(lOBJ != OIL || (int)HERE(URN, lLOC) == FALSE || (int)global PROP[URN] == 0)) {
				lOBJ=URN; global gOBJ = URN;
				 goto L5010;
			}
			if(!(lOBJ != PLANT || (int)AT(PLANT2, lLOC) == FALSE || (int)global PROP[PLANT2] == 0)) {
				lOBJ=PLANT2; global gOBJ = PLANT2;
				 goto L5010;
			}
			if(!(lOBJ != KNIFE || global KNFLOC != lLOC)) {
				global KNFLOC= -1;
				global SPK=116;
				{ goValue = GOTO2011; goto return; }
			}
			if(lOBJ != ROD || (int)HERE(ROD2, lLOC) == FALSE) goto L5190;
			lOBJ=ROD2; global gOBJ = ROD2;
			goto L5010;
		L5190:
			if((global VERB == FIND || global VERB == INVENT) && global WD2 <= 0) goto L5010;
			fSETPRM(1,global WD1,global WD1X);
			fRSPEAK(256);
			{ goValue = GOTO2012; goto return; }
	   }
	}
	fBUG(99);
	goValue = GOTO8000;
return: ;
}

/*
 * MAIN PROGRAM
 */

function main()
locals int gotoChoice, int I, int J, int lK, int K2, int KK, int KQ, int LL, int V1, int V2, int lOBJ, int lLOC
		, int HINT, int OLDOBJ, int STICK, int ATTACK
{
	lK=0;
	lOBJ=0;
	OLDOBJ = 0;
	STICK = 0;
	ATTACK = 0;

	/*  ADVENTURE (REV 2: 20 TREASURES) */

	/*  HISTORY: ORIGINAL IDEA & 5-TREASURE VERSION (ADVENTURES) BY WILLIE CROWTHER
	 *           15-TREASURE VERSION (ADVENTURE) BY DON WOODS, APRIL-JUNE 1977
	 *           20-TREASURE VERSION (REV 2) BY DON WOODS, AUGUST 1978
	 *		ERRATA FIXED: 78/12/25 */


	/* LOGICAL VARIABLES:
	 *
	 *  CLOSED SAYS WHETHER WE'RE ALL THE WAY CLOSED
	 *  CLOSNG SAYS WHETHER IT'S CLOSING TIME YET
	 *  CLSHNT SAYS WHETHER HE'S READ THE CLUE IN THE ENDGAME
	 *  LMWARN SAYS WHETHER HE'S BEEN WARNED ABOUT LAMP GOING DIM
	 *  NOVICE SAYS WHETHER HE ASKED FOR INSTRUCTIONS AT START-UP
	 *  PANIC SAYS WHETHER HE'S FOUND OUT HE'S TRAPPED IN THE CAVE
	 *  WZDARK SAYS WHETHER THE LOC HE'S LEAVING WAS DARK */

	/*  READ THE DATABASE IF WE HAVE NOT YET DONE SO */

	global MAP2[1] = 0;
	initialise();

	/*  START-UP, DWARF STUFF */

	I=(int)fRAN(-1);
	global ZZWORD=(int)fRNDVOC(3,0)+MESH*2;
	global NOVICE=(int)fYES(65,1,0);
	global NEWLOC=1;
	lLOC=1;
	global LIMIT=330;
	if(global NOVICE != FALSE)global LIMIT=1000;

	/*  CAN'T LEAVE CAVE ONCE IT'S CLOSING (EXCEPT BY MAIN OFFICE). */

L2:
	if(!((int)OUTSID(global NEWLOC) == FALSE || global NEWLOC == 0 || global CLOSNG == FALSE)) {
		fRSPEAK(130);
		global NEWLOC=lLOC;
		if(global PANIC == FALSE)global CLOCK2=15;
		global PANIC=TRUE;
	}

	/*  SEE IF A DWARF HAS SEEN HIM AND HAS COME FROM WHERE HE WANTS TO GO.  IF SO,
	 *  THE DWARF'S BLOCKING HIS WAY.  IF COMING FROM PLACE FORBIDDEN TO PIRATE
	 *  (DWARVES ROOTED IN PLACE) LET HIM GET OUT (AND ATTACKED). */

	if(!(global NEWLOC == lLOC || ((int)global COND[lLOC] == 2) || (int)CNDBIT(lLOC,3) != FALSE)) {
		for (I=1 to 5+1) {
			if(!((int)global ODLOC[I] != global NEWLOC || (int)global DSEEN[I] == FALSE)) {
				global NEWLOC=lLOC;
				fRSPEAK(2);
				goto break1;
			}
		} /* end loop */
	break1: ;
	}

	lLOC=global NEWLOC;

	/*  DWARF STUFF.  SEE EARLIER COMMENTS FOR DESCRIPTION OF VARIABLES.  REMEMBER
	 *  SIXTH DWARF IS PIRATE AND IS THUS VERY DIFFERENT EXCEPT FOR MOTION RULES. */

	/*  FIRST OFF, DON'T LET THE DWARVES FOLLOW HIM INTO A PIT OR A WALL.  ACTIVATE
	 *  THE WHOLE MESS THE FIRST TIME HE GETS AS FAR AS THE HALL OF MISTS (LOC 15).
	 *  IF NEWLOC IS FORBIDDEN TO PIRATE (IN PARTICULAR, IF IT'S BEYOND THE TROLL
	 *  BRIDGE), BYPASS DWARF STUFF.  THAT WAY PIRATE CAN'T STEAL RETURN TOLL, AND
	 *  DWARVES CAN'T MEET THE BEAR.  ALSO MEANS DWARVES WON'T FOLLOW HIM INTO DEAD
	 *  END IN MAZE, BUT C'EST LA VIE.  THEY'LL WAIT FOR HIM OUTSIDE THE DEAD END. */

	if(lLOC == 0 || ((int)global COND[lLOC] == 2) || (int)CNDBIT(global NEWLOC,3) != FALSE) goto L2000;
	if(global DFLAG == 0) {
		if((int)INDEEP(lLOC) != FALSE)global DFLAG=1;
		goto L2000;
	}

	/*  WHEN WE ENCOUNTER THE FIRST DWARF, WE KILL 0, 1, OR 2 OF THE 5 DWARVES.  IF
	 *  ANY OF THE SURVIVORS IS AT LOC, REPLACE HIM WITH THE ALTERNATE. */

	if(global DFLAG == 1) {
		if((int)INDEEP(lLOC) == FALSE || (((int)fRAN(100) < (95)) && ((int)CNDBIT(lLOC,4) == FALSE || ((int)fRAN(100) < (85))))) goto L2000;
		global DFLAG=2;
		for (I=1 to 2+1) {
			J=1+(int)fRAN(5);
			if(((int)fRAN(100) < (50)))global DLOC[J]=0;
		} /* end loop */
		for (I=1 to 5+1) {
			if((int)global DLOC[I] == lLOC)global DLOC[I]=DALTLC;
			global ODLOC[I]=global DLOC[I];
		} /* end loop */
		fRSPEAK(3);
		fDROP(AXE,lLOC);
		goto L2000;
	}

	/*  THINGS ARE IN FULL SWING.  MOVE EACH DWARF AT RANDOM, EXCEPT IF HE'S SEEN US
	 *  HE STICKS WITH US.  DWARVES STAY DEEP INSIDE.  IF WANDERING AT RANDOM,
	 *  THEY DON'T BACK UP UNLESS THERE'S NO ALTERNATIVE.  IF THEY DON'T HAVE TO
	 *  MOVE, THEY ATTACK.  AND, OF COURSE, DEAD DWARVES DON'T DO MUCH OF ANYTHING. */

	global DTOTAL=0;
	ATTACK=0;
	STICK=0;
	for (I=1 to 6+1) {
		if((int)global DLOC[I] != 0) {
			/*  FILL TK ARRAY WITH ALL THE PLACES THIS DWARF MIGHT GO. */
			J=1;
			KK=(int)global DLOC[I];
			KK=(int)global KEY[KK];
			if(KK != 0) {
				do {
					global NEWLOC=((abs((int)global TRAVEL[KK])/1000)%1000);
					
					if(!(global NEWLOC > 300 || (int)INDEEP(global NEWLOC) == FALSE
							|| global NEWLOC == (int)global ODLOC[I] || (J > 1 && global NEWLOC == (int)global TK[J-1])
							|| J >= 20 || global NEWLOC == (int)global DLOC[I] || ((int)global COND[global NEWLOC] == 2)
							|| (I == 6 && (int)CNDBIT(global NEWLOC,3) != FALSE) || abs((int)global TRAVEL[KK])/1000000 == 100)) {
						global TK[J]=global NEWLOC;
						J=J+1;
					}
					KK=KK+1;
				} while ((int)global TRAVEL[KK-1] >= 0);
			}
			global TK[J]=(int)global ODLOC[I];
			if(J >= 2)J=J-1;
			J=1+(int)fRAN(J);
			global ODLOC[I]=global DLOC[I];
			global DLOC[I]=global TK[J];
			if (((int)global DSEEN[I] != FALSE && (int)INDEEP(lLOC) != FALSE) || ((int)global DLOC[I] == lLOC || (int)global ODLOC[I] == lLOC)) {
				global DSEEN[I]=TRUE;
				global DLOC[I]=lLOC;
				if(I != 6) {
					/*  THIS THREATENING LITTLE DWARF IS IN THE ROOM WITH HIM! */

					global DTOTAL=global DTOTAL+1;
					if((int)global ODLOC[I] == (int)global DLOC[I]) {
						ATTACK=ATTACK+1;
						if(global KNFLOC >= 0)global KNFLOC=lLOC;
						if((int)fRAN(1000) < 95*(global DFLAG-2))STICK=STICK+1;
					}
				} else if (!(lLOC == CHLOC || (int)global PROP[CHEST] >= 0)) {
					/*  THE PIRATE'S SPOTTED HIM.  HE LEAVES HIM ALONE ONCE WE'VE FOUND CHEST.  lK
					 *  COUNTS IF A TREASURE IS HERE.  IF NOT, AND TALLY=1 FOR AN UNSEEN CHEST, LET
					 *  THE PIRATE BE SPOTTED.  NOTE THAT PLACE(CHEST)=0 MIGHT MEAN THAT HE'S
					 *  THROWN IT TO THE TROLL, BUT IN THAT CASE HE'S SEEN THE CHEST (PROP=0). */

					lK=0;
					for (J=50 to MAXTRS+1) {
						/*  PIRATE WON'T TAKE PYRAMID FROM PLOVER ROOM OR DARK ROOM (TOO EASY!). */
						if(!(J == PYRAM && (lLOC == (int)global PLAC[PYRAM] || lLOC == (int)global PLAC[EMRALD]))) {
							if((int)TOTING(J) != FALSE) {
								if((int)global PLACE[CHEST] == 0) {
									/*  INSTALL CHEST ONLY ONCE, TO INSURE IT IS THE LAST TREASURE IN THE LIST. */
									fMOVE(CHEST,CHLOC);
									fMOVE(MESSAG,CHLOC2);
								}
								fRSPEAK(128);
								for (J=50 to MAXTRS+1) {
									if(!(J == PYRAM && (lLOC == (int)global PLAC[PYRAM] || lLOC == (int)global PLAC[EMRALD]))) {
										if((int)AT(J, lLOC) != FALSE && (int)global FIXED[J] == 0)fCARRY(J,lLOC);
										if((int)TOTING(J) != FALSE)fDROP(J,CHLOC);
									}
								}
								global DLOC[6]=CHLOC;
								global ODLOC[6]=CHLOC;
								global DSEEN[6]=FALSE;
								goto L6030;
							}
						}
						if((int)HERE(J, lLOC) != FALSE)lK=1;
					} /* end loop */
					if(global TALLY == 1 && lK == 0 && (int)global PLACE[CHEST] == 0 && ((int)AT(LAMP, lLOC) != FALSE || (int)TOTING(LAMP) != FALSE) && (int)global PROP[LAMP] == 1) {
						fRSPEAK(186);
						fMOVE(CHEST,CHLOC);
						fMOVE(MESSAG,CHLOC2);
						global DLOC[6]=CHLOC;
						global ODLOC[6]=CHLOC;
						global DSEEN[6]=FALSE;
					} else {
						if((int)global ODLOC[6] != (int)global DLOC[6] && ((int)fRAN(100) < (20)))fRSPEAK(127);
					}
				}
			} else {
				global DSEEN[I]=FALSE;
			}
		}
	L6030: ;
	} /* end loop */

	/*  NOW WE KNOW WHAT'S HAPPENING.  LET'S TELL THE POOR SUCKER ABOUT IT.
	 *  NOTE THAT VARIOUS OF THE "KNIFE" MESSAGES MUST HAVE SPECIFIC RELATIVE
	 *  POSITIONS IN THE RSPEAK DATABASE. */

	if(global DTOTAL != 0) {
		fSETPRM(1,global DTOTAL,0);
		fRSPEAK(4+1/global DTOTAL);
		if(ATTACK != 0) {
			if(global DFLAG == 2)global DFLAG=3;
			fSETPRM(1,ATTACK,0);
			lK=6;
			if(ATTACK > 1)lK=250;
			fRSPEAK(lK);
			fSETPRM(1,STICK,0);
			fRSPEAK(lK+1+2/(1+STICK));
			if(STICK != 0) {
				global OLDLC2=lLOC;
				goto L99;
			}
		}
	}


	/*  DESCRIBE THE CURRENT LOCATION AND (MAYBE) GET NEXT COMMAND. */

	/*  PRINT TEXT FOR CURRENT LOC. */

L2000:
	if(lLOC == 0) goto L99;
	KK=(int)global STEXT[lLOC];
	if((((int)global ABB[lLOC])%global ABBNUM) == 0 || KK == 0)KK=(int)global LTEXT[lLOC];
	if(!(((int)global COND[lLOC] == 2) || (int)DARK(lLOC) == FALSE)) {
		if(global WZDARK != FALSE && ((int)fRAN(100) < (35))) goto L90;
		KK=(int)global RTEXT[16];
	}

	if((int)TOTING(BEAR) != FALSE)fRSPEAK(141);
	fSPEAK(KK);
	lK=1;
	if(((int)global COND[lLOC] == 2)) goto L8;
	if(lLOC == 33 && ((int)fRAN(100) < (25)) && global CLOSNG == FALSE)fRSPEAK(7);

	/*  PRINT OUT DESCRIPTIONS OF OBJECTS AT THIS LOCATION.  IF NOT CLOSING AND
	 *  PROPERTY VALUE IS NEGATIVE, TALLY OFF ANOTHER TREASURE.  RUG IS SPECIAL
	 *  CASE; ONCE SEEN, ITS PROP IS 1 (DRAGON ON IT) TILL DRAGON IS KILLED.
	 *  SIMILARLY FOR CHAIN; PROP IS INITIALLY 1 (LOCKED TO BEAR).  THESE HACKS
	 *  ARE BECAUSE PROP=0 IS NEEDED TO GET FULL SCORE. */

	if((int)DARK(lLOC) != FALSE) goto L2012;
	global ABB[lLOC]=(int)global ABB[lLOC]+1;
	I=(int)global ATLOC[lLOC];
L2004:
	if(I == 0) goto L2012;
	lOBJ=I;
	if(lOBJ > 100)lOBJ=lOBJ-100;
	if(!(lOBJ == STEPS && (int)TOTING(NUGGET) != FALSE)) {
		if(global CLOSED == FALSE || (int)global PROP[lOBJ] >= 0) {
			if(global CLOSED == FALSE && (int)global PROP[lOBJ] < 0) {
				global PROP[lOBJ]=0;
				if(lOBJ == RUG || lOBJ == CHAIN)global PROP[lOBJ]=1;
				global TALLY=global TALLY-1;
				/*  NOTE: THERE USED TO BE A TEST HERE TO SEE WHETHER THE PLAYER HAD BLOWN IT
				 *  SO BADLY THAT HE COULD NEVER EVER SEE THE REMAINING TREASURES, AND IF SO
				 *  THE LAMP WAS ZAPPED TO 35 TURNS.  BUT THE TESTS WERE TOO SIMPLE-MINDED;
				 *  THINGS LIKE KILLING THE BIRD BEFORE THE SNAKE WAS GONE (CAN NEVER SEE
				 *  JEWELRY), AND DOING IT "RIGHT" WAS HOPELESS.  E.G., COULD CROSS TROLL
				 *  BRIDGE SEVERAL TIMES, USING UP ALL AVAILABLE TREASURES, BREAKING VASE,
				 *  USING COINS TO BUY BATTERIES, ETC., AND EVENTUALLY NEVER BE ABLE TO GET
				 *  ACROSS AGAIN.  IF BOTTLE WERE LEFT ON FAR SIDE, COULD THEN NEVER GET EGGS
				 *  OR TRIDENT, AND THE EFFECTS PROPAGATE.  SO THE WHOLE THING WAS FLUSHED.
				 *  ANYONE WHO MAKES SUCH A GROSS BLUNDER ISN'T LIKELY TO FIND EVERYTHING
				 *  ELSE ANYWAY (SO GOES THE RATIONALISATION). */
			}
			KK=(int)global PROP[lOBJ];
			if(lOBJ == STEPS && lLOC == (int)global FIXED[STEPS])KK=1;
			fPSPEAK(lOBJ,KK);
		}
	}

	I=(int)global LINK[I];
	goto L2004;

L2009:
	lK=54;
L2010:
	global SPK=lK;
L2011:
	fRSPEAK(global SPK);

L2012:
	global VERB=0;
	OLDOBJ=lOBJ;
	lOBJ=0;

/*  CHECK IF THIS LOC IS ELIGIBLE FOR ANY HINTS.  IF BEEN HERE LONG ENOUGH,
 *  BRANCH TO HELP SECTION (ON LATER PAGE).  HINTS ALL COME BACK HERE EVENTUALLY
 *  TO FINISH THE LOOP.  IGNORE "HINTS" < 4 (SPECIAL STUFF, SEE DATABASE NOTES).
		*/

L2600:
	if((int)global COND[lLOC] >= CONDS) {
		for (HINT=1 to HNTMAX+1) {
			if((int)global HINTED[HINT] == FALSE) {
				if((int)CNDBIT(lLOC,HINT+10) == FALSE)global HINTLC[HINT]= -1;
				global HINTLC[HINT]=(int)global HINTLC[HINT]+1;
				if((int)global HINTLC[HINT] >= (int)global HINTS[HINT * 5 + 1]) {

					/*  HINTS */

					/*  COME HERE IF HE'S BEEN LONG ENOUGH AT REQUIRED LOC(S) FOR SOME UNUSED HINT.
					 *  HINT NUMBER IS IN VARIABLE "HINT".  BRANCH TO QUICK TEST FOR ADDITIONAL
					 *  CONDITIONS, THEN COME BACK TO DO NEAT STUFF.  GOTO 40010 IF CONDITIONS ARE
					 *  MET AND WE WANT TO OFFER THE HINT.  GOTO 40020 TO CLEAR HINTLC BACK TO ZERO,
					 *  40030 TO TAKE NO ACTION YET. */

					/*		CAVE  BIRD  SNAKE MAZE  DARK  WITT  URN   WOODS OGRE
					 *		JADE */

					switch (HINT == 1 to 11) {
						case 1: {
							if(!((int)global PROP[GRATE] == 0 && !((int)AT(KEYS, lLOC) != FALSE || (int)TOTING(KEYS) != FALSE))) goto L40020;
						}

						case 2: {
							if(!((int)global PLACE[BIRD] == lLOC && (int)TOTING(ROD) != FALSE && OLDOBJ == BIRD)) goto L2602;
						}

						case 3: {
							if(!((int)HERE(SNAKE, lLOC) != FALSE && (int)HERE(BIRD, lLOC) == FALSE)) goto L40020;
						}
						
						case 4: {
							if(!((int)global ATLOC[lLOC] == 0 && (int)global ATLOC[global OLDLOC] == 0 && (int)global ATLOC[global OLDLC2] == 0 && global HOLDNG > 1)) goto L40020;
						}
						
						case 5: {
							if(!((int)global PROP[EMRALD] != -1 && (int)global PROP[PYRAM] == -1)) goto L40020;
						}
						
						case 6: {
						}

						case 7: {
							if(global DFLAG != 0) goto L40020;
						}

						case 8: {
							if(!((int)global ATLOC[lLOC] == 0 && (int)global ATLOC[global OLDLOC] == 0 && (int)global ATLOC[global OLDLC2] == 0)) goto L2602;
						}

						case 9: {
							I=(int)fATDWRF(lLOC);
							if(I < 0) goto L40020;
							if(!((int)HERE(OGRE, lLOC) != FALSE && I == 0)) goto L2602;
						}

						case 10: {
							if(!(global TALLY == 1 && (int)global PROP[JADE] < 0)) goto L40020;
						}
						
						default: fBUG(27);
					}

					if((int)fYES(global HINTS[HINT * 5 + 3],0,54) != FALSE) {
						fSETPRM(1,global HINTS[HINT * 5 + 2],global HINTS[HINT * 5 + 2]);
						fRSPEAK(261);
						global HINTED[HINT]=(int)fYES(175,global HINTS[HINT * 5 + 4],54);
						if((int)global HINTED[HINT] != FALSE && global LIMIT > 30)global LIMIT=global LIMIT+30*(int)global HINTS[HINT * 5 + 2];
					}
				L40020:
					global HINTLC[HINT]=0;
				}
			}
		L2602:
			;
		} /* end loop */
	}

	/*  KICK THE RANDOM NUMBER GENERATOR JUST TO ADD VARIETY TO THE CHASE.  ALSO,
	 *  IF CLOSING TIME, CHECK FOR ANY OBJECTS BEING TOTED WITH PROP < 0 AND SET
	 *  THE PROP TO -1-PROP.  THIS WAY OBJECTS WON'T BE DESCRIBED UNTIL THEY'VE
	 *  BEEN PICKED UP AND PUT DOWN SEPARATE FROM THEIR RESPECTIVE PILES.  DON'T
	 *  TICK CLOCK1 UNLESS WELL INTO CAVE (AND NOT AT Y2). */

	if(global CLOSED != FALSE) {
		if((int)global PROP[OYSTER] < 0 && (int)TOTING(OYSTER) != FALSE)fPSPEAK(OYSTER,1);
		for (I=1 to 100+1) {
			if((int)TOTING(I) != FALSE && (int)global PROP[I] < 0)global PROP[I]= -1-(int)global PROP[I];
		} /* end loop */
	}

	global WZDARK=(int)DARK(lLOC);
	if(global KNFLOC > 0 && global KNFLOC != lLOC)global KNFLOC=0;
	I=(int)fRAN(1);
	fGETIN(&global WD1,&global WD1X,&global WD2,&global WD2X);

	/*  EVERY INPUT, CHECK "FOOBAR" FLAG.  IF ZERO, NOTHING'S GOING ON.  IF POS,
	 *  MAKE NEG.  IF NEG, HE SKIPPED A WORD, SO MAKE IT ZERO. */

L2607:
	if (global FOOBAR>0) global FOOBAR=-global FOOBAR;
	else global FOOBAR=0;
	global TURNS=global TURNS+1;
	if(global TURNS == global THRESH) {
		fSPEAK(global TTEXT[global TRNDEX]);
		global TRNLUZ=global TRNLUZ+(int)global TRNVAL[global TRNDEX]/100000;
		global TRNDEX=global TRNDEX+1;
		global THRESH= -1;
		if(global TRNDEX <= TRNVLS)global THRESH=(((int)global TRNVAL[global TRNDEX])%100000)+1;
	}

	if(global VERB == SAY && global WD2 > 0)global VERB=0;
	if(global VERB == SAY) {
		I=1;
		goto Laction;
	}
	if(global TALLY == 0 && (int)INDEEP(lLOC) != FALSE && lLOC != 33) {
		global CLOCK1=global CLOCK1-1;
	}
	if(global CLOCK1 == 0) {
		/*  CAVE CLOSING AND SCORING */


		/*  THESE SECTIONS HANDLE THE CLOSING OF THE CAVE.  THE CAVE CLOSES "CLOCK1"
		 *  TURNS AFTER THE LAST TREASURE HAS BEEN LOCATED (INCLUDING THE PIRATE'S
		 *  CHEST, WHICH MAY OF COURSE NEVER SHOW UP).  NOTE THAT THE TREASURES NEED NOT
		 *  HAVE BEEN TAKEN YET, JUST LOCATED.  HENCE CLOCK1 MUST BE LARGE ENOUGH TO GET
		 *  OUT OF THE CAVE (IT ONLY TICKS WHILE INSIDE THE CAVE).  WHEN IT HITS ZERO,
		 *  WE BRANCH TO 10000 TO START CLOSING THE CAVE, AND THEN SIT BACK AND WAIT FOR
		 *  HIM TO TRY TO GET OUT.  IF HE DOESN'T WITHIN CLOCK2 TURNS, WE CLOSE THE
		 *  CAVE; IF HE DOES TRY, WE ASSUME HE PANICS, AND GIVE HIM A FEW ADDITIONAL
		 *  TURNS TO GET FRANTIC BEFORE WE CLOSE.  WHEN CLOCK2 HITS ZERO, WE BRANCH TO
		 *  11000 TO TRANSPORT HIM INTO THE FINAL PUZZLE.  NOTE THAT THE PUZZLE DEPENDS
		 *  UPON ALL SORTS OF RANDOM THINGS.  FOR INSTANCE, THERE MUST BE NO WATER OR
		 *  OIL, SINCE THERE ARE BEANSTALKS WHICH WE DON'T WANT TO BE ABLE TO WATER,
		 *  SINCE THE CODE CAN'T HANDLE IT.  ALSO, WE CAN HAVE NO KEYS, SINCE THERE IS A
		 *  GRATE (HAVING MOVED THE FIXED OBJECT!) THERE SEPARATING HIM FROM ALL THE
		 *  TREASURES.  MOST OF THESE PROBLEMS ARISE FROM THE USE OF NEGATIVE PROP
		 *  NUMBERS TO SUPPRESS THE OBJECT DESCRIPTIONS UNTIL HE'S ACTUALLY MOVED THE
		 *  OBJECTS. */

		/*  WHEN THE FIRST WARNING COMES, WE LOCK THE GRATE, DESTROY THE BRIDGE, KILL
		 *  ALL THE DWARVES (AND THE PIRATE), REMOVE THE TROLL AND BEAR (UNLESS DEAD),
		 *  AND SET "CLOSNG" TO TRUE.  LEAVE THE DRAGON; TOO MUCH TROUBLE TO MOVE IT.
		 *  FROM NOW UNTIL CLOCK2 RUNS OUT, HE CANNOT UNLOCK THE GRATE, MOVE TO ANY
		 *  LOCATION OUTSIDE THE CAVE, OR CREATE THE BRIDGE.  NOR CAN HE BE
		 *  RESURRECTED IF HE DIES.  NOTE THAT THE SNAKE IS ALREADY GONE, SINCE HE GOT
		 *  TO THE TREASURE ACCESSIBLE ONLY VIA THE HALL OF THE MT. KING.  ALSO, HE'S
		 *  BEEN IN GIANT ROOM (TO GET EGGS), SO WE CAN REFER TO IT.  ALSO ALSO, HE'S
		 *  GOTTEN THE PEARL, SO WE KNOW THE BIVALVE IS AN OYSTER.  *AND*, THE DWARVES
		 *  MUST HAVE BEEN ACTIVATED, SINCE WE'VE FOUND CHEST. */

		global PROP[GRATE]=0;
		global PROP[FISSUR]=0;
		for (I=1 to 6+1) {
			global DSEEN[I]=FALSE;
			global DLOC[I]=0;
		} /* end loop */
		fMOVE(TROLL,0);
		fMOVE(TROLL+100,0);
		fMOVE(TROLL2,global PLAC[TROLL]);
		fMOVE(TROLL2+100,global FIXD[TROLL]);
		fJUGGLE(CHASM);
		if((int)global PROP[BEAR] != 3)fDSTROY(BEAR);
		global PROP[CHAIN]=0;
		global FIXED[CHAIN]=0;
		global PROP[AXE]=0;
		global FIXED[AXE]=0;
		fRSPEAK(129);
		global CLOCK1= -1;
		global CLOSNG=TRUE;
	} else {
		if(global CLOCK1 < 0)global CLOCK2=global CLOCK2-1;
		if(global CLOCK2 == 0) {
			/*  ONCE HE'S PANICKED, AND CLOCK2 HAS RUN OUT, WE COME HERE TO SET UP THE
			 *  STORAGE ROOM.  THE ROOM HAS TWO LOCS, HARDWIRED AS 115 (NE) AND 116 (SW).
			 *  AT THE NE END, WE PLACE EMPTY BOTTLES, A NURSERY OF PLANTS, A BED OF
			 *  OYSTERS, A PILE OF LAMPS, RODS WITH STARS, SLEEPING DWARVES, AND HIM.  AT
			 *  THE SW END WE PLACE GRATE OVER TREASURES, SNAKE PIT, COVEY OF CAGED BIRDS,
			 *  MORE RODS, AND PILLOWS.  A MIRROR STRETCHES ACROSS ONE WALL.  MANY OF THE
			 *  OBJECTS COME FROM KNOWN LOCATIONS AND/OR STATES (E.G. THE SNAKE IS KNOWN TO
			 *  HAVE BEEN DESTROYED AND NEEDN'T BE CARRIED AWAY FROM ITS OLD "PLACE"),
			 *  MAKING THE VARIOUS OBJECTS BE HANDLED DIFFERENTLY.  WE ALSO DROP ALL OTHER
			 *  OBJECTS HE MIGHT BE CARRYING (LEST HE HAVE SOME WHICH COULD CAUSE TROUBLE,
			 *  SUCH AS THE KEYS).  WE DESCRIBE THE FLASH OF LIGHT AND TRUNDLE BACK. */

			global PROP[BOTTLE]=(int)fPUT(BOTTLE,115,1);
			global PROP[PLANT]=(int)fPUT(PLANT,115,0);
			global PROP[OYSTER]=(int)fPUT(OYSTER,115,0);
			global OBJTXT[OYSTER]=3;
			global PROP[LAMP]=(int)fPUT(LAMP,115,0);
			global PROP[ROD]=(int)fPUT(ROD,115,0);
			global PROP[DWARF]=(int)fPUT(DWARF,115,0);
			lLOC=115;
			global OLDLOC=115;
			global NEWLOC=115;

		/*  LEAVE THE GRATE WITH NORMAL (NON-NEGATIVE) PROPERTY.  REUSE SIGN. */

			I=(int)fPUT(GRATE,116,0);
			I=(int)fPUT(gSIGN,116,0);
			global OBJTXT[gSIGN]=(int)global OBJTXT[gSIGN]+1;
			global PROP[SNAKE]=(int)fPUT(SNAKE,116,1);
			global PROP[BIRD]=(int)fPUT(BIRD,116,1);
			global PROP[CAGE]=(int)fPUT(CAGE,116,0);
			global PROP[ROD2]=(int)fPUT(ROD2,116,0);
			global PROP[PILLOW]=(int)fPUT(PILLOW,116,0);

			global PROP[MIRROR]=(int)fPUT(MIRROR,115,0);
			global FIXED[MIRROR]=116;

			for (I=1 to 100+1) {
				if((int)TOTING(I) != FALSE)fDSTROY(I);
			} /* end loop */

			fRSPEAK(132);
			global CLOSED=TRUE;
			goto L2;
		}
		if((int)global PROP[LAMP] == 1)global LIMIT=global LIMIT-1;
		if(global LIMIT <= 30 && (int)HERE(BATTER, lLOC) != FALSE && (int)global PROP[BATTER] == 0 && (int)HERE(LAMP, lLOC) != FALSE) {
			/*  ANOTHER WAY WE CAN FORCE AN END TO THINGS IS BY HAVING THE LAMP GIVE OUT.
			 *  WHEN IT GETS CLOSE, WE COME HERE TO WARN HIM.  WE GO TO 12000 IF THE LAMP
			 *  AND FRESH BATTERIES ARE HERE, IN WHICH CASE WE REPLACE THE BATTERIES AND
			 *  CONTINUE.  12200 IS FOR OTHER CASES OF LAMP DYING.  12400 IS WHEN IT GOES
			 *  OUT.  EVEN THEN, HE CAN EXPLORE OUTSIDE FOR A WHILE IF DESIRED. */

			fRSPEAK(188);
			global PROP[BATTER]=1;
			if((int)TOTING(BATTER) != FALSE)fDROP(BATTER,lLOC);
			global LIMIT=global LIMIT+2500;
			global LMWARN=FALSE;
		} else  if(global LIMIT == 0) {
			global LIMIT= -1;
			global PROP[LAMP]=0;
			if((int)HERE(LAMP, lLOC) != FALSE)fRSPEAK(184);
		} else if(global LIMIT <= 30) {
			if(!(global LMWARN != FALSE || (int)HERE(LAMP, lLOC) == FALSE)) {
				global LMWARN=TRUE;
				global SPK=187;
				if((int)global PLACE[BATTER] == 0)global SPK=183;
				if((int)global PROP[BATTER] == 1)global SPK=189;
				fRSPEAK(global SPK);
			}
		}
	}

	lK=43;
	if((int)LIQLOC(lLOC) == WATER)lK=70;
	V1=(int)fVOCAB(global WD1,-1);
	V2=(int)fVOCAB(global WD2,-1);
	if(V1 == ENTER && (V2 == STREAM || V2 == 1000+WATER)) goto L2010;
	if(V1 == ENTER && global WD2 > 0) goto L2800;
	if(!((V1 != 1000+WATER && V1 != 1000+OIL) || (V2 != 1000+PLANT && V2 != 1000+DOOR))) {
		if((int)AT(V2-1000, lLOC) != FALSE)global WD2=(int)fMAKEWD(16152118);
	}
	if(V1 == 1000+CAGE && V2 == 1000+BIRD && (int)HERE(CAGE, lLOC) != FALSE && (int)HERE(BIRD, lLOC) != FALSE)global WD1=(int)fMAKEWD(301200308);
L2620:
	if(global WD1 == (int)fMAKEWD(23051920)) {
		global IWEST=global IWEST+1;
		if(global IWEST == 10)fRSPEAK(17);
	}
	if(!(global WD1 != (int)fMAKEWD( 715) || global WD2 == 0)) {
		global IGO=global IGO+1;
		if(global IGO == 10)fRSPEAK(276);
	}
L2630:
	I=(int)fVOCAB(global WD1,-1);
	if(I == -1) {
		/*  GEE, I DON'T UNDERSTAND. */

		fSETPRM(1,global WD1,global WD1X);
		fRSPEAK(254);
		goto L2600;
	}
	lK=((I)%1000);
	KQ=I/1000+1;
	switch (KQ-1 == 0 to 4) {
		case 0: goto L8;
		case 1: { I=2; goto Laction; }
		case 2: { I=0; goto Laction; }
		case 3: goto L2010;
	}
	fBUG(22);

/*  GET SECOND WORD FOR ANALYSIS. */

L2800:
	global WD1=global WD2;
	global WD1X=global WD2X;
	global WD2=0;
	goto L2620;

/* VERB AND OBJECT ANALYSIS MOVED TO SEPARATE MODULE. */
	
Laction:
	global gK = lK;
	global gOBJ = lOBJ;
	global gLOC = lLOC;
	{
		gotoChoice = (int)action(I);
		lK = global gK;
		lOBJ = global gOBJ;
		lLOC = global gLOC;
		switch (gotoChoice == GOTO2 to GOTO19000 + 1) {
		   case GOTO2: goto L2;
		   case GOTO8: goto L8;
		   case GOTO2000: goto L2000;
		   case GOTO2009: goto L2009;
		   case GOTO2010: goto L2010;
		   case GOTO2011: goto L2011;
		   case GOTO2012: goto L2012;
		   case GOTO2600: goto L2600;
		   case GOTO2607: goto L2607;
		   case GOTO2630: goto L2630;
		   case GOTO2800: goto L2800;
		   
		   case GOTO8000: {
				/*  RANDOM INTRANSITIVE VERBS COME HERE.  CLEAR lOBJ JUST IN CASE (SEE "ATTACK"). */
				fSETPRM(1,global WD1,global WD1X);
				fRSPEAK(257);
				lOBJ=0;
				goto L2600;
		   }
		   
		   case GOTO18999: {
				/*  OH DEAR, HE'S DISTURBED THE DWARVES. */
				
				fRSPEAK(global SPK);
				fRSPEAK(136);
				score(0);
		   }
		   
		   case GOTO19000: {
				fRSPEAK(136);
				score(0);
		   }
		   default: fBUG(-1);
		}
	}
	fBUG(99);

/*  FIGURE OUT THE NEW LOCATION
 *
 *  GIVEN THE CURRENT LOCATION IN "LOC", AND A MOTION VERB NUMBER IN "lK", PUT
 *  THE NEW LOCATION IN "NEWLOC".  THE CURRENT LOC IS SAVED IN "OLDLOC" IN CASE
 *  HE WANTS TO RETREAT.  THE CURRENT OLDLOC IS SAVED IN OLDLC2, IN CASE HE
 *  DIES.  (IF HE DOES, NEWLOC WILL BE LIMBO, AND OLDLOC WILL BE WHAT KILLED
 *  HIM, SO WE NEED OLDLC2, WHICH IS THE LAST PLACE HE WAS SAFE.) */

L8:
	KK=(int)global KEY[lLOC];
	global NEWLOC=lLOC;
	if(KK == 0)fBUG(26);
	if(lK == NUL) goto L2;
	
	if(lK == BACK) {
		/*  HANDLE "GO BACK".  LOOK FOR VERB WHICH GOES FROM LOC TO OLDLOC, OR TO OLDLC2
		 *  IF OLDLOC HAS FORCED-MOTION.  K2 SAVES ENTRY -> FORCED LOC -> PREVIOUS LOC. */

		lK=global OLDLOC;
		if(((int)global COND[lK] == 2))lK=global OLDLC2;
		global OLDLC2=global OLDLOC;
		global OLDLOC=lLOC;
		K2=0;
		if(lK == lLOC)K2=91;
		if((int)CNDBIT(lLOC,4) != FALSE)K2=274;
		if(K2 == 0) {
		L21:
			LL=(((abs((int)global TRAVEL[KK])/1000))%1000);
			if(LL == lK) {
			L25:
				lK=((abs((int)global TRAVEL[KK]))%1000);
				KK=(int)global KEY[lLOC];
				goto L9;
			}
			if(LL <= 300) {
				J=(int)global KEY[LL];
				if(((int)global COND[LL] == 2) && (((abs((int)global TRAVEL[J])/1000))%1000) == lK)K2=KK;
			}
			if((int)global TRAVEL[KK] < 0) {
				KK=K2;
				if(KK != 0) goto L25;
				fRSPEAK(140);
				goto L2;
			}
			KK=KK+1;
			goto L21;
		}
		fRSPEAK(K2);
		goto L2;
	}
	
	if(lK == LOOK) {
		/*  LOOK.  CAN'T GIVE MORE DETAIL.  PRETEND IT WASN'T DARK (THOUGH IT MAY "NOW"
		 *  BE DARK) SO HE WON'T FALL INTO A PIT WHILE STARING INTO THE GLOOM. */
		if(global DETAIL < 3)fRSPEAK(15);
		global DETAIL=global DETAIL+1;
		global WZDARK=FALSE;
		global ABB[lLOC]=0;
		goto L2;
	}
	
	if(lK == CAVE) {
		/*  CAVE.  DIFFERENT MESSAGES DEPENDING ON WHETHER ABOVE GROUND. */
		lK=58;
		if((int)OUTSID(lLOC) != FALSE && lLOC != 8)lK=57;
		fRSPEAK(lK);
		goto L2;
	}
	
	global OLDLC2=global OLDLOC;
	global OLDLOC=lLOC;

L9:
	LL=abs((int)global TRAVEL[KK]);
	if(!(((LL)%1000) == 1 || ((LL)%1000) == lK)) {
		if((int)global TRAVEL[KK] < 0) {
			/*  NON-APPLICABLE MOTION.  VARIOUS MESSAGES DEPENDING ON WORD GIVEN. */

			global SPK=12;
			if(lK >= 43 && lK <= 50)global SPK=52;
			if(lK == 29 || lK == 30)global SPK=52;
			if(lK == 7 || lK == 36 || lK == 37)global SPK=10;
			if(lK == 11 || lK == 19)global SPK=11;
			if(global VERB == FIND || global VERB == INVENT)global SPK=59;
			if(lK == 62 || lK == 65)global SPK=42;
			if(lK == 17)global SPK=80;
			fRSPEAK(global SPK);
			goto L2;
		}
		KK=KK+1;
		goto L9;
	}
	LL=LL/1000;
L11:
	global NEWLOC=LL/1000;
	lK=((global NEWLOC)%100);
	if(global NEWLOC > 300) {
		if((int)global PROP[lK] != global NEWLOC/100-3) goto L16;
	L12:
		do {
			if((int)global TRAVEL[KK] < 0)fBUG(25);
			KK=KK+1;
			global NEWLOC=abs((int)global TRAVEL[KK])/1000;
		} while (global NEWLOC == LL);
		LL=global NEWLOC;
		goto L11;
	}
	
	if(global NEWLOC > 100) {
		if((int)TOTING(lK) != FALSE || (global NEWLOC > 200 && (int)AT(lK, lLOC) != FALSE)) goto L16;
		goto L12;
	}

	if(global NEWLOC != 0 && !((int)fRAN(100) < (global NEWLOC))) goto L12;
L16:
	global NEWLOC=((LL)%1000);
	if(global NEWLOC <= 300) goto L2;
	if(global NEWLOC > 500) {
		fRSPEAK(global NEWLOC-500);
		global NEWLOC=lLOC;
		goto L2;
	}

/*  SPECIAL MOTIONS COME HERE.  LABELLING CONVENTION: STATEMENT NUMBERS NNNXX
 *  (XX=00-99) ARE USED FOR SPECIAL CASE NUMBER NNN (NNN=301-500). */

	global NEWLOC=global NEWLOC-300;
	switch (global NEWLOC == 1 to 4) {
		case 1: {
			/*  TRAVEL 301.  PLOVER-ALCOVE PASSAGE.  CAN CARRY ONLY EMERALD.  NOTE: TRAVEL
			 *  TABLE MUST INCLUDE "USELESS" ENTRIES GOING THROUGH PASSAGE, WHICH CAN NEVER
			 *  BE USED FOR ACTUAL MOTION, BUT CAN BE SPOTTED BY "GO BACK". */

			global NEWLOC=99+100-lLOC;
			if(global HOLDNG == 0 || (global HOLDNG == 1 && (int)TOTING(EMRALD) != FALSE)) goto L2;
			global NEWLOC=lLOC;
			fRSPEAK(117);
			goto L2;
		}
		
		case 2: {
			/*  TRAVEL 302.  PLOVER TRANSPORT.  DROP THE EMERALD (ONLY USE SPECIAL TRAVEL IF
			 *  TOTING IT), SO HE'S FORCED TO USE THE PLOVER-PASSAGE TO GET IT OUT.  HAVING
			 *  DROPPED IT, GO BACK AND PRETEND HE WASN'T CARRYING IT AFTER ALL. */
			 
			fDROP(EMRALD,lLOC);
			goto L12;
		}
		
		case 3: {
			/*  TRAVEL 303.  TROLL BRIDGE.  MUST BE DONE ONLY AS SPECIAL MOTION SO THAT
			 *  DWARVES WON'T WANDER ACROSS AND ENCOUNTER THE BEAR.  (THEY WON'T FOLLOW THE
			 *  PLAYER THERE BECAUSE THAT REGION IS FORBIDDEN TO THE PIRATE.)  IF
			 *  PROP(TROLL)=1, HE'S CROSSED SINCE PAYING, SO STEP OUT AND BLOCK HIM.
			 *  (STANDARD TRAVEL ENTRIES CHECK FOR PROP(TROLL)=0.)  SPECIAL STUFF FOR BEAR. */

			if((int)global PROP[TROLL] != 1) {
				global NEWLOC=(int)global PLAC[TROLL]+(int)global FIXD[TROLL]-lLOC;
				if((int)global PROP[TROLL] == 0)global PROP[TROLL]=1;
				if((int)TOTING(BEAR) == FALSE) goto L2;
				fRSPEAK(162);
				global PROP[CHASM]=1;
				global PROP[TROLL]=2;
				fDROP(BEAR,global NEWLOC);
				global FIXED[BEAR]= -1;
				global PROP[BEAR]=3;
				global OLDLC2=global NEWLOC;
				goto L99;
			}
			
			fPSPEAK(TROLL,1);
			global PROP[TROLL]=0;
			fMOVE(TROLL2,0);
			fMOVE(TROLL2+100,0);
			fMOVE(TROLL,global PLAC[TROLL]);
			fMOVE(TROLL+100,global FIXD[TROLL]);
			fJUGGLE(CHASM);
			global NEWLOC=lLOC;
			goto L2;
		}
	}
	fBUG(20);
	
/*  END OF SPECIALS. */

/*  "YOU'RE DEAD, JIM."
 *
 *  IF THE CURRENT LOC IS ZERO, IT MEANS THE CLOWN GOT HIMSELF KILLED.  WE'LL
 *  ALLOW THIS MAXDIE TIMES.  MAXDIE IS AUTOMATICALLY SET BASED ON THE NUMBER OF
 *  SNIDE MESSAGES AVAILABLE.  EACH DEATH RESULTS IN A MESSAGE (81, 83, ETC.)
 *  WHICH OFFERS REINCARNATION; IF ACCEPTED, THIS RESULTS IN MESSAGE 82, 84,
 *  ETC.  THE LAST TIME, IF HE WANTS ANOTHER CHANCE, HE GETS A SNIDE REMARK AS
 *  WE EXIT.  WHEN REINCARNATED, ALL OBJECTS BEING CARRIED GET DROPPED AT OLDLC2
 *  (PRESUMABLY THE LAST PLACE PRIOR TO BEING KILLED) WITHOUT CHANGE OF PROPS.
 *  THE LOOP RUNS BACKWARDS TO ASSURE THAT THE BIRD IS DROPPED BEFORE THE CAGE.
 *  (THIS KLUGE COULD BE CHANGED ONCE WE'RE SURE ALL REFERENCES TO BIRD AND CAGE
 *  ARE DONE BY KEYWORDS.)  THE LAMP IS A SPECIAL CASE (IT WOULDN'T DO TO LEAVE
 *  IT IN THE CAVE).  IT IS TURNED OFF AND LEFT OUTSIDE THE BUILDING (ONLY IF HE
 *  WAS CARRYING IT, OF COURSE).  HE HIMSELF IS LEFT INSIDE THE BUILDING (AND
 *  HEAVEN HELP HIM IF HE TRIES TO XYZZY BACK INTO THE CAVE WITHOUT THE LAMP!).
 *  OLDLOC IS ZAPPED SO HE CAN'T JUST "RETREAT". */

/*  THE EASIEST WAY TO GET KILLED IS TO FALL INTO A PIT IN PITCH DARKNESS. */

L90:
	fRSPEAK(23);
	global OLDLC2=lLOC;

/*  OKAY, HE'S DEAD.  LET'S GET ON WITH IT. */

L99:
	if(global CLOSNG != FALSE) {
		/*  HE DIED DURING CLOSING TIME.  NO RESURRECTION.  TALLY UP A DEATH AND EXIT. */
		fRSPEAK(131);
		global NUMDIE=global NUMDIE+1;
		score(0);
	}
	global NUMDIE=global NUMDIE+1;
	if((int)fYES(79+global NUMDIE*2,80+global NUMDIE*2,54) == FALSE) score(0);
	if(global NUMDIE == global MAXDIE) score(0);
	global PLACE[WATER]=0;
	global PLACE[OIL]=0;
	if((int)TOTING(LAMP) != FALSE)global PROP[LAMP]=0;
	for (J=1 to 100+1) {
		I=101-J;
		if((int)TOTING(I) != FALSE) {
			lK=global OLDLC2;
			if(I == LAMP)lK=1;
			fDROP(I,lK);
		}
	} /* end loop */
	lLOC=3;
	global OLDLOC=lLOC;
	goto L2000;
}
