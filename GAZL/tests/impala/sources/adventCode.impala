/*  THROW.  SAME AS DISCARD UNLESS AXE.  THEN SAME AS ATTACK EXCEPT IGNORE BIRD,
 *  AND IF DWARF IS PRESENT THEN ONE MIGHT BE KILLED.  (ONLY WAY TO DO SO!)
 *  AXE ALSO SPECIAL FOR DRAGON, BEAR, AND TROLL.  TREASURES SPECIAL FOR TROLL. */

function doThrow()
returns int goValue
locals int I, int lLOC, int lOBJ
{
	lLOC = global gLOC;
	lOBJ = global gOBJ;
	if((int)TOTING(ROD2) != FALSE && lOBJ == ROD && (int)TOTING(ROD) == FALSE) { lOBJ=ROD2; global gOBJ = ROD2; }
	if((int)TOTING(lOBJ) == FALSE) { goValue = GOTO2011; goto return; }
	if(lOBJ >= 50 && lOBJ <= MAXTRS && (int)AT(TROLL, lLOC) != FALSE) {
	/*  SNARF A TREASURE FOR THE TROLL. */
		global SPK=159;
		fDROP(lOBJ,0);
		fMOVE(TROLL,0);
		fMOVE(TROLL+100,0);
		fDROP(TROLL2,global PLAC[TROLL]);
		fDROP(TROLL2+100,(int)global FIXD[TROLL]);
		fJUGGLE(CHASM);
		{ goValue = GOTO2011; goto return; }
	}
	if(lOBJ == FOOD && (int)HERE(BEAR, lLOC) != FALSE) {
		/*  BUT THROWING FOOD IS ANOTHER STORY. */
		lOBJ=BEAR; global gOBJ = BEAR;
		{ goValue = (int)feed(lOBJ); goto return; }
	}
	if(lOBJ != AXE) { goValue = (int)discard(FALSE); goto return; }
	I=(int)fATDWRF(lLOC);
	if(I <= 0) {
		global SPK=152;
		if((int)AT(DRAGON, lLOC) != FALSE && (int)global PROP[DRAGON] == 0) goto L9175;
		global SPK=158;
		if((int)AT(TROLL, lLOC) != FALSE) goto L9175;
		global SPK=203;
		if((int)AT(OGRE, lLOC) != FALSE) goto L9175;
		if((int)HERE(BEAR, lLOC) != FALSE && (int)global PROP[BEAR] == 0) {
			/*  THIS'LL TEACH HIM TO THROW THE AXE AT THE BEAR! */
			global SPK=164;
			fDROP(AXE,lLOC);
			global FIXED[AXE]= -1;
			global PROP[AXE]=1;
			fJUGGLE(BEAR);
			{ goValue = GOTO2011; goto return; }
		}
		lOBJ=0; global gOBJ = 0;
		{ goValue = (int)attack(); goto return; }
	}
	global SPK=48;
	if((int)fRAN(7) >= global DFLAG) {
		global DSEEN[I]=FALSE;
		global DLOC[I]=0;
		global SPK=47;
		global DKILL=global DKILL+1;
		if(global DKILL == 1)global SPK=149;
	}
L9175:
	fRSPEAK(global SPK);
	fDROP(AXE,lLOC);
	global gK = NUL;
	{ goValue = GOTO8; goto return; }
return: ;
}


