extern function score;

function fBUG(int NUM)
locals array numString[3]
{
	/*  THE FOLLOWING CONDITIONS ARE CURRENTLY CONSIDERED FATAL BUGS.  NUMBERS < 20
	 *  ARE DETECTED WHILE READING THE DATABASE; THE OTHERS OCCUR AT "RUN TIME".
	 *	0	MESSAGE LINE > 70 CHARACTERS
	 *	1	NULL LINE IN MESSAGE
	 *	2	TOO MANY WORDS OF MESSAGES
	 *	3	TOO MANY TRAVEL OPTIONS
	 *	4	TOO MANY VOCABULARY WORDS
	 *	5	REQUIRED VOCABULARY WORD NOT FOUND
	 *	6	TOO MANY RTEXT MESSAGES
	 *	7	TOO MANY HINTS
	 *	8	LOCATION HAS COND BIT BEING SET TWICE
	 *	9	INVALID SECTION NUMBER IN DATABASE
	 *	10	TOO MANY LOCATIONS
	 *	11	TOO MANY CLASS OR TURN MESSAGES
	 *	20	SPECIAL TRAVEL (500>L>300) EXCEEDS GOTO LIST
	 *	21	RAN OFF END OF VOCABULARY TABLE
	 *	22	VOCABULARY TYPE (N/1000) NOT BETWEEN 0 AND 3
	 *	23	INTRANSITIVE ACTION VERB EXCEEDS GOTO LIST
	 *	24	TRANSITIVE ACTION VERB EXCEEDS GOTO LIST
	 *	25	CONDITIONAL TRAVEL ENTRY WITH NO ALTERNATIVE
	 *	26	LOCATION HAS NO TRAVEL ENTRIES
	 *	27	HINT NUMBER EXCEEDS GOTO LIST
	 *	28	INVALID MONTH RETURNED BY DATE FUNCTION
	 *	29	TOO MANY PARAMETERS GIVEN TO SETPRM */

	output("Fatal error ");
	numString[0] = '0' + NUM / 10;
	numString[1] = '0' + NUM % 10;
	numString[2] = 0;
	output(numString);
	output(".  See source code for interpretation.\n");
	abort();
}

global int fRAN_R = 0;

function fRAN(int RANGE)
returns int RAN
locals int D, int T
{
	/*  SINCE THE RAN FUNCTION IN LIB40 SEEMS TO BE A REAL LOSE, WE'LL USE ONE OF
	 *  OUR OWN.  IT'S BEEN RUN THROUGH MANY OF THE TESTS IN KNUTH VOL. 2 AND
	 *  SEEMS TO BE QUITE RELIABLE.  RAN RETURNS A VALUE UNIFORMLY SELECTED
	 *  BETWEEN 0 AND RANGE-1. */

	D=1;
	if(!(global fRAN_R != 0 && RANGE >= 0)) {
	// SEED!
	// fDATIME(&D,&T);
//D=91172;
//T=53423;
//		global fRAN_R=((T+5)%1048576);
//		D=1000+((D)%1000);
		D=1999;
		T=(int)clock() & 0x7FFFFFFF;
	}
	for (T=1 to D+1) global fRAN_R=((global fRAN_R*1093+221587)%1048576);
	RAN=(RANGE*global fRAN_R)/1048576;
}

/*  LINE-PARSING ROUTINES (GETNUM, GETTXT, MAKEWD, PUTTXT, SHFTXT, TYPE0)
		*/

/*  THE ROUTINES ON THIS PAGE HANDLE ALL THE STUFF THAT WOULD NORMALLY BE
 *  TAKEN CARE OF BY FORMAT STATEMENTS.  WE DO IT THIS WAY INSTEAD SO THAT
 *  WE CAN HANDLE TEXTUAL DATA IN A MACHINE INDEPENDENT FASHION.  ALL THE
 *  MACHINE DEPENDENT I/O STUFF IS ON THE FOLLOWING PAGE.  SEE THAT PAGE
 *  FOR A DESCRIPTION OF MAPCOM'S INLINE ARRAY. */

/*  MACHINE DEPENDENT ROUTINES (MAPLIN, TYPE, MPINIT, SAVEIO) */


/*  REPORT ON AMOUNT OF ARRAYS ACTUALLY USED, TO PERMIT REDUCTIONS. */

readonly array fMPINIT_RUNS[7 * 2] = {32,34, 39,46, 65,90, 97,122, 37,37, 48,57, 0,126};

function fMPINIT()
locals int FIRST, int I, int J, int LAST, int VAL
{
	for (I=1 to 129) {
		global MAP1[I]= -1;
	} /* end loop */
	VAL=0;
	for (I=0 to 7) {
		FIRST=(int)global fMPINIT_RUNS[I * 2 + 0];
		LAST=(int)global fMPINIT_RUNS[I * 2 + 1];
		for (J=FIRST+1 to LAST+2) {
			if(!((int)global MAP1[J] >= 0)) {
				global MAP1[J]=VAL;
				VAL=VAL+1;
			}
		} /* end loop */
	/*etc*/ ;
	} /* end loop */
	global MAP1[128]=global MAP1[10];
/*  FOR THIS VERSION, TAB (9) MAPS TO SPACE (32), SO DEL (127) USES TAB'S VALUE */
	global MAP1[10]=global MAP1[33];
	global MAP1[11]=global MAP1[33];

	for (I=0 to 127) {
		VAL=(int)global MAP1[I+1]+1;
		global MAP2[VAL]=I*('B'-'A');
		if(I >= 64)global MAP2[VAL]=(I-64)*('B'-'A')+'@';
	} /* end loop */
}

function fMAPLIN(int FIL)
locals int I, int VAL
{
	/*  READ A LINE OF INPUT, EITHER FROM A FILE (IF FIL=.TRUE.) OR FROM THE
	 *  KEYBOARD, TRANSLATE THE CHARS TO INTEGERS IN THE RANGE 0-126 AND STORE
	 *  THEM IN THE COMMON ARRAY "INLINE".  INTEGER VALUES ARE AS FOLLOWS:
	 *     0   = SPACE [ASCII CODE 40 OCTAL, 32 DECIMAL]
	 *    1-2  = !" [ASCII 41-42 OCTAL, 33-34 DECIMAL]
	 *    3-10 = '()*+,-. [ASCII 47-56 OCTAL, 39-46 DECIMAL]
	 *   11-36 = UPPER-CASE LETTERS
	 *   37-62 = LOWER-CASE LETTERS
	 *    63   = PERCENT (%) [ASCII 45 OCTAL, 37 DECIMAL]
	 *   64-73 = DIGITS, 0 THROUGH 9
	 *  REMAINING CHARACTERS CAN BE TRANSLATED ANY WAY THAT IS CONVENIENT;
	 *  THE "TYPE" ROUTINE BELOW IS USED TO MAP THEM BACK TO CHARACTERS WHEN
	 *  NECESSARY.  THE ABOVE MAPPINGS ARE REQUIRED SO THAT CERTAIN SPECIAL
	 *  CHARACTERS ARE KNOWN TO FIT IN 6 BITS AND/OR CAN BE EASILY SPOTTED.
	 *  ARRAY ELEMENTS BEYOND THE END OF THE LINE SHOULD BE FILLED WITH 0,
	 *  AND LNLENG SHOULD BE SET TO THE INDEX OF THE LAST CHARACTER.
	 *
	 *  IF THE DATA FILE USES A CHARACTER OTHER THAN SPACE (E.G., TAB) TO
	 *  SEPARATE NUMBERS, THAT CHARACTER SHOULD ALSO TRANSLATE TO 0.
	 *
	 *  THIS PROCEDURE MAY USE THE MAP1,MAP2 ARRAYS TO MAINTAIN STATIC DATA FOR
	 *  THE MAPPING.  MAP2(1) IS SET TO 0 WHEN THE PROGRAM STARTS
	 *  AND IS NOT CHANGED THEREAFTER UNLESS THE ROUTINES ON THIS PAGE CHOOSE
	 *  TO DO SO.
	 *
	 *  NOTE THAT MAPLIN IS EXPECTED TO OPEN THE FILE THE FIRST TIME IT IS
	 *  ASKED TO READ A LINE FROM IT.  THAT IS, THERE IS NO OTHER PLACE WHERE
	 *  THE DATA FILE IS OPENED. */

	if((int)global MAP2[1] == 0)fMPINIT();

	do {
		if(FIL==FALSE) {
			input(99, global INLINE+1);
			if ((int)inputEOF() != FALSE) score(1);
		} else {
			fBUG(-1);
		}

		global LNLENG=0;
		for (I=1 to 100+1) {
			if ((int)global INLINE[I] == 0) goto break1;
			VAL=(int)global INLINE[I]+1;
			global INLINE[I]=global MAP1[VAL];
			if((int)global INLINE[I] != 0)global LNLENG=I;
		} /* end loop */
	break1:
		global LNPOSN=1;
	} while (FIL != FALSE && global LNLENG == 0);

	/*  ABOVE IS TO GET AROUND AN F40 COMPILER BUG WHEREIN IT READS A BLANK
	 *  LINE WHENEVER A CRLF IS BROKEN ACROSS A RECORD BOUNDARY. */
}

global int fGETTXT_SPLITTING = -1;

function fGETTXT(int SKIP,int ONEWRD,int UPPER,int HASH)
returns int GETTXT
locals int CHAR, int I
{
	/*  TAKE CHARACTERS FROM AN INPUT LINE AND PACK THEM INTO 30-BIT WORDS.
	 *  SKIP SAYS TO SKIP LEADING BLANKS.  ONEWRD SAYS STOP IF WE COME TO A
	 *  BLANK.  UPPER SAYS TO MAP ALL LETTERS TO UPPERCASE.  HASH MAY BE USED
	 *  AS A PARAMETER FOR ENCRYPTING THE TEXT IF DESIRED; HOWEVER, A HASH OF 0
	 *  SHOULD RESULT IN UNMODIFIED BYTES BEING PACKED.  IF WE REACH THE
	 *  END OF THE LINE, THE WORD IS FILLED UP WITH BLANKS (WHICH ENCODE AS 0'S).
	 *  IF WE'RE ALREADY AT END OF LINE WHEN GETTXT IS CALLED, WE RETURN -1. */

	if(global LNPOSN != global fGETTXT_SPLITTING)global fGETTXT_SPLITTING = -1;
	GETTXT= -1;
L10:
	if(global LNPOSN > global LNLENG) goto return;
	if(!((SKIP==FALSE) || (int)global INLINE[global LNPOSN] != 0)) {
		global LNPOSN=global LNPOSN+1;
		goto L10;
	}

	GETTXT=0;
	for (I=1 to 5+1) {
		GETTXT=GETTXT*64;
		if(global LNPOSN > global LNLENG || (ONEWRD != FALSE && (int)global INLINE[global LNPOSN] == 0)) goto L15;
		CHAR=(int)global INLINE[global LNPOSN];
		if(!(CHAR >= 63)) {
			global fGETTXT_SPLITTING = -1;
			if(UPPER != FALSE && CHAR >= 37)CHAR=CHAR-26;
			GETTXT=GETTXT+CHAR;
		} else {
			if(!(global fGETTXT_SPLITTING == global LNPOSN)) {
				GETTXT=GETTXT+63;
				global fGETTXT_SPLITTING = global LNPOSN;
				goto L15;
			}
			GETTXT=GETTXT+CHAR-63;
			global fGETTXT_SPLITTING = -1;
		}
		global LNPOSN=global LNPOSN+1;
	L15: ;
	} /* end loop */

	if(HASH != FALSE)GETTXT=GETTXT+((HASH*13579+5432)%97531)*12345+HASH;
return: ;
}

function fMAKEWD(int LETTRS)
returns int MAKEWD
locals int I, int L 
{
	/*  COMBINE FIVE UPPERCASE LETTERS (REPRESENTED BY PAIRS OF DECIMAL DIGITS
	 *  IN LETTRS) TO FORM A 30-BIT VALUE MATCHING THE ONE THAT GETTXT WOULD
	 *  RETURN GIVEN THOSE CHARACTERS PLUS TRAILING BLANKS AND HASH=0.  CAUTION:
	 *  LETTRS WILL OVERFLOW 31 BITS IF 5-LETTER WORD STARTS WITH V-Z.  AS A
	 *  KLUDGEY WORKAROUND, YOU CAN INCREMENT A LETTER BY 5 BY ADDING 50 TO
	 *  THE NEXT PAIR OF DIGITS. */

	MAKEWD=0;
	I=1;
	L=LETTRS;
	do {
		MAKEWD=MAKEWD+I*(((L)%50)+10);
		I=I*64;
		if(((L)%100) > 50)MAKEWD=MAKEWD+I*5;
		L=L/100;
	} while (L != 0);
	I=64*64*64*64*64/I;
	MAKEWD=MAKEWD*I;
}

function fSHFTXT(int FROM,int DELTA)
locals int I, int II, int JJ
{
/*  MOVE INLINE(N) TO INLINE(N+DELTA) FOR N=FROM,LNLENG.  DELTA CAN BE
 *  NEGATIVE.  LNLENG IS UPDATED; LNPOSN IS NOT CHANGED. */

	if(!(global LNLENG < FROM || DELTA == 0)) {
		for (I=FROM to global LNLENG+1) {
			II=I;
			if(DELTA > 0)II=FROM+global LNLENG-I;
			JJ=II+DELTA;
			global INLINE[JJ]=global INLINE[II];
		} /* end loop */
	}
	global LNLENG=global LNLENG+DELTA;
}


function fPUTTXT(int WORD,pointer sTATE,int CASE,int HASH)
locals int ALPH1, int ALPH2, int BYTE, int DIV, int I, int W
{
	/*  UNPACK THE 30-BIT VALUE IN WORD TO OBTAIN UP TO 5 INTEGER-ENCODED CHARS,
	 *  AND STORE THEM IN INLINE STARTING AT LNPOSN.  IF LNLENG>=LNPOSN, SHIFT
	 *  EXISTING CHARACTERS TO THE RIGHT TO MAKE ROOM.  HASH MUST BE THE SAME
	 *  AS IT WAS WHEN GETTXT CREATED THE 30-BIT WORD.  STATE WILL BE ZERO WHEN
	 *  PUTTXT IS CALLED WITH THE FIRST OF A SEQUENCE OF WORDS, BUT IS THEREAFTER
	 *  UNCHANGED BY THE CALLER, SO PUTTXT CAN USE IT TO MAINTAIN STATE ACROSS
	 *  CALLS.  LNPOSN AND LNLENG ARE INCREMENTED BY THE NUMBER OF CHARS STORED.
	 *  IF CASE=1, ALL LETTERS ARE MADE UPPERCASE; IF -1, LOWERCASE; IF 0, AS IS.
	 *  ANY OTHER VALUE FOR CASE IS THE SAME AS 0 BUT ALSO CAUSES TRAILING BLANKS
	 *  TO BE INCLUDED (IN ANTICIPATION OF SUBSEQUENT ADDITIONAL TEXT). */

	ALPH1=13*CASE+24;
	ALPH2=26*abs(CASE)+ALPH1;
	if(abs(CASE) > 1)ALPH1=ALPH2;
/*  ALPH1&2 DEFINE RANGE OF WRONG-CASE CHARS, 11-36 OR 37-62 OR EMPTY. */
	DIV=64*64*64*64;
	W=WORD;
	if(HASH!=0)W=W-((HASH*13579+5432)%97531)*12345-HASH;
	for (I=1 to 5+1) {
		if(W <= 0 && (int)(*sTATE) == 0 && abs(CASE) <= 1) goto return;
		BYTE=W/DIV;
		if(!((int)(*sTATE) != 0 || BYTE != 63)) {
			(int)(*sTATE)=63;
		} else {
			fSHFTXT(global LNPOSN,1);
			(*sTATE)=(int)(*sTATE)+BYTE;
			if((int)(*sTATE) < ALPH2 && (int)(*sTATE) >= ALPH1)(*sTATE)=(int)(*sTATE)-26*CASE;
			global INLINE[global LNPOSN]=(*sTATE);
			global LNPOSN=global LNPOSN+1;
			(int)(*sTATE)=0;
		}
		W=(W-BYTE*DIV)*64;
	} /* end loop */
return: ;
}

/*  I/O ROUTINES (SPEAK, PSPEAK, RSPEAK, SETPRM, GETIN, YES) */

function fTYPE()
locals int I, int VAL
{
	/*  TYPE THE FIRST "LNLENG" CHARACTERS STORED IN INLINE, MAPPING THEM
	 *  FROM INTEGERS TO TEXT PER THE RULES DESCRIBED ABOVE.  INLINE(I),
	 *  I=1,LNLENG MAY BE CHANGED BY THIS ROUTINE. */

	if(!(global LNLENG != 0)) {
		output("\n");
		goto return;
	}
	if((int)global MAP2[1] == 0)fMPINIT();
	for (I=1 to global LNLENG+1) {
		VAL=(int)global INLINE[I];
		global INLINE[I]=global MAP2[VAL+1];
	} /* end loop */
	global INLINE[global LNLENG+1]=0;
	output(global INLINE+1); output("\n");
return: ;
}

function fTYPE0()
locals int TEMP
{
	/*  TYPE A BLANK LINE.  THIS PROCEDURE IS PROVIDED AS A CONVENIENCE FOR CALLERS
	 *  WHO OTHERWISE HAVE NO USE FOR MAPCOM. */

	TEMP=global LNLENG;
	global LNLENG=0;
	fTYPE();
	global LNLENG=TEMP;
}

function fSPEAK(int N)
locals int BLANK, int CASE, int I, int K, int L, int NEG, int NPARMS, int PARM, int PRMTYP, int STATE
{

	/*  PRINT THE MESSAGE WHICH STARTS AT LINES(N).  PRECEDE IT WITH A BLANK LINE
	 *  UNLESS BLKLIN IS FALSE. */

	if(N == 0) goto return;
	BLANK=global BLKLIN;
	K=N;
	NPARMS=1;
L10:
	L=abs((int)global LINES[K])-1;
	K=K+1;
	global LNLENG=0;
	global LNPOSN=1;
	STATE=0;
	for (I=K to L+1) {
		fPUTTXT(global LINES[I],&STATE,2,I);
	} /* end loop */
	global LNPOSN=0;
L30:
	global LNPOSN=global LNPOSN+1;
L32:
	if(global LNPOSN > global LNLENG) goto L40;
	if((int)global INLINE[global LNPOSN] != 63) goto L30;
	PRMTYP=(int)global INLINE[global LNPOSN+1];
	
	/*  63 IS A "%"; THE NEXT CHARACTER DETERMINE THE TYPE OF PARAMETER:  1 (!) =
	 *  SUPPRESS MESSAGE COMPLETELY, 29 (S) = NULL IF PARM=1, ELSE 'S' (OPTIONAL
	 *  PLURAL ENDING), 33 (W) = WORD (TWO 30-BIT VALUES) WITH TRAILING SPACES
	 *  SUPPRESSED, 22 (L) OR 31 (U) = WORD BUT MAP TO LOWER/UPPER CASE, 13 (C) =
	 *  WORD IN LOWER CASE WITH FIRST LETTER CAPITALISED, 30 (T) = TEXT ENDING
	 *  WITH A WORD OF -1, 65-73 (1-9) = NUMBER USING THAT MANY CHARACTERS,
	 *  12 (B) = VARIABLE NUMBER OF BLANKS. */
	 
	if(PRMTYP == 1) goto return;
	if(PRMTYP == 29) goto L320;
	if(PRMTYP == 30) goto L340;
	if(PRMTYP == 12) goto L360;
	if(PRMTYP == 33 || PRMTYP == 22 || PRMTYP == 31 || PRMTYP == 13) goto
		L380;
	PRMTYP=PRMTYP-64;
	if(PRMTYP < 1 || PRMTYP > 9) goto L30;
	fSHFTXT(global LNPOSN+2,PRMTYP-2);
	global LNPOSN=global LNPOSN+PRMTYP;
	PARM=abs((int)global PARMS[NPARMS]);
	NEG=0;
	if((int)global PARMS[NPARMS] < 0)NEG=9;
	for (I=1 to PRMTYP+1) {
		global LNPOSN=global LNPOSN-1;
		global INLINE[global LNPOSN]=((PARM)%10)+64;
		if(I == 1 || PARM != 0) goto L390;
		global INLINE[global LNPOSN]=NEG;
		NEG=0;
	L390:
		PARM=PARM/10;
	} /* end loop */
	global LNPOSN=global LNPOSN+PRMTYP;
L395:
	NPARMS=NPARMS+1;
	goto L32;

L320:
	fSHFTXT(global LNPOSN+2,-1);
	global INLINE[global LNPOSN]=55;
	if((int)global PARMS[NPARMS] == 1)fSHFTXT(global LNPOSN+1,-1);
	goto L395;

L340:
	fSHFTXT(global LNPOSN+2,-2);
	STATE=0;
	CASE=2;
L345:
	if((int)global PARMS[NPARMS] < 0) goto L395;
	if((int)global PARMS[NPARMS+1] < 0)CASE=0;
	fPUTTXT(global PARMS[NPARMS],&STATE,CASE,0);
	NPARMS=NPARMS+1;
	goto L345;

L360:
	PRMTYP=(int)global PARMS[NPARMS];
	fSHFTXT(global LNPOSN+2,PRMTYP-2);
	if(PRMTYP == 0) goto L395;
	for (I=1 to PRMTYP+1) {
		global INLINE[global LNPOSN]=0;
		global LNPOSN=global LNPOSN+1;
	} /* end loop */
	goto L395;

L380:
	fSHFTXT(global LNPOSN+2,-2);
	STATE=0;
	CASE= -1;
	if(PRMTYP == 31)CASE=1;
	if(PRMTYP == 33)CASE=0;
	I=global LNPOSN;
	fPUTTXT(global PARMS[NPARMS],&STATE,CASE,0);
	fPUTTXT(global PARMS[NPARMS+1],&STATE,CASE,0);
	if(PRMTYP == 13 && (int)global INLINE[I] >= 37 && (int)global INLINE[I] <= 62)global INLINE[I]=(int)global INLINE[I]-26;
	NPARMS=NPARMS+2;
	goto L32;

L40:
	if(BLANK != FALSE)fTYPE0();
	BLANK=FALSE;
	fTYPE();
	K=L+1;
	if((int)global LINES[K] >= 0) goto L10;
	
return: ;
}

function fPSPEAK(int MSG, int SKIP)
locals int I, int M
{
	/*  FIND THE SKIP+1ST MESSAGE FROM MSG AND PRINT IT.  MSG SHOULD BE THE INDEX OF
	 *  THE INVENTORY MESSAGE FOR OBJECT.  (INVEN+N+1 MESSAGE IS PROP=N MESSAGE). */
	M=(int)global PTEXT[MSG];
	if(!(SKIP < 0)) {
		for (I=0 to SKIP+1) {
			do {
				M=abs((int)global LINES[M]);
			} while ((int)global LINES[M] >= 0);
		} /* end loop */
	}
	fSPEAK(M);
}

function fRSPEAK(int I) {
	/*  PRINT THE I-TH "RANDOM" MESSAGE (SECTION 6 OF DATABASE). */

	if(I != 0)fSPEAK(global RTEXT[I]);
}

function fSETPRM(int FIRST,int P1,int P2) {
	/*  STORES PARAMETERS INTO THE PRMCOM PARMS ARRAY FOR USE BY SPEAK.  P1 AND P2
	 *  ARE STORED INTO PARMS(FIRST) AND PARMS(FIRST+1). */
 
	if(FIRST >= 25)fBUG(29);
	global PARMS[FIRST]=P1;
	global PARMS[FIRST + 1]=P2;
}



function fGETIN(pointer wORD1,pointer wORD1X,pointer wORD2,pointer wORD2X)
locals int JUNK
{

	/*  GET A COMMAND FROM THE ADVENTURER.  SNARF OUT THE FIRST WORD, PAD IT WITH
	 *  BLANKS, AND RETURN IT IN WORD1.  CHARS 6 THRU 10 ARE RETURNED IN WORD1X, IN
	 *  CASE WE NEED TO PRINT OUT THE WHOLE WORD IN AN ERROR MESSAGE.  ANY NUMBER OF
	 *  BLANKS MAY FOLLOW THE WORD.  IF A SECOND WORD APPEARS, IT IS RETURNED IN
	 *  WORD2 (CHARS 6 THRU 10 IN WORD2X), ELSE WORD2 IS -1. */

L10:
	do {
		if(global BLKLIN != FALSE)fTYPE0();
		fMAPLIN(FALSE);
		(*wORD1)=fGETTXT(TRUE,TRUE,TRUE,0);
	} while (global BLKLIN != FALSE && (int)(*wORD1) < 0);
	(*wORD1X)=fGETTXT(FALSE,TRUE,TRUE,0);
	do {
		JUNK=(int)fGETTXT(FALSE,TRUE,TRUE,0);
	} while (JUNK > 0);
	(*wORD2)=fGETTXT(TRUE,TRUE,TRUE,0);
	(*wORD2X)=fGETTXT(FALSE,TRUE,TRUE,0);
	do {
		JUNK=(int)fGETTXT(FALSE,TRUE,TRUE,0);
	} while (JUNK > 0);
	if((int)fGETTXT(TRUE,TRUE,TRUE,0) <= 0)goto return;
	fRSPEAK(53);
	goto L10;
return: ;
}

function fYES(int X,int Y,int Z)
returns int YES
locals int REPLY, int JUNK1, int JUNK2, int JUNK3
{
	/*  PRINT MESSAGE X, WAIT FOR YES/NO ANSWER.  IF YES, PRINT Y AND RETURN TRUE;
	 *  IF NO, PRINT Z AND RETURN FALSE. */

L1:
	fRSPEAK(X);
	fGETIN(&REPLY,&JUNK1,&JUNK2,&JUNK3);
	if(REPLY == (int)fMAKEWD(250519) || REPLY == (int)fMAKEWD(25)) {
		YES=TRUE;
		fRSPEAK(Y);
		goto return;
	}
	if(REPLY == (int)fMAKEWD(1415) || REPLY == (int)fMAKEWD(14)) {
		YES=FALSE;
		fRSPEAK(Z);
		goto return;
	}
	fRSPEAK(185);
	goto L1;
return: ;
}

/*
 * SCORING AND WRAP-UP
 */

function score(int MODE)
locals int I, int K
{
	/* MODE <0 if scoring, >0 if quitting, =0 if died or won */

	/*  THE PRESENT SCORING ALGORITHM IS AS FOLLOWS:
	 *     OBJECTIVE:          POINTS:        PRESENT TOTAL POSSIBLE:
	 *  GETTING WELL INTO CAVE   25                    25
	 *  EACH TREASURE < CHEST    12                    60
	 *  TREASURE CHEST ITSELF    14                    14
	 *  EACH TREASURE > CHEST    16                   224
	 *  SURVIVING             (MAX-NUM)*10             30
	 *  NOT QUITTING              4                     4
	 *  REACHING "CLOSNG"        25                    25
	 *  "CLOSED": QUIT/KILLED    10
	 *            KLUTZED        25
	 *            WRONG WAY      30
	 *            SUCCESS        45                    45
	 *  CAME TO WITT'S END        1                     1
	 *  ROUND OUT THE TOTAL       2                     2
	 *                                       TOTAL:   430
	 *  POINTS CAN ALSO BE DEDUCTED FOR USING HINTS OR TOO MANY TURNS, OR FOR
	 *  SAVING INTERMEDIATE POSITIONS. */

	global SCORE=0;
	global MXSCOR=0;

	/*  FIRST TALLY UP THE TREASURES.  MUST BE IN BUILDING AND NOT BROKEN.
	 *  GIVE THE POOR GUY 2 POINTS JUST FOR FINDING EACH TREASURE. */

	for (I=50 to MAXTRS+1) {
		if((int)global PTEXT[I] != 0) {
			K=12;
			if(I == CHEST)K=14;
			if(I > CHEST)K=16;
			if((int)global PROP[I] >= 0)global SCORE=global SCORE+2;
			if((int)global PLACE[I] == 3 && (int)global PROP[I] == 0)global SCORE=global SCORE+K-2;
			global MXSCOR=global MXSCOR+K;
		}
	} /* end loop */

/*  NOW LOOK AT HOW HE FINISHED AND HOW FAR HE GOT.  MAXDIE AND NUMDIE TELL US
 *  HOW WELL HE SURVIVED.  DFLAG WILL
 *  TELL US IF HE EVER GOT SUITABLY DEEP INTO THE CAVE.  CLOSNG STILL INDICATES
 *  WHETHER HE REACHED THE ENDGAME.  AND IF HE GOT AS FAR AS "CAVE CLOSED"
 *  (INDICATED BY "CLOSED"), THEN BONUS IS ZERO FOR MUNDANE EXITS OR 133, 134,
 *  135 IF HE BLEW IT (SO TO SPEAK). */

	global SCORE=global SCORE+(global MAXDIE-global NUMDIE)*10;
	global MXSCOR=global MXSCOR+global MAXDIE*10;
	if(MODE == 0)global SCORE=global SCORE+4;
	global MXSCOR=global MXSCOR+4;
	if(global DFLAG != 0)global SCORE=global SCORE+25;
	global MXSCOR=global MXSCOR+25;
	if(global CLOSNG != FALSE)global SCORE=global SCORE+25;
	global MXSCOR=global MXSCOR+25;
	if(global CLOSED != FALSE) {
		if(global BONUS == 0)global SCORE=global SCORE+10;
		if(global BONUS == 135)global SCORE=global SCORE+25;
		if(global BONUS == 134)global SCORE=global SCORE+30;
		if(global BONUS == 133)global SCORE=global SCORE+45;
	}
	global MXSCOR=global MXSCOR+45;

/*  DID HE COME TO WITT'S END AS HE SHOULD? */

	if((int)global PLACE[MAGZIN] == 108)global SCORE=global SCORE+1;
	global MXSCOR=global MXSCOR+1;

/*  ROUND IT OFF. */

	global SCORE=global SCORE+2;
	global MXSCOR=global MXSCOR+2;

/*  DEDUCT FOR HINTS/TURNS/SAVES.  HINTS < 4 ARE SPECIAL; SEE DATABASE DESC. */

	for (I=1 to HNTMAX+1) {
		if((int)global HINTED[I] != 0)global SCORE=global SCORE-(int)global HINTS[I * 5 + 2];
	} /* end loop */
	if(global NOVICE != FALSE)global SCORE=global SCORE-5;
	if(global CLSHNT != FALSE)global SCORE=global SCORE-10;
	global SCORE=global SCORE-global TRNLUZ-global SAVED;

/*  RETURN TO global SCORE COMMAND IF THAT'S WHERE WE CAME FROM. */

	if(MODE < 0) goto return;

/*  THAT SHOULD BE GOOD ENOUGH.  LET'S TELL HIM ALL ABOUT IT. */

	if(global SCORE+global TRNLUZ+1 >= global MXSCOR && global TRNLUZ != 0)fRSPEAK(242);
	if(global SCORE+global SAVED+1 >= global MXSCOR && global SAVED != 0)fRSPEAK(143);
	fSETPRM(1,global SCORE,global MXSCOR);
	fSETPRM(3,global TURNS,global TURNS);
	fRSPEAK(262);
	for (I=1 to CLSSES+1) {
		if((int)global CVAL[I] >= global SCORE) {
			fSPEAK(global CTEXT[I]);
			global SPK=264;
			if(I < CLSSES) {
				I=(int)global CVAL[I]+1-global SCORE;
				fSETPRM(1,I,I);
				global SPK=263;
			}
			fRSPEAK(global SPK);
			exit(0);
		}
	} /* end loop */
	global SPK=265;
	fRSPEAK(global SPK);
	exit(0);

return: ;
}

/*  DATA STRUC. ROUTINES (VOCAB, DSTROY, JUGGLE, MOVE, PUT, CARRY, DROP, ATDWRF) */

function fVOCAB(int ID,int INIT)
returns int VOCAB
locals int HASH, int I
{
	/*  LOOK UP ID IN THE VOCABULARY (ATAB) AND RETURN ITS "DEFINITION" (KTAB), OR
	 *  -1 IF NOT FOUND.  IF INIT IS POSITIVE, THIS IS AN INITIALISATION CALL SETTING
	 *  UP A KEYWORD VARIABLE, AND NOT FINDING IT CONSTITUTES A BUG.  IT ALSO MEANS
	 *  THAT ONLY KTAB VALUES WHICH TAKEN OVER 1000 EQUAL INIT MAY BE CONSIDERED.
	 *  (THUS "STEPS", WHICH IS A MOTION VERB AS WELL AS AN OBJECT, MAY BE LOCATED
	 *  AS AN OBJECT.)  AND IT ALSO MEANS THE KTAB VALUE IS TAKEN MOD 1000. */

	HASH=10000;
	for (I=1 to TABSIZ+1) {
		if((int)global KTAB[I] == -1) {
			VOCAB= -1;
			if(INIT < 0) goto return;
			fBUG(5);
		}
		HASH=HASH+7;
		if(!(INIT >= 0 && (int)global KTAB[I]/1000 != INIT)) {
			if((int)global ATAB[I] == ID+HASH*HASH) {
				VOCAB=(int)global KTAB[I];
				if(INIT >= 0)VOCAB=((VOCAB)%1000);
				goto return;
			}
		}
	} /* end loop */
	fBUG(21);
return: ;
}

function fCARRY(int OBJECT,int WHERE)
locals int TEMP
{
	/*  START TOTING AN OBJECT, REMOVING IT FROM THE LIST OF THINGS AT ITS FORMER
	 *  LOCATION.  INCR HOLDNG UNLESS IT WAS ALREADY BEING TOTED.  IF OBJECT>100
	 *  (MOVING "FIXED" SECOND LOC), DON'T CHANGE PLACE OR HOLDNG. */

	if(OBJECT <= 100) {
		if((int)global PLACE[OBJECT] == -1) goto return;
		global PLACE[OBJECT]= -1;
		global HOLDNG=global HOLDNG+1;
	}
	if((int)global ATLOC[WHERE] == OBJECT) {
		global ATLOC[WHERE]=global LINK[OBJECT];
		goto return;
	}
	TEMP=(int)global ATLOC[WHERE];
	while ((int)global LINK[TEMP] != OBJECT) {
		TEMP=(int)global LINK[TEMP];
	}
	global LINK[TEMP]=global LINK[OBJECT];
return: ;
}

function fDROP(int OBJECT,int WHERE) {
	/*  PLACE AN OBJECT AT A GIVEN LOC, PREFIXING IT ONTO THE ATLOC LIST.  DECR
	 *  HOLDNG IF THE OBJECT WAS BEING TOTED. */

	if(OBJECT <= 100) {
		if((int)global PLACE[OBJECT] == -1)global HOLDNG=global HOLDNG-1;
		global PLACE[OBJECT]=WHERE;
	} else {
		global FIXED[OBJECT-100]=WHERE;
	}
	if(WHERE > 0) {
		global LINK[OBJECT]=global ATLOC[WHERE];
		global ATLOC[WHERE]=OBJECT;
	}
}

function fMOVE(int OBJECT,int WHERE)
locals int FROM
{
	/*  PLACE ANY OBJECT ANYWHERE BY PICKING IT UP AND DROPPING IT.  MAY ALREADY BE
	 *  TOTING, IN WHICH CASE THE CARRY IS A NO-OP.  MUSTN'T PICK UP OBJECTS WHICH
	 *  ARE NOT AT ANY LOC, SINCE CARRY WANTS TO REMOVE OBJECTS FROM ATLOC CHAINS. */

	if(OBJECT <= 100) {
		FROM=(int)global PLACE[OBJECT];
	} else {
		FROM=(int)global FIXED[OBJECT-100];
	}
	if(FROM > 0 && FROM <= 300)fCARRY(OBJECT,FROM);
	fDROP(OBJECT,WHERE);
}

function fDSTROY(int OBJECT) {
	/*  PERMANENTLY ELIMINATE "OBJECT" BY MOVING TO A NON-EXISTENT LOCATION. */

	fMOVE(OBJECT,0);
}

function fJUGGLE(int OBJECT)
locals int I, int J
{
	/*  JUGGLE AN OBJECT BY PICKING IT UP AND PUTTING IT DOWN AGAIN, THE PURPOSE
	 *  BEING TO GET THE OBJECT TO THE FRONT OF THE CHAIN OF THINGS AT ITS LOC. */
	 
	I=(int)global PLACE[OBJECT];
	J=(int)global FIXED[OBJECT];
	fMOVE(OBJECT,I);
	fMOVE(OBJECT+100,J);
}

function fPUT(int OBJECT,int WHERE,int PVAL)
returns int PUT
{
	/*  PUT IS THE SAME AS MOVE, EXCEPT IT RETURNS A VALUE USED TO SET UP THE
	 *  NEGATED PROP VALUES FOR THE REPOSITORY OBJECTS. */

	fMOVE(OBJECT,WHERE);
	PUT=(-1)-PVAL;
}

function fATDWRF(int WHERE)
returns int ATDWRF
locals int I
{
	/*  RETURN THE INDEX OF FIRST DWARF AT THE GIVEN LOCATION, ZERO IF NO DWARF IS
	 *  THERE (OR IF DWARVES NOT ACTIVE YET), -1 IF ALL DWARVES ARE DEAD.  IGNORE
	 *  THE PIRATE (6TH DWARF). */

	ATDWRF=0;
	if(global DFLAG < 2) goto return;
	ATDWRF= -1;
	for (I=1 to 5+1) {
		if((int)global DLOC[I] == WHERE) {
			ATDWRF=I;
			goto return;
		}
		if((int)global DLOC[I] != 0)ATDWRF=0;
	} /* end loop */
return: ;
}

function fRNDVOC(int CHAR,int FORCE)
returns int RNDVOC
locals int DIV, int I, int J
{
	/*  SEARCHES THE VOCABULARY FOR A WORD WHOSE SECOND CHARACTER IS CHAR, AND
	 *  CHANGES THAT WORD SUCH THAT EACH OF THE OTHER FOUR CHARACTERS IS A
	 *  RANDOM LETTER.  IF FORCE IS NON-ZERO, IT IS USED AS THE NEW WORD.
	 *  RETURNS THE NEW WORD. */

	RNDVOC=FORCE;
	if(RNDVOC == 0) {
		for (I=1 to 5+1) {
			J=11+(int)fRAN(26);
			if(I == 2)J=CHAR;
			RNDVOC=RNDVOC*64+J;
		} /* end loop */
	}
	J=10000;
	DIV=64*64*64;
	for (I=1 to TABSIZ+1) {
		J=J+7;
		if(((((int)global ATAB[I]-J*J)/DIV)%64) == CHAR) {
			(int)global ATAB[I]=RNDVOC+J*J;
			goto return;
		}
	} /* end loop */
	fBUG(5);
return: ;
}

/*  FINISH CONSTRUCTING INTERNAL DATA FORMAT */

/*  HAVING READ IN THE DATABASE, CERTAIN THINGS ARE NOW CONSTRUCTED.  PROPS ARE
 *  SET TO ZERO.  WE FINISH SETTING UP COND BY CHECKING FOR FORCED-MOTION TRAVEL
 *  ENTRIES.  THE PLAC AND FIXD ARRAYS ARE USED TO SET UP ATLOC(N) AS THE FIRST
 *  OBJECT AT LOCATION N, AND LINK(OBJ) AS THE NEXT OBJECT AT THE SAME LOCATION
 *  AS OBJ.  (OBJ>100 INDICATES THAT FIXED(OBJ-100)=LOC; LINK(OBJ) IS STILL THE
 *  CORRECT LINK TO USE.)  ABB IS ZEROED; IT CONTROLS WHETHER THE ABBREVIATED
 *  DESCRIPTION IS PRINTED.  COUNTS MOD 5 UNLESS "LOOK" IS USED. */

function initialise()
locals int I, int K
{
	for (I=1 to 100+1) {
		global PLACE[I]=0;
		global PROP[I]=0;
		global LINK[I]=0;
		global LINK[I + 100]=0;
	} /* end loop */

	for (I=1 to LOCSIZ+1) {
		global ABB[I]=0;
		if(!((int)global LTEXT[I] == 0 || (int)global KEY[I] == 0)) {
			K=(int)global KEY[I];
			if(((abs((int)global TRAVEL[K]))%1000) == 1)global COND[I]=2;
		}
		global ATLOC[I]=0;
	} /* end loop */

	/*  SET UP THE ATLOC AND LINK ARRAYS AS DESCRIBED ABOVE.  WE'LL USE THE DROP
	 *  SUBROUTINE, WHICH PREFACES NEW OBJECTS ON THE LISTS.  SINCE WE WANT THINGS
	 *  IN THE OTHER ORDER, WE'LL RUN THE LOOP BACKWARDS.  IF THE OBJECT IS IN TWO
	 *  LOCS, WE DROP IT TWICE.  THIS ALSO SETS UP "PLACE" AND "FIXED" AS COPIES OF
	 *  "PLAC" AND "FIXD".  ALSO, SINCE TWO-PLACED OBJECTS ARE TYPICALLY BEST
	 *  DESCRIBED LAST, WE'LL DROP THEM FIRST. */

	for (I=1 to 100+1) {
		K=101-I;
		if(!((int)global FIXD[K] <= 0)) {
			fDROP(K+100,global FIXD[K]);
			fDROP(K,global PLAC[K]);
		}
	} /* end loop */

	for (I=1 to 100+1) {
		K=101-I;
		global FIXED[K]=global FIXD[K];
		if((int)global PLAC[K] != 0 && (int)global FIXD[K] <= 0)fDROP(K,global PLAC[K]);
	} /* end loop */

	/*  TREASURES, AS NOTED EARLIER, ARE OBJECTS 50 THROUGH MAXTRS (CURRENTLY 79).
	 *  THEIR PROPS ARE INITIALLY -1, AND ARE SET TO 0 THE FIRST TIME THEY ARE
	 *  DESCRIBED.  TALLY KEEPS TRACK OF HOW MANY ARE NOT YET FOUND, SO WE KNOW
	 *  WHEN TO CLOSE THE CAVE. */

//	MAXTRS=79;
	global TALLY=0;
	for (I=50 to MAXTRS+1) {
		if((int)global PTEXT[I] != 0)global PROP[I]= -1;
		global TALLY=global TALLY-(int)global PROP[I];
	} /* end loop */

/*  CLEAR THE HINT STUFF.  HINTLC(I) IS HOW LONG HE'S BEEN AT LOC WITH COND BIT
 *  I.  HINTED(I) IS TRUE IFF HINT I HAS BEEN USED. */

	for (I=1 to HNTMAX+1) {
		global HINTED[I]=FALSE;
		global HINTLC[I]=0;
	} /* end loop */
	
	/*  INITIALISE THE DWARVES.  DLOC IS LOC OF DWARVES, HARD-WIRED IN.  ODLOC IS
	 *  PRIOR LOC OF EACH DWARF, INITIALLY GARBAGE.  DALTLC IS ALTERNATE INITIAL LOC
	 *  FOR DWARF, IN CASE ONE OF THEM STARTS OUT ON TOP OF THE ADVENTURER.  (NO 2
	 *  OF THE 5 INITIAL LOCS ARE ADJACENT.)  DSEEN IS TRUE IF DWARF HAS SEEN HIM.
	 *  DFLAG CONTROLS THE LEVEL OF ACTIVATION OF ALL THIS:
	 *	0	NO DWARF STUFF YET (WAIT UNTIL REACHES HALL OF MISTS)
	 *	1	REACHED HALL OF MISTS, BUT HASN'T MET FIRST DWARF
	 *	2	MET FIRST DWARF, OTHERS START MOVING, NO KNIVES THROWN YET
	 *	3	A KNIFE HAS BEEN THROWN (FIRST SET ALWAYS MISSES)
	 *	3+	DWARVES ARE MAD (INCREASES THEIR ACCURACY)
	 *  SIXTH DWARF IS SPECIAL (THE PIRATE).  HE ALWAYS STARTS AT HIS CHEST'S
	 *  EVENTUAL LOCATION INSIDE THE MAZE.  THIS LOC IS SAVED IN CHLOC FOR REF.
	 *  THE DEAD END IN THE OTHER MAZE HAS ITS LOC STORED IN CHLOC2. */

//	CHLOC=114;
//	CHLOC2=140;
	for (I=1 to 6+1) {
		global DSEEN[I]=FALSE;
	} /* end loop */
	global DFLAG=0;
	global DLOC[1]=19;
	global DLOC[2]=27;
	global DLOC[3]=33;
	global DLOC[4]=44;
	global DLOC[5]=64;
	global DLOC[6]=CHLOC;

	/*  OTHER RANDOM FLAGS AND COUNTERS, AS FOLLOWS:
	 *	ABBNUM	HOW OFTEN WE SHOULD PRINT NON-ABBREVIATED DESCRIPTIONS
	 *	BONUS	USED TO DETERMINE AMOUNT OF BONUS IF HE REACHES CLOSING
	 *	CLOCK1	NUMBER OF TURNS FROM FINDING LAST TREASURE TILL CLOSING
	 *	CLOCK2	NUMBER OF TURNS FROM FIRST WARNING TILL BLINDING FLASH
	 *	CONDS	MIN VALUE FOR COND(LOC) IF LOC HAS ANY HINTS
	 *	DETAIL	HOW OFTEN WE'VE SAID "NOT ALLOWED TO GIVE MORE DETAIL"
	 *	DKILL	NUMBER OF DWARVES KILLED (UNUSED IN SCORING, NEEDED FOR MSG)
	 *	FOOBAR	CURRENT PROGRESS IN SAYING "FEE FIE FOE FOO".
	 *	HOLDNG	NUMBER OF OBJECTS BEING CARRIED
	 *	IGO	HOW MANY TIMES HE'S SAID "GO XXX" INSTEAD OF "XXX"
	 *	IWEST	HOW MANY TIMES HE'S SAID "WEST" INSTEAD OF "W"
	 *	KNFLOC	0 IF NO KNIFE HERE, LOC IF KNIFE HERE, -1 AFTER CAVEAT
	 *	LIMIT	LIFETIME OF LAMP (NOT SET HERE)
	 *	MAXDIE	NUMBER OF REINCARNATION MESSAGES AVAILABLE (UP TO 5)
	 *	NUMDIE	NUMBER OF TIMES KILLED SO FAR
	 *	THRESH	NEXT #TURNS THRESHHOLD (-1 IF NONE)
	 *	TRNDEX	INDEX IN TRNVAL OF NEXT THRESHHOLD (SECTION 14 OF DATABASE)
	 *	TRNLUZ	# POINTS LOST SO FAR DUE TO NUMBER OF TURNS USED
	 *	TURNS	TALLIES HOW MANY COMMANDS HE'S GIVEN (IGNORES YES/NO)
	 *	LOGICALS WERE EXPLAINED EARLIER */

	global THRESH= -1;
	if(TRNVLS > 0)global THRESH=(((int)global TRNVAL[1])%100000)+1;
	for (I=0 to 4+1) {
		if((int)global RTEXT[2*I+81] != 0)global MAXDIE=I+1;
	} /* end loop */
}

/* @@@ */

function TOTING(int OBJ) returns int r { r = FALSE; if ((int)global PLACE[OBJ] == -1) r = TRUE; }
function AT(int OBJ, int LOC) returns int r { r = FALSE; if ((int)global PLACE[OBJ] == LOC || (int)global FIXED[OBJ] == LOC) r = TRUE; }
function HERE(int OBJ, int LOC) returns int r { r = FALSE; if (((int)AT(OBJ, LOC) | (int)TOTING(OBJ)) != FALSE) r = TRUE; }
function LIQ2(int PBOTL) returns int r { r = ((1-(PBOTL))*WATER+((PBOTL)/2)*(WATER+OIL)); }
function LIQ() returns int r { if ((int)global PROP[BOTTLE]<0) r = -1-(int)global PROP[BOTTLE]; else r = (int)global PROP[BOTTLE]; r = (int)LIQ2(r); }
function LIQLOC(int LOC) returns int r { r = (int)LIQ2(((((int)global COND[LOC]/2*2)%8)-5)*(((int)global COND[LOC]/4)%2)+1); }
function CNDBIT(int L, int N) returns int r { r = FALSE; if (((int)global COND[L] & (1 << N)) != 0) r = TRUE; }
function DARK(int LOC) returns int r { r = FALSE; if (((int)CNDBIT(LOC,0) == FALSE) && ((int)global PROP[LAMP] == 0 || (int)HERE(LAMP, LOC) == FALSE)) r = TRUE; }
function GSTONE(int OBJ) returns int r { r = FALSE; if ((OBJ) == EMRALD || (OBJ) == RUBY || (OBJ) == AMBER || (OBJ) == SAPPH) r = TRUE; }
function FOREST(int LOC) returns int r { r = FALSE; if ((LOC) >= 145 && (LOC) <= 166) r = TRUE; }

/*  THE FOLLOWING TWO FUNCTIONS WERE ADDED TO FIX A BUG (CLOCK1 DECREMENTED
 *  WHILE IN FOREST).  THEY SHOULD PROBABLY BE REPLACED BY USING ANOTHER
 *  "COND" BIT.  FOR NOW, HOWEVER, A QUICK FIX...  OUTSID(LOC) IS TRUE IF
 *  LOC IS OUTSIDE, INDEEP(LOC) IS TRUE IF LOC IS "DEEP" IN THE CAVE (HALL
 *  OF MISTS OR DEEPER).  NOTE SPECIAL KLUDGES FOR "FOOF" LOCS. */

function OUTSID(int LOC) returns int r { r = FALSE; if ((LOC) <= 8 || (int)FOREST(LOC) != FALSE || (LOC) == (int)global PLAC[SAPPH] || (LOC) == 180 || (LOC) == 182) r = TRUE; }
function INDEEP(int LOC) returns int r { r = FALSE; if ((LOC) >= 15 && (int)OUTSID(LOC) == FALSE && (LOC) != 179) r = TRUE; }

/*  DISCARD OBJECT.  "THROW" ALSO COMES HERE FOR MOST OBJECTS.  SPECIAL CASES FOR
 *  BIRD (MIGHT ATTACK SNAKE OR DRAGON) AND CAGE (MIGHT CONTAIN BIRD) AND VASE.
 *  DROP COINS AT VENDING MACHINE FOR EXTRA BATTERIES. */

function discard(int just_do_it)
returns int goValue
locals int lK, int lLOC, int lOBJ
{
	lLOC = global gLOC;
	lOBJ = global gOBJ;
	if(just_do_it == FALSE) {
		if((int)TOTING(ROD2) != FALSE && lOBJ == ROD && (int)TOTING(ROD) == FALSE) { lOBJ=ROD2; global gOBJ = lOBJ; }
		if((int)TOTING(lOBJ) == FALSE) { goValue = GOTO2011; goto return; }
		else if(!(lOBJ != BIRD || (int)HERE(SNAKE, lLOC) == FALSE)) {
			fRSPEAK(30);
			if(global CLOSED != FALSE) { goValue = GOTO19000; goto return; }
			fDSTROY(SNAKE);
		/*  SET PROP FOR USE BY TRAVEL OPTIONS */
			global PROP[SNAKE]=1;
		} else if(!(!((int)GSTONE(lOBJ) != FALSE && (int)AT(CAVITY, lLOC) != FALSE && (int)global PROP[CAVITY] != 0))) {
			fRSPEAK(218);
			global PROP[lOBJ]=1;
			global PROP[CAVITY]=0;
			if(!((int)HERE(RUG, lLOC) == FALSE || !((lOBJ == EMRALD && (int)global PROP[RUG] != 2) || (lOBJ == RUBY && (int)global PROP[RUG] == 2)))) {
				global SPK=219;
				if((int)TOTING(RUG) != FALSE)global SPK=220;
				if(lOBJ == RUBY)global SPK=221;
				fRSPEAK(global SPK);
				if(!(global SPK == 220)) {
					lK=2-(int)global PROP[RUG];
					global PROP[RUG]=lK;
					if(lK == 2) lK=(int)global PLAC[SAPPH];
					fMOVE(RUG+100,lK);
				}
			}
		} else if(!(lOBJ != COINS || (int)HERE(VEND, lLOC) == FALSE)) {
			fDSTROY(COINS);
			fDROP(BATTER,lLOC);
			fPSPEAK(BATTER,0);
			{ goValue = GOTO2012; goto return; }
		} else if(!(lOBJ != BIRD || (int)AT(DRAGON, lLOC) == FALSE || (int)global PROP[DRAGON] != 0)) {
			fRSPEAK(154);
			fDSTROY(BIRD);
			global PROP[BIRD]=0;
			{ goValue = GOTO2012; goto return; }
		} else if(!(lOBJ != BEAR || (int)AT(TROLL, lLOC) == FALSE)) {
			fRSPEAK(163);
			fMOVE(TROLL,0);
			fMOVE(TROLL+100,0);
			fMOVE(TROLL2,global PLAC[TROLL]);
			fMOVE(TROLL2+100,global FIXD[TROLL]);
			fJUGGLE(CHASM);
			global PROP[TROLL]=2;
		} else if(!(lOBJ == VASE && lLOC != (int)global PLAC[PILLOW])) {
			fRSPEAK(54);
		} else {
			global PROP[VASE]=2;
			if((int)AT(PILLOW, lLOC) != FALSE)global PROP[VASE]=0;
			fPSPEAK(VASE,(int)global PROP[VASE]+1);
			if((int)global PROP[VASE] != 0)global FIXED[VASE]= -1;
		}
	}

	lK=(int)LIQ(); global gK = lK;
	if(lK == lOBJ) { lOBJ=BOTTLE; global gOBJ = BOTTLE; }
	if(lOBJ == BOTTLE && lK != 0)global PLACE[lK]=0;
	if(lOBJ == CAGE && (int)global PROP[BIRD] == 1)fDROP(BIRD,lLOC);
	fDROP(lOBJ,lLOC);
	if(lOBJ != BIRD) { goValue = GOTO2012; goto return; }
	global PROP[BIRD]=0;
	if((int)FOREST(lLOC) != FALSE)global PROP[BIRD]=2;
	{ goValue = GOTO2012; goto return; }
return: ;
}

/*  FILL.  BOTTLE OR URN MUST BE EMPTY, AND LIQUID AVAILABLE.  (VASE IS NASTY.) */

function fill(int OBJ)
returns int goValue
locals int lK, int lLOC
{
	lLOC = global gLOC;
	if(OBJ != VASE) {
		if(OBJ == URN) {
			global SPK=213;
			if((int)global PROP[URN] != 0) { goValue = GOTO2011; goto return; }
			global SPK=144;
			lK=(int)LIQ(); global gK = lK;
			if(lK == 0 || (int)HERE(BOTTLE, lLOC) == FALSE) { goValue = GOTO2011; goto return; }
			global PLACE[lK]=0;
			global PROP[BOTTLE]=1;
			if(lK == OIL)global PROP[URN]=1;
			global SPK=211+(int)global PROP[URN];
			{ goValue = GOTO2011; goto return; }
		}
		if(OBJ != 0 && OBJ != BOTTLE) { goValue = GOTO2011; goto return; }
		if(OBJ == 0 && (int)HERE(BOTTLE, lLOC) == FALSE) { goValue = GOTO8000; goto return; }
		global SPK=107;
		if((int)LIQLOC(lLOC) == 0)global SPK=106;
		if((int)HERE(URN, lLOC) != FALSE && (int)global PROP[URN] != 0)global SPK=214;
		if((int)LIQ() != 0)global SPK=105;
		if(global SPK != 107) { goValue = GOTO2011; goto return; }
		global PROP[BOTTLE]=(((int)global COND[lLOC])%4)/2*2;
		lK=(int)LIQ(); global gK = lK;
		if((int)TOTING(BOTTLE) != FALSE)global PLACE[lK]= -1;
		if(lK == OIL)global SPK=108;
		{ goValue = GOTO2011; goto return; }
	} else {
		global SPK=29;
		if((int)LIQLOC(lLOC) == 0)global SPK=144;
		if((int)LIQLOC(lLOC) == 0 || (int)TOTING(VASE) == FALSE) { goValue = GOTO2011; goto return; }
		fRSPEAK(145);
		global PROP[VASE]=2;
		global FIXED[VASE]= -1;
		{ goValue = (int)discard(TRUE); goto return; }
	}
return: ;
}

/*  CARRY AN OBJECT.  SPECIAL CASES FOR BIRD AND CAGE (IF BIRD IN CAGE, CAN'T
 *  TAKE ONE WITHOUT THE OTHER).  LIQUIDS ALSO SPECIAL, SINCE THEY DEPEND ON
 *  STATUS OF BOTTLE.  ALSO VARIOUS SIDE EFFECTS, ETC. */

function carry()
returns int goValue
locals int lK, int lLOC, int lOBJ
{
	lK = global gK;
	lOBJ = global gOBJ;
	lLOC = global gLOC;
	if((int)TOTING(lOBJ) != FALSE) { goValue = GOTO2011; goto return; }
	global SPK=25;
	if(lOBJ == PLANT && (int)global PROP[PLANT] <= 0)global SPK=115;
	if(lOBJ == BEAR && (int)global PROP[BEAR] == 1)global SPK=169;
	if(lOBJ == CHAIN && (int)global PROP[BEAR] != 0)global SPK=170;
	if(lOBJ == URN)global SPK=215;
	if(lOBJ == CAVITY)global SPK=217;
	if(lOBJ == BLOOD)global SPK=239;
	if(lOBJ == RUG && (int)global PROP[RUG] == 2)global SPK=222;
	if(lOBJ == gSIGN)global SPK=196;
	if(lOBJ == MESSAG) {
		global SPK=190;
		fDSTROY(MESSAG);
	}
	if((int)global FIXED[lOBJ] != 0) { goValue = GOTO2011; goto return; }
	if(!(lOBJ != WATER && lOBJ != OIL)) {
		lK=lOBJ; global gK = lOBJ;
		lOBJ=BOTTLE; global gOBJ = BOTTLE;
		if(!((int)HERE(BOTTLE, lLOC) != FALSE && (int)LIQ() == lK)) {
			if((int)TOTING(BOTTLE) != FALSE && (int)global PROP[BOTTLE] == 1) { goValue = (int)fill(lOBJ); goto return; }
			if((int)global PROP[BOTTLE] != 1)global SPK=105;
			if((int)TOTING(BOTTLE) == FALSE)global SPK=104;
			{ goValue = GOTO2011; goto return; }
		}
	}
	global SPK=92;
	if(global HOLDNG >= 7) { goValue = GOTO2011; goto return; }
	if(!(lOBJ != BIRD || (int)global PROP[BIRD] == 1 || -1-(int)global PROP[BIRD] == 1)) {
		if((int)global PROP[BIRD] == 2) {
			global SPK=238;
			fDSTROY(BIRD);
			{ goValue = GOTO2011; goto return; }
		}
		if((int)TOTING(CAGE) == FALSE)global SPK=27;
		if((int)TOTING(ROD) != FALSE)global SPK=26;
		if(global SPK/2 == 13) { goValue = GOTO2011; goto return; }
		global PROP[BIRD]=1;
	}
	if((lOBJ == BIRD || lOBJ == CAGE) && ((int)global PROP[BIRD] == 1 || -1-(int)global PROP[BIRD] == 1))fCARRY(BIRD+CAGE-lOBJ,lLOC);
	fCARRY(lOBJ,lLOC);
	lK=(int)LIQ(); global gK = lK;
	if(lOBJ == BOTTLE && lK != 0)global PLACE[lK]= -1;
	if((int)GSTONE(lOBJ) == FALSE || (int)global PROP[lOBJ] == 0) { goValue = GOTO2009; goto return; }
	global PROP[lOBJ]=0;
	global PROP[CAVITY]=1;
	{ goValue = GOTO2009; goto return; }
return: ;
}

/*  ATTACK.  ASSUME TARGET IF UNAMBIGUOUS.  "THROW" ALSO LINKS HERE.  ATTACKABLE
 *  OBJECTS FALL INTO TWO CATEGORIES: ENEMIES (SNAKE, DWARF, ETC.)  AND OTHERS
 *  (BIRD, CLAM, MACHINE).  AMBIGUOUS IF 2 ENEMIES, OR NO ENEMIES BUT 2 OTHERS. */

function attack()
returns int goValue
locals int I, int lK, int lLOC, int lOBJ
{
	lLOC = global gLOC;
	lOBJ = global gOBJ;
	I=(int)fATDWRF(lLOC);
	if(lOBJ == 0) {
		if(I > 0) { lOBJ = DWARF; global gOBJ = DWARF; }
		if((int)HERE(SNAKE, lLOC) != FALSE) { lOBJ=lOBJ*100+SNAKE; global gOBJ = lOBJ; }
		if((int)AT(DRAGON, lLOC) != FALSE && (int)global PROP[DRAGON] == 0) { lOBJ=lOBJ*100+DRAGON; global gOBJ = lOBJ; }
		if((int)AT(TROLL, lLOC) != FALSE) { lOBJ=lOBJ*100+TROLL; global gOBJ = lOBJ; }
		if((int)AT(OGRE, lLOC) != FALSE) { lOBJ=lOBJ*100+OGRE; global gOBJ = lOBJ; }
		if((int)HERE(BEAR, lLOC) != FALSE && (int)global PROP[BEAR] == 0) { lOBJ=lOBJ*100+BEAR; global gOBJ = lOBJ; }
		if(lOBJ > 100) { goValue = GOTO8000; goto return; }
		if(lOBJ == 0) {
		/*  CAN'T ATTACK BIRD OR MACHINE BY THROWING AXE. */
			if((int)HERE(BIRD, lLOC) != FALSE && global VERB != THROW) { lOBJ=BIRD; global gOBJ = lOBJ; }
			if((int)HERE(VEND, lLOC) != FALSE && global VERB != THROW) { lOBJ=lOBJ*100+VEND; global gOBJ = lOBJ; }
		/*  CLAM AND OYSTER BOTH TREATED AS CLAM FOR INTRANSITIVE CASE; NO HARM DONE. */
			if((int)HERE(CLAM, lLOC) != FALSE || (int)HERE(OYSTER, lLOC) != FALSE) { lOBJ=100*lOBJ+CLAM; global gOBJ = lOBJ; }
			if(lOBJ > 100) { goValue = GOTO8000; goto return; }
		}
	}
	if(lOBJ == BIRD) {
		global SPK=137;
		if(global CLOSED != FALSE) { goValue = GOTO2011; goto return; }
		fDSTROY(BIRD);
		global PROP[BIRD]=0;
		global SPK=45;
	}
	if(lOBJ == VEND) {
		fPSPEAK(VEND,(int)global PROP[VEND]+2);
		global PROP[VEND]=3-(int)global PROP[VEND];
		 { goValue = GOTO2012; goto return; }
	}
	if(lOBJ == 0)global SPK=44;
	if(lOBJ == CLAM || lOBJ == OYSTER)global SPK=150;
	if(lOBJ == SNAKE)global SPK=46;
	if(lOBJ == DWARF)global SPK=49;
	if(lOBJ == DWARF && global CLOSED != FALSE) { goValue = GOTO19000; goto return; }
	if(lOBJ == DRAGON)global SPK=167;
	if(lOBJ == TROLL)global SPK=157;
	if(lOBJ == OGRE)global SPK=203;
	if(!(lOBJ == OGRE && I > 0)) {
		if(lOBJ == BEAR)global SPK=165+((int)global PROP[BEAR]+1)/2;
		if(lOBJ != DRAGON || (int)global PROP[DRAGON] != 0) { goValue = GOTO2011; goto return; }
	/*  FUN STUFF FOR DRAGON.  IF HE INSISTS ON ATTACKING IT, WIN!  SET PROP TO DEAD,
	 *  MOVE DRAGON TO CENTRAL LOC (STILL FIXED), MOVE RUG THERE (NOT FIXED), AND
	 *  MOVE HIM THERE, TOO.  THEN DO A NULL MOTION TO GET NEW DESCRIPTION. */
		fRSPEAK(49);
		global VERB=0;
		lOBJ=0; global gOBJ=0;
		fGETIN(&global WD1,&global WD1X,&global WD2,&global WD2X);
		if(global WD1 != (int)fMAKEWD(25) && global WD1 != (int)fMAKEWD(250519)) { goValue = GOTO2607; goto return; }
		fPSPEAK(DRAGON,3);
		global PROP[DRAGON]=1;
		global PROP[RUG]=0;
		lK=((int)global PLAC[DRAGON]+(int)global FIXD[DRAGON])/2;
		fMOVE(DRAGON+100,-1);
		fMOVE(RUG+100,0);
		fMOVE(DRAGON,lK);
		fMOVE(RUG,lK);
		fDROP(BLOOD,lK);
		for (lOBJ=1 to 100+1) {
			if((int)global PLACE[lOBJ] == (int)global PLAC[DRAGON] || (int)global PLACE[lOBJ] == (int)global FIXD[DRAGON])fMOVE(lOBJ,lK);
		}
		global gOBJ = lOBJ;
		global gLOC=lK;
		global gK = NUL;
		{ goValue = GOTO8; goto return; }
	}
	
	fRSPEAK(global SPK);
	fRSPEAK(6);
	fDSTROY(OGRE);
	lK=0;
	for (I=1 to 5+1) {
		if((int)global DLOC[I] != lLOC) goto continue1;
		lK=lK+1;
		global DLOC[I]=61;
		global DSEEN[I]=FALSE;
	continue1: ;
	} /* end loop */
	global gK = lK;
	global SPK=global SPK+1+1/lK;;
	{ goValue = GOTO2011; goto return; }
return: ;
}


/*  FEED.  IF BIRD, NO SEED.  SNAKE, DRAGON, TROLL: QUIP.  IF DWARF, MAKE HIM
 *  MAD.  BEAR, SPECIAL. */

function feed(int OBJ)
returns int goValue
locals int lLOC
{
	lLOC = global gLOC;
	if(OBJ == BIRD) {
		global SPK=100;
		{ goValue = GOTO2011; goto return; }
	}

	if(!(OBJ != SNAKE && OBJ != DRAGON && OBJ != TROLL)) {
		global SPK=102;
		if(OBJ == DRAGON && (int)global PROP[DRAGON] != 0)global SPK=110;
		if(OBJ == TROLL)global SPK=182;
		if(OBJ != SNAKE || global CLOSED != FALSE || (int)HERE(BIRD, lLOC) == FALSE) { goValue = GOTO2011; goto return; }
		global SPK=101;
		fDSTROY(BIRD);
		global PROP[BIRD]=0;
		{ goValue = GOTO2011; goto return; }
	}

	if(OBJ == DWARF) {
		if((int)HERE(FOOD, lLOC) == FALSE) { goValue = GOTO2011; goto return; }
		global DFLAG=global DFLAG+2;
		global SPK=103;
		{ goValue = GOTO2011; goto return; }
	}

	if(OBJ == BEAR) {
		if((int)global PROP[BEAR] == 0)global SPK=102;
		if((int)global PROP[BEAR] == 3)global SPK=110;
		if((int)HERE(FOOD, lLOC) == FALSE) { goValue = GOTO2011; goto return; }
		fDSTROY(FOOD);
		global PROP[BEAR]=1;
		global FIXED[AXE]=0;
		global PROP[AXE]=0;
