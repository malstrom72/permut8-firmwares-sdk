/*
	Impala source for a Permut8 demonstration firmware patch.
	
	Impala is a high-level assembler for the GAZL virtual machine. Syntax is similar to C. Language constructs map
	nearly 1 to 1 with GAZL instructions.

	There are two different kinds of firmware patches for Permut8. First, there are "mod" patches which just replace
	one or more of the built-in operators. Their inputs and outputs are memory read positions for left and right
	channels. Second, there are "full" patches which replaces the code for the entire virtual DSP, taking 12-bit
	audio signals as input and output.
	
	"Full patches" implement `process()`. "Mod patches" implement `operate1()` and / or `operate2()`.
*/

/* ------ Firmware API ------ */

const int PRAWN_FIRMWARE_PATCH_FORMAT = 2	// Should be 2 for a valid Permut8 version 1.1 firmware patch
const int FALSE = 0
const int TRUE = 1

/*
	These text lines will be used in exchange of the standard Permut8 screenprint. They all follow a fixed character
	position format. First 3 characters is the instruction mnemonic, then a space, then 3 characters per switch for the
	first group, space again, and then the same for the second group. A zero length line means no tape on that row. The
	pointers do not need to point to constant data, but after the call to `init()` the data shouldn't change.
*/
readonly array panelTextRows[8] = {
	" ",
	" ",
	"     _____ THRESHOLD ______   _______ BANDS ________",
	"           00 -> FF           low      mid      high",
	" ",
	" ",
	"     ________ DECAY _______   ______ PARTIALS ______",
	"            00 -> FF         x1 x2 x3 x4 x5 x6 x7 x8"
}

extern native abort								// `abort()` : Kills the "firmware" and restores normal operation.
extern native trace								// `trace(pointer string)` : Traces a null-terminated string to Prawn console and standard output (Mac) or DebugView (Windows).
extern native yield								// `yield()` : As a more effective alternative to returning from the `process()` function you may call `yield()`. It will return processing to the Permut8 audio engine and when the next sample needs to be processed, `yield()` will return back to your GAZL code.
extern native write								// `write(int offset, int frameCount, pointer values)` : Writes a variable number of 12-bit sample frames to the delay-line memory. Reading and writing is automatically wrapped to delay-line size. Values are written and read in interleaved stereo format.
extern native read								// `read(int offset, int frameCount, pointer values)` : Reads a variable number of 12-bit sample frames from the delay-line memory. Reading and writing is automatically wrapped to delay-line size. Values are written and read in interleaved stereo format.

const int DEBUG									// Defined by host. If non-zero, asserts and tracing are enabled. In Permut8 asserts and traces are enabled when loading the firmware from the console and disabled when the firmware is loaded with a .p8bank file.

const int OPERATOR_1_NOP						// Externally defined constants for `global params[OPERATOR_1_PARAM_INDEX]`
const int OPERATOR_1_AND
const int OPERATOR_1_MUL
const int OPERATOR_1_OSC
const int OPERATOR_1_RND
const int OPERATOR_1_COUNT

const int OPERATOR_2_NOP						// Externally defined constants for `global params[OPERATOR_2_PARAM_INDEX]`
const int OPERATOR_2_OR
const int OPERATOR_2_XOR
const int OPERATOR_2_MSK
const int OPERATOR_2_SUB
const int OPERATOR_2_COUNT

const int SWITCHES_SYNC_MASK					// Externally defined bit masks for `global params[SWITCHES_PARAM_INDEX]` (e.g. `(global params[SWITCHES_PARAM_INDEX] & SWITCHES_SYNC_MASK) != 0` to test if sync switch is on)
const int SWITCHES_TRIPLET_MASK
const int SWITCHES_DOTTED_MASK
const int SWITCHES_WRITE_PROTECT_MASK
const int SWITCHES_REVERSE_MASK

const int CLOCK_FREQ_PARAM_INDEX				// Clock frequency / sample rate rounded to an integer Hz.
const int SWITCHES_PARAM_INDEX					// Bit mask, see constants above.
const int OPERATOR_1_PARAM_INDEX				// Operator 1 is an integer 0 to 4 (see definitions above).
const int OPERAND_1_HIGH_PARAM_INDEX			// Operand 1 high is an integer 0 to 255
const int OPERAND_1_LOW_PARAM_INDEX				// Operand 1 low is an integer 0 to 255
const int OPERATOR_2_PARAM_INDEX				// Operator 2 is an integer 0 to 4 (see definitions above).
const int OPERAND_2_HIGH_PARAM_INDEX			// Operand 2 high is an integer 0 to 255
const int OPERAND_2_LOW_PARAM_INDEX				// Operand 2 low is an integer 0 to 255
const int PARAM_COUNT							// Param count can be changed in the future if more parameters are published to GAZL.

const int POSITION_INT_BITS						// Number of integer bits of position (should be 16) (for "mod patches")
const int POSITION_FRACT_BITS					// Number of fraction bits of position (should be 4) (for "mod patches")

global int clock								// `clock` increments between every `process()` (or decrements in reverse mode) and has a cycle size of 16-bit (from 0 to 65536). If tempo sync is enabled, `clock` will be the absolute position within the chosen time division. (Optional.)
global array params[PARAM_COUNT]				// `params` (all ints) are updated by Permut8 whenever any exposed parameter is updated. If there is a defined `update()` function it is called on this occasion. (Optional.)
global array displayLEDs[4]						// Four 8-bit masks for the visualizer LEDs under the operand switches. Order: operand 1 high & low, operand 2 high & low.
global int instance								// A session unique number for the plug-in. Always valid and won't change after init. You can use this to initialize random seeds. (Optional.)
readonly int clockFreqLimit = 44100				// Defines maximum clock frequency limit. Permut8 normally runs as fast as up to 352.8 kHz but often you want a speed limit for custom firwmares since GAZL is much more CPU intensive than native DSP code. Permut8 only reads this global once after calling `init()`. (Optional and 0 means no limit.)
// global array config[100]						// Declare this array to allow the end user to enter a configuration string for the firmware. This is either done by clicking the "firmware tape" on the main GUI or entering a string after the firmware name when patching via the console. This array will be filled before `init()` is called. (Optional. Can be any number of elements.)
// global pointer configText					// When clicking the "firmware tape" on the main GUI, the dialog can display a custom description text for the configuration parameter. This global string pointer defines the text. (Optional.)
global array signal[2]							// For "full patches" only: left and right 12-bit samples to be processed (from -2047 to 2047). Replace with output.
// global array positions[2]					// For "mod patches" only: Left and right memory positions to be processed by `operate1()` and `operate2()`. Positions are expressed in fixed point notation with 4 bits fraction for linear interpolation of memory data. In other words, the full range is 0x00000 to 0xFFFFF. Replace `positions` with output. Values outside of range will be wrapped to range. (Required if `operate1()` or `operate2()` is defined.)

/* ------ Standard Tables ------ */

/* ------ Utilities ------ */

// impala does not support file inclusion or linking of separate compilation units. Therefore we have this snippets
// file with useful utility functions that you can simply copy & paste. (Another solution for sharing common code is
// otherwise to concat different .gazl files.)

/* ------ Strings and tracing ------ */

function error(pointer s)
{
	trace(s);
	abort();
}

/* ------ Math ------ */

const float LOG2 = 0.69314718055994530942
const float LOG2R = 1.44269504088896340736
const float LOG10R = 0.43429448190325182765
const float E = 2.71828182845904523536
const float HALF_PI = 1.57079632679489661923
const float PI = 3.14159265358979323846
const float TWICE_PI = PI * 2.0
const float COS_EPSILON = 1.0e-6

function trunc(float x)
returns float y
{
	if (x < 0.0) y = -floor(-x);
	else y = floor(x);
}

function fmod(float x, float y)
returns float z
{
	if (y == 0.0) error("Division by zero");
	else z = x - (float) trunc(x / y) * y;
}

/*
	Derived from:
	
				 oo
				=====      n
				\      (-1)   2 n
		cos x =  >    ------ x
				/     (2 n)!
				=====
				n = 0
*/
function cos(float x)
returns	float y
locals	float a
		, float n
		, float m
		, float t
{
	m = (float) fmod(x, TWICE_PI);
	m = -m * m;
	a = 1.0;
	n = 1.0;
	y = 1.0;
	do {
		t = y;
		a = a * m / (n * n + n);
		y = y + a;
		n = n + 2.0;
	} while (y != t);
	if (abs(y) < COS_EPSILON) y = 0.0;
}

function sin(float x)
returns float y
{
	y = (float) cos(x - HALF_PI);
}

function sqrt(float x)
returns float y
locals	float t
{
	if (x < 0.0) error("Domain error");
	y = x;
	t = 0.0;
	while (y != t) {
		t = y;
		y = 0.5 * (y + x / y);
	}
}


/* ------ Firmware constants ------ */

const int FFT_POWER = 12;
const int FFT_SIZE = (1 << FFT_POWER);
const int FFT_SIZE_2 = FFT_SIZE / 2;
const int PROCESS_SPREAD_FACTOR = 5;
const float IFFT_SCALE = (2.0 / itof(FFT_SIZE));
const float ANTI_DENORMAL_CONSTANT = 1.0e-10;
const int PERFORM_RESET = 0;
const int ANALYSIS_WINDOW = PERFORM_RESET + 1;
const int ANALYSIS_REINDEX = ANALYSIS_WINDOW + 1;
const int ANALYSIS_FFT_2 = ANALYSIS_REINDEX + 1;
const int ANALYSIS_UNTANGLE = ANALYSIS_FFT_2 + FFT_POWER - 1;
const int PROCESS_FIND_MAX = ANALYSIS_UNTANGLE + 1;
const int PROCESS_FEEDBACK = PROCESS_FIND_MAX + 1;
const int PROCESS_PARTIAL_1 = PROCESS_FEEDBACK + 1;
const int SYNTHESIS_SMEAR_LEFT = PROCESS_PARTIAL_1 + 8;
const int SYNTHESIS_UNTANGLE_LEFT = SYNTHESIS_SMEAR_LEFT + 1;
const int SYNTHESIS_REINDEX_LEFT = SYNTHESIS_UNTANGLE_LEFT + 1;
const int SYNTHESIS_FFT_LEFT_2 = SYNTHESIS_REINDEX_LEFT + 1;
const int SYNTHESIS_MIX_LEFT = SYNTHESIS_FFT_LEFT_2 + FFT_POWER - 1;
const int SYNTHESIS_SMEAR_RIGHT = SYNTHESIS_MIX_LEFT + 1;
const int SYNTHESIS_UNTANGLE_RIGHT = SYNTHESIS_SMEAR_RIGHT + 1;
const int SYNTHESIS_REINDEX_RIGHT = SYNTHESIS_UNTANGLE_RIGHT + 1;
const int SYNTHESIS_FFT_RIGHT_2 = SYNTHESIS_REINDEX_RIGHT + 1;
const int SYNTHESIS_MIX_RIGHT = SYNTHESIS_FFT_RIGHT_2 + FFT_POWER - 1;
const int PROCESS_STEPS = SYNTHESIS_MIX_RIGHT + 1;
const int THRESHOLD_PARAM = OPERAND_1_HIGH_PARAM_INDEX
const int BAND_PARAM = OPERAND_1_LOW_PARAM_INDEX;
const int DECAY_PARAM = OPERAND_2_HIGH_PARAM_INDEX
const int PARTIALS_PARAM = OPERAND_2_LOW_PARAM_INDEX;
readonly int updateMask =						// A bit-mask that can be defined to filter out certain parameters from triggering update(). E.g. use ~(1 << CLOCK_FREQ_PARAM_INDEX) to prevent calls to update() when clock frequency changes.
		(1 << THRESHOLD_PARAM) | (1 << DECAY_PARAM);

/* ------ Firmware globals ------ */

global int doReset = TRUE
global array window[FFT_SIZE_2];
global array cRotateRe[256];
global array cRotateIm[256];
global array partialGains[8];
global array fftWPRe[FFT_POWER - 1];
global array fftWPIm[FFT_POWER - 1];
global float threshold;
global float decayConstant;
global float outputGain;
global array randomArray[FFT_SIZE_2];
global array untangleParams[2];

/* ------ Firmware functions ------ */

function fftReIndex(int n, pointer data)
locals int nn, int j, int i, int m, float t
{
	// reverse-binary reindexing
	nn = n >> 1;
	j = 0;
	i = 0; while (i < n) {
	    if (j > i) {
	        t = (float) data[j]; (float) data[j] = (float) data[i]; (float) data[i] = t;
	        t = (float) data[j + 1]; (float) data[j + 1] = (float) data[i + 1]; (float) data[i + 1] = t;
	    };
	    m = nn;
	    while (m >= 2 && j >= m) {
	        j = j - m;
	        m = m >> 1;
	    };
	    j = j + m;
	    i = i + 2;
	};
}

// 0 <= fftStep < (fft power of 2) - 1
function fftPass4(int n, pointer data, int fftStep)
locals int mmax, int m, int i, int i1, int i2, int i3, int j, int j1, int j2, int j3
		, float wTemp, float wpRe, float wpIm, float wRe, float wIm
		, float w2Re, float w2Im, float w3Re, float w3Im
		, float d0Re, float d0Im, float d1Re, float d1Im, float d2Re, float d2Im, float d3Re, float d3Im
{
	mmax = 2 << fftStep;
	wpRe = (float) global fftWPRe[fftStep];
	wpIm = (float) global fftWPIm[fftStep];
    wRe = 1.0;
    wIm = 0.0;
    m = 0;
	while (m < mmax) {
	    i = m;
	    while (i < n) {
	        i1 = i + mmax;
	        j1 = i1 + 1;
	        d1Re = ((float) data[i1] * w2Re - (float) data[j1] * w2Im);
	        d1Im = ((float) data[j1] * w2Re + (float) data[i1] * w2Im);

	        i2 = i1 + mmax;
	        j2 = i2 + 1;
	        d2Re = ((float) data[i2] * wRe - (float) data[j2] * wIm);
	        d2Im = ((float) data[j2] * wRe + (float) data[i2] * wIm);

	        i3 = i2 + mmax;
	        j3 = i3 + 1;
	        d3Re = ((float) data[i3] * w3Re - (float) data[j3] * w3Im);
	        d3Im = ((float) data[j3] * w3Re + (float) data[i3] * w3Im);

	        d0Re = (float) data[i];
	        d0Im = (float) data[i + 1];
	        data[i3] = (d0Re - d2Im) - (d1Re - d3Im);
	        data[j3] = (d0Im + d2Re) - (d1Im + d3Re);
	        data[i2] = (d0Re - d2Re) + (d1Re - d3Re);
	        data[j2] = (d0Im - d2Im) + (d1Im - d3Im);
	        data[i1] = (d0Re + d2Im) - (d1Re + d3Im);
	        data[j1] = (d0Im - d2Re) - (d1Im - d3Re);
	        data[i] = (d0Re + d2Re) + (d1Re + d3Re);
	        data[i + 1] = (d0Im + d2Im) + (d1Im + d3Im);

	        i = i + mmax * 4;
	    }
	    wTemp = wRe;
	    wRe = wRe + wRe * wpRe - wIm * wpIm;
	    wIm = wIm + wIm * wpRe + wTemp * wpIm;

	    w2Re = (wRe * wRe - wIm * wIm);
	    w2Im = (wIm * wRe + wRe * wIm);
	    w3Re = (w2Re * wRe - w2Im * wIm);
	    w3Im = (w2Im * wRe + w2Re * wIm);

	    m = m + 2;
	}
}

// 0 <= fftStep < (fft power of 2) - 1
function fftPass0(int n, pointer data)
locals int i, int i1, int j, int j1, int m
		, float dj0, float dj1, float di0, float di1
{
    m = 0;
    i = m;
    while (i < n) {
        j = i + 2;
        i1 = i + 1;
        j1 = j + 1;
        dj0 = (float) data[j];
        dj1 = (float) data[j1];
        di0 = (float) data[i];
        di1 = (float) data[i1];
        data[j] = (float) di0 - dj0;
        data[j1] = (float) di1 - dj1;
        data[i] = (float) di0 + dj0;
        data[i1] = (float) di1 + dj1;
        i = j + 2;
    }
}

// 0 <= fftStep < (fft power of 2) - 1
function fftPass(int n, pointer data, int fftStep)
locals int mmax, int i, int i1, int j, int j1, int m
		, float wTemp, float wpRe, float wpIm, float wRe, float wIm, float tempRe, float tempIm
		, float dj0, float dj1, float di0, float di1
{
	mmax = 2 << fftStep;
	wpRe = (float) global fftWPRe[fftStep];
	wpIm = (float) global fftWPIm[fftStep];
    wRe = 1.0;
    wIm = 0.0;
    m = 0;
    do {
        i = m;
        while (i < n) {
            j = i + mmax;
            i1 = i + 1;
            j1 = j + 1;
            dj0 = (float) data[j];
            dj1 = (float) data[j1];
            di0 = (float) data[i];
            di1 = (float) data[i1];
            tempRe = wRe * (float) dj0 - wIm * (float) dj1;
            tempIm = wRe * (float) dj1 + wIm * (float) dj0;
            data[j] = (float) di0 - tempRe;
            data[j1] = (float) di1 - tempIm;
            data[i] = (float) di0 + tempRe;
            data[i1] = (float) di1 + tempIm;
            i = j + mmax;
        }
        wTemp = wRe;
        wRe = wRe + (wRe * wpRe - wIm * wpIm);
        wIm = wIm + (wIm * wpRe + wTemp * wpIm);
        m = m + 2;
    } while (m < mmax);
}

// 2 params
function fftUntangleParams(int n, pointer params)
locals float wpRe, float wpIm
{
	wpRe = (float) sqrt(2.0) * (float) sin(2.0 * PI * 0.5 / itof(n)); // 1-cos = improved precision with low rates compared to using cos
	wpRe = wpRe * wpRe;
	wpIm = (float) sin(2.0 * PI / itof(n));
	params[0] = wpRe;
	params[1] = wpIm;
}

function fftUntangle(int n, pointer data, pointer params)
locals int indexA, int indexB, int i
		, float r0, float i0, float wRe, float wIm, float wpRe, float wpIm, float nwr, float nwy, float r1, float i1
		, float r0r1, float i0i1, float i0i1wr, float i0i1wi, float r1r0wr, float r0r1wi, float re0, float im0
		, float re1, float im1
{
	r0 = (float) data[0];
	i0 = (float) data[1];
	data[0] = (r0 + i0);
	data[1] = (r0 - i0);

	wRe = 1.0;
	wIm = 0.0;
	wpRe = (float) params[0];
	wpIm = (float) params[1];
	indexA = 2;
	indexB = n - 2;
	for (i = 1 to n / 4) {                                                                                                                                
		nwr = wRe - wRe * wpRe - wIm * wpIm;
		nwy = wRe * wpIm + wIm - wIm * wpRe;
		wRe = nwr;
		wIm = nwy;

		r0 = (float) data[indexA];
		i0 = (float) data[indexA + 1];
		r1 = (float) data[indexB];
		i1 = (float) data[indexB + 1];

		r0r1 = r0 + r1;
		i0i1 = i0 - i1;
		
		i0i1wr = (i0 + i1) * wRe;
		i0i1wi = (i0 + i1) * wIm;
		r1r0wr = (r1 - r0) * wRe;
		r0r1wi = (r0 - r1) * wIm;

		re0 = 0.5 * (i0i1wr - r0r1wi + r0r1);
		im0 = 0.5 * (r1r0wr - i0i1wi + i0i1);
		re1 = 0.5 * (r0r1wi - i0i1wr + r0r1);
		im1 = 0.5 * (r1r0wr - i0i1wi - i0i1);

		data[indexA] = re0;
		data[indexA + 1] = im0;
		data[indexB] = re1;
		data[indexB + 1] = im1;

		indexA = indexA + 2;
		indexB = indexB - 2;
	}
}

function mixOutput(pointer fftBuffer, pointer mixBuffer, int mixBufferOffset, int channel)
locals	int i, int i2
{
	i2 = mixBufferOffset + channel;
	for (i = 0 to FFT_SIZE_2) {
		mixBuffer[i2] = (int) mixBuffer[i2] + ftoi((float) fftBuffer[i] * (float) global window[i] * 2048.0);
		i2 = i2 + 2;
	}
	i2 = FFT_SIZE - mixBufferOffset + channel;
	for (i = FFT_SIZE_2 to FFT_SIZE) {
		mixBuffer[i2] = ftoi((float) fftBuffer[i] * (float) global window[FFT_SIZE - 1 - i] * 2048.0);
		i2 = i2 + 2;
	}
}

/*
	(Optional.)

	`init()` is called once right after the GAZL is assembled.
*/
function init()
locals	int i, float theta, float wTemp, int prng
{
	trace("init");

	for (i = 0 to FFT_SIZE_2) {
		global window[i] = (float) sin(PI / itof(FFT_SIZE) * itof(i));
	}

	for (i = 0 to 256) {
		theta = 2.0 * PI / 256.0 * itof(i);
		global cRotateRe[i] = (float) cos(theta);
		global cRotateIm[i] = (float) sin(theta);
	}

	for (i = 0 to 8) {
		global partialGains[i] = IFFT_SCALE / (float) sqrt(itof(i + 1));
	}

	for (i = 0 to FFT_POWER - 1) {
	    theta = -(2.0 * PI / itof(2 << i));
	    wTemp = (float) sin(0.5 * theta);
	    global fftWPRe[i] = -2.0 * wTemp * wTemp;
	    global fftWPIm[i] = (float) sin(theta);
	}
	prng = 2463534242 ^ (global instance << 13);
	for (i = 1 to FFT_SIZE_2) {
		prng = prng ^ (prng << 13);
		prng = prng ^ (prng >>> 17);
		prng = prng ^ (prng << 5);
		global randomArray[i] = prng & 255;
	}

	fftUntangleParams(FFT_SIZE, global untangleParams);
}

/*
	(Optional.)

	`reset()` is called whenever the user flips the "RESET" switch and when the host requests a plug-in reset. Will also
	be called once after init() and the first call to update().
*/
function reset()
{
	trace("reset");
	global doReset = TRUE;
}

/*
	(Optional.)

	`update()` is called whenever one or more of `params` are updated (usually not more frequent than every 136 or 137
	sample). It is also called once initially (before reset()). The global 'updateMask' can define a filter to prevent
	calls to `update()` when certain parameters changes.
*/
function update()
locals	float f
{
	trace("update");
	f = itof((int) global params[THRESHOLD_PARAM]) * (1.0 / 255.0);
	f = f * f * f;
	global threshold = f;

	f = 1.0 - itof((int) global params[DECAY_PARAM]) * (1.0 / 255.0);
	global decayConstant = 1.0 - (f * f * f);

	global outputGain = (float) sqrt((float) sqrt(1.0 - global decayConstant));
}

/*
	`process()` is the main processing function for "full patches". Process left and right sample in `signal` global
	array.
	
	Because of the single-sample feedback loop in Permut8, this API is designed to process one sample frame at a time,
	otherwise some cpu could have been saved by processing a batch of frames. As a more effective alternative to
	returning from the `process()` function you may call `yield()`. It will return processing to the Permut8 audio
	engine and when the next sample needs to be processed, `yield()` will return back to your GAZL code.
	
	Performance gain is also possible by implementing your own batch processing with buffering, but that will of course
	introduce additional (uncompensated) latency.
	
	Globals are slow in GAZL so if you use a lot of global data, use the "copy" feature in Impala to efficiently load it
	into (fast) local data. E.g. `copy (PARAM_COUNT from global params to params)`.
*/

function process()
locals	array fftBuffer[FFT_SIZE], array inputBuffer[FFT_SIZE], int clock, int i, int i2, int processStep, float useThreshold,
		int bandBits, int nextBandBit, float re, float im, float power, array feedbackRe[FFT_SIZE_2], array feedbackIm[FFT_SIZE_2],
		float k, int partial, int partialBase1, int partialBase1Div2, float g, float cMulARe, float cMulAIm, float cMulBRe, float cMulBIm,
		float cMulRe, float cMulIm, int rotateIndex, int x, int y, int t, int prng,
		array mixBuffer[FFT_SIZE * 2], int mixBufferOffset, int myInstance
{
	global doReset = TRUE;
	t = global instance;
	myInstance = 0;
	for (i = 0 to PROCESS_SPREAD_FACTOR) {
		myInstance = (myInstance << 1) | (t & 1);
		t = t >> 1;
	}
	prng = 2463534242 ^ (myInstance << 13);
	for (i = 0 to FFT_SIZE) {
		inputBuffer[i] = 0.0;
	}
	mixBufferOffset = 0;
	processStep = PROCESS_STEPS;

	loop {
		clock = global clock;
		if ((clock & ((1 << PROCESS_SPREAD_FACTOR) - 1)) == myInstance) {
			processStep = processStep + 1;
			if ((clock & (FFT_SIZE_2 - 1)) == myInstance) {
				processStep = PERFORM_RESET;
			}
			switch (processStep == 0 to PROCESS_STEPS) {
				case PERFORM_RESET: {
					if (global doReset != FALSE) {
						global doReset = FALSE;
						for (i = 0 to FFT_SIZE_2) {
							feedbackIm[i] = 0.0;
							feedbackRe[i] = 0.0;
						}
						for (i = 0 to FFT_SIZE) {
							mixBuffer[i] = 0;
						}
						mixBufferOffset = 0;
					}
				}
				
				case ANALYSIS_WINDOW: {
					for (i = 0 to FFT_SIZE_2) {
						fftBuffer[i] = (float) inputBuffer[(clock - FFT_SIZE + i) & (FFT_SIZE - 1)] * (float) global window[i];
					}
					for (i = FFT_SIZE_2 to FFT_SIZE) {
						fftBuffer[i] = (float) inputBuffer[(clock - FFT_SIZE + i) & (FFT_SIZE - 1)] * (float) global window[FFT_SIZE - 1 - i];
					}
				}
				
				case ANALYSIS_REINDEX, SYNTHESIS_REINDEX_LEFT, SYNTHESIS_REINDEX_RIGHT: {
					fftReIndex(FFT_SIZE, fftBuffer);
				}
				
				case ANALYSIS_FFT_2: {
					fftPass0(FFT_SIZE, fftBuffer);
				}
				case ANALYSIS_FFT_2 + 1, ANALYSIS_FFT_2 + 2, ANALYSIS_FFT_2 + 3
						, ANALYSIS_FFT_2 + 4, ANALYSIS_FFT_2 + 5, ANALYSIS_FFT_2 + 6, ANALYSIS_FFT_2 + 7
						, ANALYSIS_FFT_2 + 8, ANALYSIS_FFT_2 + 9, ANALYSIS_FFT_2 + 10: {
					fftPass(FFT_SIZE, fftBuffer, processStep - ANALYSIS_FFT_2);
				}
				
				case ANALYSIS_UNTANGLE, SYNTHESIS_UNTANGLE_LEFT, SYNTHESIS_UNTANGLE_RIGHT: {
					fftUntangle(FFT_SIZE, fftBuffer, global untangleParams);
				}

				case PROCESS_FIND_MAX: {
					useThreshold = 0.0;
					bandBits = (int) global params[BAND_PARAM];
					nextBandBit = 1 << (FFT_POWER - 8);
					for (i = 1 to FFT_SIZE_2) {
						if (i == nextBandBit) {
							nextBandBit = nextBandBit << 1;
							bandBits = bandBits << 1;
						}
						i2 = i * 2;
						if ((bandBits & (1 << 7)) == 0) {
							fftBuffer[i2] = 0.0;
							fftBuffer[i2 + 1] = 0.0;
						} else {
							re = (float) fftBuffer[i2];
							im = (float) fftBuffer[i2 + 1];
							power = re * re + im * im;
							if (power > useThreshold) {
								useThreshold = power;
							}
						}
					}
					useThreshold = useThreshold * global threshold;
				}

				case PROCESS_FEEDBACK: {
					k = global decayConstant;
					for (i = 1 to FFT_SIZE_2) {
						feedbackRe[i] = (float) feedbackRe[i] * k + ANTI_DENORMAL_CONSTANT;
						feedbackIm[i] = (float) feedbackIm[i] * k + ANTI_DENORMAL_CONSTANT;
						if (i > 256 && (i & 15) == 0) {	// roll-off for more natural reverb decay
							k = k * (1.0 - 1.0 / 256.0);
						}

						i2 = i * 2;
						re = (float) fftBuffer[i2];
						im = (float) fftBuffer[i2 + 1];
						if (re * re + im * im < useThreshold) {
							fftBuffer[i2] = 0.0;
							fftBuffer[i2 + 1] = 0.0;
						}
					}
				}

				case PROCESS_PARTIAL_1, PROCESS_PARTIAL_1 + 1, PROCESS_PARTIAL_1 + 2, PROCESS_PARTIAL_1 + 3
						, PROCESS_PARTIAL_1 + 4, PROCESS_PARTIAL_1 + 5, PROCESS_PARTIAL_1 + 6, PROCESS_PARTIAL_1 + 7:  {
					partial = processStep - PROCESS_PARTIAL_1;
					if (((int) global params[PARTIALS_PARAM] & (128 >>> partial)) != 0) {
						g = global outputGain * (float) global partialGains[partial];
						partialBase1 = (partial + 1);
						partialBase1Div2 = (partialBase1 / 2);
						for (i = 1 to FFT_SIZE_2) {
							i2 = (i + partialBase1Div2) / partialBase1 * 2;
							feedbackRe[i] = (float) feedbackRe[i] + (float) fftBuffer[i2] * g;
							feedbackIm[i] = (float) feedbackIm[i] + (float) fftBuffer[i2 + 1] * g;
						}
					}
				}

				case SYNTHESIS_SMEAR_LEFT, SYNTHESIS_SMEAR_RIGHT: {
					for (i = 1 to FFT_SIZE_2) {
						rotateIndex = (int) global randomArray[(prng + i) & (FFT_SIZE_2 - 1)];

						cMulARe = (float) global cRotateRe[rotateIndex];
						cMulAIm = (float) global cRotateIm[rotateIndex];
						cMulBRe = (float) feedbackRe[i];
						cMulBIm = (float) feedbackIm[i];
						cMulRe = (cMulARe * cMulBRe - cMulAIm * cMulBIm);
						cMulIm = (cMulAIm * cMulBRe + cMulARe * cMulBIm);
						feedbackRe[i] = cMulRe;
						feedbackIm[i] = cMulIm;

						i2 = (FFT_SIZE_2 - i) * 2;	// part of the inverse fft reordering (for using the same untangle function as forward)
						fftBuffer[i2] = cMulRe;
						fftBuffer[i2 + 1] = cMulIm;
					}
					fftBuffer[0] = 0.0;
					fftBuffer[1] = 0.0;
					prng = prng ^ (prng << 13);
					prng = prng ^ (prng >>> 17);
					prng = prng ^ (prng << 5);
				}

				case SYNTHESIS_FFT_LEFT_2: {
					fftPass0(FFT_SIZE, fftBuffer);
				}

				case SYNTHESIS_FFT_LEFT_2 + 1, SYNTHESIS_FFT_LEFT_2 + 2, SYNTHESIS_FFT_LEFT_2 + 3
						, SYNTHESIS_FFT_LEFT_2 + 4, SYNTHESIS_FFT_LEFT_2 + 5, SYNTHESIS_FFT_LEFT_2 + 6, SYNTHESIS_FFT_LEFT_2 + 7
						, SYNTHESIS_FFT_LEFT_2 + 8, SYNTHESIS_FFT_LEFT_2 + 9, SYNTHESIS_FFT_LEFT_2 + 10: {
					fftPass(FFT_SIZE, fftBuffer, processStep - SYNTHESIS_FFT_LEFT_2);
				}

				case SYNTHESIS_FFT_RIGHT_2: {
					fftPass0(FFT_SIZE, fftBuffer);
				}

				case SYNTHESIS_FFT_RIGHT_2 + 1, SYNTHESIS_FFT_RIGHT_2 + 2, SYNTHESIS_FFT_RIGHT_2 + 3
						, SYNTHESIS_FFT_RIGHT_2 + 4, SYNTHESIS_FFT_RIGHT_2 + 5, SYNTHESIS_FFT_RIGHT_2 + 6, SYNTHESIS_FFT_RIGHT_2 + 7
						, SYNTHESIS_FFT_RIGHT_2 + 8, SYNTHESIS_FFT_RIGHT_2 + 9, SYNTHESIS_FFT_RIGHT_2 + 10: {
					fftPass(FFT_SIZE, fftBuffer, processStep - SYNTHESIS_FFT_RIGHT_2);
				}

				case SYNTHESIS_MIX_LEFT: {
					mixOutput(fftBuffer, mixBuffer, mixBufferOffset, 0);
				}

				case SYNTHESIS_MIX_RIGHT: {
					mixOutput(fftBuffer, mixBuffer, mixBufferOffset, 1);
					write((clock & ~(FFT_SIZE_2 - 1)) + (PROCESS_STEPS << PROCESS_SPREAD_FACTOR), FFT_SIZE_2, mixBuffer + mixBufferOffset);
					mixBufferOffset = FFT_SIZE - mixBufferOffset;
				}
			}
		}

		inputBuffer[clock & (FFT_SIZE - 1)] = itof((int) global signal[0] + (int) global signal[1]) * (1.0 / (2048.0 * 2.0));
		read(clock, 1, global signal);

		yield();
	}
}

/*
	`operate1()` and `operate2()` are the main processing functions for "mod patches". Process left and right positions
	in `positions` global array. Return 1 if positions where processed or 0 if you want to pass the processing on to the
	original "factory firmware" operator. Positions are expressed in fixed point notation with 4 bits fraction for
	linear interpolation of memory data. In other words, the full range is 0x00000 to 0xFFFFF. Values outside of range
	will be wrapped to range.

	function operate1()
	returns int processed
	{
		processed = 0
	}

	function operate2()
	returns int processed
	{
		processed = 0
	}
*/
