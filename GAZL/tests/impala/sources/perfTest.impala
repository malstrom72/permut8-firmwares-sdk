extern native print;
extern native abort;

const int PRAWN_FIRMWARE_PATCH_FORMAT = 1;

const float LOG2 = 0.69314718055994530942;
const float LOG2R = 1.44269504088896340736;
const float LOG10R = 0.43429448190325182765;
const float E = 2.71828182845904523536;
const float HALF_PI = 1.57079632679489661923;
const float PI = 3.14159265358979323846;
const float TWICE_PI = PI * 2.0;
const float COS_EPSILON = 1.0e-6;

const int FALSE = 0;
const int TRUE = 1;

function error(pointer s)
{
	if (s != null) {
		print("Error: ");
		print(s);
		abort();
	}
}

/*
	Derived from:
	
			  oo
			 =====  n
		 x   \     x
		e  =  >    --
			 /     n!
			 =====
			 n = 0
	
	... which is the same as:
		
		1   x   x x   x x x
		- + - + --- + ----- + ...
		1   1   1*2   1*2*3
	
	... which is the same as:
	
		1   x   x x   x x x
		- + - + - - + - - - + ...
		1   1   1 2   1 2 3
		
	Negative x yields huge floating point precision problems so we negate x before and do 1.0 / y afterwards instead.
*/
function exp(float x)
returns	float y
locals	float a
		, float n
		, float m
		, float t
{
	m = abs(x);
	a = 1.0;
	n = 1.0;
	y = 1.0;
	do {
		t = y;
		a = a * m / n;
		y = y + a;
		n = n + 1.0;
	} while (y != t);
	if (x < 0.0) y = 1.0 / y;
}

/*
	Derived from:
	
					  oo
					 =====            n
					 \         n + 1 x
		log(1 + x) =  >    (-1)      --
					 /                n
					 =====
					 n = 1

	Taylor for log is only reliable between -0.5 and 0.5, so we scale beforehand.
*/
function log(float x)
returns float y
locals	float a
		, float b
		, float m
		, float n
		, float t
{
	if (x <= 0.0 || x >= 1.0e38) error("Domain error");
	else {
		b = 0.0;
		m = x;
		while (m < 0.5) { m = m * 2.0; b = b - LOG2; }
		while (m > 1.5) { m = m * 0.5; b = b + LOG2; }
		m = 1.0 - m;
		a = -1.0;
		n = 1.0;
		y = 0.0;
		do {
			t = y;
			a = a * m;
			y = y + a / n;
			n = n + 1.0;
		} while (y != t);
		y = y + b;
	}
}

function log2(float x)
returns float y
{
	y = (float)log(x) * LOG2R;
}

function log10(float x)
returns float y
{
	y = (float)log(x) * LOG10R;
}

function trunc(float x)
returns float y
{
	if (x < 0.0) y = -floor(-x);
	else y = floor(x);
}

function fmod(float x, float y)
returns float z
{
	if (y == 0.0) error("Division by zero");
	else z = x - (float)trunc(x / y) * y;
}

/*
	Derived from:
	
				 oo
				=====      n
				\      (-1)   2 n
		cos x =  >    ------ x
				/     (2 n)!
				=====
				n = 0
*/
function cos(float x)
returns	float y
locals	float a
		, float n
		, float m
		, float t
{
	m = (float)fmod(x, TWICE_PI);
	m = -m * m;
	a = 1.0;
	n = 1.0;
	y = 1.0;
	do {
		t = y;
		a = a * m / (n * n + n);
		y = y + a;
		n = n + 2.0;
	} while (y != t);
	if (abs(y) < COS_EPSILON) y = 0.0;
}

function sin(float x)
returns float y
{
	y = (float)cos(x - HALF_PI);
}

function tan(float x)
returns float y
locals	float c
{
	y = 0.0;
	c = (float)cos(x);
	if (c == 0.0) error("Domain error");
	else y = (float)sin(x) / c;
}

function pow(float x, float y)
returns float z
locals	float a
{
	z = 0.0;
	a = x;
	if (a < 0.0 && y == floor(y)) a = -a;
	if (a > 0.0) z = (float)exp((float)log(a) * y);
	else if (a < 0.0 || y <= 0.0) error("Domain error");
	if (a != x && (y * 0.5) != floor(y * 0.5)) z = -z;
}

function ceil(float x)
returns float y
{
	y = -floor(-x);
}

function sqrt(float x)
returns float y
{
	y = (float)pow(x, 0.5);
}

global array gGlobalState[14];

function main()
locals float fpi, float rq
		, float dxL, float d0L, float d1L, float d2L, float d3L, float gL
		, float dxR, float d0R, float d1R, float d2R, float d3R, float gR
		, float r, float k, float g0
		, float dxzL, float d0zL, float d1zL, float d2zL, float d3zL
		, float dxzR, float d0zR, float d1zR, float d2zR, float d3zR
		, float left, float right
		, int i
{
	dxzL = d0zL = d1zL = d2zL = d3zL = 0.0;
	dxzR = d0zR = d1zR = d2zR = d3zR = 0.0;

	rq = itof(55) * (1.0 / 255.0 * 2.0);
	fpi = itof(102) * (1.0 / 256.0 * 0.5 * PI);
	r = (4.0 - rq) / (1.0 + rq);
	k = ((float) sin(fpi)) / ((float) cos(fpi) + (float) sin(fpi));		// or : k = 1.0 / (1.0 + 1.0 / tan(f * pi)), not sure which one is more prone to rounding errors as the divisors in both variants can get near 0 and infinity. 
	g0 = r / (1.0 + r * k * k * k * k);
	r = (1.0 + r);
	
	for (i = 0 to 44100) {
		copy (13 from global gGlobalState to &r);
		
		left = 0.5;
		right = 0.5;
		
		dxL = 0.5 * (dxzL + left * r);
		d0L = d0zL + k * (dxL - d0zL);
		d1L = d1zL + k * (d0L - d1zL);
		d2L = d2zL + k * (d1L - d2zL);
		d3L = d3zL + k * (d2L - d3zL);
		gL = g0 * (d3L + d3L - d3zL); dxzL = dxL + dxL - dxzL - gL;
		gL = gL * k; d0zL = d0L + d0L - d0zL - gL;
		gL = gL * k; d1zL = d1L + d1L - d1zL - gL;
		gL = gL * k; d2zL = d2L + d2L - d2zL - gL;
		gL = gL * k; d3zL = d3L + d3L - d3zL - gL;

		dxR = 0.5 * (dxzR + right * r);
		d0R = d0zR + k * (dxR - d0zR);
		d1R = d1zR + k * (d0R - d1zR);
		d2R = d2zR + k * (d1R - d2zR);
		d3R = d3zR + k * (d2R - d3zR);
		gR = g0 * (d3R + d3R - d3zR); dxzR = dxR + dxR - dxzR - gR;
		gR = gR * k; d0zR = d0R + d0R - d0zR - gR;
		gR = gR * k; d1zR = d1R + d1R - d1zR - gR;
		gR = gR * k; d2zR = d2R + d2R - d2zR - gR;
		gR = gR * k; d3zR = d3R + d3R - d3zR - gR;

		copy (10 from &dxzL to &global gGlobalState[3]);
	}
}
