/* ------ Firmware constants ------ */

const int SOUNDS_COUNT = 4;
const int DRUM_COUNT = 3;
const int DRUM_PARAM_COUNT = 8;

// osc rate, osc drop, osc gain, rnd seed, rnd ^, rnd +, rnd gain, fade

readonly array DRUM_PARAMS[DRUM_COUNT * SOUNDS_COUNT * DRUM_PARAM_COUNT] = {
	// BD

	  435,  94, 75535, 0, 0, 0, 0, 1523
	, 773, 136, 52429, 0, 0, 0, 0,  523
	, 556,  58, 65535, 0, 0, 0, 0,  780
	, 267,  10, 35643, 0, 0, 0, 0,  500

	// HH

	, 0, 0, 0, 32790,  5233, 33422, 27716, 7372
	, 0, 0, 0, 53569, 17694, 34085, 27404, 5160 
	, 0, 0, 0, 23423, 39970,     1, 28783, 3121 
	, 0, 0, 0, 22772, 42265,  1110, 25783, 1963 
	
	// SD
	
	, 1300, 252, 39324,  8350, 45219,  9832, 35234, 2050
	, 984,   76, 28459,     0,   459, 23332, 34147, 2513
	, 897,   99, 57673, 23423, 24248, 14417, 57671, 6000
	, 802,   80, 53255, 29321, 42598,  1311, 58496, 3522 
};

/* ------ Firmware globals ------ */

global array stepSounds[16];

/* ------ Firmware functions ------ */

/*
	`init()` is called once right after the GAZL is assembled. (Optional.)
*/
/*
function init()
{
}
*/

/*
	`update()` is called whenever one or more of `params` are updated (usually not more frequent than every 136 or 137
	sample). It is also called once initially (before reset()). (Optional.)
*/
function update()
locals	int operand1Bits, int operand2Bits, array drumSounds[DRUM_COUNT], int step, int n, int i
{
	operand1Bits = ((int) global params[OPERAND_1_HIGH_PARAM_INDEX] << 8) | (int) global params[OPERAND_1_LOW_PARAM_INDEX]; 
	operand2Bits = ((int) global params[OPERAND_2_HIGH_PARAM_INDEX] << 8) | (int) global params[OPERAND_2_LOW_PARAM_INDEX]; 
	drumSounds[0] = (int) global params[OPERATOR_1_PARAM_INDEX];
	drumSounds[1] = (int) global params[OPERATOR_2_PARAM_INDEX];
	drumSounds[2] = (int) global params[OPERATOR_2_PARAM_INDEX];
	for (step = 0 to 16) {
		n = (((operand1Bits >> step) & 0x1) | (((operand2Bits >> step) & 0x1) << 1)) - 1;
		i = -1;
		if (n >= 0 && (int) drumSounds[n] > 0) i = (n * SOUNDS_COUNT + ((int) drumSounds[n] - 1)) * DRUM_PARAM_COUNT;
		global stepSounds[15 - step] = i;
	}
}

/*
	`process()` is the main processing function for "full patches". Process left and right sample in `signal` global
	array.
	
	Because of the single-sample feedback loop in Permut8, this API is designed to process one sample frame at a time,
	otherwise some cpu could have been saved by processing a batch of frames. As a more effective alternative to
	returning from the `process()` function you may call `yield()`. It will return processing to the Permut8 audio
	engine and when the next sample needs to be processed, `yield()` will return back to your GAZL code.
	
	Performance gain is also possible by implementing your own batch processing with buffering, but that will of course
	introduce additional (uncompensated) latency.
	
	Globals are slow in GAZL so if you use a lot of global data, use the "copy" feature in Impala to efficiently load it
	into (fast) local data. E.g. `copy (PARAM_COUNT from global params to params)`.
*/
function process()
locals	int rnd, int rndXor, int rndAdd, int rndGain
		, int oscPhase, int oscRate, int oscDrop, int oscGain, int osc
		, int fadeRate
		, int y
		, int i
		, int lastStep, int step
		, int pump
{
	oscPhase = oscRate = oscDrop = oscGain = 0;
	rnd = rndXor = rndAdd = rndGain = 0;
	fadeRate = 0;
	lastStep = -1;
	pump = 0x1000;
	
	loop {
		step = global clock >> 12;
		if (lastStep != step) {
			lastStep = step;
			global displayLEDs[0] = global displayLEDs[2] = 0x80 >> step;
			global displayLEDs[1] = global displayLEDs[3] = 0x8000 >> step;
			i = (int) global stepSounds[step];
			if (i >= 0) {
				oscRate = (int)global DRUM_PARAMS[i + 0];
				oscDrop = (int)global DRUM_PARAMS[i + 1];
				oscGain = (int)global DRUM_PARAMS[i + 2];
				rnd = (int)global DRUM_PARAMS[i + 3];
				rndXor = (int)global DRUM_PARAMS[i + 4];
				rndAdd = (int)global DRUM_PARAMS[i + 5];
				rndGain = (int)global DRUM_PARAMS[i + 6];
				fadeRate = (int)global DRUM_PARAMS[i + 7];
				oscPhase = 0x2000;
				pump = 0;
			}
		}			

		rndGain = rndGain - fadeRate;
		if (rndGain < 0) rndGain = 0;
		oscRate = oscRate - oscDrop;
		if (oscRate < 0) oscRate = 0;
		oscGain = oscGain - fadeRate;
		if (oscGain < 0) oscGain = 0;

		for (i = 0 to 256) {
			rnd = ((((rnd << 1) | (rnd >> 15)) ^ rndXor) + rndAdd) & 0xFFFF;
			oscPhase = (oscPhase + oscRate) & 0xFFFF;
			if (oscPhase > 0x8000) osc = 0xC000 - oscPhase;
			else osc = oscPhase - 0x4000;
			y = ((((osc >> 4) * oscGain) >> 16) + ((((rnd - 0x8000) >> 7) * rndGain) >> 16)) * 2;
			global signal[0] = (((int) global signal[0] * pump) >> 12) + y;
			global signal[1] = (((int) global signal[1] * pump) >> 12) + y;
			write(global clock, 1, global signal);
			yield();
			global signal[0] = (((int) global signal[0] * pump) >> 12) + y;
			global signal[1] = (((int) global signal[1] * pump) >> 12) + y;
			write(global clock, 1, global signal);
			yield();
			pump = pump + 0x2;
			if (pump > 0x1000) pump = 0x1000;
		}
	}
}
