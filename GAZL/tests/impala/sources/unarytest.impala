const int SOME_CONST;

global array ga[100];

function test()
locals int i, float f, pointer p, array a[100], funcptr fp
{
	p = &i;
	p = &f;
	i = 23;
	p = a + i;
	p = &global ga[i];
	p = &a[i * 23 + 1] + i * 55 + 432;
	i = (int) a[i];
	i = (int) i;
	f = (float) a[i];
	f = (float) f;
	fp = (funcptr) a[i];
	fp = (funcptr) fp;
	p = (pointer) a[i];
	p = (pointer) p;
	i = -i;
	f = -f;
	i = ~i;
	p = &p;
	p = global ga + 11 + SOME_CONST;
	a[0] = *p;
	p = (pointer) *(p + 23);
	p = (pointer) *(p - 23);
	p = (pointer) *(p + i * 123 + i);
	p = (pointer) *(p - i * 123 - i);
	fp = test;
	f = itof(i);
	i = ftoi(f);
	i = abs(i * (23 - 12));
	i = 57 * abs((23 - 12));
	f = abs(f);
	f = itof(ftoi(abs(55.5 * 1234.5 + 2345.5)));
	fp();
}
