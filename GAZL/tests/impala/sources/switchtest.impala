function x() locals int i, int j, int k {
	switch(i == 0 to 10) {
	case 0,1,2,3: j = i;
	case 5: x();
	default: i = j;
	  case   11 , 33   :  k = j;
	}
}

const int CONSTANT = 2949;
function y() locals int i, array a[5] {
	switch ((int) a[i] == 0 to 'a') { }
	switch (i == 23+5 to 234 * 2) { }
	switch (i == 4+1 to 9) { case 23+57, -1, CONSTANT: i=i+1234; case'y': ; case 4*CONSTANT: { i = i * 100; } }
	switch (i == 10 to 100) { case 100: x(); default: ; case 200: i = i + 1; case 'zzz': i = (int) a[i]; }
}

extern native printInt;
extern native printLF;
const int MINUS_FIVE = -5;
global array gx[10];

function test(int a, int b) {
	printInt(a);
	printInt(b);
}

function main()
locals int i, int a, int b, int c, int d
{
	a = 1;
	b = 5;
	c = 10;
	d = 15;
	test(2/(1+b)+a+1, b);
	test(a+1+2/(1+b), b);
	test(a+1+2/(1+b)+(int)(test(3,1)), a+1+2/(1+b));

	for (i = -5 to 20) {
		switch (i == (MINUS_FIVE + 5) to 10+1) {
			case -2: printInt(-2);
			case 11-1: printInt(10);
			case 'a'-'a': printInt(0);
			default: {
				switch (i * 2 == 0 to 6) {
								default : printInt(-1000);
					case 2 : printInt(11111);
					case 5 : if (1 == 1) printInt(5555);

				}
			}
			case 5: printInt(5);
		};
		printLF();
	}
};
