extern native sin;
extern native cos;
const float PI = 3.14159265358979323846;
const int BATCH_SIZE = 64;

const float rq = 0.1;
const float f = 0.01;

temporary float _ldxz;
temporary float _ld0z;
temporary float _ld1z;
temporary float _ld2z;
temporary float _ld3z;
temporary float _rdxz;
temporary float _rd0z;
temporary float _rd1z;
temporary float _rd2z;
temporary float _rd3z;

function filter(int hasSoundIn, pointer left, pointer right)
returns int hasSoundOut
locals float r, float k, float g0
		, float ldx, float ld0, float ld1, float ld2, float ld3, float ldxz, float ld0z, float lg
		, float rdx, float rd0, float rd1, float rd2, float rd3, float rdxz, float rd0z, float rg
		, float ld1z, float ld2z, float ld3z
		, float rd1z, float rd2z, float rd3z
		, float fpi, int i
{
	
	r = (4.0 - rq) / (1.0 + rq);
	fpi = f * PI;
	k = ((float) sin(fpi)) / ((float) cos(fpi) + (float) sin(fpi));		// or : k = 1.0 / (1.0 + 1.0 / tan(f * pi)), not sure which one is more prone to rounding errors as the divisors in both variants can get near 0 and infinity.
	g0 = r / (1.0 + r * k * k * k * k);

	ldxz = global _ldxz;
	ld0z = global _ld0z;
	ld1z = global _ld1z;
	ld2z = global _ld2z;
	ld3z = global _ld3z;

	for (i = 0 to BATCH_SIZE) {
		ldx = 0.5 * (ldxz + (float) left[i] * (1.0 + r));
		ld0 = ld0z + k * (ldx - ld0z);
		ld1 = ld1z + k * (ld0 - ld1z);
		ld2 = ld2z + k * (ld1 - ld2z);
		ld3 = ld3z + k * (ld2 - ld3z);
		lg = g0 * (ld3 + ld3 - ld3z);
		ldxz = ldx + ldx - ldxz - lg;
		lg = lg * k;
		ld0z = ld0 + ld0 - ld0z - lg;
		lg = lg * k;
		ld1z = ld1 + ld1 - ld1z - lg;
		lg = lg * k;
		ld2z = ld2 + ld2 - ld2z - lg;
		lg = lg * k;
		ld3z = ld3 + ld3 - ld3z - lg;
		// d0z = Clip(d0z * 1.1, 0.2);
	
		// d3z = JuliusShaper2(d3z * 4.2) / 4;
	
		left[i] = ld3z;
		right[i] = ld3z;
	}

	global _ldxz = ldxz;
	global _ld0z = ld0z;
	global _ld1z = ld1z;
	global _ld2z = ld2z;
	global _ld3z = ld3z;
}

temporary array audioBuffers[BATCH_SIZE * 2];
