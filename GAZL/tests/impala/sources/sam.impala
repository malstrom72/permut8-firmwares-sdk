};

function outputSample(int delayIndex, int sample)
locals int delay, int bufferposScaled, int i, int s
{
	assert(0 <= sample && sample < 16);
	delay = (int)global timetable[global oldtimetableindex * 5 + delayIndex];
	global oldtimetableindex = delayIndex;
	bufferposScaled = (global bufferpos = global bufferpos + delay) / global useScale;
	s = global lastSample;
	for (i = 0 to bufferposScaled - global writepos) {
		global signal[0] = global signal[1] = s;
		yield();
	}
	global writepos = bufferposScaled;
	global lastSample = (sample << 7) - 1024; // 50% volume
}

function SAMInit()
locals int i
{
	for (i = 0 to 256) {
		global pitches[i] = 0;
		global amplitude1[i] = 0;
		global amplitude2[i] = 0;
		global amplitude3[i] = 0;
		global frequency1[i] = 0;
		global frequency2[i] = 0;
		global frequency3[i] = 0;
		global stress[i] = 0;
		global phonemeLength[i] = 0;
		global tab44800[i] = 0;
	}

	for (i = 0 to 60) {
		global phonemeIndexOutput[i] = 0;
		global stressOutput[i] = 0;
		global phonemeLengthOutput[i] = 0;
	}
}

readonly array tables[7] = {
	global pitches, global frequency1, global frequency2, global frequency3, global amplitude1, global amplitude2
	, global amplitude3
};

function Parser1()
returns int r
locals int i, int sign1, int sign2, int position, int X, int A, int Y
{
	position = 0;
	X = 0;
	A = 0;
	Y = 0;
	
	for (i = 0 to 256) global stress[i] = 0;

	loop {
	continue0:
		sign1 = (int)global input[X];
		if (sign1 == 155) {
			(int)global phonemeIndex[position] = 255;      //mark endpoint
			r = 1;   //all ok
			goto _return;
		}
		X = X + 1;
		sign2 = (int)global input[X];

		for (Y = 0 to 81) {
			if ((int)global signInputTable1[Y] == sign1) {
				A = (int)global signInputTable2[Y];
				if ((A != '*') && (A == sign2)) {
					(int)global phonemeIndex[position] = Y;
					position = position + 1;
					X = X + 1;
					goto continue0;
				}
			}
		}

		for (Y = 0 to 81) {
			if ((int)global signInputTable2[Y] == '*') {
				if ((int)global signInputTable1[Y] == sign1) {
					(int)global phonemeIndex[position] = Y;
					position = position + 1;
					goto continue0;
				}
			}
		}
			
		Y = 8;
		while ((sign1 != (int)global stressInputTable[Y]) && (Y > 0)) Y = Y - 1;

		if (Y == 0) {
			r = 0;
			goto _return;
		}
		
		(int)global stress[position-1] = Y;
	} //while

_return: ;
}


function Insert(int position/*var57*/, int mem60, int mem59, int mem58)
locals int i, int iPlusOne
{
	i = 253;
	while (i >= position) { // ML : always keep last safe-guarding 255
		(int)global phonemeIndex[iPlusOne = (i+1)] = (int)global phonemeIndex[i];
		(int)global phonemeLength[iPlusOne] = (int)global phonemeLength[i];
		(int)global stress[iPlusOne] = (int)global stress[i];
		i = i - 1;
	}

	(int)global phonemeIndex[position] = mem60;
	(int)global phonemeLength[position] = mem59;
	(int)global stress[position] = mem58;
}

function Parser2()
locals int pos, int mem58, int X, int Y, int A, int index
{	
	pos = 0;
	mem58 = 0;

	loop {
		X = pos;
		A = (int)global phonemeIndex[pos];

		if (A == 0) goto continue0;
		if (A == 255) goto _return;

		Y = A;

		if (((int)global flags[A] & 16) != 0) {
			mem58 = (int)global stress[pos];
			A = (int)global flags[Y] & 32;
			if (A == 0) A = 20;     // 'WX' = 20 'YX' = 21
			else A = 21;

			Insert(pos+1, A, 0, mem58);
			X = pos;
			goto pos41749;
		}

		A = (int)global phonemeIndex[X];
		if (A >= 78 && A <= 80) {
			if (A == 78) {				// 'UL'
				A = 24;					// 'L'                 //change 'UL' to 'AX L'
			} else if (A == 79) {		// 'UM'
				A = 27;					// 'M'  //changle 'UM' to  'AX M'
			} else {					// 'UN'
				A = 28;					// 'N' //change UN to 'AX N'
			}
			mem58 = (int)global stress[X];
			(int)global phonemeIndex[X] = 13;		// 'AX'
			Insert(X+1, A, 0, mem58);
			goto continue0;
		}
		
		Y = A;
		A = (int)global flags[A] & 128;

		if (A != 0) {
			A = (int)global stress[X];
			if (A != 0) {
				X = X + 1;
				A = (int)global phonemeIndex[X];
				if (A == 0) {
					X = X + 1;
					Y = (int)global phonemeIndex[X];
					if (Y != 255 && ((int)global flags[Y] & 128) != 0) {
						A = (int)global stress[X];
						if (A != 0)
						{
							// 31 = 'Q'
							Insert(X, 31, 0, 0);
							goto continue0;
						}
					}
				}
			}
		}

		X = pos;
		A = (int)global phonemeIndex[pos];
		if (A != 23) goto pos41611;     // 'R'
		X = X - 1;
		A = (int)global phonemeIndex[pos-1];
		
		if (A == 69) {                   // 'T'
			(int)global phonemeIndex[pos-1] = 42;
			goto pos41779;
		}

		if (A == 57) {                   // 'D'
			(int)global phonemeIndex[pos-1] = 44;
			goto pos41788;
		}

		A = (int)global flags[A] & 128;
		if (A != 0) (int)global phonemeIndex[pos] = 18;  // 'RX'
		goto continue0;

	pos41611:
		if (A == 24) {    // 'L'
			if (((int)global flags[(int)global phonemeIndex[pos-1]] & 128) == 0) goto continue0;
			(int)global phonemeIndex[X] = 19;     // 'LX'
			goto continue0;
		}

		if (A == 32) {   // 'S'
			if ((int)global phonemeIndex[pos-1] == 60) (int)global phonemeIndex[pos] = 38;    // 'Z'
			goto continue0;
		}

		if (A == 72) {   // 'K'
			Y = (int)global phonemeIndex[pos+1];
			if (Y == 255 || ((int)global flags[Y] & 32) == 0) (int)global phonemeIndex[pos] = 75;  // 'KX'
		} else if (A == 60) {   // 'G'
			index = (int)global phonemeIndex[pos+1];
			if (index != 255 && ((int)global flags[index] & 32) != 0) goto continue0;
			(int)global phonemeIndex[pos] = 63; // 'GX'
			goto continue0;
		}
		Y = (int)global phonemeIndex[pos];
		A = (int)global flags[Y] & 1;
		if (A != 0) {
			A = (int)global phonemeIndex[pos-1];
			if (A != 32) {   // 'S'
				A = Y;
				goto pos41812;
			}
			(int)global phonemeIndex[pos] = Y-12;
			goto continue0;
		}

	pos41749:
		A = (int)global phonemeIndex[X];
		if (A == 53) {   // 'UW'
			Y = (int)global phonemeIndex[X-1];
			A = (int)global flags2[Y] & 4;
			if (A != 0) (int)global phonemeIndex[X] = 16;
			goto continue0;
		}

	pos41779:
		if (A == 42) {   // 'CH'
			Insert(X+1, A+1, 0, global stress[X]);
			goto continue0;
		}

	pos41788:
		if (A == 44) { // 'J'
			Insert(X+1, A+1, 0, global stress[X]);
			goto continue0;
		}
		
	pos41812:
		if (A != 69 && A != 57 || ((int)global flags[(int)global phonemeIndex[X-1]] & 128) == 0) goto continue0;    // 'T' 'D'

		X = X + 1;

		A = (int)global phonemeIndex[X];
		if (A != 0) {
			if (((int)global flags[A] & 128) == 0 || (int)global stress[X] != 0) goto continue0;
			(int)global phonemeIndex[pos] = 30;       // 'DX'
		} else {
			A = (int)global phonemeIndex[X+1];
			if (A != 255 && ((int)global flags[A] & 128) != 0) (int)global phonemeIndex[pos] = 30;  // 'DX'
		}

	continue0:
		pos = pos + 1;

	} // while

_return: ;
}

//add 1 to (int)global stress under some circumstances
function Code41883()
locals int pos, int Y
{
	pos = 0;
	while ((Y = (int)global phonemeIndex[pos]) != 255) {
		if (((int)global flags[Y] & 64) != 0) {
			Y = (int)global phonemeIndex[pos+1];
			if (Y != 255 && ((int)global flags[Y] & 128) != 0) { //prevent buffer overflow
				Y = (int)global stress[pos+1];
				if (Y != 0 && (Y & 128) == 0) (int)global stress[pos] = Y+1;
			}
		}
		pos = pos + 1;
	}
}

//change phoneme length
function Code48619()
locals int X, int A, int index, int mem66, int mem56
{
	X = 0;
	mem66=0;
	
	loop {
	continue0:
		index = (int)global phonemeIndex[X];
		if (index == 255) goto break0;
		if(((int)global flags2[index] & 1) == 0) {
			X = X + 1;
			goto continue0;
		}
		mem66 = X;
	
		do {
			X = X - 1;
			if(X == 0) goto break0;
			index = (int)global phonemeIndex[X];
		} while (index != 255 && ((int)global flags[index] & 128) == 0);

		do
		{
			index = (int)global phonemeIndex[X];
			if (index != 255)//inserted to prevent access overrun
			if((((int)global flags2[index] & 32) == 0) || (((int)global flags[index] & 4) != 0))     //nochmal ¸berpr¸fen
			{
				A = (int)global phonemeLength[X];
				A = (A >> 1) + A + 1;   // 3/2*A+1 ???
				assert(0 <= A && A <= 255);
				(int)global phonemeLength[X] = A;
			}

			X = X + 1;
		} while (X != mem66);

		X = X + 1;
	}  // while
break0:

	mem66 = 0;

	loop {
		X = mem66;
		index = (int)global phonemeIndex[X];
		if (index == 255) goto _return;
		A = (int)global flags[index] & 128;
		if (A != 0) {
			X = X + 1;
			index = (int)global phonemeIndex[X];

			if (((int)global flags[index] & 64) == 0) {
				if ((index == 18) || (index == 19)) {  // 'RX' & 'LX'
					X = X + 1;
					index = (int)global phonemeIndex[X];
					if (((int)global flags[index] & 64) != 0)
						(int)global phonemeLength[mem66] = (int)global phonemeLength[mem66] - 1;
				}
			} else {
				mem56 = 65;
				if (index != 255) mem56 = (int)global flags[index];
				if ((mem56 & 4) == 0) {
					if((mem56 & 1) != 0) {
						X = X - 1;
						mem56 = (int)global phonemeLength[X] >> 3;
						(int)global phonemeLength[X] = (int)global phonemeLength[X] - mem56;
					}
				} else {
					A = (int)global phonemeLength[X-1];
					(int)global phonemeLength[X-1] = (A >> 2) + A + 1;     // 5/4*A + 1
					assert(0 <= (int)global phonemeLength[X-1] && (int)global phonemeLength[X-1] <= 255);
				}
			}
		} else if (((int)global flags2[index] & 8) != 0) {
			X = X + 1;
			index = (int)global phonemeIndex[X];
			if (index != 255 && ((int)global flags[index] & 2) != 0) {
				(int)global phonemeLength[X] = 6;
				(int)global phonemeLength[X-1] = 5;
			}
		} else if (((int)global flags[index] & 2) != 0) {
			do {
				X = X + 1;
				index = (int)global phonemeIndex[X];
			} while (index == 0);

			if (index != 255 && ((int)global flags[index] & 2) != 0) { //buffer overflow
				(int)global phonemeLength[X] = ((int)global phonemeLength[X] >> 1) + 1;
				X = mem66;
				(int)global phonemeLength[mem66] = ((int)global phonemeLength[mem66] >> 1) + 1;
			}
		} else if (((int)global flags2[index] & 16) != 0) {
			index = (int)global phonemeIndex[X-1];
			if (((int)global flags[index] & 2) != 0) (int)global phonemeLength[X] = (int)global phonemeLength[X] - 2;
		}

		mem66 = mem66 + 1;
	}
_return: ;
}

//change phonemelength depedendent on stress
function SetPhonemeLength()
locals int A, int position, pointer table
{
	position = 0;
	while ((int)global phonemeIndex[position] != 255) {
		A = (int)global stress[position];
		table = global phonemeLengthTable2;
		if ((A == 0) || ((A & 128) != 0)) table = global phonemeLengthTable1;
		(int)global phonemeLength[position] = (int)table[(int)(int)global phonemeIndex[position]];
		position = position + 1;
	}
}


function Code41240()
returns int X
locals int pos, int A, int index
{
	pos = 0;
	X = 0;

	while ((int)global phonemeIndex[pos] != 255) {
		X = pos;
		index = (int)global phonemeIndex[pos];
		if (((int)global flags[index]&2) == 0) {
			pos = pos + 1;
			goto continue0;
		} else if (((int)global flags[index]&1) == 0) {
			Insert(pos+1, index+1, (int)global phonemeLengthTable1[index+1], (int)global stress[pos]);
			Insert(pos+2, index+2, (int)global phonemeLengthTable1[index+2], (int)global stress[pos]);
			goto inc3AndContinue0;
		}

		do {
			X = X + 1;
			A = (int)global phonemeIndex[X];
		} while (A==0);

		if (A != 255 && (((int)global flags[A] & 8) != 0 || (A == 36) || (A == 37))) {
			pos = pos + 1;
			goto continue0;
		}

		Insert(pos+1, index+1, (int)global phonemeLengthTable1[index+1], (int)global stress[pos]);
		Insert(pos+2, index+2, (int)global phonemeLengthTable1[index+2], (int)global stress[pos]);
	inc3AndContinue0: ;
		pos = pos + 3;
	continue0: ;
	}
}

function InitPlayback()
returns int r
locals int A, int X, int mem54, int mem55, int index, int mem66
{
	SAMInit();
	
	(int)global phonemeIndex[255] = 255; //to prevent buffer overflow // ML : changed from 32 to 255 to stop freezing with long input

	if ((int)Parser1() == 0) {
		r = 0;
		goto _return;
	}
	Parser2();
	Code41883();
	SetPhonemeLength();
	Code48619();
	for (X = (int)Code41240() to 256) {
		if ((int)global phonemeIndex[X] > 80) {
			(int)global phonemeIndex[X] = 255;
			goto break0; // error: delete all behind it
		}
	}
break0:

	mem54 = 255;
	X = X + 1;
	mem55 = 0;
	mem66 = 0;
	
	loop {
	continue1:
		X = mem66;
		index = (int)global phonemeIndex[X];
		if (index == 255) goto break1;
		mem55 = mem55 + (int)global phonemeLength[X];

		if (mem55 < 232) {
			if (index != 254) { // ML : Prevents an index out of bounds problem
				A = (int)global flags2[index]&1;
				if (A != 0) {
					X = X + 1;
					mem55 = 0;
					Insert(X, 254, 0, 0);
					mem66 = mem66 + 2;
					goto continue1;
				}
			}
			if (index == 0) mem54 = X;
			mem66 = mem66 + 1;
		} else {
			X = mem54;
			(int)global phonemeIndex[X] = 31;   // 'Q'
			(int)global phonemeLength[X] = 4;
			(int)global stress[X] = 0;
			X = X + 1;
			mem55 = 0;
			Insert(X, 254, 0, 0);
			X = X + 1;
			mem66 = X;
		}
	}
break1:

	r = 1;
_return: ;
}


readonly array tab39140[30] = {0, 0, 0, 0, 0, 10, 14, 19, 24, 27, 23, 21, 16, 20, 14, 18, 14, 18, 18, 16, 13, 15, 11, 18, 14, 11, 9, 6, 6, 6}; 
readonly array tab39170[30] = {255, 255, 255, 255, 255, 84, 73, 67, 63, 40, 44, 31, 37, 45, 73, 49, 36, 30, 51, 37, 29, 69, 24, 50, 30, 24, 83, 46, 54, 86};

//there must be no zeros in this 2 tables
readonly array tab39200[6] = {19, 27, 21, 27, 18, 13};
readonly array tab39206[6] = {72, 39, 31, 43, 30, 34};

// some kind of multiplication, but weird rounding
function trans(int a, int b)
returns	int r
locals	int carry, int temp, int X, int c, int d
{
	r = 0;
	c = a;
	d = 0;
	for (X = 0 to 8) {
		carry = c & 1;
		c = c >> 1;
		if (carry != 0) {
			temp = r + b;
			carry = temp >> 8;
			r = temp & 255;
		}
		temp = r & 1;
		assert(carry == 0 || carry == 1);
		r = (r >> 1) | (carry << 7);
		carry = temp;
	}
	// ML : rotating with the carry here seems strange, but correct according to original machine code
	temp = d >> 7;
	assert(carry == 0 || carry == 1);
	d = (d << 1) | carry;
	carry = temp;
	temp = r >> 7;
	assert(carry == 0 || carry == 1);
	r = (r << 1) | carry;
}

function SetMouthThroat(int mouth, int throat)
locals	int b, int c, int pos, int Y
{
	c = 0;

	for (pos = 5 to 30) {
		b = (int)global tab39140[pos];
		if (b != 0) c = (int)trans(mouth, b);
		global freq1data[pos] = c;
		b = (int)global tab39170[pos];
		if (b != 0) c = (int)trans(throat, b);
		global freq2data[pos] = c;
	}

	for (pos = 48 to 54) {
		Y = pos - 48;
		b = (int)global tab39200[Y];
		c = (int)trans(mouth, b);
		global freq1data[pos] = c;
		b = (int)global tab39206[Y];
		c = (int)trans(throat, b);
		global freq2data[pos] = c;
	}
}

function Special1(int mem48, int X)
returns int i
locals int A
{
	if (X <= 30) i = 0;
	else i = X - 30;

	// ML : A =, fixes a problem with invalid pitch with '.'
	while ((A = (int)global pitches[i]) == 127) i = i + 1;

	loop {
        A = A + mem48;
		(int)global pitches[i] = A;
		do {
			i = (i + 1) & 255;
			if (i == X) goto _return;
		} while ((int)global pitches[i] == 255);
	}
_return: ;
}

function GenerateNoise(int Y0, int mem39, pointer mem44, pointer mem66)
returns int Y
locals	int A, int X, int mem53, int mem49, int mem47, int i, int j
{
	Y = Y0;
	mem49 = Y;
	A = mem39&7;
	X = A-1;
	mem53 = (int)global tab48426[X];
	mem47 = X;
	A = mem39 & 248;
	if(A == 0) {
		Y = mem49;
		A = (int)global pitches[mem49] >> 4;
		Y = (int)*mem66;
		for (i = A ^ 255 to 256) {
			A = (int)global randomtable[mem47*256+Y];
			for (j = 0 to 8) {
				A = A << 1;
				if ((A & 256) != 0) {
					outputSample(3, 26 & 15);
				} else {
					outputSample(4, 6);
				}
			}

			Y = Y + 1;
		}
		(int)*mem44 = 1;
		(int)*mem66 = Y;
		Y = mem49;
	} else {
		for (Y = A ^ 255 to 256) {
			A = (int)global randomtable[mem47*256+Y];

			for (j = 0 to 8) {
				A = A << 1;
				if ((A & 256) == 0) {
					outputSample(1, mem53 & 15);
					if(mem53 != 0) goto pos48296;
				}
				outputSample(2, 5);

			pos48296: ;
			}
		}

		(int)*mem44 = 1;
		Y = mem49;
	}
}

function ProduceOutput()
locals	int phase1, int phase2, int phase3, int mem66, int mem38, int mem40, int speedcounter, int mem48, int mem56
		, int mem53, int mem51, int mem50, int mem49, int mem44, int mem39, int A, int X, int Y, int i, int carry
		, pointer p, int mem36, int mem37
		
	, array intsToTrace[10]
{
	if ((int)global phonemeIndexOutput[0] == 255) goto _return; //exit if no data

	A = 0;
	X = 0;
	phase1 = 0;  //mem43   // ML : reset for 100% consistent output
	phase2 = 0;	
	phase3 = 0;
	mem66 = 0;
	mem38 = 0;
	mem40 = 0;
	speedcounter = 0; //mem45
	mem48 = 0;

	for (mem44 = 0 to 256) {
		mem56 = (int)global phonemeIndexOutput[mem44];
		if (mem56 == 255) goto break0;
		else if (mem56 == 1) X = (int)Special1(1, X);
		else if (mem56 == 2) X = (int)Special1(255, X);

		phase1 = (int)global tab47492[(int)global stressOutput[mem44] + 1];
		phase2 = (int)global phonemeLengthOutput[mem44];

		do {
			global frequency1[X] = (int)global freq1data[mem56];
			global frequency2[X] = (int)global freq2data[mem56];
			global frequency3[X] = (int)global freq3data[mem56];
			global amplitude1[X] = (int)global ampl1data[mem56];
			global amplitude2[X] = (int)global ampl2data[mem56];
			global amplitude3[X] = (int)global ampl3data[mem56];
			global tab44800[X] = (int)global tab45936[mem56];
			(int)global pitches[X] = global pitch + phase1;
		//	assert(0 <= (int)global pitches[X] && (int)global pitches[X] <= 255);
			X = X + 1;
			phase2 = phase2 - 1;
		} while (phase2 != 0);
	}
break0:

	A = 0;
	mem44 = 0;
	mem49 = 0;
	X = 0;
	
	loop { //while No. 1
		Y = (int)global phonemeIndexOutput[X];
		A = (int)global phonemeIndexOutput[X+1];
		X = X + 1;
		if (A == 255) goto break1;
		X = A;
		mem56 = (int)global tab45856[A];
		A = (int)global tab45856[Y];
		if (A == mem56) {
			phase1 = (int)global tab45696[Y];
			phase2 = (int)global tab45696[X];
		} else if (A < mem56) {
			phase1 = (int)global tab45776[X];
			phase2 = (int)global tab45696[X];
		} else {
			phase1 = (int)global tab45696[Y];
			phase2 = (int)global tab45776[Y];
		}

		Y = mem44;
		mem49 = mem49 + (int)global phonemeLengthOutput[mem44];
		A = mem49 + phase2; //Maybe Problem because of carry flag
		assert(0 <= A && A <= 255);
		speedcounter = A;
		phase3 = mem49 - phase1;
		mem38 = phase1 + phase2;
		X = mem38;
		X = X - 2;
		if ((X & 128) == 0) {
			for (p = global tables to global tables + 7) {
				mem40 = mem38;
				
				if (p == global tables) {
					mem36 = (int)global phonemeLengthOutput[mem44] >> 1;
					mem37 = (int)global phonemeLengthOutput[mem44+1] >> 1;
					mem40 = mem36 + mem37;
					mem37 = mem37 + mem49;
					mem36 = mem49 - mem36;
					mem53 = (int)global pitches[mem37] - (int)global pitches[mem36];
					Y = mem36;
				} else {
					assert(0 <= Y && Y <= 255);
					mem53 = (int)(((pointer)*p)[speedcounter]) - (int)(((pointer)*p)[phase3]);
					Y = phase3;
				}

				// ML : Code47503 is division with remainder, and mem50 gets the sign
				mem50 = 0;
				if (mem53 < 0) mem50 = 128;
				mem51 = abs(mem53) % mem40;
				mem53 = mem53 / mem40;
				X = mem40;
				/*       	Code47503(mem40);*/
				//       	Y = phase3;

				mem56 = 0;
				loop {     //while No. 3
					A = ((int)(((pointer)*p)[Y]) + mem53) & 255; //carry alway cleared

					mem48 = A;
					Y = Y + 1;
					X = X - 1;
					if(X == 0) goto break3;

					mem56 = mem56 + mem51;
					if (mem56 >= mem40) {  //???
						 mem56 = mem56 - mem40; //carry? is set
						 if ((mem50 & 128)==0) {
							if(mem48 != 0) mem48 = mem48 + 1;
						 } else mem48 = mem48 - 1;
					}
					assert(0 <= Y && Y <= 255);
					((pointer)*p)[Y] = mem48;
				} // while No. 3
			break3: ;
			} // for
		}

		mem44 = mem44 + 1;
		X = mem44;
	}  //while No. 1

break1:

/*	if (!singmode)
	{*/
		for(i=0 to 256)
			(int)global pitches[i] = (int)global pitches[i] - ((int)global frequency1[i] >> 1);
/*	}
*/

	//amplitude rescaling
	for(i=0 to 256) {
		global amplitude1[i] = (int)global amplitudeRescale[(int)global amplitude1[i]];
		global amplitude2[i] = (int)global amplitudeRescale[(int)global amplitude2[i]];
		global amplitude3[i] = (int)global amplitudeRescale[(int)global amplitude3[i]];
	}

	mem48 = mem49 + (int)global phonemeLengthOutput[mem44];
	speedcounter = 72; //sam standard speed

	Y = 0;

	//finally the loop for sound output
	while (global pleaseBreak == FALSE) {
		mem44 = (int)global pitches[Y];
		mem38 = mem44 - (mem44 >> 2);
		phase1 = 0;
		phase2 = 0;
		phase3 = 0;
		loop {
			mem39 = (int)global tab44800[Y];
			if((mem39 & 248) != 0) {
				Y = (int)GenerateNoise(Y, mem39, &mem44, &mem66) + 2;
				speedcounter = global speed;
				mem48 = mem48 - 2;
				if (mem48 == 0) goto _return;
			} else {
				mem56 = (int)global multtable[(int)global sinus[phase1] | (int)global amplitude1[Y]];
				mem56 = mem56 + (int)global multtable[(int)global sinus[phase2] | (int)global amplitude2[Y]];
				A = (mem56 & 0xFF) + ((mem56 & 0x100) >> 8)
						+ (int)global multtable[(int)global rectangle[phase3] | (int)global amplitude3[Y]];
				A = ((A + ((A & 0x100) >> 8) + 136) & 0xFF) >> 4;
				
				outputSample(0, A);
				speedcounter = speedcounter - 1;
				if (speedcounter == 0) {
					speedcounter = global speed;
					Y = Y + 1;
					mem48 = mem48 - 1;
					if (mem48 == 0) goto _return;
				}
			}
			mem44 = mem44 - 1;
			if (mem44 == 0) goto break4;
			mem38 = mem38 - 1;
			if (mem38 == 0 && mem39 != 0) {
				Y = (int)GenerateNoise(Y, mem39, &mem44, &mem66);
				goto break4;
			}
			phase1 = (phase1 + (int)global frequency1[Y]) & 0xFF;
			phase2 = (phase2 + (int)global frequency2[Y]) & 0xFF;
			phase3 = (phase3 + (int)global frequency3[Y]) & 0xFF;
		}
	break4: ;
	}
_return: ;
}

function Play()
locals int A, int X, int Y
{
	X = 0;
	Y = 0;
	
	global writepos = 0;
	global lastSample = 0;
	global bufferpos = 0;
	global useScale = global scale;
	SetMouthThroat(global mouth, global throat);
	while (global pleaseBreak == FALSE) {
		A = (int)global phonemeIndex[X];
		if (A == 255) {
			(int)global phonemeIndexOutput[Y] = 255;
			ProduceOutput();
			goto break0;
		} else if (A == 254) {
			(int)global phonemeIndexOutput[Y] = 255;
			ProduceOutput();
			Y = 0;
		} else if (A != 0) {
			(int)global phonemeIndexOutput[Y] = A;
			(int)global phonemeLengthOutput[Y] = (int)global phonemeLength[X];
			(int)global stressOutput[Y] = (int)global stress[X];
			Y = Y + 1;
		}
		X = X + 1;
	}
break0: ;
}

function init()
locals array buffer[256], pointer p
{
	p = global config;
	if ((int) *p == 0) {
		trace("This firmware requires a configuration string. E.g. \"reciter HI THERE!\"");
		abort();
	}
	strcpy(global dynamicPanelTextRow, global panelTextRows[4]);
	strcpy(&global dynamicPanelTextRow[6], global config);
	strcat(&global dynamicPanelTextRow[6], "\"");
	global panelTextRows[4] = global dynamicPanelTextRow;
	
	if ((int) *p == '!') {
		global abortWhenDone = TRUE;
		p = p + 1;
	}
	
	if ((int) *p == '%') strcpy(global input, p + 1);
	else {
		strcpy(global input, p);
		if ((int) TextToPhonemes(global input) == 0) abort();
		p = (pointer) stpcpy(buffer, "Phonetic: %");
		p = (pointer) stpcpy(p, global input);
		if (p != buffer && (int) *(p = p - 1) == 155) {
			do {
				*p = 0;
			} while (p != buffer && (int) *(p = p - 1) == ' ');
		}
		trace(buffer);
	}
	strcat(global input, "\u009b");
	strcat(global input, "?");
	if ((int) InitPlayback() == 0) {
		trace("Couldn't initialize playback. Invalid input?");
		abort();
	}
}

function reset()
{
	global lastClock = 0x7FFFFFFF;
	global pleaseBreak = TRUE;
}

function update()
locals	array localParams[PARAM_COUNT], int newSpeed, int newPitch, int newMouth, int newThroat, int newScale
{
	copy (PARAM_COUNT from global params to localParams);
	
	newSpeed = 255 - (int) localParams[OPERAND_1_HIGH_PARAM_INDEX];
	newPitch = 255 - (int) localParams[OPERAND_1_LOW_PARAM_INDEX];
	newMouth = (int) localParams[OPERAND_2_HIGH_PARAM_INDEX];
	newThroat = (int) localParams[OPERAND_2_LOW_PARAM_INDEX];
	newScale = (int) global scales[(int) localParams[OPERATOR_1_PARAM_INDEX]];

	if (global speed != newSpeed || global pitch != newPitch || global mouth != newMouth || global throat != newThroat
			|| global scale != newScale) {
		global speed = newSpeed;
		global pitch = newPitch;
		global mouth = newMouth;
		global throat = newThroat;
		global scale = newScale;
		global lastClock = 0x7FFFFFFF;
		global pleaseBreak = TRUE;
	}
}

/*
//	`buffer` needs to be at least `GAZL_WORD_SIZE + 2` in size (incl. terminating zero). Output will be right-aligned in
//	this buffer and returned pointer is the first character, so the length of the output is
//	`buffer + (GAZL_WORD_SIZE + 1) - returned pointer`. `minLength` is usually 1 (or `i == 0` will return an empty
//	string), increasing it will add leading zeroes.
const int GAZL_WORD_SIZE
function intToString(int i, int radix, int minLength, pointer buffer)
returns	pointer p
locals	pointer e, int x
{
	assert(2 <= radix && radix <= 16);
	assert(0 <= minLength && minLength <= GAZL_WORD_SIZE);
	
	*(p = buffer + GAZL_WORD_SIZE + 1) = 0;
	e = p - minLength;
	x = i;
	while (p > e || x != 0) {
		assert(p >= buffer + 2);
		*(p = p - 1) = ("fedcba9876543210123456789abcdef")[15 + x % radix];													// Mirrored hex string to handle negative x.
		x = x / radix;
	}
	if (i < 0) *(p = p - 1) = '-';
}

function traceInts(pointer prefix, int n, pointer ints)
locals	array buffer[GAZL_WORD_SIZE + 2]
		, array line[1024]
		, int i
		, pointer p
{
	p = &line[0];
	if (prefix != null) p = (pointer) stpcpy(p, prefix);
	*p = 0;
	for (i = 0 to n) {
		if (i != 0) { *p = ','; p = p + 1; }
		p = (pointer) stpcpy(p, intToString(ints[i], 10, 1, buffer));
	}
	trace(line);
}

function traceInt(int i)
locals	array buffer[GAZL_WORD_SIZE + 2]
{
	trace(intToString(i, 10, 1, buffer));
}
*/

function process()
locals	int c
{
	loop {
		do {
			// Wait for next clock reset

			while ((c = global clock) >= global lastClock) {
				global lastClock = c;
				global signal[0] = global signal[1] = 0;
				yield();
			}

			global pleaseBreak = FALSE;
			
			Play();

			if (global pleaseBreak == FALSE) global lastClock = global clock;
					
		} while (global pleaseBreak != FALSE || (int) global params[OPERATOR_2_PARAM_INDEX] >= 2);

		if (global abortWhenDone != FALSE) exit();
		else {
			while (global pleaseBreak == FALSE && (int) global params[OPERATOR_2_PARAM_INDEX] < 2) {
				global signal[0] = global signal[1] = 0;
				yield();
			}
		}
	}
}
