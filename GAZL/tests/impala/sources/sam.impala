function TextToPhonemes(pointer input)
returns	int r
locals	array inputCopy[256], pointer p, int A, int X, int Y, int mem56, int mem57, int mem58, int mem59, int mem60
		, int mem61, int currentChar, int equalPos, int closePos, int openPos
{
	inputCopy[0] = ' ';

	// secure copy of input
	// because input will be overwritten by phonemes
	
	for (Y = 0 to 255) {
		A = (int)input[Y] & 127;
		if (A >= 112) A = A & 95;
		else if (A >= 96) A = A & 79;
		inputCopy[Y + 1] = A;
	}

	inputCopy[255] = 27;

	mem61 = -1;
	mem56 = -1;

pos36554:
	loop {
		mem61 = mem61 + 1;
		X = mem61;
		currentChar = (int)inputCopy[X];
		if (currentChar == 27) {    // esc
			mem56 = mem56 + 1;
			input[mem56] = 155;
			r = 1;
			goto _return;
		}

		if (currentChar != '.') goto break0;   // '.'
		X = X + 1;
		Y = (int)inputCopy[X];
		if(((int)global someFlags[Y] & 1) != 0) goto break0;
		mem56 = mem56 + 1;
		input[mem56] = '.';
	} //while

break0:

	Y = currentChar;
	mem57 = (int)global someFlags[currentChar];
	if((mem57 & 2) != 0) {
		p = &global rules[5541];
		goto nextRule;
	}

	if (mem57 == 0) {
		inputCopy[X] = ' ';
		mem56 = mem56 + 1;
		if (mem56 > 120) {
			input[mem56] = 155;
			r = 1;
			goto _return;
		}
		input[mem56] = ' ';
		goto pos36554;
	}

	if((mem57 & 128) == 0) {
		r = 0;
		goto _return;
	}

	// go to the right rule for this character.
	assert(65 <= currentChar && currentChar < 65 + 26);
	p = &global rules[(int)global rulesOffsets[currentChar - 65]];
// -------------------------------------
// go to next rule
// -------------------------------------

nextRule:

// find next rule
	Y = 0;
	do {
		p = p + 1;
	} while (((int)p[Y] & 128) == 0);
	Y = Y + 1;

// find '('
	while ((int)p[Y] != '(') Y = Y + 1;

	openPos = Y;

// find ')'
	do {
		Y = Y + 1;
	} while ((int)p[Y] != ')');
	closePos = Y;

// find '='
	do {
		Y = Y + 1;
	} while (((int)p[Y] & 127) != '=');   // '='
	equalPos = Y;

	X = mem61;
	mem60 = X;

	Y = openPos + 1;

	loop {
		if ((int)p[Y] != (int)inputCopy[X]) goto nextRule;
		Y = Y + 1;
		if (Y == closePos) goto break2;
		X = X + 1;
		mem60 = X;
	}
break2:

	A = mem61;
	mem59 = mem61;

	loop {
		loop {
			openPos = openPos - 1;
			mem57 = (int)p[openPos];
			if ((mem57 & 128) != 0) goto break4;
			X = mem57 & 127;
			if (((int)global someFlags[X] & 128) == 0) goto break3;
			X = mem59 - 1;
			if ((int)inputCopy[X] != mem57) goto nextRule;
			mem59 = X;
		}
	break3:

		X = mem59 - 1;
		
		switch (mem57 == 0 to 256) {
			case ' ': {
				if(((int)global someFlags[(int)inputCopy[X]] & 128) != 0) goto nextRule;
			}
			case '#': {
				if(((int)global someFlags[(int)inputCopy[X]] & 64) == 0) goto nextRule;
			}
			case '.': {
				if(((int)global someFlags[(int)inputCopy[X]] & 8) == 0) goto nextRule;
			}
			case '&': {
				if(((int)global someFlags[(int)inputCopy[X]] & 16) == 0) {
					A = (int)inputCopy[X];
					if (A != 72) goto nextRule;
					X = X - 1;
					if (!((A == 67) || (A == 83))) goto nextRule;
				}
			}
			case '@': {
				if(((int)global someFlags[(int)inputCopy[X]] & 4) == 0) {
					A = (int)inputCopy[X];
					if (A != 72) goto nextRule;
					if ((A != 84) && (A != 67) && (A != 83)) goto nextRule;
				}
			}
			case '^': {
				if(((int)global someFlags[(int)inputCopy[X]] & 32) == 0) goto nextRule;
			}
			case '+': {
				A = (int)inputCopy[X];
				if (!((A == 69) || (A == 73) || (A == 89))) goto nextRule; //'E' 'I' 'Y'
			}
			case ':': {
				while (((int)global someFlags[(int)inputCopy[X]] & 32) != 0) X = X - 1;
				X = X + 1;
			}
			default: {
				r = 0;
				goto _return;
			}

		}
		mem59 = X;
	}

break4:

	mem58 = mem60;

	loop {
	continue1:
		Y = closePos + 1;
		if (Y == equalPos) {
			Y = equalPos;
