//26 items. From 'A' to 'Z'
readonly array rulesOffsets[26] = {
	0,405,503,674,825,1221,1286,1406,1479,1830,1847,1870,1937,2033,2133,2721,2814,2852,2885,3117,3495,3638,3667,3886,3911,4058
