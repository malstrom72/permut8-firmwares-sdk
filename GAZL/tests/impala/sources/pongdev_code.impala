global array temp[2];
global array buffer[BATCH_SIZE * 2];

/*
	`process()` is the main processing function for "full patches". Process left and right sample in `signal` global
	array.
	
	Because of the single-sample feedback loop in Permut8, this API is designed to process one sample frame at a time,
	otherwise some cpu could have been saved by processing a batch of frames. As a more effective alternative to
	returning from the `process()` function you may call `yield()`. It will return processing to the Permut8 audio
	engine and when the next sample needs to be processed, `yield()` will return back to your GAZL code.
	
	Performance gain is also possible by implementing your own batch processing with buffering, but that will of course
	introduce additional (uncompensated) latency.
	
	Globals are slow in GAZL so if you use a lot of global data, use the "copy" feature in Impala to efficiently load it
	into (fast) local data. E.g. `copy (PARAM_COUNT from global params to params)`.
*/
function process()
locals	array tapData[TAP_STRUCT_SIZE], array tapped[2],
		int i, int mixL, int mixR, int clock, int l, int r, pointer p

	, pointer bp, int bi
	, array _tapped[BATCH_SIZE * 2], pointer tp
	, int ledBits
{
if (1 == 1) {
	loop {
		mixL = 0;
		mixR = 0;

		clock = global clock;
		write(clock, 1, global signal);
		p = global tapData;
		for (i = 0 to global tapCount) {
			copy (TAP_STRUCT_SIZE from p to tapData);
			read(clock - (int) tapData[TAP_DELAY], 1, tapped);
			if (((int) tapData[TAP_BITS] & (1 << RECTIFIER_BIT)) != 0) {
				l = abs((int) tapped[0]);
				r = abs((int) tapped[1]);
				tapped[0] = l + (l >> 1);
				tapped[1] = r + (r >> 1);
			}
			mixL = mixL + (int) tapped[0] * (int) tapData[TAP_LEFT_GAIN];
			mixR = mixR + (int) tapped[1] * (int) tapData[TAP_RIGHT_GAIN];
			p = p + TAP_STRUCT_SIZE;
		}
		global signal[0] = mixL >> 8;
		global signal[1] = mixR >> 8;
		yield();
	}
} else {
	loop {
		ledBits = 0;

		bp = global buffer;
		for (bi = 0 to BATCH_SIZE) {
			copy (2 from global signal to global temp);
			copy (2 from bp to global signal);
			copy (2 from global temp to bp);
			bp = bp + 2;
			yield();
		}

		clock = global clock - BATCH_SIZE;
		write(clock, BATCH_SIZE, global buffer);
		for (bp = global buffer to global buffer + BATCH_SIZE * 2) *bp = 0;

		p = global tapData;
		for (i = 0 to global tapCount) {
			bp = global buffer;
			copy (TAP_STRUCT_SIZE from p to tapData);
			read(clock - (int) tapData[TAP_DELAY], BATCH_SIZE, _tapped);
			if (((int) tapData[TAP_BITS] & (1 << RECTIFIER_BIT)) != 0) {
				tp = _tapped;
				for (bi = 0 to BATCH_SIZE / 2) {
					l = abs((int) *tp); *tp = l + (l >> 1);
					r = abs((int) tp[1]); tp[1] = r + (r >> 1);
					l = abs((int) tp[2]); tp[2] = r + (r >> 1);
					r = abs((int) tp[3]); tp[3] = r + (r >> 1);
					tp = tp + 4;
				}
			}
			l = (int) tapData[TAP_LEFT_GAIN];
			r = (int) tapData[TAP_RIGHT_GAIN];
			tp = _tapped;
			if (abs((int) *tp) > 12) ledBits = ledBits | ((int) tapData[TAP_BITS] >> 16);
			for (bi = 0 to BATCH_SIZE / 2) {
				*bp = (int) *bp + (int) *tp * l;
				bp[1] = (int) bp[1] + (int) tp[1] * r;
				bp[2] = (int) bp[2] + (int) tp[2] * l;
				bp[3] = (int) bp[3] + (int) tp[3] * r;
				bp = bp + 4;
				tp = tp + 4;
			}
			p = p + TAP_STRUCT_SIZE;
		}

		for (bp = global buffer to global buffer + BATCH_SIZE * 2) *bp = (int) *bp >> 8;

		global displayLEDs[1] = (int) global params[OPERAND_1_LOW_PARAM_INDEX] & (ledBits >> 8);
		global displayLEDs[3] = (int) global params[OPERAND_2_LOW_PARAM_INDEX] & ledBits;
	}
}
}

/*
	`operate1()` and `operate2()` are the main processing functions for "mod patches". Process left and right positions
	in `positions` global array. Return 1 if positions where processed or 0 if you want to pass the processing on to the
	original "factory firmware" operator. Positions are expressed in fixed point notation with 4 bits fraction for
	linear interpolation of memory data. In other words, the full range is 0x00000 to 0xFFFFF. Values outside of range
	will be wrapped to range.

	function operate1()
	returns int processed
	{
		processed = 0
	}

	function operate2()
	returns int processed
	{
		processed = 0
	}
*/
