/* ------ Utilities ------ */

const float LOG2 = 0.69314718055994530942
const float LOG2R = 1.44269504088896340736
const float LOG10R = 0.43429448190325182765
const float E = 2.71828182845904523536
const float HALF_PI = 1.57079632679489661923
const float PI = 3.14159265358979323846
const float TWICE_PI = PI * 2.0
const float COS_EPSILON = 1.0e-6
const float EPSILON_FLOAT = 1.0e-45
const float SMALL_FLOAT = 1.0e-5
const float LARGE_FLOAT = 1.0e+10
const float HUGE_FLOAT = 1.0e+38

const float XOR_SHIFT_RANDOM_TO_FLOAT_FACTOR = 4.6566128730774e-10 // To scale result from xorShiftRandom() to -1 to 1 range.

function stpcpy(pointer d, pointer s)
returns pointer a
locals	pointer b
{
	a = d;
	b = s;
	while ((*a = (int)*b) != 0) {
		a = a + 1;
		b = b + 1;
	}
}

/*
	`buffer` needs to be at least `GAZL_WORD_SIZE + 2` in size (incl. terminating zero). Output will be right-aligned in
	this buffer and returned pointer is the first character, so the length of the output is
	`buffer + (GAZL_WORD_SIZE + 1) - returned pointer`. `minLength` is usually 1 (or `i == 0` will return an empty
	string), increasing it will add leading zeroes.
*/
const int GAZL_WORD_SIZE
function intToString(int i, int radix, int minLength, pointer buffer)
returns	pointer p
locals	pointer e, int x
{
	assert(2 <= radix && radix <= 16);
	assert(0 <= minLength && minLength <= GAZL_WORD_SIZE);
	
	*(p = buffer + GAZL_WORD_SIZE + 1) = 0;
	e = p - minLength;
	x = i;
	while (p > e || x != 0) {
		assert(p >= buffer + 2);
		*(p = p - 1) = ("fedcba9876543210123456789abcdef")[15 + x % radix];	// Mirrored hex string to handle negative x.
		x = x / radix;
	}
	if (i < 0) *(p = p - 1) = '-';
}


// buffer should hold at least 32 elements
function floatToString(float f, int precision, pointer buffer)
returns	pointer p
locals float x, float y, int e, float g, pointer dp, pointer pp, pointer ep, int i
{
	assert(1 <= precision && precision <= 24);

	y = abs(f);
	if (y <= EPSILON_FLOAT) p = "0";
	else if (y >= HUGE_FLOAT) p = "HUGE";
	else {
		e = 0;
		ep = buffer + 3 + precision;
		
		loop {
			pp = buffer + 3;
			x = y;
			
			// Normalize values > 10 and move period position.
			
			while (x >= 10.0 && pp < ep) {
				pp = pp + 1;
				x = x * 0.1;
			}
						
			if (pp < ep && y > SMALL_FLOAT && y < LARGE_FLOAT) goto break;
			
			// Exponential treatment of very small or large values.

			g = y;
			while (y < 1.0) {
				e = e - 1;
				y = y * 10.0;
			}
			while (y >= 10.0) {
				e = e + 1;
				y = y * 0.1;
			}
		}
	break:
		
		// For values < 1, spit out leading 0's and increase precision.

		dp = buffer + 2;
		while (x < 1.0 && dp < buffer + 32) {
			*dp = '0';
			dp = dp + 1;
			if (dp == pp) {	// Hop over period position (set to 9 to avoid when eliminating 9's).
				*dp = '9';
				dp = dp + 1;
			}
			ep = ep + 1;
			x = x * 10.0;
		}
		
		// Exhaust all remaining digits of mantissa into buffer.
		
		while (dp < ep) {
			i = ftoi(x);
			*dp = i + '0';
			dp = dp + 1;
			if (dp == pp) {	// Hop over period position (set to 9 to avoid when eliminating 9's).
				*dp = '9';
				dp = dp + 1;
			}
			x = (x - itof(i)) * 10.0;
		}
		
		// If remainder is >= 5, increment trailing 9's...
		
		p = buffer + 2;
		if (x >= 5.0) {
			while ((int) dp[-1] == '9') *(dp = dp - 1) = '0';
			
			// If we are at spare position, set to '1' and include, otherwise, increment last non-9.
			
			if (dp == p) *(p = p - 1) = '1';
			else dp[-1] = (int) dp[-1] + 1;
		}
		
		*pp = '.';
		
		// Trim trailing zeroes (and possibly '.').
		
		if (ep > pp) while ((int) ep[-1] == '0') ep = ep - 1;
		if (ep - 1 == pp) ep = ep - 1;
		
		// Add any exponent and negative sign.
		
		if (e != 0) {
			*ep = 'e';
			i = '+';
			if (e < 0) i = '-';
			*(ep = ep + 1) = i;
			i = abs(e);
			if (i >= 100) *(ep = ep + 1) = '0' + ((i / 100) % 10);
			if (i >= 10) *(ep = ep + 1) = '0' + ((i / 10) % 10);
			*(ep = ep + 1) = '0' + (i % 10);
			ep = ep + 1;
		}
		*ep = 0;

		if (f < 0.0) *(p = p - 1) = '-';
	}
}

function traceInts(pointer text, int n, pointer ints)
locals	array buffer[GAZL_WORD_SIZE + 2]
		, array line[1024]
		, int i
		, pointer p
{
	p = &line[0];
	if (text != null) p = (pointer) stpcpy(p, text);
	*p = 0;
	for (i = 0 to n) {
		if (i != 0) { *p = ','; p = p + 1; }
		p = (pointer) stpcpy(p, intToString(ints[i], 10, 1, buffer));
	}
	trace(line);
}

function traceFloats(pointer text, int n, pointer floats, int precision)
locals	array buffer[GAZL_WORD_SIZE + 2]
		, array line[1024]
		, int i
		, pointer p
{
	p = &line[0];
	if (text != null) p = (pointer) stpcpy(p, text);
	*p = 0;
	for (i = 0 to n) {
		if (i != 0) { *p = ','; p = p + 1; }
		p = (pointer) stpcpy(p, floatToString(floats[i], precision, buffer));
	}
	trace(line);
}

function traceInt(pointer text, int i)
locals	array ints[1]
{
	ints[0] = i;
	traceInts(text, 1, ints);
}

function traceFloat(pointer text, float f, int precision)
locals	array floats[1]
{
	floats[0] = f;
	traceFloats(text, 1, floats, precision);
}

function error(pointer s)
{
	trace(s);
	abort();
}

function trunc(float x)
returns	float y
{
	if (x < 0.0) y = -floor(-x);
	else y = floor(x);
}

function fmod(float x, float y)
returns	float z
{
	if (y == 0.0) error("Division by zero");
	else z = x - (float)trunc(x / y) * y;
}

/*
	Derived from:
	
				 oo
				=====      n
				\      (-1)   2 n
		cos x =  >    ------ x
				/     (2 n)!
				=====
				n = 0
*/
function cos(float x)
returns	float y
locals	float a, float n, float m, float t
{
	m = (float) fmod(x, TWICE_PI);
	m = -m * m;
	a = n = y = 1.0;
	do {
		t = y;
		a = a * m / (n * n + n);
		y = y + a;
		n = n + 2.0;
	} while (y != t);
	if (abs(y) < COS_EPSILON) y = 0.0;
}

function sin(float x)
returns float y
{
	y = (float) cos(x - HALF_PI);
}

function square(float x)
returns float y
{
	y = x * x;
}

function complexFFT(int n, /* float */ pointer data)
locals	int i, int j, int m, int mmax,
		float theta, float rx, float ry, float px, float py, float nx, float ny, float tr, float ti,
		array tmp[2]
{
	assert(n >= 2 && (n & (n - 1)) == 0);

	// Reverse binary indexing

	{
		j = 1;
		i = 1;
		while (i < n) {
			if (j > i) {
				tmp[0] = data[j - 1]; tmp[1] = data[j];
				data[j - 1] = data[i - 1]; data[j] = data[i];
				data[i - 1] = tmp[0]; data[i] = tmp[1];
			}
			m = n >> 1;
			while (m >= 2 && j > m) {
				j = j - m;
				m = m >> 1;
			}
			j = j + m;
			i = i + 2;
		}
	}
	
	// Danielson-Lanczos

	mmax = 2;
	while (mmax < n) {
		theta = -2.0 * PI / itof(mmax);
		rx = 2.0 * (float) square((float) sin(theta * 0.5)); // 2 * sin^2(t/2) = 1 - cos(t), improves precision with low rates compared to using cos
		ry = (float) sin(theta);
		px = 1.0;
		py = 0.0;

		m = 0;
		while (m < mmax) {
			i = m;
			while (i < n) {
				j = i + mmax;
				tr = px * (float) data[j + 0] - py * (float) data[j + 1];
				ti = px * (float) data[j + 1] + py * (float) data[j + 0];
				data[j + 0] = (float) data[i + 0] - tr;
				data[j + 1] = (float) data[i + 1] - ti;
				data[i + 0] = (float) data[i + 0] + tr;
				data[i + 1] = (float) data[i + 1] + ti;
				i = i + (mmax << 1);
			}
			nx = px - px * rx - py * ry;
			ny = px * ry + py - py * rx;
			px = nx;
			py = ny;
			m = m + 2;
		}
		mmax = mmax << 1;
	}
}

function realFFT(int n, /* float */ pointer input, /* float */ pointer output)
locals	int i, int j,
		float r0, float i0, float r1, float i1, float theta, float rx, float ry, float px, float py, float nx, float ny
{
	assert(n >= 2 && (n & (n - 1)) == 0);
	assert(output != input);

	complexFFT(n, input);
	
	// "Untangle" complex pairs
	{
		r0 = (float) input[0];
		i0 = (float) input[1];
		output[0] = (r0 + i0);
		output[1] = (i0 - r0);
		
		theta = 2.0 * PI / itof(n);
		rx = 2.0 * (float) square((float) sin(theta * 0.5)); // 2 * sin^2(t/2) = 1 - cos(t), improves precision with low rates compared to using cos
		ry = (float) sin(theta);
		px = 1.0;
		py = 0.0;
		j = n - 2;
		i = 2;
		while (i < n) {
			nx = px - px * rx - py * ry;
			ny = px * ry + py - py * rx;
			px = nx;
			py = ny;
			r0 = (float) input[i + 0];
			i0 = (float) input[i + 1];
			r1 = (float) input[j + 0];
			i1 = (float) input[j + 1];
			output[i + 0] = 0.5 * (r0 - r0 * py + i0 * px + r1 + r1 * py + i1 * px);
			output[i + 1] = 0.5 * (i0 - i0 * py - r0 * px + r1 * px - i1 - i1 * py);
			j = j - 2;
			i = i + 2;
		}
	}
}

/*
	Derived from:
	
			  oo
			 =====  n
		 x   \     x
		e  =  >    --
			 /     n!
			 =====
			 n = 0
	
	... which is the same as:
		
		1   x   x x   x x x
		- + - + --- + ----- + ...
		1   1   1*2   1*2*3
	
	... which is the same as:
	
		1   x   x x   x x x
		- + - + - - + - - - + ...
		1   1   1 2   1 2 3
		
	Negative x yields huge floating point precision problems so we negate x before and do 1.0 / y afterwards instead.
*/
function exp(float x)
returns	float y
locals	float a
		, float n
		, float m
		, float t
{
	m = abs(x);
	a = 1.0;
	n = 1.0;
	y = 1.0;
	do {
		t = y;
		a = a * m / n;
		y = y + a;
		n = n + 1.0;
	} while (y != t);
	if (x < 0.0) y = 1.0 / y;
}

/*
	Derived from:
	
					  oo
					 =====            n
					 \         n + 1 x
		log(1 + x) =  >    (-1)      --
					 /                n
					 =====
					 n = 1

	Taylor for log is only reliable between -0.5 and 0.5, so we scale beforehand.
*/
function log(float x)
returns float y
locals	float a
		, float b
		, float m
		, float n
		, float t
{
	if (x <= 0.0 || x >= 1.0e38) error("Domain error");
	else {
		b = 0.0;
		m = x;
		while (m < 0.5) { m = m * 2.0; b = b - LOG2; }
		while (m > 1.5) { m = m * 0.5; b = b + LOG2; }
		m = 1.0 - m;
		a = -1.0;
		n = 1.0;
		y = 0.0;
		do {
			t = y;
			a = a * m;
			y = y + a / n;
			n = n + 1.0;
		} while (y != t);
		y = y + b;
	}
}

function pow(float x, float y)
returns float z
locals	float a
{
	z = 0.0;
	a = x;
	if (a < 0.0 && y == floor(y)) a = -a;
	if (a > 0.0) z = (float) exp((float) log(a) * y);
	else if (a < 0.0 || y <= 0.0) error("Domain error");
	if (a != x && (y * 0.5) != floor(y * 0.5)) z = -z;
}

function sqrt(float x)
returns float y
{
	y = (float) pow(x, 0.5);
}

global int xorShiftRandomSeedX = 123456789
global int xorShiftRandomSeedY = 362436069
function xorShiftRandom()
returns	int y
locals	int x
		, int t
{
	x = global xorShiftRandomSeedX;
	y = global xorShiftRandomSeedY;
	t = x ^ (x << 10);
	x = y;
	y = y ^ (y >>> 13) ^ t ^ (t >>> 10);
	global xorShiftRandomSeedX = x;
	global xorShiftRandomSeedY = y;
}

/* ------ Firmware constants ------ */

const int MAX_TAP_COUNT = 16

const int PAN_LEFT_BIT = 7
const int PAN_RIGHT_BIT = 6
const int VOL_DEC_BIT= 5
const int VOL_INC_BIT = 4
const int ACCELERATE_BIT = 3
const int DEACCELERATE_BIT = 2
const int RANDOM_BIT = 1
const int RECTIFIER_BIT = 0

const int SIXTEENTHS_MODE = 1
const int EIGHTS_MODE = 2
const int ODD_SIXTEENTHS_MODE = 3
const int MORE_SIXTEENTHS_MODE = 4

const float VOL_DEC_FACTOR = 0.70710678118655
const float VOL_INC_FACTOR = 1.414213562373
const float VOL_DEC_FACTOR_EXTENDED = 0.70710678118655
const float VOL_INC_FACTOR_EXTENDED = 1.414213562373
const float TIME_DEC_FACTOR = 0.70710678118655
const float TIME_INC_FACTOR = 1.414213562373
const float PAN_ATTENUATE = 0.25

const int BATCH_SIZE = 64;

/* ------ Firmware globals ------ */

const int TAP_BITS = 0
const int TAP_DELAY = 1
const int TAP_LEFT_GAIN = 2
const int TAP_RIGHT_GAIN = 3
const int TAP_STRUCT_SIZE = 4

global int tapCount
global array tapData[TAP_STRUCT_SIZE * MAX_TAP_COUNT]

/* ------ Firmware functions ------ */

/*
	`init()` is called once right after the GAZL is assembled. (Optional.)
*/
function init()
locals int i, array buf[256]
{
	trace("init");
	trace(intToString(global instance, 10, 1, buf));
}

/*
	`reset()` is called whenever the user flips the "RESET" switch and when the host requests a plug-in reset. Will also
	be called once after init() and the first call to update(). (Optional.)
*/
function reset()
{
	trace("reset");
	traceInts(" params: ", PARAM_COUNT, global params);
//	global doReset = TRUE;
}

function maxi(int a, int b)
returns int y
{
	y = a;
	if (b > y) y = b;
}

function calcGainsAndDelays(int highBits, int lowBits, float initGain, float initDelay
		, pointer gains, pointer delays, pointer maxGain, pointer maxDelay, pointer endGain, pointer endDelay)
locals	float g, float d, int i
{
	g = initGain;
	d = initDelay;
	for (i = 0 to 8) {
		if ((lowBits & (0x80 >> i)) != 0) {
			if ((highBits & (1 << VOL_INC_BIT)) != 0) g = g * VOL_INC_FACTOR;
			if ((highBits & (1 << VOL_DEC_BIT)) != 0) g = g * VOL_DEC_FACTOR;
			if ((highBits & (1 << ACCELERATE_BIT)) != 0) d = d * TIME_DEC_FACTOR;
			if ((highBits & (1 << DEACCELERATE_BIT)) != 0) d = d * TIME_INC_FACTOR;
		}
		if (g > (float) *maxGain) *maxGain = g;
		if (d > (float) *maxDelay) *maxDelay = d;
		gains[i] = g;
		delays[i] = d;
	}
	traceFloats("gains: ", 8, gains, 8);
	traceFloat("max: ", (float) *maxGain, 8);
	traceFloats("delays: ", 8, delays, 8);
	traceFloat("max: ", (float) *maxDelay, 8);
	*endGain = g;
	*endDelay = d;
}

function addTaps(int op, int highBits, int lowBits, 
		float offset, pointer gains, pointer delays, float gainScale, float delayScale
		, int firstStep)
returns float o
locals	float g, float d, int i, float lg, float rg
		, float r, pointer p
{
	o = offset;
	p = global tapData + global tapCount * TAP_STRUCT_SIZE;
	for (i = 0 to 8) {
		g = (float) gains[i] * gainScale;
		d = (float) delays[i] * delayScale;
		if ((lowBits & (0x80 >> i)) != 0) {
			lg = g;
			rg = g;
			if ((highBits & (1 << PAN_LEFT_BIT)) == 0) lg = lg * PAN_ATTENUATE;
			if ((highBits & (1 << PAN_RIGHT_BIT)) == 0) rg = rg * PAN_ATTENUATE;
			r = 0.0;
			if ((highBits & (1 << RANDOM_BIT)) != 0) r = itof((int) xorShiftRandom()) * (XOR_SHIFT_RANDOM_TO_FLOAT_FACTOR * (1.0/12.0)) * d;
			p[TAP_BITS] = highBits | (0x80000000 >>> (i + firstStep));
			p[TAP_DELAY] = maxi(ftoi(o + r) - BATCH_SIZE, 0);
			p[TAP_LEFT_GAIN] = ftoi(lg);
			p[TAP_RIGHT_GAIN] = ftoi(rg);
			p = p + TAP_STRUCT_SIZE;
			global tapCount = global tapCount + 1;
		}
		o = o + d;
	}
}

const int CHECK_PARAMS_COUNT = 6;
global array lastParams[CHECK_PARAMS_COUNT];
readonly array CHECK_PARAMS[CHECK_PARAMS_COUNT] = {
	OPERATOR_1_PARAM_INDEX,OPERAND_1_HIGH_PARAM_INDEX,OPERAND_1_LOW_PARAM_INDEX,OPERATOR_2_PARAM_INDEX,OPERAND_2_HIGH_PARAM_INDEX,OPERAND_2_LOW_PARAM_INDEX
};

/*
	`update()` is called whenever one or more of `params` are updated (usually not more frequent than every 136 or 137
	sample). It is also called once initially (before reset()). (Optional.)
*/
function update()
locals array localParams[PARAM_COUNT], int i, int v, int rebuild, float stepLength, float offset
		, array gains[16], array delays[16], float maxGain1, float maxDelay1, float maxGain2
		, float maxDelay2, float endGain, float endDelay
{
	rebuild = FALSE;
	copy (PARAM_COUNT from global params to localParams);
	for (i = 0 to CHECK_PARAMS_COUNT) {
		v = (int) localParams[(int) global CHECK_PARAMS[i]];
		if ((int) global lastParams[i] != v) {
			global lastParams[i] = v;
			rebuild = TRUE;
		}
	}
	if (rebuild != FALSE) {
		trace("rebuilding");
		global tapCount = 0;
		global xorShiftRandomSeedX = 123456789;
		global xorShiftRandomSeedY = 362436069;
		stepLength = (65536.0 / 8.0);
		maxGain1 = 0.00001;
		maxDelay1 = 0.00001;
		if ((int) localParams[OPERATOR_1_PARAM_INDEX] > 0) {
			stepLength = itof(65536 >> (2 + (int) localParams[OPERATOR_1_PARAM_INDEX]));
			calcGainsAndDelays((int) localParams[OPERAND_1_HIGH_PARAM_INDEX], (int) localParams[OPERAND_1_LOW_PARAM_INDEX], 1.0, 1.0, gains, delays, &maxGain1, &maxDelay1, &endGain, &endDelay);
		}
		offset = 0.0;
		switch ((int) localParams[OPERATOR_2_PARAM_INDEX] == 0 to 5) {
			case 0: goto noSecond;
			case 1: ;
			case 2: stepLength = stepLength * 0.5;
			case 3: offset = stepLength * 0.5;
			case 4: {
				calcGainsAndDelays((int) localParams[OPERAND_2_HIGH_PARAM_INDEX], (int) localParams[OPERAND_2_LOW_PARAM_INDEX], endGain, endDelay, &gains[8], &delays[8], &maxGain1, &maxDelay1, &endGain, &endDelay);
				offset = (float) addTaps((int) localParams[OPERATOR_1_PARAM_INDEX], (int) localParams[OPERAND_1_HIGH_PARAM_INDEX], (int) localParams[OPERAND_1_LOW_PARAM_INDEX], 0.0, gains, delays, 256.0 / maxGain1, stepLength / maxDelay1, 0);
				addTaps((int) localParams[OPERATOR_2_PARAM_INDEX], (int) localParams[OPERAND_2_HIGH_PARAM_INDEX], (int) localParams[OPERAND_2_LOW_PARAM_INDEX], offset, &gains[8], &delays[8], 256.0 / maxGain1, stepLength / maxDelay1, 8);
				goto done;
			}
		}
		maxGain2 = 0.00001;
		maxDelay2 = 0.00001;
		calcGainsAndDelays((int) localParams[OPERAND_2_HIGH_PARAM_INDEX], (int) localParams[OPERAND_2_LOW_PARAM_INDEX], 1.0, 1.0, &gains[8], &delays[8], &maxGain2, &maxDelay2, &endGain, &endDelay);
		addTaps((int) localParams[OPERATOR_2_PARAM_INDEX], (int) localParams[OPERAND_2_HIGH_PARAM_INDEX], (int) localParams[OPERAND_2_LOW_PARAM_INDEX], offset, &gains[8], &delays[8], 256.0 / maxGain2, stepLength / maxDelay2, 8);
	noSecond: ;
		if ((int) localParams[OPERATOR_1_PARAM_INDEX] > 0) {
			addTaps((int) localParams[OPERATOR_1_PARAM_INDEX], (int) localParams[OPERAND_1_HIGH_PARAM_INDEX], (int) localParams[OPERAND_1_LOW_PARAM_INDEX], 0.0, gains, delays, 256.0 / maxGain1, stepLength / maxDelay1, 0);
		}
	done: ;
	}

