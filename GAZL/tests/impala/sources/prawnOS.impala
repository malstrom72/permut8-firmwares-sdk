extern native print;
extern native printInt;
extern native printLF;
extern native abort;
extern native input;
extern native inputEOF;
extern native launch;

function strcmp(pointer s0, pointer s1)
returns int d
locals pointer a, pointer b
{
	a = s0;
	b = s1;
	while ((int)*a != 0 && (int)*a == (int)*b) {
		a = a + 1;
		b = b + 1;
	}
	d = (int)*a - (int)*b;
}

function main()
locals array inp[256]
{
	mainLoop:

		print("> ");
		input(255, inp);

		if ((int)strcmp(inp, "logon") == 0) {
			do {
				print("Enter username: ");
				input(255, inp);
			} while ((int)strcmp(inp, "username") != 0);
			launch("advent");
		}

	goto mainLoop;
}
