/* ------ Utilities ------ */

const float LOG2 = 0.69314718055994530942
const float LOG2R = 1.44269504088896340736
const float LOG10R = 0.43429448190325182765
const float E = 2.71828182845904523536
const float HALF_PI = 1.57079632679489661923
const float PI = 3.14159265358979323846
const float TWICE_PI = PI * 2.0
const float COS_EPSILON = 1.0e-6

function error(pointer s)
{
	trace(s);
	abort();
}

function trunc(float x)
returns	float y
{
	if (x < 0.0) y = -floor(-x);
	else y = floor(x);
}

function fmod(float x, float y)
returns	float z
{
	if (y == 0.0) error("Division by zero");
	else z = x - (float)trunc(x / y) * y;
}

/*
	Derived from:
	
				 oo
				=====      n
				\      (-1)   2 n
		cos x =  >    ------ x
				/     (2 n)!
				=====
				n = 0
*/
function cos(float x)
returns	float y
locals	float a, float n, float m, float t
{
	m = (float) fmod(x, TWICE_PI);
	m = -m * m;
	a = n = y = 1.0;
	do {
		t = y;
		a = a * m / (n * n + n);
		y = y + a;
		n = n + 2.0;
	} while (y != t);
	if (abs(y) < COS_EPSILON) y = 0.0;
}

function sin(float x)
returns float y
{
	y = (float) cos(x - HALF_PI);
}

/* ------ Firmware constants ------ */

const int CURVE_SIZE_BITS = 4
const int CURVE_SIZE = (1 << CURVE_SIZE_BITS)
const int CURVE_SIZE_PLUS_1 = CURVE_SIZE + 1
const int CURVE_SHIFT = (12 - CURVE_SIZE_BITS)
const int CURVE_FRACTION_MASK = ~(~0 << CURVE_SHIFT)
const int CURVE_STEP_SIZE = (1 << CURVE_SHIFT)
const float STEP_TO_FLOAT_SCALE = (1.0 / itof(CURVE_STEP_SIZE));

const int NO_SHAPER = 0
const int LINEAR_SHAPER = 1
const int QUADRATIC_SHAPER = 2
const int SHAPER_COUNT = 3
const int BIT_CRUSH = 1
const int SINE_SHAPE = 2
const int SPIN = 3
const int STEREO_DELAY = 4

readonly array OPERATOR_SHAPERS[5] = { NO_SHAPER, LINEAR_SHAPER, LINEAR_SHAPER, QUADRATIC_SHAPER, QUADRATIC_SHAPER };

/* ------ Firmware globals ------ */

global array sinTable[0x1000]
global array linCurveA[CURVE_SIZE]			// Coefficients for linear curve, e.g. intercept and slope
global array linCurveB[CURVE_SIZE]
global array quadCurveA[CURVE_SIZE_PLUS_1]	// Coefficients for quadratic curve. More intricate.
global array quadCurveB[CURVE_SIZE_PLUS_1]
global array quadCurveC[CURVE_SIZE_PLUS_1]
global int op1 = -1							// Pre-calculated in update()
global int shaper
global int op1Stuff
global int spinXOrR
global int biasL
global int biasR
global int delayL
global int delayR
global int lastOp1Param = -1				// Used for speeding up update()
global int lastOp2 = -1
global int lastShaperBits = -1

/* ------ Firmware functions ------ */

/*
	`init()` is called once right after the GAZL is assembled. (Optional.)
*/
function init()
locals	int i, int s
{
	for (i = 0 to 0x1000) {
		s = ftoi(floor(0.5 + itof(0x800) * (float) sin(2.0 * PI / 4096.0 * itof(i))));
		if (s < -0x7FF) s = -0x7FF;
		else if (s > 0x7FF) s = 0x7FF;
		global sinTable[i] = s;
	}
}

/*
	`update()` is called whenever one or more of `params` are updated (usually not more frequent than every 136 or 137
	sample). It is also called once initially (before reset()). (Optional.)
*/
function update()
locals	array params[PARAM_COUNT], array quadPoints[CURVE_SIZE_PLUS_1 + 3],
		int v, int mask, int d, int i, int shaperBits, int shelf, int op1, int op2, int op1Param, int stereoBit,
		int t,
		float a, float b, float c
{
	copy (PARAM_COUNT from global params to params);
	op1 = (int) params[OPERATOR_1_PARAM_INDEX];
	op1Param = (int) params[OPERAND_1_HIGH_PARAM_INDEX];
	if (global op1 != op1 || global lastOp1Param != op1Param) {
		global op1 = op1;
		global lastOp1Param = op1Param;

		stereoBit = (op1Param & 0x80); 
		switch (op1 == 0 to 5) {
			case BIT_CRUSH: {
				t = ((op1Param & 0x7F) << 3);
				if ((op1Param & 0x1) != 0) t = t | 0x07;
				global op1Stuff = t;
				global displayLEDs[0] = (~(~0 << ((t + (1 << (10 - 3 - 1))) >>> (10 - 3))));
				if (stereoBit != 0) {
					global biasL = t;
					global biasR = 0;
				} else {
					t = t >> 1;
					global biasL = t;
					global biasR = t;
				}
			}

			case SINE_SHAPE: {
				t = (op1Param & 0x7F) + 1;
				global op1Stuff = t;
				global biasL = (stereoBit << 2); // 0x80 == 0x200
				global displayLEDs[0] = (~(~0 << ((t + (1 << (7 - 3 - 1))) >>> (7 - 3))));
			}

			case SPIN: {
				global op1Stuff = (op1Param & 0x7F);
				global spinXOrR = 0;
				if (stereoBit != 0) {
					global spinXOrR = 0xFFF;
				}
				global displayLEDs[0] = 0;
			}

			case STEREO_DELAY: {
				global delayL = (int) global EIGHT_BIT_EXP_TABLE[op1Param];
				global displayLEDs[0] = 0x1 << (op1Param >> (8 - 3));
			}
		}
	}
	
	global delayR = (int) global EIGHT_BIT_EXP_TABLE[(int) params[OPERAND_1_LOW_PARAM_INDEX]];
	global displayLEDs[1] = 0x1 << ((int) params[OPERAND_1_LOW_PARAM_INDEX] >> (8 - 3));

	op2 = (int) params[OPERATOR_2_PARAM_INDEX];
	shaperBits = ((int) params[OPERAND_2_HIGH_PARAM_INDEX] << 8) | (int) params[OPERAND_2_LOW_PARAM_INDEX];
	if (global lastOp2 != op2 || global lastShaperBits != shaperBits) {
		global lastOp2 = op2;
		global lastShaperBits = shaperBits;
		global shaper = (int) global OPERATOR_SHAPERS[op2];
		shelf = (op2 & 1);
		v = 0;
		mask = 0x10000;
		for (i = 0 to CURVE_SIZE) {
			mask = mask >>> 1;
			global linCurveA[i] = v;
			d = 0;
			if ((shaperBits & mask) == 0) d = CURVE_STEP_SIZE;
			else if (shelf == 0) d = -CURVE_STEP_SIZE;
			global linCurveB[i] = d;
			v = v + d;
		}
		d = (int) global linCurveA[CURVE_SIZE / 2];
		for (i = 0 to CURVE_SIZE) {
			global linCurveA[i] = (int) global linCurveA[i] - d;
			quadPoints[i + 1] = itof((int) global linCurveA[i]);
		}
		quadPoints[CURVE_SIZE_PLUS_1] = itof((int) global linCurveA[CURVE_SIZE - 1] + (int) global linCurveB[CURVE_SIZE - 1]);
		quadPoints[CURVE_SIZE + 2] = (float) quadPoints[CURVE_SIZE_PLUS_1];
		quadPoints[0] = itof((int) global linCurveA[0]);
		quadPoints[1] = (float) quadPoints[0];
		for (i = 0 to CURVE_SIZE_PLUS_1) {
			a = (float) quadPoints[i];
			b = (float) quadPoints[i + 1];
			c = (float) quadPoints[i + 2];
			global quadCurveA[i] = 0.5 * (a + b);
			global quadCurveB[i] = (b - a);
			global quadCurveC[i] = 0.5 * (a - 2.0 * b + c);
		}
	}
}

function process()
locals	array localSignal[2],
		int left, int right, int localClock, int xl, int xr, int il, int ir, int tmp,
		float pl, float pr, int peak, int dip, int spinner,
		int innerLoopIndex, int localOp1, int localOp1Stuff, int localShaper, int localDelayL, int localDelayR,
		int localBiasL, int localBiasR, int localSpinXOrR, int clockDir
{
	peak = 0;
	dip = 0;
	spinner = 0;
	localClock = 0;
	loop {
		localOp1 = global op1;
		localOp1Stuff = global op1Stuff;
		localShaper = global shaper;
		localDelayL = global delayL;
		localDelayR = global delayR;
		localBiasL = global biasL;
		localBiasR = global biasR;
		localSpinXOrR = global spinXOrR;

		clockDir = 1;
		if (((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_REVERSE_MASK) != 0) {
			clockDir = -1;
		}
		
		if (((int) global params[SWITCHES_PARAM_INDEX] & SWITCHES_SYNC_MASK) != 0) {
			tmp = global clock;
			if (tmp != localClock) {
				localClock = tmp;
				spinner = localClock * localOp1Stuff;
			}
		}
		
		peak = peak + (-peak >> 8);
		dip = dip - (dip >> 8);
		global displayLEDs[3] = (0xFF >>> ((peak + (1 << (10 - 3)) >>> (11 - 3)))) ^ 0xFF;
		global displayLEDs[2] = (0xFF << ((-dip + (1 << (10 - 3)) >>> (11 - 3)))) ^ 0xFF;
		if (localOp1 == SPIN) {
			tmp = (spinner >>> 15);
			il = (tmp ^ (-((tmp & 0x8) >>> 3))) & 0x7;
			ir = il ^ (localSpinXOrR & 0x7);
			global displayLEDs[0] = (0x80 >> il) | (0x80 >> ir);
		}
		
		for (innerLoopIndex = 0 to 64) {
			left = (int) global signal[0];
			right = (int) global signal[1];

			localSignal[0] = left;
			localSignal[1] = right;
			write(localClock, 1, localSignal);
			read(localClock - localDelayR, 1, localSignal);
			left = (int) localSignal[0];
			right = (int) localSignal[1];

			switch (localOp1 == 0 to 5) {
				case BIT_CRUSH: {
					left = (left | localOp1Stuff) - localBiasL;
					right = (right | localOp1Stuff) - localBiasR;
				}

				case SINE_SHAPE: {
					left = (int) global sinTable[(((left * localOp1Stuff) >> 2) - localBiasL) & 0xFFF];
					right = (int) global sinTable[(((right * localOp1Stuff) >> 2) + localBiasL) & 0xFFF];
				}

				case SPIN: {
					tmp = (spinner >>> 6);
					il = (left + tmp);
					ir = (right + (tmp ^ localSpinXOrR));
					left = ((il ^ (-((il & 0x1000) >>> 12))) & 0xFFF) - 0x800;
					right = ((ir ^ (-((ir & 0x1000) >>> 12))) & 0xFFF) - 0x800;
					spinner = spinner + localOp1Stuff;
				}

				case STEREO_DELAY: {
					read(localClock - localDelayL, 1, localSignal);
					left = (int) localSignal[0];
				}
			}

			if (left > peak) peak = left;
			if (left < dip) dip = left;
			if (right > peak) peak = right;
			if (right < dip) dip = right;

			switch (localShaper == 0 to SHAPER_COUNT) {
				case LINEAR_SHAPER: {
					xl = left + 0x800;
					xr = right + 0x800;
					il = xl >> CURVE_SHIFT;
					ir = xr >> CURVE_SHIFT;
					left = (int) global linCurveA[il] + (((int) global linCurveB[il] * (xl & CURVE_FRACTION_MASK)) >> CURVE_SHIFT);
					right = (int) global linCurveA[ir] + (((int) global linCurveB[ir] * (xr & CURVE_FRACTION_MASK)) >> CURVE_SHIFT);
				}
				case QUADRATIC_SHAPER: {
					xl = left + 0x800 + (1 << (CURVE_SHIFT - 1));
					xr = right + 0x800 + (1 << (CURVE_SHIFT - 1));
					il = xl >> CURVE_SHIFT;
					ir = xr >> CURVE_SHIFT;
					pl = itof(xl & CURVE_FRACTION_MASK) * STEP_TO_FLOAT_SCALE;
					pr = itof(xr & CURVE_FRACTION_MASK) * STEP_TO_FLOAT_SCALE;
					left = ftoi((float) global quadCurveA[il] + ((float) global quadCurveB[il] + (float) global quadCurveC[il] * pl) * pl);
					right = ftoi((float) global quadCurveA[ir] + ((float) global quadCurveB[ir] + (float) global quadCurveC[ir] * pr) * pr);
				}
			}

			global signal[0] = left;
			global signal[1] = right;
			
			yield();

			localClock = (localClock + clockDir) & 0xFFFF;
		}
	}
}
