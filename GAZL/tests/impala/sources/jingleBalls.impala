const int DEBUG = 1
const float MAX_GRAVITY = 40.0
const float MIN_SPEED = 0.01
const float MAX_SPEED = 20.0
const int GRAVITY_PARAM = 0
const int BUMPER_FORCE_PARAM = 1
const int PARAM_COUNT = 2
const int BALL_COUNT = 3
const int BALL_ACTIVE_PARAM = 0
const int BALL_X_PARAM = 1
const int BALL_Y_PARAM = 2
const int BALL_DX_PARAM = 3
const int BALL_DY_PARAM = 4
const int BALL_PARAMS_COUNT = 5

const float PI = 3.14159265358979323846

extern native printLF;
extern native abort;

extern native atan2;
extern native log;
extern native sqrt;

function error(pointer s)
{
	printLF(s);
	abort();
}

function cube(float x)
returns float y
{
	y = x * x * x;
}

function clamp(float x, float min, float max)
returns float y
{
	y = x;
	if (y < min) y = min;
	else if (y > max) y = max;
}

function floorMod(float a, float n)
returns float r
{
	r = a - n * floor(a / n);
}

function round(float x)
returns float y
{
	y = floor(x + 0.5);
}

global array params[PARAM_COUNT]
global array balls[BALL_COUNT * BALL_PARAMS_COUNT]

function tick(int sampleFrames, float sampleRate)
locals float rsr16, float gravity, float bumperForce, float nx, float ny, float d, float dx, float dy, float a, float v
	, int eventCount, int i, int offset, int midiVel, int octave, int note
	, array ballParams[BALL_PARAMS_COUNT]
{
	rsr16 = 16.0 / sampleRate;

	gravity = (float) cube((float) global params[GRAVITY_PARAM]) * MAX_GRAVITY;
	bumperForce = (float) global params[BUMPER_FORCE_PARAM] * 2.0;
	eventCount = 0;
	while (offset < sampleFrames) {
		for (i = 0 to BALL_COUNT) {
			copy (BALL_PARAMS_COUNT from &global balls[i * BALL_PARAMS_COUNT] to ballParams);
			if ((int) ballParams[BALL_ACTIVE_PARAM] != 0) {
				nx = (float) ballParams[BALL_X_PARAM] + (float) ballParams[BALL_DX_PARAM] * rsr16;
				ny = (float) ballParams[BALL_Y_PARAM] + (float) ballParams[BALL_DY_PARAM] * rsr16;
				d = nx * nx + ny * ny;
				if (d < 1.0) {
					ballParams[BALL_X_PARAM] = nx;
					ballParams[BALL_Y_PARAM] = ny;
					ballParams[BALL_DY_PARAM] = (float) ballParams[BALL_DY_PARAM] + gravity * rsr16;
				} else {
					dx = (float) ballParams[BALL_DX_PARAM];
					dy = (float) ballParams[BALL_DY_PARAM];
					ballParams[BALL_DX_PARAM] = (dx * ny * ny - dx * nx * nx - 2.0 * nx * ny * dy) / d;
					ballParams[BALL_DY_PARAM] = (dy * nx * nx - dy * ny * ny - 2.0 * nx * ny * dx) / d;
					a = (float) atan2((float) ballParams[BALL_Y_PARAM], (float) ballParams[BALL_X_PARAM]);
					v = (float) sqrt((float) ballParams[BALL_DX_PARAM] * (float) ballParams[BALL_DX_PARAM] + (float) ballParams[BALL_DY_PARAM] * (float) ballParams[BALL_DY_PARAM]);
					midiVel = 0;
					if (v > 0.00001) midiVel = ftoi((float) clamp((float) round(50.0 * (float) log(v) + 127.0), 0.0, 127.0));
					if (midiVel > 0) {
						octave = 4 + (i + 1) % 3;
						note = ftoi((float) floorMod((float) round(a * (12.0 / (2.0 * PI)) + 9.0), 12.0)) + octave * 12;
						/*if (eventCount < maxEvents) {
							MidiEvent evt;
							evt.offset = offset;
							evt.status = 0x90 | midiChannel;
							evt.data1 = note;
							evt.data2 = midiVel;
							events[eventCount] = evt;
							++eventCount;
							evt.offset = offset + duration;
							evt.status = 0x80 | midiChannel;
							noteOffs.push_back(evt);
						}*/
					}
					if (v * bumperForce < MIN_SPEED) {
						ballParams[BALL_DX_PARAM] = 0.0;
						ballParams[BALL_DY_PARAM] = 0.0;
					} else if (v * bumperForce > MAX_SPEED) {
						ballParams[BALL_DX_PARAM] = (float) ballParams[BALL_DX_PARAM] * MAX_SPEED / v;
						ballParams[BALL_DY_PARAM] = (float) ballParams[BALL_DY_PARAM] * MAX_SPEED / v;
					} else {
						ballParams[BALL_DX_PARAM] = (float) ballParams[BALL_DX_PARAM] * bumperForce;
						ballParams[BALL_DY_PARAM] = (float) ballParams[BALL_DY_PARAM] * bumperForce;
					}
				}
				copy (BALL_PARAMS_COUNT from ballParams to &global balls[i * BALL_PARAMS_COUNT]);
			}
		}
		offset = offset + 16;
	}
	/*
	while (eventCount < maxEvents && !noteOffs.empty() && noteOffs.front().offset < sampleFrames) {
		events[eventCount] = noteOffs.front();
		++eventCount;
		noteOffs.pop_front();
	}
	for (std::deque<MidiEvent>::iterator it = noteOffs.begin(); it != noteOffs.end(); ++it) {
		it->offset = max(it->offset - sampleFrames, 0);
	}
	offset -= sampleFrames;
	assert(0 <= offset && offset < 16);
	return eventCount;*/
}

function init()
locals int i, int o
{
	for (i = 0 to BALL_COUNT) {
		global balls[o + BALL_ACTIVE_PARAM] = 0;
		global balls[o + BALL_X_PARAM] = 0.0;
		global balls[o + BALL_Y_PARAM] = 0.0;
		global balls[o + BALL_DX_PARAM] = 0.0;
		global balls[o + BALL_DY_PARAM] = 0.0;
		o = o + BALL_PARAMS_COUNT;
	}
	global balls[0 + BALL_ACTIVE_PARAM] = 1;
	global balls[0 + BALL_DY_PARAM] = 1.0;
}

function main()
locals int i
{
	init();
	for (i = 0 to 100000000) tick(64, 44100.0);
}
