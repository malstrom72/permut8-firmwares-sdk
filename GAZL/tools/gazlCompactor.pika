#! /usr/local/bin/PikaCmd

include('stdlib.pika');
include('debug.pika');

::compactGAZL = function {
	args(@source);
	o = '';
	tokenize(source, >{
		s = $0;
		l = '';
		for (; s != '' && s{0} != ';'; ) {
			if ((i = span(s, " \t")) > 0) { if (l != void) l #= ' '; s = s{i:}; };
			if (s{:4} == 'DATs') { l #= s; s = ''; }
			else { l #= s{:i = find(s, " \t;")}; s = s{i:}; }
		};
		l = l{:rspan(l, ' ') + 1};
		if (l != '') o #= l # LF;
	});
	( o )
};

save($2, compactGAZL(load($1)));
